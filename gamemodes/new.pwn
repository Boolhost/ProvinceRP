CMD:heal(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MEMBER] != 4) return SendClientMessage(playerid, COLOR_WARNING, "Данная команда для Вас недоступна!");
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /heal [ид]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(10.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок далеко от Вас!");

	if(GetPVarInt(params[0],"yesno") == 1) return SendClientMessage(playerid,COLOR_WARNING,"Игроку уже поступило предложение!");

	new str1[145], str2[145];
	format(str1,sizeof(str1),"{1fa1ea}Вы предложили курс лечения игроку %s за 200 рублей",PLAYER_DATA[params[0]][data_NAME]);
	SendClientMessage(playerid, 0xFF66CCFF, str1);
	format(str2,sizeof(str2),"{1fa1ea}%s предложил Вам курс лечения за 200 рублей. Для согласия {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME]);
	SendClientMessage(params[0], 0xFF66CCFF, str2);

    SetPVarInt(params[0], "yesno_heal", 1);
    SetPVarInt(params[0], "yesno_playerid", playerid);
    SetPVarInt(params[0], "yesno", 1);
	return true;
}

CMD:call(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_PHONE] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет телефона!");
	if(PLAYER_DATA[playerid][data_NUMBER] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет SIM карты!");
    if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /call [номер]");
    if(PLAYER_DATA[playerid][data_NUMBER] == params[0]) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя позвонить самому себе!");

    if(params[0] == 222)
    {
        if(PLAYER_DATA[playerid][data_911_1] > 0) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя вызывать полицию слишком часто!");
		ShowPlayerDialogFix(playerid, dialog_911_1, DIALOG_STYLE_INPUT, "{FFCC00}Полиция", "{FFFFFF}Сообщите Вашу проблему и местонахождение", "Подтвердить", "Отмена");
        return true;
    }
    if(params[0] == 333)
    {
        if(PLAYER_DATA[playerid][data_911_2] > 0) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя вызывать скорую помощь слишком часто!");
		ShowPlayerDialogFix(playerid, dialog_911_2, DIALOG_STYLE_INPUT, "{FFCC00}Скорая помощь", "{FFFFFF}Сообщите Вашу проблему и местонахождение", "Подтвердить", "Отмена");
        return true;
    }


	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		if(PLAYER_DATA[i][data_NUMBER] == params[0])
 		{
   			if(PLAYER_DATA[playerid][data_NUMBER_M] <= 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на телефоне!");
      		if(PLAYER_DATA[i][data_CALL] != -1) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок разговаривает по телефону!");
			PLAYER_DATA[playerid][data_CALL] = i;
      		SendClientMessage(i, -1, "У Вас звонит телефон. Чтобы поднять трубку введите: /p");
      		PlayerPlaySound(i, 20600, 0.0, 0.0, 0.0);
      		PlayerPlaySound(playerid, 3600, 0.0, 0.0, 0.0);
      		SendClientMessage(playerid,0xFFCC33FF,"Вызов...");
			if(!IsPlayerInAnyVehicle(playerid)) SetPlayerSpecialAction(playerid, SPECIAL_ACTION_USECELLPHONE);
			return true;
  		}
	}
	SendClientMessage(playerid,COLOR_WARNING,"Данного игрока нет на сервере!");
	return true;
}

CMD:p(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_PHONE] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет телефона!");
	if(PLAYER_DATA[playerid][data_NUMBER] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет SIM карты!");
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
	    if(PLAYER_DATA[i][data_CALL] == playerid)
	    {
    		PLAYER_DATA[playerid][data_CALL] = i;
    		SetPVarInt(i,"call_m", 1);
    		SendClientMessage(i,0xFFCC33FF,"Собеседник поднял трубку");
    		SendClientMessage(playerid,0xFFCC33FF,"Соединение установлено...");
			if(!IsPlayerInAnyVehicle(playerid)) SetPlayerSpecialAction(playerid, SPECIAL_ACTION_USECELLPHONE);
			return true;
		}
	}
	SendClientMessage(playerid,COLOR_WARNING,"Вам никто не звонит!");
	return true;
}

CMD:h(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_PHONE] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет телефона!");
	if(PLAYER_DATA[playerid][data_NUMBER] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет SIM карты!");
	if(PLAYER_DATA[playerid][data_CALL] == -1) return SendClientMessage(playerid,COLOR_WARNING,"Вы не разговариваете по телефону!");
	new id = PLAYER_DATA[playerid][data_CALL];
	if(!IsPlayerInAnyVehicle(playerid)) SetPlayerSpecialAction(playerid, SPECIAL_ACTION_STOPUSECELLPHONE);
	if(PLAYER_DATA[id][data_CALL] == playerid)
 	{
    	if(!IsPlayerInAnyVehicle(id)) SetPlayerSpecialAction(id, SPECIAL_ACTION_STOPUSECELLPHONE);
 	}
 	PLAYER_DATA[id][data_CALL] = -1;
 	PLAYER_DATA[playerid][data_CALL] = -1;
	SetPVarInt(id,"call_m",0);
	SetPVarInt(playerid,"call_m",0);
	SendClientMessage(playerid,0xFF6633FF,"Вы положили трубку");
	SendClientMessage(id,0xFF6633FF,"Ваш собеседник положил трубку");
	return true;
}

CMD:sms(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MUTE] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Ваш чат временно заблокирован!");
	if(sscanf(params, "ds[84]", params[0],params[1])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /sms [номер] [текст]");
    if(PLAYER_DATA[playerid][data_PHONE] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет телефона!");
	if(PLAYER_DATA[playerid][data_NUMBER] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет SIM карты!");
    if(PLAYER_DATA[playerid][data_NUMBER] == params[0]) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя отправить SMS самому себе!");

    if(params[0] == 555)
	{
	    if(efir == false) return SendClientMessage(playerid,COLOR_WARNING,"В данный момент действущих эфиров нет!");
	    if(efir_sms == false) return SendClientMessage(playerid,COLOR_WARNING,"Прием SMS отключен!");
	    if(PLAYER_DATA[playerid][data_NUMBER_M] <= 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас закончились деньги на телефоне!");
		new message[145],message2[145],id = efir_ved;
		format(message,sizeof(message),"[СМС]: %s | %s[%d](%d) <<<",params[1],PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[playerid][data_NUMBER]);
		SendClientMessage(id,0xFFFF33FF,message);
		format(message2,sizeof(message2),"[СМС] %s | %s[%d](%d) >>>",params[1],PLAYER_DATA[id][data_NAME],id,params[0]);
		SendClientMessage(playerid,0xFFFF33FF,message2);
		PLAYER_DATA[playerid][data_NUMBER_M]--;
		PlayerPlaySound(efir_ved, 40407, 0.0, 0.0, 0.0);
		return true;
	}


	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		if(PLAYER_DATA[i][data_NUMBER] == params[0])
 		{
   			if(PLAYER_DATA[playerid][data_NUMBER_M] <= 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас закончились деньги на счету!");
			new message[145],message2[145];
   			format(message,sizeof(message),"[СМС]: %s | %s[%d](%d) <<<",params[1],PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[playerid][data_NUMBER]);
			SendClientMessage(params[0],0xFFFF33FF,message);
			format(message2,sizeof(message2),"[СМС] %s | %s[%d](%d) >>>",params[1],PLAYER_DATA[i][data_NAME],params[0],PLAYER_DATA[i][data_NUMBER]);
			SendClientMessage(playerid,0xFFFF33FF,message2);
			PLAYER_DATA[playerid][data_NUMBER_M]--;
			PlayerPlaySound(i, 40407, 0.0, 0.0, 0.0);
			return true;
  		}
	}
	SendClientMessage(playerid,COLOR_WARNING,"Данного игрока нет на сервере!");
	return true;
}

CMD:number(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_PHONEBOOK] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет телефонной книги!");
	if(sscanf(params, "s[24]", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /number [имя]");
	new count = 0;
    for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i)) continue;
        if(strfind(PLAYER_DATA[i][data_NAME], params[0], true) == 0)
        {
            if(PLAYER_DATA[i][data_NUMBER] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У данного игрока нет номера телефона");
            count++;
            new str[MAX_PLAYER_NAME+15];
            format(str,sizeof(str),"%s - %d",PLAYER_DATA[i][data_NAME],PLAYER_DATA[i][data_NUMBER]);
            SendClientMessage(playerid, 0x99FF33FF , str);
			return true;
        }
    }
    if(count == 0) return SendClientMessage(playerid, COLOR_WARNING, "Игрок не найден!");
    return true;
}

CMD:fuelcar(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_KANISTRA] == 0) return SendClientMessage(playerid, COLOR_WARNING, "У Вас нет канистры. Купить ее можно на любом АЗС области!");
	new carid = GetPlayerVehicleID(playerid);
	if(carid == INVALID_VEHICLE_ID) return SendClientMessage(playerid, COLOR_WARNING, "Нужно находиться в автомобиле!");
	if(CAR_DATA[carid][data_FUEL] == 50) return SendClientMessage(playerid, COLOR_WARNING, "Бак автомобиля полон!");
	if(CAR_DATA[carid][data_FUEL] < 50 && CAR_DATA[carid][data_FUEL] >= 40) CAR_DATA[carid][data_FUEL] = 50;
	else CAR_DATA[carid][data_FUEL] += 10;
	new c = CAR_DATA[carid][data_ID];
	if(carid == PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_VEH])
	{
		PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_CARFUEL][c] = CAR_DATA[carid][data_FUEL];
	}
	SendClientMessage(playerid, 0x66CC00FF, "Вы заправили свой автомобиль");
	PLAYER_DATA[playerid][data_KANISTRA] = 0;
	return true;
}

CMD:healcar(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ZAPCHASTI] == 0) return SendClientMessage(playerid, COLOR_WARNING, "У Вас нет инструментов. Купить их можно на любом АЗС области!");
	new carid = GetPlayerVehicleID(playerid);
	new Float:hpc;
	if(carid == INVALID_VEHICLE_ID) return SendClientMessage(playerid, COLOR_WARNING, "Нужно находиться в автомобиле!");
    GetVehicleHealth(carid,hpc);
    if(hpc == 1000.0) return SendClientMessage(playerid, COLOR_WARNING, "Ваш автомобиль находиться в идеальном состоянии!");
	SetVehicleHealth(carid,1000.0);
	RepairVehicle(carid);
	SendClientMessage(playerid, 0x66CC00FF, "Вы починили свой автомобиль");
	PLAYER_DATA[playerid][data_ZAPCHASTI] = 0;
	return true;
}

CMD:fixveh(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new carid = GetPlayerVehicleID(playerid);
	new Float:hpc;
	if(carid == INVALID_VEHICLE_ID) return SendClientMessage(playerid, COLOR_WARNING, "Нужно находиться в автомобиле!");
    GetVehicleHealth(carid,hpc);
	SetVehicleHealth(carid,1000.0);
	RepairVehicle(carid);
	SendClientMessage(playerid, 0x66CC00FF, "Вы починили свой автомобиль");
	return true;
}

CMD:buyprod(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED]== false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return true;
    if(PLAYER_DATA[playerid][data_START_JOB] == 8)
	{
	    new car = GetPlayerVehicleID(playerid);
        if(PlayerToPoint(50.0, playerid, 2738.6606,-2273.4192,17.9269) && IsPlayerInAnyVehicle(playerid))
        {
            if(CAR_DATA[car][data_GRUZ] != 0) return SendClientMessage(playerid, COLOR_WARNING, "Вы уже загрузили свою машину товаром, чтобы выгрузить товар и забрать деньги введите: /unload");
            ShowPlayerDialogFix(playerid, dialog_BUYPROD, DIALOG_STYLE_LIST, "{FFCC00}Выберите товар",
			"{1fa1ea}1.{FFFFFF}Продукты\n\
			{1fa1ea}2.{FFFFFF}Топливо\n\
			{1fa1ea}3.{FFFFFF}Брендовая одежда\n\
			{1fa1ea}4.{FFFFFF}Оружие и патроны\n\
			{1fa1ea}5.{FFFFFF}Еда и напитки\n\
			{1fa1ea}6.{FFFFFF}Автозапчасти", "Выбрать", "Отмена");
		}
		else SendClientMessage(playerid, COLOR_WARNING, "Нужно находиться возле склада!");
	}
	else SendClientMessage(playerid, COLOR_WARNING, "Данная функция Вам недоступна!");
	return true;
}


CMD:prodmenu(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_START_JOB] != 8) return true;
    ShowPlayerDialogFix(playerid, dialog_PRODMENU, DIALOG_STYLE_LIST, "{FFCC00}Развозчик продуктов",
	"{1fa1ea}1.{FFFFFF}Мониторинг\n\
	{1fa1ea}2.{FFFFFF}Информация о грузе\n\
	{1fa1ea}3.{FFFFFF}GPS", "Выбрать", "Отмена");
	return true;
}

CMD:buyfuel(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    for(new b = 0; b < TotalBusiness; b++)
    {
        if(PlayerToPoint(10.0, playerid, BUSINESS_DATA[b][data_BUYX],BUSINESS_DATA[b][data_BUYY], BUSINESS_DATA[b][data_BUYZ]))
        {
            if(BUSINESS_DATA[b][data_TYPE] == 1)
            {
				new dtext[256];
				format(dtext,sizeof(dtext),
				"{1fa1ea}1.{FFFFFF}Бензин\n\
				{1fa1ea}2.{FFFFFF}Канистра (10л)\n\
				{1fa1ea}3.{FFFFFF}Запчасти");
			    ShowPlayerDialogFix(playerid, dialog_BUYFUEL, DIALOG_STYLE_LIST, "{FFCC00}АЗС", dtext, "Купить", "Отмена");
			    SetPVarInt(playerid, "business",b);
				return true;
			}
		}
	}
	return true;
}

CMD:utilcar(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");


    new string[256];
	for(new c = 0; c < 3; c++)
	{
	    if(PLAYER_DATA[playerid][data_CAR][c] == 0)
	    {
	    	format(string,sizeof(string),"%s{FFFFFF}[%d] cвободно\n",string, c+1);
		}
		else
		{
		    format(string,sizeof(string),"%s{FFFFFF}[%d] модель:%d\n",string, c+1, PLAYER_DATA[playerid][data_CAR][c]);
		}
	}
	ShowPlayerDialogFix(playerid,dialog_UTILCAR, DIALOG_STYLE_LIST, "{FFCC00}Утилизация автомобилей", string, "Выбрать", "Отмена");
	return true;
}

CMD:sellcar(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");


    new string[256];
	for(new c = 0; c < 3; c++)
	{
	    if(PLAYER_DATA[playerid][data_CAR][c] == 0)
	    {
	    	format(string,sizeof(string),"%s{FFFFFF}[%d] cвободно\n",string, c+1);
		}
		else
		{
		    format(string,sizeof(string),"%s{FFFFFF}[%d] {1fa1ea}%s{FFFFFF}\n",string, c+1, VehicleNames[PLAYER_DATA[playerid][data_CAR][c]-400],PLAYER_DATA[playerid][data_CAR][c]);
		}
	}
	ShowPlayerDialogFix(playerid,dialog_SELLCAR, DIALOG_STYLE_LIST, "{FFCC00}Продажа автомобилей", string, "Выбрать", "Отмена");
	return true;
}

CMD:gps(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(GetPVarFloat(playerid,"gps_pos_y") != 0)
	{
 		DisablePlayerCheckpoint(playerid);
		DeletePVar(playerid, "gps_pos_x");
		DeletePVar(playerid, "gps_pos_y");
		DeletePVar(playerid, "gps_pos_z");
		UseGPS[playerid] = false;
		KillTimer(markTimer[playerid]);
        markDist[playerid] = 0.0;
		HideGPSTextDraws(playerid);
		SendClientMessage(playerid,0x33CC99FF,"[GPS]: Отметка на вашем радаре была убрана");
 	}
 	ShowPlayerDialogFix(playerid, dialog_GPS, DIALOG_STYLE_LIST, "{FFCC00}GPS",
	"{1fa1ea}1.{FFFFFF}Работа\n\
	{1fa1ea}2.{FFFFFF}Отделение Банков\n\
	{1fa1ea}3.{FFFFFF}Автосалон\n\
	{1fa1ea}4.{FFFFFF}Важные места\n\
	{1fa1ea}5.{FFFFFF}Базы организаций\n\
	{1fa1ea}6.{FFFFFF}Поиск дома\n\
	{1fa1ea}7.{FFFFFF}Поиск подъезда\n\
	{1fa1ea}8.{FFFFFF}Поиск бизнеса\n\
	{1fa1ea}9.{FFFFFF}Развлечения\n\
	{1fa1ea}10.{FFFFFF}Автошкола", "Выбрать", "Отмена");
	return true;
}

CMD:fixcar(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_HOUSE] == INVALID_HOUSE_ID && PLAYER_DATA[playerid][data_KV] == INVALID_KV_ID) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет дома/квартиры!");

	new string[256];
	for(new c = 0; c < 3; c++)
	{
	    if(PLAYER_DATA[playerid][data_CAR][c] == 0)
	    {
	    	format(string,sizeof(string),"%s{FFFFFF}[%d] cвободно\n",string, c+1);
		}
		else
		{
		    format(string,sizeof(string),"%s{FFFFFF}[%d] {1fa1ea}%s{FFFFFF}\n",string, c+1, VehicleNames[PLAYER_DATA[playerid][data_CAR][c]-400],PLAYER_DATA[playerid][data_CAR][c]);
		}
	}
	ShowPlayerDialogFix(playerid,dialog_FIXCAR, DIALOG_STYLE_LIST, "{FFCC00}Гараж", string, "Выбрать", "Отмена");
	return true;
}

CMD:ad(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_PHONE] == 0) return SendClientMessage(playerid, COLOR_WARNING, "У Вас нет мобильного телефона!");
    if(PLAYER_DATA[playerid][data_NUMBER] == 0) return SendClientMessage(playerid, COLOR_WARNING, "У Вас нет SIM-карты!");
    if(sscanf(params, "s[100]",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /ad [текст]");
	if(ad_timer != 0) return SendClientMessage(playerid,COLOR_WARNING,"Объявление можно подать через 15 секунд!");
	if(TotalAD == 15) return SendClientMessage(playerid, COLOR_WARNING, "В данный момент редакция переполнена!");
    new money = strlen(params[0])*3,dtext[160];
	new text[145];
    SetPVarInt(playerid,"ad_money",money);
    strmid(text, params[0], 0, strlen(params[0]), 128);
    SetPVarString(playerid, "ad_text",text);
	format(dtext,sizeof(dtext),"{FFFFFF}Текст: %s\nСтоимость: %d рублей",text,money);
    ShowPlayerDialogFix(playerid,dialog_AD,DIALOG_STYLE_MSGBOX,"{FFCC00}Объявление", dtext, "Подать","Отмена");
	return true;
}

CMD:news(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MEMBER] != 9) return SendClientMessage(playerid, COLOR_WARNING, "Данная команда для Вас недоступна!");
    new car = GetPlayerVehicleID(playerid);
    if(PlayerToPoint(10.0, playerid, 1949.2260,2922.0525,1672.9301) || car >= smi_car[0] && car <= smi_car[1]) return ShowPlayerDialogFix(playerid,dialog_NEWS,DIALOG_STYLE_LIST,"{FFCC00}Меню новостей",
	"{1fa1ea}1.{FFFFFF}Объявления\n\
	{1fa1ea}2.{FFFFFF}Начать эфир\n\
	{1fa1ea}3.{FFFFFF}Завершить эфир\n\
	{1fa1ea}4.{FFFFFF}Включить SMS сообщения\n\
	{1fa1ea}5.{FFFFFF}Выключить SMS сообщения\n\
	{1fa1ea}6.{FFFFFF}Добавить игрока в эфир\n\
	{1fa1ea}7.{FFFFFF}Удалить игрока из эфира\n\
	{1fa1ea}8.{FFFFFF}Казна СМИ", "Выбрать","Отмена");
	else SendClientMessage(playerid,COLOR_WARNING,"Нужно находиться в спец.транспорте или в студии!");
	return true;
}

CMD:su(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    if(sscanf(params, "us[50]", params[0], params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /su [ид] [причина]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(PLAYER_DATA[playerid][data_RANK] < 2 && PLAYER_DATA[playerid][data_MEMBER] != 8) return SendClientMessage(playerid,COLOR_WARNING,"Ваш ранг слишком мал для использования данной команды!");
	if(PLAYER_DATA[params[0]][data_WANTED] == 6) return SendClientMessage(playerid,COLOR_WARNING,"У игрока максимальный уровень розыска!");
	PLAYER_DATA[params[0]][data_WANTED]++;
	SetPlayerWantedLevel(params[0],PLAYER_DATA[params[0]][data_WANTED]);
	if(PLAYER_DATA[params[0]][data_ZAKON] > 0) PLAYER_DATA[params[0]][data_ZAKON]--;
	new str1[145],str2[145];
	format(str1,sizeof(str1),"[R] %s объявлен(а) в розыск. Обвинитель: %s. Причина: %s. %d/6",PLAYER_DATA[params[0]][data_NAME],PLAYER_DATA[playerid][data_NAME],params[1],PLAYER_DATA[params[0]][data_WANTED]);
	SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER],COLOR_AC,str1);
	format(str2,sizeof(str2),"%s объявил(а) Вас в розыск. Причина: %s",PLAYER_DATA[playerid][data_NAME],params[1]);
	SendClientMessage(params[0],COLOR_AC,str2);
	return true;
}

CMD:clear(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /clear [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(PLAYER_DATA[params[0]][data_WANTED] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У игрока нет розыска!");
	PLAYER_DATA[params[0]][data_WANTED] = 0;
	SetPlayerWantedLevel(params[0],PLAYER_DATA[params[0]][data_WANTED]);

	new message[145];
	format(message,sizeof(message),"{808080}[A] %s обнулил розыск %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	SendAdminMessage(0x666699FF,message);
	return true;
}


CMD:clearsu(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    if(PLAYER_DATA[playerid][data_LEADER] == 0) return SendClientMessage(playerid,COLOR_WARNING,"Ваш ранг слишком мал для использования данной команды!");
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /clearsu [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(PLAYER_DATA[params[0]][data_WANTED] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У игрока нет розыска!");
	PLAYER_DATA[params[0]][data_WANTED] = 0;
	SetPlayerWantedLevel(params[0],PLAYER_DATA[params[0]][data_WANTED]);
	new str1[145],str2[145];
	format(str1,sizeof(str1),"[R] %s снял розыск с %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER],COLOR_AC,str1);
	format(str2,sizeof(str2),"%s снял с Вас розыск",PLAYER_DATA[playerid][data_NAME]);
	SendClientMessage(params[0],COLOR_AC,str2);
	return true;
}

CMD:cuff(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /cuff [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(PLAYER_DATA[playerid][data_RANK] < 2 && PLAYER_DATA[playerid][data_MEMBER] != 8) return SendClientMessage(playerid,COLOR_WARNING,"Ваш ранг слишком мал для использования данной команды!");
	new Float:x,Float:y,Float:z,str[145];
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(3.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");
    if(GetPVarInt(params[0],"PlayerCuffed") == 1) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок уже в наручниках!");
	SetPlayerSpecialAction(params[0], SPECIAL_ACTION_CUFFED);
	SetPlayerAttachedObject(params[0],5,19418,6,0.020000,0.049999,-0.015000,-11.899997,-13.999941,-103.800086,1.110999,1.042000,1.934998);
	SetPVarInt(params[0],"PlayerCuffed",1);
	FreezePlayer(params[0]);
	format(str,sizeof(str),"%s надел(а) наручники на %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
 	ProxDetector(30.0, playerid, str,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
	return true;
}

CMD:uncuff(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /uncuff [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(PLAYER_DATA[playerid][data_RANK] < 2 && PLAYER_DATA[playerid][data_MEMBER] != 8) return SendClientMessage(playerid,COLOR_WARNING,"Ваш ранг слишком мал для использования данной команды!");
	new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(3.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");
    if(GetPVarInt(params[0],"PlayerCuffed") == 0) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок без наручников!");
	SetPlayerSpecialAction(params[0], 0);
	RemovePlayerAttachedObject(params[0], 5);
	DeletePVar(params[0],"PlayerCuffed");
	UnfreezePlayer(params[0]);
	new str[145];
	format(str,sizeof(str),"%s снял(а) наручники с %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
 	ProxDetector(30.0, playerid, str,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
	return true;
}

CMD:incar(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /incar [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(PLAYER_DATA[playerid][data_RANK] < 2 && PLAYER_DATA[playerid][data_MEMBER] != 8) return SendClientMessage(playerid,COLOR_WARNING,"Ваш ранг слишком мал для использования данной команды!");
    if(GetPVarInt(params[0],"PlayerCuffed") == 0) return SendClientMessage(playerid,COLOR_WARNING,"Игрок должен находиться в наручниках!");
	if(!IsPlayerInAnyVehicle(playerid)) return  SendClientMessage(playerid,COLOR_WARNING,"Вы должны находиться в автомобиле!");
	new Float:x,Float:y,Float:z;
	new car = GetPlayerVehicleID(playerid);
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(5.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");
	if(GetVehicleModel(car) == 599 || GetVehicleModel(car) == 597 || GetVehicleModel(car) == 523 || GetVehicleModel(car) == 601 ||
	GetVehicleModel(car) == 490 || GetVehicleModel(car) == 551)
	{
	    if(GetFreeSeat(car) == -1) return SendClientMessage(playerid,COLOR_WARNING,"В машине нет места!");
	    new str[145];
	    PutPlayerInVehicleAC(params[0],car,GetFreeSeat(car));
     	FreezePlayer(params[0]);
	    format(str,sizeof(str),"%s затащил(а) в автомобиль %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	    ProxDetector(30.0, playerid, str,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт не предназначен для перевозки преступников!");
	return true;
}

CMD:uncar(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /uncar [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(PLAYER_DATA[playerid][data_RANK] < 2 && PLAYER_DATA[playerid][data_MEMBER] != 8) return SendClientMessage(playerid,COLOR_WARNING,"Ваш ранг слишком мал для использования данной команды!");
    if(!IsPlayerInAnyVehicle(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Игрок должен находиться в транспорте!");
	new Float:x,Float:y,Float:z,str[145];
	GetPlayerPos(playerid,x,y,z);
	if(!PlayerToPoint(5.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");
 	UnfreezePlayer(params[0]);
 	SetPlayerPosAC(params[0],x+1.0,y,z);
  	format(str,sizeof(str),"%s вытащил(а) из автомобиля %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
  	ProxDetector(30.0, playerid, str,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
	return true;
}

CMD:arrest(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /arrest [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(PLAYER_DATA[playerid][data_RANK] < 2 && PLAYER_DATA[playerid][data_MEMBER] != 8) return SendClientMessage(playerid,COLOR_WARNING,"Ваш ранг слишком мал для использования данной команды!");
	new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(3.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");
	if(GetPVarInt(params[0],"PlayerCuffed") == 0) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок должен находиться в наручниках!");
	if(PLAYER_DATA[params[0]][data_WANTED] == 0) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не находиться в розыске!");


	if(PlayerToPoint(100.0, playerid, 26.4853,279.5816,12.5592))
	{
	    new str[145],str1[145];
		PLAYER_DATA[params[0]][data_JAIL] = 1;
		format(str,sizeof(str),"[R] %s[%d] нейтрализовал(а) преступника %s[%d]",PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[params[0]][data_NAME],params[0]);
		SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER],0x5882FAFF,str);
		format(str,sizeof(str),"Вас посадили в КПЗ. Офицер: %s",PLAYER_DATA[playerid][data_NAME]);
		SendClientMessage(params[0],COLOR_AC,str1);
		give_player_money(playerid,500,"#78");

	}
	else return SendClientMessage(playerid,COLOR_WARNING,"Нужно находиться возле здания ППС!");

    PLAYER_DATA[params[0]][data_JAILTIME] = 600*PLAYER_DATA[params[0]][data_WANTED];
	UnfreezePlayer(params[0]);
	PLAYER_DATA[params[0]][data_WANTED] = 0;
	SetPlayerWantedLevel(params[0],PLAYER_DATA[params[0]][data_WANTED]);
	SetPlayerSpawn(params[0]);
	SetPlayerSpecialAction(params[0], 0);
	RemovePlayerAttachedObject(params[0], 5);
	ResetWeaponAll(params[0]);
	DeletePVar(params[0],"PlayerCuffed");
	return true;
}

CMD:setmark(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    if(sscanf(params, "d",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /setmark [номер дела]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(GetPlayerInterior(params[0]) != 0) return SendClientMessage(playerid,COLOR_WARNING,"Игрок находиться в интерьере!");
	if(PLAYER_DATA[params[0]][data_WANTED] == 0) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не находиться в розыске!");
	if(PLAYER_DATA[playerid][data_SETMARK] != 0) return SendClientMessage(playerid, COLOR_WARNING, "Данную функцию можно использовать только один раз в минуту!");
    new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	SetPVarFloat(playerid, "gps_pos_x", x);
	SetPVarFloat(playerid, "gps_pos_y", y);
	SetPVarFloat(playerid, "gps_pos_z", z);
	DisablePlayerCheckpoint(playerid);
 	SetPlayerCheckpoint(playerid,x,y,z,5.0);
	SendClientMessage(playerid,0x33CC99FF,"[GPS]: Игрок был отмечен на вашем радаре красной меткой");
	GPSPlayer_(playerid, x, z, y, "Преступник");
	PLAYER_DATA[playerid][data_SETMARK] = 60;
	return true;
}


CMD:wanted(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
	new dtext[512],bugfix;
	for(new i = 0; i < MAX_PLAYERS; i++)
 	{
 	    if(!IsPlayerConnected(playerid)) continue;
		if(PLAYER_DATA[i][data_WANTED] != 0)
		{
		    bugfix = 1;
    		format(dtext,sizeof(dtext),"%s\n{FFFFFF}Дело №%d, имя: %s, уровень розыска: %d\n",dtext, i,PLAYER_DATA[i][data_NAME],PLAYER_DATA[i][data_WANTED]);
    	}
    }
	if(bugfix == 0) return ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Преступники", "{FFFFFF}Область чиста, преступники не обнаружены!", "Закрыть", "");
    ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Преступники", dtext, "Закрыть", "");
	return true;
}

CMD:tc(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /tc [ид]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(PLAYER_DATA[playerid][data_MEMBER] == 3)
    {
        if(PLAYER_DATA[params[0]][data_911_1] == 0) return SendClientMessage(playerid, COLOR_WARNING, "Игрок не вызывал полицию!");
        SetPVarFloat(playerid, "gps_pos_x", x);
		SetPVarFloat(playerid, "gps_pos_y", y);
		SetPVarFloat(playerid, "gps_pos_z", z);
  		DisablePlayerCheckpoint(playerid);
  		SetPlayerCheckpoint(playerid,x, y, z,5.0);
  		PLAYER_DATA[params[0]][data_911_1] = 0;
  		SendClientMessage(playerid,0x33CC99FF,"[GPS]: Игрок был отмечен на вашем радаре красной меткой");
  		GPSPlayer_(playerid, x, z, y, "Выезд на преступление");
	}
	else if(PLAYER_DATA[playerid][data_MEMBER] == 4)
	{
	    if(PLAYER_DATA[params[0]][data_911_2] == 0) return SendClientMessage(playerid, COLOR_WARNING, "Игрок не вызывал скорую помощь!");
        SetPVarFloat(playerid, "gps_pos_x", x);
		SetPVarFloat(playerid, "gps_pos_y", y);
		SetPVarFloat(playerid, "gps_pos_z", z);
  		DisablePlayerCheckpoint(playerid);
  		SetPlayerCheckpoint(playerid,x, y, z,5.0);
  		PLAYER_DATA[params[0]][data_911_2] = 0;
  		SendClientMessage(playerid,0x33CC99FF,"[GPS]: Игрок был отмечен на вашем радаре красной меткой");
  		GPSPlayer_(playerid, x, z, y, "Выезд на помощь");
	}
	else SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
	return true;
}


CMD:capture(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MEMBER] == 5
	|| PLAYER_DATA[playerid][data_MEMBER] == 6
	|| PLAYER_DATA[playerid][data_MEMBER] == 7)
	{
		if(PLAYER_DATA[playerid][data_RANK] < 6) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
		{
			for(new b = 0; b < TotalBusiness; b++)
			{
			    if(PlayerToPoint(10.0, playerid, BUSINESS_DATA[b][data_ENTERX],BUSINESS_DATA[b][data_ENTERY],BUSINESS_DATA[b][data_ENTERZ]) && BUSINESS_DATA[b][data_TYPE] != 1 ||
				PlayerToPoint(10.0, playerid, BUSINESS_DATA[b][data_BUYX],BUSINESS_DATA[b][data_BUYY],BUSINESS_DATA[b][data_BUYZ]) && BUSINESS_DATA[b][data_TYPE] == 1)
		  		{
					if(BUSINESS_DATA[b][data_MAFIA] == 0)
					{
				  		BUSINESS_DATA[b][data_MAFIA] = PLAYER_DATA[playerid][data_MEMBER];
						SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER],COLOR_AC,"[F] Ваша группировка захватила новый бизнес!");
						SaveBusinessData(b);
						return true;
					}
		  			if(BUSINESS_DATA[b][data_MAFIA] == PLAYER_DATA[playerid][data_MEMBER]) return SendClientMessage(playerid, COLOR_WARNING,"Данный бизнес уже пренадлежит вашей группировке!");
					if(IsCapture == true) return SendClientMessage(playerid, COLOR_WARNING,"В данный момент происходит захват бизнеса. Дождитесь окончания захвата!");
					capt_time = 600;
					capt_one_team = PLAYER_DATA[playerid][data_MEMBER];
					capt_two_team = BUSINESS_DATA[b][data_MAFIA];
					capt_one_kill = 0;
					capt_two_kill = 0;
					capt_biz = b;
					IsCapture = true;
			 		CaptureStart(capt_one_team,capt_two_team);
					return true;
				}
			}
		}
	}

	return true;
}

CMD:bizlist(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	new string[3000];
    for(new b = 0; b < TotalBusiness; b++)
    {
        new mafia[16];
		switch(BUSINESS_DATA[b][data_MAFIA])
		{
			case 5: mafia = "Трамповское ОПГ";
			case 6: mafia = "Майкопское ОПГ";
			case 7: mafia = "Одесское ОПГ";
			default: mafia = "Нет";
		}

		if(BUSINESS_DATA[b][data_OWNED] == 0)
		{
        	format(string,sizeof(string),"%s{FFFFFF}[%d] %s, крыша: %s, стоимость: {66FF33}%d рублей\n",string,b+1,BUSINESS_DATA[b][data_NAME],mafia,BUSINESS_DATA[b][data_PRICE]);
        }
		else
		{
		    format(string,sizeof(string),"%s{FFFFFF}[%d] %s, крыша: %s, владелец: %s\n",string,b+1,BUSINESS_DATA[b][data_NAME],mafia,BUSINESS_DATA[b][data_OWNER]);
		}
    }
    ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Список бизнесов", string, "Закрыть", "");
	return true;
}

CMD:tracklist(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	new string[1024];


    for(new t = 0; t < 10; t++)
    {
        format(string,sizeof(string),"%s{FFFFFF}%d - %s\n",string, t+1, CT_DATA[t][data_NAME]);
    }
    ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}ТОП", string, "Закрыть", "");
	return true;
}


CMD:givegun(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(sscanf(params, "ud", params[0], params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /givegun [ид] [кол-во]");
	if(playerid == params[0]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя передавать самому себе!");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");

	new Float:x,Float:y,Float:z;
	GetPlayerPos(playerid, x,y,z);
    if(!PlayerToPoint(5.0, params[0], x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Нужно находиться возле игрока!");

	new string[145];
	new gun = GetPlayerWeapon(playerid);
	new gunslot = getWeaponIdSlot(gun);


	if(params[1] < 1) return SendClientMessage(playerid, COLOR_WARNING, "Недопустимое значение!");
	if(PLAYER_DATA[playerid][data_GUN][gunslot] == 0 || gunslot == 0) return SendClientMessage(playerid,COLOR_WARNING,"Чтобы передать оружие, нужно взять его в руки!");
	if(PLAYER_DATA[playerid][data_AMMO][gunslot] < params[1]) return SendClientMessage(playerid,COLOR_WARNING, "У Вас нет такого количества патронов!");


	new ammonew = PLAYER_DATA[playerid][data_AMMO][gunslot] - params[1];

	SetWeapon(playerid, gun, ammonew);
    GiveWeapon(params[0], gun, params[1]);



    format(string, sizeof(string), "%s передал(а) оружие %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
	SetPlayerChatBubble(playerid, "передал(а) оружие", 0xFF66CCFF, 20.0, 4000);
	return true;
}

CMD:startgolos(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 6) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(VIBORY_STATUS == 1) return SendClientMessage(playerid, COLOR_WARNING, "В данный момент уже проходят выборы!");
    for(new i = 0; i < 5; i++) strmid(VIBORY_DATA[i][data_NAME], "None", 0, 5, 5);
    for(new i = 0; i < 5; i++) VIBORY_DATA[i][data_GOLOS] = 0;
    ShowPlayerDialogFix(playerid, dialog_VIBORY_1, DIALOG_STYLE_INPUT, "{FFCC00}Запуск выборов", "{FFFFFF}Введите имя кандидата №1", "Далее", "Отмена");
	return true;
}

CMD:stopgolos(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 6) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(VIBORY_STATUS == 0) return SendClientMessage(playerid, COLOR_WARNING, "В данный момент никаких выборов нет!");
    ShowPlayerDialogFix(playerid, dialog_VIBORY_7, DIALOG_STYLE_MSGBOX, "{FFCC00}Завершение выборов", "{FFFFFF}Вы желаете завершить выборы?", "Далее", "Отмена");
	return true;
}

CMD:finvite(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	new team = GetPlayerPolit(playerid);
	if(strfind(POLIT_TEAM[team][data_OWNER], PLAYER_DATA[playerid][data_NAME], true) != -1)
	{
		if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /finvite [ид]");
	    if(params[0] == playerid) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя использовать на самом себе!");
		if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
		if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
		if(PLAYER_DATA[params[0]][data_POLIT] != 0) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок состоит в семье!");
		new Float:x,Float:y,Float:z;
		GetPlayerPos(params[0],x,y,z);
		if(!PlayerToPoint(5.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");

		SetPVarInt(params[0], "yesno_pinvite", 1);
	    SetPVarInt(params[0], "yesno_playerid", playerid);
	    SetPVarInt(params[0], "yesno", 1);
		new str1[145], str2[145];
		format(str1,sizeof(str1),"{1fa1ea}Вы предложили присоединиться к вашей семье %s",PLAYER_DATA[params[0]][data_NAME]);
		SendClientMessage(playerid, 0xFF66CCFF, str1);
		format(str2,sizeof(str2),"{1fa1ea}%s предложил Вам присоедениться к его семье. Для согласия {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME]);
		SendClientMessage(params[0], 0xFF66CCFF, str2);
	}
	else SendClientMessage(playerid, COLOR_WARNING,"Данная функция доступна только основателю семьи!");
	return true;
}

CMD:offpmember(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    new team = GetPlayerPolit(playerid);
	if(strfind(POLIT_TEAM[team][data_OWNER], PLAYER_DATA[playerid][data_NAME], true) != -1)
	{
		if(sscanf(params, "s[24]", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /offpmember [имя]");
	    new query[60];
 		format(query, sizeof(query), "SELECT * FROM `accounts` WHERE `name` = '%s'",params[0]);
 		mysql_function_query(dbHandle, query, true, "OffPMember", "is", playerid, params[0]);
	}
	else SendClientMessage(playerid, COLOR_WARNING,"Данная функция доступна только основателю семьи!");


	return true;
}

