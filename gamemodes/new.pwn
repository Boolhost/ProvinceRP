stock IsPlayerInBandOnline(bandid)
{
	new band;
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(IsPlayerConnected(i)) continue;
		if(PLAYER_DATA[i][data_MEMBER] == bandid) band++;
	}
	return band;
}


stock give_player_money(playerid,amount,log[])
{
    if(IsPlayerConnected(playerid))
	{
	    GivePlayerMoney(playerid,amount);
	    PLAYER_DATA[playerid][data_MONEY] += amount;
        new gtfp[20],logtext[64],ctext[20];
	    if(amount < 0)
	    {
	        format(gtfp,sizeof(gtfp),"~r~%d RUB",amount);
	        GameTextForPlayer(playerid,gtfp, 1000, 1);

	        format(ctext,sizeof(ctext),"%d RUB",amount);
   			SetPlayerChatBubble(playerid, ctext, 0xFF3333FF, 20.0, 1500);


	    }
	    else
	    {
	        format(gtfp,sizeof(gtfp),"~g~%d RUB",amount);
	        GameTextForPlayer(playerid,gtfp, 1000, 1);

	        format(ctext,sizeof(ctext),"+%d RUB",amount);
         	SetPlayerChatBubble(playerid, ctext, 0x66FF33FF, 20.0, 1500);
	    }

		format(logtext,sizeof(logtext),"%d %s", amount,log);
		LOG("log_transfermoney",PLAYER_DATA[playerid][data_NAME], logtext);
    }
}

stock RandomEX(min, max)
{
	new a = random(max - min) + min;
	return a;
}

stock set_player_money(playerid,amount)
{
    if(IsPlayerConnected(playerid))
	{
	    ResetPlayerMoney(playerid);
	    GivePlayerMoney(playerid,amount);
    }
}

stock get_player_money(playerid)
{
    return PLAYER_DATA[playerid][data_MONEY];
}


stock ResetWeaponAll(playerid)
{
    ResetPlayerWeapons(playerid);
    for(new s; s != 13; s++)
    {
        PLAYER_DATA[playerid][data_GUN][s] = 0;
        PLAYER_DATA[playerid][data_AMMO][s] = 0;
    }
    return true;
}

stock getWeaponIdSlot(weaponid)
{
    switch(weaponid)
    {
        case 0, 1: return 0;
        case 2..9: return true;
        case 10..15: return 10;
        case 16..18, 39: return 8;
        case 22..24: return 2;
        case 25..27: return 3;
        case 28, 29, 32: return 4;
        case 30, 31: return 5;
        case 33, 34: return 6;
        case 35..38: return 7;
        case 40: return 12;
        case 41..43: return 9;
        case 44..46: return 11;
    }
    return -1;
}


stock ResetWeaponSlot(playerid, slot) //[slot 0-12]
{
    if(!IsPlayerConnected(playerid)) return false;
    new weapon[13], ammo[13];

    for(new i = 0; i < 13; i++)
    {
        if(i != slot)
		{
			weapon[i] = PLAYER_DATA[playerid][data_GUN][i];
			ammo[i] = PLAYER_DATA[playerid][data_AMMO][i];
		}
    }
    ResetWeaponAll(playerid);
    for(new i = 0; i < 13; i++)
    {
        if(i != slot) GiveWeapon(playerid, weapon[i], ammo[i]);
    }
    return true;
}

stock SetWeapon(playerid, gunid, ammo)
{
    new slotgunid = getWeaponIdSlot(gunid);

    ResetWeaponSlot(playerid, slotgunid);

    GivePlayerWeapon(playerid, gunid, ammo);

    PLAYER_DATA[playerid][data_GUN][slotgunid] = gunid;
    PLAYER_DATA[playerid][data_AMMO][slotgunid] = ammo;


    ac_gun[playerid][slotgunid] = 1;
    return true;
}


stock GiveWeapon(playerid, gunid, ammo)
{
    new slotgunid = getWeaponIdSlot(gunid);

    GivePlayerWeapon(playerid, gunid, ammo);

    PLAYER_DATA[playerid][data_GUN][slotgunid] = gunid;
    PLAYER_DATA[playerid][data_AMMO][slotgunid] += ammo;


    ac_gun[playerid][slotgunid] = 1;
    return true;
}

stock ShowAdmInfo(playerid, targetid)
{
	new carid = GetPlayerVehicleID(targetid);
	new Float:hp,Float:arm;
	new str1[20],str2[20],str3[20],str4[20],str5[20],str6[20],str7[20],str8[20],str9[20],str10[20],str11[40],str12[40];
	GetPlayerHealth(targetid,hp);
	GetPlayerArmour(targetid,arm);
	format(str1,sizeof(str1),"~b~FPS: ~w~%d",GetPlayerFPS(targetid));
	format(str2,sizeof(str2),"~b~PING: ~w~%d",GetPlayerPing(targetid));
	format(str3,sizeof(str3),"~b~SPEED: ~w~%d",Player_Speed(targetid));
    format(str4,sizeof(str4),"~b~CARID: ~w~%d",carid);
	format(str5,sizeof(str5),"~b~LVL: ~w~%d",PLAYER_DATA[targetid][data_LVL]);
	format(str6,sizeof(str6),"~b~HP: ~w~%.2f",hp);
	format(str7,sizeof(str7),"~b~ARM: ~w~%.2f",arm);
	format(str8,sizeof(str8),"~b~CASH: ~w~%d",get_player_money(targetid));
	format(str9,sizeof(str9),"~b~BANK: ~w~%d",PLAYER_DATA[targetid][data_BANK]);
	format(str10,sizeof(str10),"~b~WARN: ~w~%d",PLAYER_DATA[targetid][data_WARN]);
	format(str11,sizeof(str11),"~b~REG-IP: ~w~%s",PLAYER_DATA[targetid][data_REGISTER_IP]);
	format(str12,sizeof(str12),"~b~LOG-IP: ~w~%s",PLAYER_DATA[targetid][data_LOGIN_IP]);

	PlayerTextDrawSetString(playerid, adm_info[playerid][0], str1);
	PlayerTextDrawSetString(playerid, adm_info[playerid][1], str2);
	PlayerTextDrawSetString(playerid, adm_info[playerid][2], str3);
	PlayerTextDrawSetString(playerid, adm_info[playerid][3], str4);
	PlayerTextDrawSetString(playerid, adm_info[playerid][4], str5);
	PlayerTextDrawSetString(playerid, adm_info[playerid][5], str6);
	PlayerTextDrawSetString(playerid, adm_info[playerid][6], str7);
	PlayerTextDrawSetString(playerid, adm_info[playerid][7], str8);
	PlayerTextDrawSetString(playerid, adm_info[playerid][8], str9);
	PlayerTextDrawSetString(playerid, adm_info[playerid][9], str10);
	PlayerTextDrawSetString(playerid, adm_info[playerid][10], str11);
	PlayerTextDrawSetString(playerid, adm_info[playerid][11], str12);

	for(new i = 0; i < 12; i++) PlayerTextDrawShow(playerid, adm_info[playerid][i]);
	return true;
}

stock HideAdmInfo(playerid)
{
	for(new i = 0; i < 12; i++) PlayerTextDrawHide(playerid, adm_info[playerid][i]);
	return true;
}

stock GetPlayerFPS(playerid)
{
	SetPVarInt(playerid, "DrunkL", GetPlayerDrunkLevel(playerid));
 	if(GetPVarInt(playerid, "DrunkL") < 100) SetPlayerDrunkLevel(playerid, 2000);
	else
	{
		if(GetPVarInt(playerid, "LDrunkL") != GetPVarInt(playerid, "DrunkL"))
		{
			SetPVarInt(playerid, "FPS", (GetPVarInt(playerid, "LDrunkL") - GetPVarInt(playerid, "DrunkL")));
 			SetPVarInt(playerid, "LDrunkL", GetPVarInt(playerid, "DrunkL"));
     		if((GetPVarInt(playerid, "FPS") > 0) && (GetPVarInt(playerid, "FPS") < 256))
    		{
     			return GetPVarInt(playerid, "FPS") - 1;
    		}
		}
	}
  	return false;
}

stock SetPlayerSpawn(playerid)
{
	if(PLAYER_DATA[playerid][data_HP] < 30) PLAYER_DATA[playerid][data_HP] = 30.0;

    switch(PLAYER_DATA[playerid][data_SPAWN])
    {
        case 1:
        {
            if(PLAYER_DATA[playerid][data_MEMBER] == 0) PLAYER_DATA[playerid][data_SPAWN] = 0;
        }
        case 2:
        {
            if(PLAYER_DATA[playerid][data_HOUSE] == INVALID_HOUSE_ID && PLAYER_DATA[playerid][data_KV] == INVALID_HOUSE_ID) PLAYER_DATA[playerid][data_SPAWN] = 0;
        }
    }
    SetPlayerSkills(playerid);
    SetPlayerColorEx(playerid);
    SetPlayerHealthAC(playerid, PLAYER_DATA[playerid][data_HP]);
    SetPlayerTeam(playerid, NO_TEAM);
    if(PLAYER_DATA[playerid][data_MEMBER] == 0)
	{
		SetPlayerSkinAC(playerid, PLAYER_DATA[playerid][data_SKIN]);
	}
    else
	{
		SetPlayerSkinAC(playerid, PLAYER_DATA[playerid][data_SKINM]);
	}


    set_player_money(playerid,PLAYER_DATA[playerid][data_MONEY]);
	SetPlayerScore(playerid, PLAYER_DATA[playerid][data_LVL]);
 	SetPlayerWantedLevel(playerid,PLAYER_DATA[playerid][data_WANTED]);

	if(GetPVarInt(playerid, "SpecBool") == 1)
	{
	    DeletePVar(playerid, "SpecBool");
	    DeletePVar(playerid, "FlyMode");
		SetPlayerPosAC(playerid, GetPVarFloat(playerid,"SpecX"), GetPVarFloat(playerid,"SpecY"), GetPVarFloat(playerid,"SpecZ"));
		SetPlayerFacingAngle(playerid, GetPVarFloat(playerid,"SpecFA"));
		SetPlayerInterior(playerid,GetPVarInt(playerid,"SpecInt"));
		SetPlayerVirtualWorld(playerid,GetPVarInt(playerid,"SpecWorld"));
		HideAdmInfo(playerid);
		return true;
	}

	if(PLAYER_DATA[playerid][data_CS_TEAM] != 0 && PLAYER_DATA[playerid][data_HOSPITAL] == 1)
	{
	    PLAYER_DATA[playerid][data_CS_TEAM] = 0;
	    PLAYER_DATA[playerid][data_HOSPITAL] = 0;
	    SetPlayerHealthAC(playerid, 100);

	    SetPlayerPosAC(playerid, 2285.4358,1370.0557,11.4574);
	    SetPlayerVirtualWorld(playerid, 0);
		SetPlayerInterior(playerid,0);
		SetPlayerFacingAngle(playerid, 90.0);
		SetCameraBehindPlayer(playerid);
	    return true;
	}

	switch(PLAYER_DATA[playerid][data_JAIL])
	{
	    case 1:
	    {
 			SetPlayerVirtualWorld(playerid,1);
			SetPlayerInterior(playerid,1);
