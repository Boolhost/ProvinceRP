				        new dtext[30];
						format(dtext,sizeof(dtext),"{33CC99}%d рублей",smi_money);
					    ShowPlayerDialogFix(playerid,dialog_NEWS_11, DIALOG_STYLE_INPUT, dtext, "{FFFFFF}Введите сумму, которую желаете снять", "Снять", "Отмена");
