    if(playerid == params[0]) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя приминить на себе!");
	if(PLAYER_DATA[params[0]][data_ADMLVL] > PLAYER_DATA[playerid][data_ADMLVL]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к старшей администрации!");
	PLAYER_DATA[params[0]][data_MEMBER] = 0;
	PLAYER_DATA[params[0]][data_LEADER] = 0;
	PLAYER_DATA[params[0]][data_RANK] = 0;
	PLAYER_DATA[params[0]][data_ADMLVL] = 0;
 	new query[256];
    mysql_format(dbHandle,query, sizeof(query), "INSERT INTO `banlist` ( `name`,`admin`, `day`, `text`, `ip`) VALUES ( '%e', '%e', '%d', '%e', '%e')",PLAYER_DATA[params[0]][data_NAME],PLAYER_DATA[playerid][data_NAME],params[1],params[2],PLAYER_DATA[params[0]][data_LOGIN_IP]);
    mysql_function_query(dbHandle, query, false, "", "");
    for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(GetPVarInt(i,"gPlayerAaction") == 0)
	    {
	        new string[145];
			format(string, sizeof(string), "Администратор %s заблокировал %s на %d дней. Причина: %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME],params[1],params[2]);
			SendClientMessage(i,COLOR_AC,string);
		}
	}
	Kick(params[0]);
	return true;
}

CMD:offban(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 8) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new nickbancmd[24], daybancmd, prinbancmd[32];
	if(sscanf(params,"s[24]ds[32]", nickbancmd, daybancmd, prinbancmd)) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /offban [имя] [кол-во дней] [причина]");
	if(daybancmd < 1 || daybancmd > 90) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя меньше 1 дня и больше 90 дней!");
    if(PLAYER_DATA[playerid][data_NAME] == strlen(nickbancmd)) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя приминить на себе!");
	//if(PLAYER_DATA[params[0]][data_ADMLVL] > PLAYER_DATA[playerid][data_ADMLVL]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к старшей администрации!");

    for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
  		if(!strcmp(nickbancmd, PLAYER_DATA[i][data_NAME], false)) return SendClientMessage(playerid, COLOR_WARNING,"Этот игрок в сети, используйте /ban");
	}

	/*new debug128[128];
	format(debug128, sizeof(debug128), "Debug name: %s", nickbancmd);
	SendClientMessage(playerid, -1, debug128);*/

	//SetPVarInt(playerid,"PlayerBan",params[0]);
	SetPVarInt(playerid,"DaysBan", daybancmd);
 	SetPVarString(playerid,"TextBan", prinbancmd);
	new query[60];
 	mysql_format(dbHandle,query, sizeof(query), "SELECT * FROM `accounts` WHERE `name` = '%e'", nickbancmd);
 	mysql_function_query(dbHandle, query, true, "OffBan", "is", playerid, nickbancmd);
	return true;
}

