CMD:invite(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

	switch(PLAYER_DATA[playerid][data_MEMBER])
	{
		case 1:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 6) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 2:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 13) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 3:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 14) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 4:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 5) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 5,6,7:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 6) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 8:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 13) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 9:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 6) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		default: return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");

	}


	if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /invite [ид]");
	if(params[0] == playerid) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя использовать на самом себе!");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(PLAYER_DATA[params[0]][data_MEMBER] != 0) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок состоит во организации!");
	if(PLAYER_DATA[params[0]][data_WARN] != 0) return SendClientMessage(playerid,COLOR_WARNING,"У данного игрока есть предупреждения!");
	new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(5.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");


	SetPVarInt(params[0], "yesno_invite", 1);
	SetPVarInt(params[0], "yesno_playerid", playerid);
	SetPVarInt(params[0], "yesno", 1);
	new str1[145], str2[145];
	format(str1,sizeof(str1),"{1fa1ea}Вы предложили присоединиться к вашей организации %s",PLAYER_DATA[params[0]][data_NAME]);
	SendClientMessage(playerid, 0xFF66CCFF, str1);
	format(str2,sizeof(str2),"{1fa1ea}%s предложил Вам присоедениться к его организации. Для согласия {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME]);
	SendClientMessage(params[0], 0xFF66CCFF, str2);
	return true;
}


CMD:leave(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_VIP] != 1 || PLAYER_DATA[playerid][data_IMPROVEMENTS1]) return SendClientMessage(playerid, COLOR_WARNING, "Данная функция доступна VIP игрокам или у кого куплено улучшения Решительность!");
	if(PLAYER_DATA[playerid][data_MEMBER] == 0) return SendClientMessage(playerid, COLOR_WARNING, "Вы не состоите в организации!");

	new str[145];
	format(str,sizeof(str),"[R] %s вышел из организации",PLAYER_DATA[playerid][data_NAME]);
	SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER], 0xFF3333FF, str);
	PLAYER_DATA[playerid][data_MEMBER] = 0;
	PLAYER_DATA[playerid][data_PODMEMBER] = 0;
	PLAYER_DATA[playerid][data_RANK] = 0;
	PLAYER_DATA[playerid][data_LEADER] = 0;
	SetPlayerSkinAC(playerid,PLAYER_DATA[playerid][data_SKIN]);
	SetPlayerColorEx(playerid);

	if(IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	{
		new Float:x, Float:y, Float:z;
	 	GetPlayerPos(playerid,x,y,z);
	 	SetPlayerPosAC(playerid,x,y,z+2);
	}
	return true;
}



CMD:uninvite(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

    switch(PLAYER_DATA[playerid][data_MEMBER])
	{
		case 1:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 6) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 2:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 13) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 3:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 14) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 4:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 5) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 5,6,7:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 6) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 8:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 13) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		case 9:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 6) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		default: return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");

	}

    if(sscanf(params,"us[60]",params[0],params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /uninvite [ид] [причина]");
    if(params[0] == playerid) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя использовать на самом себе!");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(PLAYER_DATA[playerid][data_MEMBER] != PLAYER_DATA[params[0]][data_MEMBER]) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не состоит в Вашей организации!");
	if(PLAYER_DATA[params[0]][data_LEADER] != 0) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к лидеру!");
	new str[145];
	format(str,sizeof(str),"[R] %s уволил из организации %s. Причина: %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME],params[1]);
	SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER], 0xFF3333FF, str);
	PLAYER_DATA[params[0]][data_MEMBER] = 0;
	PLAYER_DATA[params[0]][data_PODMEMBER] = 0;
	PLAYER_DATA[params[0]][data_RANK] = 0;
	PLAYER_DATA[params[0]][data_LEADER] = 0;
	SetPlayerSkinAC(params[0],PLAYER_DATA[params[0]][data_SKIN]);
	SetPlayerColorEx(params[0]);

	if(IsPlayerInAnyVehicle(params[0]) && GetPlayerState(params[0]) == PLAYER_STATE_DRIVER)
	{
		new Float:x, Float:y, Float:z;
	 	GetPlayerPos(params[0],x,y,z);
	 	SetPlayerPosAC(params[0],x,y,z+2);
	}
	return true;
}

