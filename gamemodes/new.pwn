stock GetFreeSeat(vehicleid)
{
	if(!vehicleid) return -1;
	new model = GetVehicleModel(vehicleid);
	new maxs = GetMaxSeat(model) - 1;
	new bool:seat[3],cnt;
	for(new i;i<MAX_PLAYERS;i++)
	{
		if(!IsPlayerConnected(i) || GetPlayerVehicleID(i) != vehicleid) continue;
		new pseat = GetPlayerVehicleSeat(i);
		if(pseat < 1 || pseat > 3) continue;
		seat[pseat-1] = true;
		cnt++;
		if(cnt >= maxs) return -1;
	}
	for(new i;i<3;i++) if(!seat[i]) return i+1;
	return -1;
}

stock GetMaxSeat(modelid)
{
	switch(modelid)
	{
		case 596..598,427,490: return 4;
		case 599,497,528: return 2;
	}
	return -1;
}

stock AddCheater(playerid)
{
	for(new i = 0; i < 9; i++)
	{
	    if(CheatID[i] == playerid) return true;
	}

	CheatID[0] = playerid;
    new str_0[4], str_1[4], str_2[4], str_3[4], str_4[4], str_5[4], str_6[4], str_7[4], str_8[4];

    format(str_0, sizeof(str_0), "%d", playerid);
    TextDrawSetString(CheatText[0], str_0);
    format(str_1, sizeof(str_1), "%d", CheatID[1]);
    TextDrawSetString(CheatText[1], str_1);
    format(str_2, sizeof(str_2), "%d", CheatID[2]);
    TextDrawSetString(CheatText[2], str_2);
    format(str_3, sizeof(str_3), "%d", CheatID[3]);
    TextDrawSetString(CheatText[3], str_3);
    format(str_4, sizeof(str_4), "%d", CheatID[4]);
    TextDrawSetString(CheatText[4], str_4);
    format(str_5, sizeof(str_5), "%d", CheatID[5]);
    TextDrawSetString(CheatText[5], str_5);
    format(str_6, sizeof(str_6), "%d", CheatID[6]);
    TextDrawSetString(CheatText[6], str_6);
    format(str_7, sizeof(str_7), "%d", CheatID[7]);
    TextDrawSetString(CheatText[7], str_7);
    format(str_8, sizeof(str_8), "%d", CheatID[8]);
    TextDrawSetString(CheatText[8], str_8);

    CheatID[8] = CheatID[7];
    CheatID[7] = CheatID[6];
    CheatID[6] = CheatID[5];
    CheatID[5] = CheatID[4];
    CheatID[4] = CheatID[3];
    CheatID[3] = CheatID[2];
    CheatID[2] = CheatID[1];
    CheatID[1] = CheatID[0];
    return true;
}

stock IsVehicleOccupied(vehicleid)
{
	for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i)) continue;
        if(IsPlayerInVehicle(i,vehicleid)) return true;
    }
	return false;
}

stock SetPlayerSkills(playerid)
{
    SetPlayerSkillLevel(playerid, WEAPONSKILL_PISTOL, PLAYER_DATA[playerid][data_PISTOL]*10);
    SetPlayerSkillLevel(playerid, WEAPONSKILL_PISTOL_SILENCED, PLAYER_DATA[playerid][data_SDPISTOL]*10);
    SetPlayerSkillLevel(playerid, WEAPONSKILL_DESERT_EAGLE, PLAYER_DATA[playerid][data_DEAGLE]*10);
    SetPlayerSkillLevel(playerid, WEAPONSKILL_SHOTGUN, PLAYER_DATA[playerid][data_SHOTGUN]*10);
    SetPlayerSkillLevel(playerid, WEAPONSKILL_MP5, PLAYER_DATA[playerid][data_MP5]*10);
    SetPlayerSkillLevel(playerid, WEAPONSKILL_AK47, PLAYER_DATA[playerid][data_AK47]*10);
    SetPlayerSkillLevel(playerid, WEAPONSKILL_SNIPERRIFLE, PLAYER_DATA[playerid][data_SNIPERRIFLE]*10);
    return true;
}


stock ShowSpeedometr(playerid)
{
	new carid = GetPlayerVehicleID(playerid);
    if(!IsABMX(carid)) SetPVarInt(playerid,"open_speed",1);
    PLAYER_DATA[playerid][data_SPEED_UPDATE] = SetTimerEx("SpeedUpdate", 200, true, "d", playerid);
    if(GetPVarInt(playerid, "gPlayerSpeed") == 1) return true;
    TextDrawShowForPlayer(playerid, SpeedometrFon);
	PlayerTextDrawShow(playerid, SpeedometrSpeed[playerid]);
	switch(CAR_DATA[carid][data_ENG])
	{
		case 0: PlayerTextDrawShow(playerid, SpeedometrEngine[playerid][1]);
		case 1: PlayerTextDrawShow(playerid, SpeedometrEngine[playerid][0]);
	}
	switch(CAR_DATA[carid][data_LOCK])
	{
		case 0: PlayerTextDrawShow(playerid, SpeedometrLock[playerid][1]);
		case 1: PlayerTextDrawShow(playerid, SpeedometrLock[playerid][0]);
	}
	switch(CAR_DATA[carid][data_LAMP])
	{
		case 0: PlayerTextDrawShow(playerid, SpeedometrLamp[playerid][1]);
		case 1: PlayerTextDrawShow(playerid, SpeedometrLamp[playerid][0]);
	}
	//PlayerTextDrawShow(playerid, SpeedometrOdometr[playerid]);
	//PlayerTextDrawShow(playerid, SpeedometrII[playerid]);
	PlayerTextDrawShow(playerid, SpeedometrFuel[playerid]);
	return true;
}

stock HideSpeedometr(playerid)
{
    //cef_destroy_browser(playerid, 0x12348);
    DeletePVar(playerid,"open_speed");
    KillTimer(PLAYER_DATA[playerid][data_SPEED_UPDATE]);
    TextDrawHideForPlayer(playerid, SpeedometrFon);
	PlayerTextDrawHide(playerid, SpeedometrSpeed[playerid]);
	PlayerTextDrawHide(playerid, SpeedometrEngine[playerid][1]);
	PlayerTextDrawHide(playerid, SpeedometrEngine[playerid][0]);
	PlayerTextDrawHide(playerid, SpeedometrLock[playerid][1]);
	PlayerTextDrawHide(playerid, SpeedometrLock[playerid][0]);
	PlayerTextDrawHide(playerid, SpeedometrLamp[playerid][1]);
	PlayerTextDrawHide(playerid, SpeedometrLamp[playerid][0]);
	//PlayerTextDrawHide(playerid, SpeedometrOdometr[playerid]);
	//PlayerTextDrawHide(playerid, SpeedometrII[playerid]);
	PlayerTextDrawHide(playerid, SpeedometrFuel[playerid]);
}



stock addkv(playerid)
{
    new query[600];
    new Float:a1 = GetPVarFloat(playerid, "aEnterX");
    new Float:a2 = GetPVarFloat(playerid, "aEnterY");
    new Float:a3 = GetPVarFloat(playerid, "aEnterZ");
    new Float:a4 = GetPVarFloat(playerid, "aCarX");
    new Float:a5 = GetPVarFloat(playerid, "aCarY");
    new Float:a6 = GetPVarFloat(playerid, "aCarZ");
    new Float:a7 = GetPVarFloat(playerid, "aCarAngle");


	mysql_format(dbHandle,query, sizeof query, "INSERT INTO `kvartiry` ( `enter_x`, `enter_y`, `enter_z`, `car_posx`, `car_posy`, `car_posz`, `car_posa`) VALUES ( '%f', '%f', '%f', '%f', '%f', '%f', '%f')",a1,a2,a3,a4,a5,a6,a7);
    mysql_function_query(dbHandle, query, false, "", "");

    CreateDynamicMapIcon(GetPVarFloat(playerid, "aEnterX"), GetPVarFloat(playerid, "aEnterY"), GetPVarFloat(playerid, "aEnterZ"), 31, -1, 0, -1, -1, 100.0);
    CreateDynamicPickup(1273, 23, GetPVarFloat(playerid, "aEnterX"), GetPVarFloat(playerid, "aEnterY"), GetPVarFloat(playerid, "aEnterZ"),-1);
	return true;
}

stock AddHouse(playerid)
{
    new query[600];
    new h = TotalHouses;
    new Float:a1 = GetPVarFloat(playerid, "aEnterX");
    new Float:a2 = GetPVarFloat(playerid, "aEnterY");
    new Float:a3 = GetPVarFloat(playerid, "aEnterZ");
    new Float:a4 = GetPVarFloat(playerid, "aExitX");
    new Float:a5 = GetPVarFloat(playerid, "aExitY");
    new Float:a6 = GetPVarFloat(playerid, "aExitZ");
    new a7 = GetPVarInt(playerid, "aInt");
    new a8 = GetPVarInt(playerid, "aClass");
    new a9 = GetPVarInt(playerid, "aPrice");
    new Float:a10 = GetPVarFloat(playerid, "aCarX");
    new Float:a11 = GetPVarFloat(playerid, "aCarY");
    new Float:a12 = GetPVarFloat(playerid, "aCarZ");
    new Float:a13 = GetPVarFloat(playerid, "aCarAngle");
    SetPVarInt(playerid,"addhouse", 0);
    SendClientMessage(playerid,-1, "Дом добавлен");
    HOUSE_DATA[h][data_ENTERX] = a1;
    HOUSE_DATA[h][data_ENTERY] = a2;
    HOUSE_DATA[h][data_ENTERZ] = a3;
    HOUSE_DATA[h][data_EXITX] = a4;
    HOUSE_DATA[h][data_EXITY] = a5;
    HOUSE_DATA[h][data_EXITZ] = a6;
    HOUSE_DATA[h][data_INT] = a7;
    HOUSE_DATA[h][data_CLASS] = a8;
    HOUSE_DATA[h][data_PRICE] = a9;
    HOUSE_DATA[h][data_CARX] = a10;
    HOUSE_DATA[h][data_CARY] = a11;
    HOUSE_DATA[h][data_CARZ] = a12;
    HOUSE_DATA[h][data_CARANGLE] = a13;
    if(HOUSE_DATA[h][data_OWNED] == 0)
   	{
		HOUSE_DATA[h][data_PICKUPENTER] = CreateDynamicPickup(1273, 23, HOUSE_DATA[h][data_ENTERX], HOUSE_DATA[h][data_ENTERY], HOUSE_DATA[h][data_ENTERZ],-1);
		HOUSE_DATA[h][data_MAPICON] = CreateDynamicMapIcon(HOUSE_DATA[h][data_ENTERX], HOUSE_DATA[h][data_ENTERY], HOUSE_DATA[h][data_ENTERZ], 31, -1, 0, -1, -1, 200.0);
	}
	else
	{
		HOUSE_DATA[h][data_PICKUPENTER] = CreateDynamicPickup(19131, 23, HOUSE_DATA[h][data_ENTERX], HOUSE_DATA[h][data_ENTERY], HOUSE_DATA[h][data_ENTERZ],0);
		HOUSE_DATA[h][data_MAPICON] = CreateDynamicMapIcon(HOUSE_DATA[h][data_ENTERX], HOUSE_DATA[h][data_ENTERY], HOUSE_DATA[h][data_ENTERZ], 32, -1, 0, -1, -1, 200.0);
	}
	TotalHouses++;
	mysql_format(dbHandle,query, sizeof query, "INSERT INTO `houses` ( `enterx`, `entery`, `enterz`, `exitx`, `exity`, `exitz`, `carx`, `cary`, `carz`, `cara`, `int`, `class`, `price`) VALUES ( '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%d', '%d', '%d')",a1,a2,a3,a4,a5,a6,a10,a11,a12,a13,a7,a8,a9);
    mysql_function_query(dbHandle, query, false, "", "");
	return true;
}

stock StartShar()
{
    shar_ex = 0;

    for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i)) continue;
        if(!PlayerToPoint(30.0, i, shar_cords[0][0], shar_cords[0][1], shar_cords[0][2])) continue;
    	ProxDetector(30.0, i, "Шар отправляется в путь через 10 секунд!", 0x99FF99FF, 0x99FF99FF, 0x99FF99FF, 0x99FF99FF, 0x99FF99FF);
	}
	shar_timer = SetTimer("SharTimer",10000,true);
	return true;
}

public SharTimer()
{
    new Float:x, Float:y, Float:z;
	GetObjectPos(shar, x, y, z);

	if(shar_cords[0][0] == x && shar_cords[0][1] == y && shar_ex == 0)
	{
	    shar_ex = 1;
	    MoveObject(shar, shar_cords[1][0], shar_cords[1][1], shar_cords[1][2], 2.5);
	    return true;
	}
	else if(shar_cords[1][0] == x && shar_cords[1][1] && shar_ex == 1)
	{
        shar_ex = 2;
	    MoveObject(shar, shar_cords[2][0], shar_cords[2][1], shar_cords[2][2], 2.5);
	    return true;
	}
    else if(shar_cords[2][0] == x && shar_cords[2][1] && shar_ex == 2)
	{
	    shar_ex = 3;
	    MoveObject(shar, shar_cords[3][0], shar_cords[3][1], shar_cords[3][2], 2.5);
	    return true;
	}
	else if(shar_cords[3][0] == x && shar_cords[3][1] && shar_ex == 3)
	{
	    KillTimer(shar_timer);
	    MoveObject(shar, shar_cords[4][0], shar_cords[4][1], shar_cords[4][2], 2.5);
	    return true;
	}
	return true;
}
forward timer();
public timer()
{
	new hour, minute, second;
	gettime(hour, minute, second);
	if(minute == 0)
	{
		SetWorldTime(hour);
	}
	return true;
}

public GarageTpCar(vehid,Float:x,Float:y,Float:z,Float:f,w)
{
    new playerid = GetPVarInt(playerid, "player");
	SetVehiclePos(vehid, x,y,z);
	SetVehicleZAngle(vehid, f);
	SetVehicleVirtualWorld(vehid, w);
	PutPlayerInVehicleAC(playerid, vehid, 0);
	return true;
}

stock add_business(playerid,b)
{
	new query[512],str[256],name[15];
	new Float:enterx = GetPVarFloat(playerid,"add_b_enterX");
	new Float:entery = GetPVarFloat(playerid,"add_b_enterY");
	new Float:enterz = GetPVarFloat(playerid,"add_b_enterZ");
	new Float:exitx = GetPVarFloat(playerid,"add_b_exitX");
	new Float:exity = GetPVarFloat(playerid,"add_b_exitY");
	new Float:exitz = GetPVarFloat(playerid,"add_b_exitZ");
	new Float:buyx = GetPVarFloat(playerid,"add_b_buyX");
	new Float:buyy = GetPVarFloat(playerid,"add_b_buyY");
	new Float:buyz = GetPVarFloat(playerid,"add_b_buyZ");


	new inter = GetPVarInt(playerid,"add_b_int");
	new map = GetPVarInt(playerid,"add_b_map");
	new vw = GetPVarInt(playerid,"add_b_vw");
	new type = GetPVarInt(playerid,"add_b_type");
	new price = GetPVarInt(playerid,"add_b_price");




	SendClientMessage(playerid,-1, "Бизнес был добавлен");
	strmid(name, BUSINESS_DATA[b][data_NAME], 0, 25, 25);
	BUSINESS_DATA[b][data_OWNED] = 0;
	BUSINESS_DATA[b][data_PRICE] = price;
	BUSINESS_DATA[b][data_ENTERX] = enterx;
	BUSINESS_DATA[b][data_ENTERY] = entery;
	BUSINESS_DATA[b][data_ENTERZ] = enterz;
	BUSINESS_DATA[b][data_BUYX] = buyx;
	BUSINESS_DATA[b][data_BUYY] = buyy;
	BUSINESS_DATA[b][data_BUYZ] = buyz;
	BUSINESS_DATA[b][data_EXITX] = exitx;
	BUSINESS_DATA[b][data_EXITY] = exity;
	BUSINESS_DATA[b][data_EXITZ] = exitz;
	BUSINESS_DATA[b][data_TYPE] = type;
	BUSINESS_DATA[b][data_INT] = inter;
	BUSINESS_DATA[b][data_VW] = vw;
	BUSINESS_DATA[b][data_MAPICON] = map;
	TotalBusiness++;
	if(BUSINESS_DATA[b][data_TYPE] == 1)
	{
		format(str,sizeof(str), "{CCFF00}Название бизнеса: {FFFFFF}%s\n{CCFF00}Стоимость бизнеса: {FFFFFF}%i рублей\n{CCFF00}Для покупки бизнеса используйте: {FFFFFF}/buy\n{339966}/buyfuel",BUSINESS_DATA[b][data_NAME], BUSINESS_DATA[b][data_PRICE]);
		BUSINESS_DATA[b][data_TEXTINFO] = CreateDynamic3DTextLabel(str, -1, BUSINESS_DATA[b][data_BUYX],BUSINESS_DATA[b][data_BUYY], BUSINESS_DATA[b][data_BUYZ],3.0);
		BUSINESS_DATA[b][data_MAPICON] = CreateDynamicMapIcon(BUSINESS_DATA[b][data_BUYX], BUSINESS_DATA[b][data_BUYY], BUSINESS_DATA[b][data_BUYZ], BUSINESS_DATA[b][data_MAPICON], -1, 0, -1, -1, 200.0);
	}
	else
	{
		format(str,sizeof(str), "{CCFF00}Название бизнеса: {FFFFFF}%s\n{CCFF00}Стоимость бизнеса: {FFFFFF}%i рублей\n{CCFF00}Для покупки бизнеса используйте: {FFFFFF}/buy",BUSINESS_DATA[b][data_NAME],BUSINESS_DATA[b][data_PRICE]);
		BUSINESS_DATA[b][data_TEXTINFO] = CreateDynamic3DTextLabel(str, -1,BUSINESS_DATA[b][data_ENTERX], BUSINESS_DATA[b][data_ENTERY], BUSINESS_DATA[b][data_ENTERZ],3.0);
		BUSINESS_DATA[b][data_PICKENTER] = CreateDynamicPickup(19132, 23, BUSINESS_DATA[b][data_ENTERX], BUSINESS_DATA[b][data_ENTERY], BUSINESS_DATA[b][data_ENTERZ],-1);
		BUSINESS_DATA[b][data_PICKEXIT] = CreateDynamicPickup(19132, 23, BUSINESS_DATA[b][data_EXITX], BUSINESS_DATA[b][data_EXITY], BUSINESS_DATA[b][data_EXITZ],BUSINESS_DATA[b][data_VW]);
		BUSINESS_DATA[b][data_MAPICON] = CreateDynamicMapIcon(BUSINESS_DATA[b][data_ENTERX], BUSINESS_DATA[b][data_ENTERY], BUSINESS_DATA[b][data_ENTERZ], BUSINESS_DATA[b][data_MAPICON], -1, 0, -1, -1, 200.0);
		BUSINESS_DATA[b][data_CHEK] = CreateDynamicPickup(1239,23,BUSINESS_DATA[b][data_BUYX], BUSINESS_DATA[b][data_BUYY], BUSINESS_DATA[b][data_BUYZ],BUSINESS_DATA[b][data_VW]);
	}
	mysql_format(dbHandle,query, sizeof query, "INSERT INTO `business` ( `name`, `enter_x`, `enter_y`, `enter_z`, `exit_x`, `exit_y`, `exit_z`, `buy_x`, `buy_y`, `buy_z`, `int`, `vw`, `mapicon`, `price`, `type`) VALUES ( '%e', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%d', '%d', '%d', '%d', '%d')",name,enterx,entery,enterz,exitx,exity,exitz,buyx,buyy,buyz,inter,vw,map,price,type);
    mysql_function_query(dbHandle, query, false, "", "");
	return true;
}

