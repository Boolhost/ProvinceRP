stock GOCS()
{
    if(cs_open == true) return true;
	cs_open = true;



    SetTimer("StartCS",1000*60*3,false);
	cs_status = true;
	cs_people = 0;

	SendClientMessageToAll(0xFF66CCFF,"[Мероприятие]Через 5 минут стартует командная игра Counter-Strike (/gps > Развлечения > Counter-Strike)");
	return true;
}



public StartZaezd()
{
    SendClientMessageToAll(0xFF66CCFF,"[Мероприятие]Через 2 минуты стартует гоночное мероприятие 'Трек' (/gps > Развлечения > Трек)");
	SetTimer("StartZaezdGO",1000*60*2, false);
	return true;
}



stock GOZaezd()
{
    if(cartrack_open == true) return true;
	cartrack_open = true;




	for(new i = 0; i < 10; i++)
	{
		CT_DATA[i][data_STATUS] = 0;
		strmid(CT_DATA[i][data_NAME], "нет", 0, 24, 24);
	}

    SetTimer("StartZaezd",1000*60*3,false);
	cartrack_status = true;
	cartrack_people = 0;

	SendClientMessageToAll(0xFF66CCFF,"[Мероприятие]Через 5 минут стартует гоночное мероприятие 'Трек' (/gps > Развлечения > Трек)");
	return true;
}
public DrevLoaded(playerid)
{
    SetPVarInt(playerid,"ac_timer", 4);
	ClearAnimations(playerid);
    SetPlayerCheckpoint(playerid, 1598.1444,-794.5472,41.5058, 2.0);
	ApplyAnimation(playerid,"PED","IDLE_chat",100.0,0,0,0,1,3150);
    ResetWeaponSlot(playerid, 1);
   	DeletePVar(playerid, "process");
    switch(random(5))
    {
        case 0: SetPVarInt(playerid, "tovar", 40);
        case 1: SetPVarInt(playerid, "tovar", 45);
        case 2: SetPVarInt(playerid, "tovar", 50);
        case 3: SetPVarInt(playerid, "tovar", 55);
        case 4: SetPVarInt(playerid, "tovar", 60);
    }
	SetPlayerAttachedObject(playerid, 1, 1458, 1, -1.034844, 1.116571, -0.065124, 76.480148, 75.781570, 280.952545, 0.575599, 0.604554, 0.624122);
	SetPlayerAttachedObject(playerid, 2, 1463, 1, -0.205007, 1.545087, -0.014800, 171.406829, 96.114616, 0.066009, 0.403667, 1.000000, 1.021239 );
	return true;
}

public YabloLoaded(playerid)
{
    SetPVarInt(playerid,"ac_timer",3);
    ApplyAnimation(playerid,"CAMERA","picstnd_out",4.1,0, 0, 0, 1, 1);


	if(GetPVarInt(playerid, "yablo_check") == 5)
	{
	    ApplyAnimation(playerid,"CARRY","crry_prtial",4.1,0,0,0,1,1);
        SetPlayerAttachedObject(playerid, 1, 3052, 5, 0.01, 0.1, 0.2, 100, 190, 90);
    	SetPlayerCheckpoint(playerid, 2466.0354,1444.6637,11.0666, 2.0);
   		DeletePVar(playerid, "process");
		SetPVarInt(playerid, "tovar", 1);
		KillTimer(PLAYER_DATA[playerid][data_YABLO_TIMER_ID]);
		ClearAnim(playerid);
		return true;

	}
	SetPVarInt(playerid, "yablo_check", GetPVarInt(playerid, "yablo_check")+1);
	return true;
}


public PayDay(playerid)
{
    new hour, minute, second;
    gettime(hour, minute, second);
    if(PLAYER_DATA[playerid][data_LOGGED] == false)
    {
        new str[256];
		gettime(hour, minute, second);
		format(str,sizeof(str),"Точное время сервера: %02d:%02d", hour, minute);
		SendClientMessage(playerid,0xFF6600AA,str);
        return true;
    }
    if(PLAYER_DATA[playerid][data_AFK] > 30)
    {
        SendClientMessage(playerid, COLOR_AC, "Вы не получили PayDay, т.к находились в АФК");
        return true;
    }

    if(PLAYER_DATA[playerid][data_ADMLVL] != 0) PLAYER_DATA[playerid][data_SALARY] += 1500*PLAYER_DATA[playerid][data_ADMLVL];





	switch(PLAYER_DATA[playerid][data_MEMBER])
	{
	    case 1:
	    {
	        switch(PLAYER_DATA[playerid][data_RANK])
	        {
				case 1,2: PLAYER_DATA[playerid][data_SALARY] += 13500;
				case 3: PLAYER_DATA[playerid][data_SALARY] += 14300;
				case 4: PLAYER_DATA[playerid][data_SALARY] += 16800;
				case 5: PLAYER_DATA[playerid][data_SALARY] += 18200;
				case 6: PLAYER_DATA[playerid][data_SALARY] += 19600;
				case 7: PLAYER_DATA[playerid][data_SALARY] += 21900;
				case 8: PLAYER_DATA[playerid][data_SALARY] += 24700;
	        }
	    }
		case 2:PLAYER_DATA[playerid][data_SALARY] += 2250*PLAYER_DATA[playerid][data_RANK];
		case 3:PLAYER_DATA[playerid][data_SALARY] += 3550*PLAYER_DATA[playerid][data_RANK];
		case 4:PLAYER_DATA[playerid][data_SALARY] += 5800*PLAYER_DATA[playerid][data_RANK];
		case 5,6,7:PLAYER_DATA[playerid][data_SALARY] += 4050*PLAYER_DATA[playerid][data_RANK];
		case 8:PLAYER_DATA[playerid][data_SALARY] += 6500*PLAYER_DATA[playerid][data_RANK];
		case 9:PLAYER_DATA[playerid][data_SALARY] += 5750*PLAYER_DATA[playerid][data_RANK];
	}

	new lvlup = 0;
	new nextlvl = PLAYER_DATA[playerid][data_LVL]+1;
	new nextexp = nextlvl*4;


	if(X2DAY == true) PLAYER_DATA[playerid][data_EXP] += 2;
	else PLAYER_DATA[playerid][data_EXP]++;

	if(PLAYER_DATA[playerid][data_WANTED] > 0)
	{
	    PLAYER_DATA[playerid][data_WANTED]--;
	    SetPlayerWantedLevel(playerid,PLAYER_DATA[playerid][data_WANTED]);
	}

	if(PLAYER_DATA[playerid][data_ZAKON] < 100) PLAYER_DATA[playerid][data_ZAKON]++;
	if(PLAYER_DATA[playerid][data_EXP] >= nextexp)
	{
 		lvlup = 1;
 		PLAYER_DATA[playerid][data_EXP] = 0;
 		PLAYER_DATA[playerid][data_LVL]++;
 		SetPlayerScore(playerid,PLAYER_DATA[playerid][data_LVL]);

 		if(PLAYER_DATA[playerid][data_LVL] == 4)
		{
		    new bugfix;
			for(new i = 0; i < MAX_PLAYERS; i++)
			{
				if(!IsPlayerConnected(i)) continue;
				if(strfind(PLAYER_DATA[playerid][data_REFERAL], PLAYER_DATA[i][data_NAME], true) != -1)
				{
				    PLAYER_DATA[i][data_SALARY] += 50000;
				    bugfix = 1;
				    break;
				}
			}
		    if(bugfix == 0)
		    {
		        new query[256];
		        mysql_format(dbHandle,query, sizeof(query), "SELECT * FROM `accounts` WHERE `name` = '%e' LIMIT 1",PLAYER_DATA[playerid][data_REFERAL]);
			   	mysql_function_query(dbHandle, query, true, "CheckReferal", "i", playerid);
			}
		}
	}

	PLAYER_DATA[playerid][data_BANK] += PLAYER_DATA[playerid][data_SALARY];
	new strt[256],zptext[256],lvltext[256],exptext[256],banktext[256];
	SendClientMessage(playerid,0xFFFFFF,"{FFCC00}БАНКОВСКИЙ ЧЕК");
	SendClientMessage(playerid,0xFFFFFF,"{FFCC00}___________________________________________");
	SendClientMessage(playerid,-1,strt);
	format(strt,sizeof(strt),"Время сервера:{1fa1ea} %02d:%02d", hour, minute);
	SendClientMessage(playerid,-1,strt);
 	format(zptext,sizeof(zptext),"Ваша зарплата:{1fa1ea} %d рублей",PLAYER_DATA[playerid][data_SALARY]);
 	SendClientMessage(playerid,-1,zptext);
 	format(lvltext,sizeof(lvltext),"Ваш уровень:{1fa1ea} %d",PLAYER_DATA[playerid][data_LVL]);
 	SendClientMessage(playerid,-1,lvltext);
 	format(exptext,sizeof(exptext),"Ваш опыт:{1fa1ea} %d из %d",PLAYER_DATA[playerid][data_EXP],nextexp);
 	SendClientMessage(playerid,-1,exptext);
 	format(banktext,sizeof(banktext),"Банковский счет:{1fa1ea} %d рублей",PLAYER_DATA[playerid][data_BANK]);
 	SendClientMessage(playerid,-1,banktext);
	SendClientMessage(playerid,0xFFFFFF,"{FFCC00}___________________________________________");
	PLAYER_DATA[playerid][data_SALARY] = 0;
	if(lvlup == 1) SendClientMessage(playerid,0x33993300,"{1fa1ea}Ваш игровой уровень повысился. Поздравляем!");
	SendClientMessageToAll(-1, "{FFCC00}Неизвестный: {ffffff}Поговаривают что в этот час по всей области есть 6 кладов");
	PlayerPlaySound(playerid, 5203, 0.0, 0.0, 0.0);
	
	Klad();
	return true;
}

stock Klad()
{
    for(new klad = 0; klad <= 6; klad++)
	{
	    if(klad_active[klad] == 0) DestroyDynamic3DTextLabel(klad_spawn[klad]);
        KladDestroyObj(klad);
		new rand_klad = random(22);
		klad_spawn[klad] = CreateDynamic3DTextLabel("{ffffff}Здесь мягкая почва\n{FFCC00}Попробуйте тут покапать\nALT", -1, klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2], 3.0);
        //CreateDynamic3DTextLabel("{ffffff}Здесь мягкая почва\n{FFCC00}Попробуйте тут покапать\nALT", -1, klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2], 3.0, 0);
		klad_for[klad] = rand_klad;
        klad_active[klad] = 1;
        KladCreateObj(klad, rand_klad);
	}
}

stock KladCreateObj(klad_n, rand_klad)
{
	if(klad_n == 0)
	{
    	klad_obj[0] = CreateDynamicObject(3014, klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.95, 0.0000, 0.0000, 0.0000);
		klad_obj[1] = CreateDynamicObject(3017,klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.77, 0.0000, 0.0000, 0.0000);
	}
	if(klad_n == 1)
	{
    	klad_obj[2] = CreateDynamicObject(3014, klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.95, 0.0000, 0.0000, 0.0000);
		klad_obj[3] = CreateDynamicObject(3017,klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.77, 0.0000, 0.0000, 0.0000);
	}
	if(klad_n == 2)
	{
    	klad_obj[4] = CreateDynamicObject(3014, klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.95, 0.0000, 0.0000, 0.0000);
		klad_obj[5] = CreateDynamicObject(3017,klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.77, 0.0000, 0.0000, 0.0000);
	}
	if(klad_n == 3)
	{
    	klad_obj[6] = CreateDynamicObject(3014, klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.95, 0.0000, 0.0000, 0.0000);
		klad_obj[7] = CreateDynamicObject(3017,klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.77, 0.0000, 0.0000, 0.0000);
	}
	if(klad_n == 4)
	{
    	klad_obj[8] = CreateDynamicObject(3014, klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.95, 0.0000, 0.0000, 0.0000);
		klad_obj[9] = CreateDynamicObject(3017,klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.77, 0.0000, 0.0000, 0.0000);
	}
	if(klad_n == 5)
	{
    	klad_obj[10] = CreateDynamicObject(3014, klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.95, 0.0000, 0.0000, 0.0000);
		klad_obj[11] = CreateDynamicObject(3017,klad_pos[rand_klad][0],klad_pos[rand_klad][1],klad_pos[rand_klad][2]-0.77, 0.0000, 0.0000, 0.0000);
	}
}

stock KladDestroyObj(klad_n)
{
	if(klad_n == 0)
	{
	    DestroyDynamicObject(klad_obj[0]);
	    DestroyDynamicObject(klad_obj[1]);
	}
	if(klad_n == 1)
	{
    	DestroyDynamicObject(klad_obj[2]);
	    DestroyDynamicObject(klad_obj[3]);
	}
	if(klad_n == 2)
	{
    	DestroyDynamicObject(klad_obj[4]);
	    DestroyDynamicObject(klad_obj[5]);
	}
	if(klad_n == 3)
	{
    	DestroyDynamicObject(klad_obj[6]);
	    DestroyDynamicObject(klad_obj[7]);
	}
	if(klad_n == 4)
	{
    	DestroyDynamicObject(klad_obj[8]);
	    DestroyDynamicObject(klad_obj[9]);
	}
	if(klad_n == 5)
	{
    	DestroyDynamicObject(klad_obj[10]);
	    DestroyDynamicObject(klad_obj[11]);
	}
}

stock UpdateBusinessData(b)
{
	new str[256];
    if(BUSINESS_DATA[b][data_TYPE] == 1)
	{
	    if(BUSINESS_DATA[b][data_OWNED] == 1)
		{
		    new mafia[16];
			switch(BUSINESS_DATA[b][data_MAFIA])
			{
				case 5: mafia = "Трамповское ОПГ";
				case 6: mafia = "Майкопское ОПГ";
				case 7: mafia = "Одесское ОПГ";
				default: mafia = "Нет";
			}
	    	format(str,sizeof(str), "{3399FF}%s\n{CCFF00}Владелец: {FFFFFF}%s\n{CCFF00}Топлива: {FFFFFF}%i л\n{CCFF00}Цена за 1 л: {FFFFFF}%i рублей\n{CCFF00}Закупочная цена: {FFFFFF}%i рублей\n{CCFF00}Крыша: {FFFFFF}%s\n{339966}/buyfuel",BUSINESS_DATA[b][data_NAME],BUSINESS_DATA[b][data_OWNER],BUSINESS_DATA[b][data_PROD],BUSINESS_DATA[b][data_CENA],BUSINESS_DATA[b][data_PRICEPROD],mafia);
     		UpdateDynamic3DTextLabelText(BUSINESS_DATA[b][data_TEXTINFO], -1, str);
		}
		else
		{
			format(str,sizeof(str), "{3399FF}%s\n{CCFF00}Стоимость бизнеса: {FFFFFF}%i рублей\n{CCFF00}Для покупки бизнеса используйте: {FFFFFF}/buy\n{339966}/buyfuel",BUSINESS_DATA[b][data_NAME],BUSINESS_DATA[b][data_PRICE]);
			UpdateDynamic3DTextLabelText(BUSINESS_DATA[b][data_TEXTINFO], -1, str);
		}
	}
	else
	{
		if(BUSINESS_DATA[b][data_OWNED] == 1)
		{
		    new mafia[16];
			switch(BUSINESS_DATA[b][data_MAFIA])
			{
				case 5: mafia = "Трамповское ОПГ";
				case 6: mafia = "Майкопское ОПГ";
				case 7: mafia = "Одесское ОПГ";
				default: mafia = "Нет";
			}
			format(str,sizeof(str), "{3399FF}%s\n{CCFF00}Владелец: {FFFFFF}%s\n{CCFF00}Продуктов: {FFFFFF}%i шт\n{CCFF00}Цена покупки продуктов: {FFFFFF}%i рублей\n{CCFF00}Крыша: {FFFFFF}%s\n{FE2E2E}Вход бесплатный",BUSINESS_DATA[b][data_NAME],BUSINESS_DATA[b][data_OWNER],BUSINESS_DATA[b][data_PROD],BUSINESS_DATA[b][data_PRICEPROD],mafia);
			UpdateDynamic3DTextLabelText(BUSINESS_DATA[b][data_TEXTINFO], -1, str);
		}
		else
		{
			format(str,sizeof(str), "{3399FF}%s\n{CCFF00}Стоимость бизнеса: {FFFFFF}%i рублей\n{CCFF00}Для покупки бизнеса используйте: {FFFFFF}/buy",BUSINESS_DATA[b][data_NAME],BUSINESS_DATA[b][data_PRICE]);
			UpdateDynamic3DTextLabelText(BUSINESS_DATA[b][data_TEXTINFO], -1, str);
		}
	}
	return true;
}


stock SaveBusinessData(b)
{
	new query[1000], string[145];
	query = "UPDATE `business` SET ";
	acc_str_strcat(query, sizeof(query), "owner", BUSINESS_DATA[b][data_OWNER]);
	acc_int_strcat(query, sizeof(query), "owned", BUSINESS_DATA[b][data_OWNED]);
	acc_str_strcat(query, sizeof(query), "name", BUSINESS_DATA[b][data_NAME]);
	acc_int_strcat(query, sizeof(query), "mafia", BUSINESS_DATA[b][data_MAFIA]);
	acc_int_strcat(query, sizeof(query), "prod", BUSINESS_DATA[b][data_PROD]);
	acc_int_strcat(query, sizeof(query), "day", BUSINESS_DATA[b][data_DAY]);
	acc_int_strcat(query, sizeof(query), "lock", BUSINESS_DATA[b][data_LOCK]);
	acc_int_strcat(query, sizeof(query), "cena", BUSINESS_DATA[b][data_CENA]);
	acc_int_strcat(query, sizeof(query), "price_prod", BUSINESS_DATA[b][data_PRICEPROD]);
	acc_int_strcat(query, sizeof(query), "bank", BUSINESS_DATA[b][data_BANK]);
	strdel(query, strlen(query)-1, strlen(query));
	format(string,sizeof(string)," WHERE `id` = '%d' LIMIT 1",BUSINESS_DATA[b][data_ID]);
	strcat(query, string);
	mysql_function_query(dbHandle, query, true, "", "");
	return true;
}


