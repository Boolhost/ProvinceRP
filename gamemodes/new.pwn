{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_YT] < 1) return true;

	ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX, "Команды для ютуберов",
	"{f0e86b}/ythelp{FFFFFF} - команды для ютуберов\n\
	{f0e86b}/fixyt{FFFFFF} - починить свой автомобиль(надпись в чат не выводится)\n\
