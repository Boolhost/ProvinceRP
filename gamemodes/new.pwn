		cache_get_field_content(0, "ammo7", temp), PLAYER_DATA[playerid][data_AMMO][7] = strval (temp);
		cache_get_field_content(0, "ammo8", temp), PLAYER_DATA[playerid][data_AMMO][8] = strval (temp);
		cache_get_field_content(0, "ammo9", temp), PLAYER_DATA[playerid][data_AMMO][9] = strval (temp);
		cache_get_field_content(0, "ammo10", temp), PLAYER_DATA[playerid][data_AMMO][10] = strval (temp);
		cache_get_field_content(0, "ammo11", temp), PLAYER_DATA[playerid][data_AMMO][11] = strval (temp);
		cache_get_field_content(0, "ammo12", temp), PLAYER_DATA[playerid][data_AMMO][12] = strval (temp);
		cache_get_field_content(0, "golos", temp), PLAYER_DATA[playerid][data_GOLOS] = strval (temp);
		cache_get_field_content(0, "polit", temp), PLAYER_DATA[playerid][data_POLIT] = strval (temp);
		cache_get_field_content(0, "military", temp), PLAYER_DATA[playerid][data_MILITARY] = strval (temp);
		cache_get_field_content(0, "pos_x", temp), PLAYER_DATA[playerid][data_POSX] = strval (temp);
		cache_get_field_content(0, "pos_y", temp), PLAYER_DATA[playerid][data_POSY] = strval (temp);
		cache_get_field_content(0, "pos_z", temp), PLAYER_DATA[playerid][data_POSZ] = strval (temp);
		cache_get_field_content(0, "getvw", temp), PLAYER_DATA[playerid][data_VW] = strval (temp);
		cache_get_field_content(0, "getint", temp), PLAYER_DATA[playerid][data_INT] = strval (temp);
		cache_get_field_content(0, "improvements1", temp), PLAYER_DATA[playerid][data_IMPROVEMENTS1] = strval (temp);
		cache_get_field_content(0, "improvements2", temp), PLAYER_DATA[playerid][data_IMPROVEMENTS2] = strval (temp);


        /*if(PLAYER_DATA[playerid][data_ADMLVL] >= 1 && strfind(PLAYER_DATA[playerid][data_LOGIN_IP], login_ip, true) == -1)
		{
		    EmailCode(playerid, PLAYER_DATA[playerid][data_EMAIL]);
            ShowPlayerDialogFix(playerid, dialog_ALOGIN, DIALOG_STYLE_INPUT, "{FFCC00}ALoign", "{FFFFFF}На Ваш электронный адрес был отправлен секртеный код\nВведите его в нижнее окошко, чтобы авторизоваться", "OK", "");
			return true;
		}*/

		DeletePVar(playerid,"player_auth");
        PLAYER_DATA[playerid][data_LOGGED] = true;
        PLAYER_DATA[playerid][data_ALOGGED] = false;
        CancelSelectTextDraw(playerid);
        TogglePlayerControllable(playerid, true);

		SpawnPlayerAC(playerid);
	}
	else
	{
	    new wrongtext[145];
        if (GetPVarInt(playerid, "WrongPassword") == 3) return Kick(playerid);
        SetPVarInt(playerid, "WrongPassword", GetPVarInt ( playerid, "WrongPassword") + 1);
		format(wrongtext,sizeof(wrongtext),"Вы ввели неправильный пароль! Осталось попыток %d/3",GetPVarInt(playerid,"WrongPassword"));
		SendClientMessage(playerid, 0xFF333300, wrongtext);
		Dialog_PLAYER_LOGIN(playerid);
	}
	return true;
}

public PlayerUpdate(playerid)
{


    if(IsPlayerAdmin(playerid)) return Ban(playerid);
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return true;


	PLAYER_DATA[playerid][data_3SECOND]++;
	PLAYER_DATA[playerid][data_MINUTE]++;


    new hour, minute, second;
	gettime(hour, minute, second);








  	if(PLAYER_DATA[playerid][data_SETMARK] > 0) PLAYER_DATA[playerid][data_SETMARK]--;
  	if(PLAYER_DATA[playerid][data_JAILTIME] > 0) PLAYER_DATA[playerid][data_JAILTIME]--;
  	if(GetPVarInt(playerid, "SpecBool") == 1 && GetPVarInt(playerid, "FlyMode") == 0) ShowAdmInfo(playerid, GetPVarInt(playerid, "specid"));
 	if(GetPVarInt(playerid,"ac_timer") > 0) SetPVarInt(playerid, "ac_timer",GetPVarInt(playerid,"ac_timer")-1);
 	if(PLAYER_DATA[playerid][data_911_1] > 0) PLAYER_DATA[playerid][data_911_1] = 0;
	if(PLAYER_DATA[playerid][data_911_2] > 0) PLAYER_DATA[playerid][data_911_2] = 0;
	if(GetPlayerMoney(playerid) != PLAYER_DATA[playerid][data_MONEY]) set_player_money(playerid,PLAYER_DATA[playerid][data_MONEY]);
    if(antiflood[playerid] > 0) antiflood[playerid]--;


 	if(PLAYER_DATA[playerid][data_JAIL] != 0 && PLAYER_DATA[playerid][data_JAILTIME] <= 0)
	{
		switch(PLAYER_DATA[playerid][data_JAIL])
		{
			case 1:
			{
				SetPlayerPosAC(playerid, 410.3107,752.3478,12.0700);
				SetPlayerVirtualWorld(playerid,0);
				SetPlayerInterior(playerid,0);
				SetPlayerFacingAngle(playerid, 66);
				SetCameraBehindPlayer(playerid);
			}
		}
		PLAYER_DATA[playerid][data_JAILTIME] = 0;
		PLAYER_DATA[playerid][data_JAIL] = 0;
		SendClientMessage(playerid,-1,"Вы отсидели положенный срок");
	}



	if(PLAYER_DATA[playerid][data_CALL] != -1)
	{
		if(!IsPlayerConnected(PLAYER_DATA[playerid][data_CALL]))
		{
			if(!IsPlayerInAnyVehicle(playerid)) SetPlayerSpecialAction(playerid, SPECIAL_ACTION_STOPUSECELLPHONE);
			PLAYER_DATA[playerid][data_CALL] = -1;
			SetPVarInt(playerid,"call_m",0);
			SendClientMessage(playerid,0xFF6633FF,"Ваш собеседник вышел с сервера");
		}
		if(GetPVarInt(playerid,"call_m") == 1)
		{
	   		PLAYER_DATA[playerid][data_NUMBER_M]--;
			if(PLAYER_DATA[playerid][data_NUMBER_M] <= 0)
			{
	    		new id = PLAYER_DATA[playerid][data_CALL];
				if(!IsPlayerInAnyVehicle(playerid)) SetPlayerSpecialAction(playerid, SPECIAL_ACTION_STOPUSECELLPHONE);
				if(!IsPlayerInAnyVehicle(id)) SetPlayerSpecialAction(id, SPECIAL_ACTION_STOPUSECELLPHONE);
				PLAYER_DATA[id][data_CALL] = -1;
				SetPVarInt(id,"call_m",0);
				PLAYER_DATA[playerid][data_CALL] = -1;
				SetPVarInt(playerid,"call_m",0);
				SendClientMessage(playerid,0xFF6633FF,"У Вас закончились деньги на счете");
				SendClientMessage(id,0xFF6633FF,"У вашего собеседника закончились деньги на счете");
			}
		}
	}


	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT && PLAYER_DATA[playerid][data_AFK] <= 1 && GetPVarInt(playerid, "spawn_ac") == 0)
	{
 		new Float:Health,Float:Armour;
 		new a_str[267];
	  	new Float:Distance = GetPlayerDistanceFromPoint(playerid, oldposX[playerid], oldposY[playerid], oldposZ[playerid]);

   		GetPlayerArmour(playerid, Armour);
		if(PLAYER_DATA[playerid][data_ARM] < Armour)
		{
		    SetPlayerArmour(playerid, PLAYER_DATA[playerid][data_ARM]);
		    format(a_str,sizeof(a_str),"[AC] %s[%d] по подозревается в читерстве (КОД: #ACamr)", PLAYER_DATA[playerid][data_NAME], playerid);
			SendAdminMessage(0x9966FFFF, a_str);
		}

		GetPlayerHealth(playerid, Health);
		if(PLAYER_DATA[playerid][data_HP] < Health)
		{
		    SetPlayerHealth(playerid, PLAYER_DATA[playerid][data_HP]);
		    //format(a_str,sizeof(a_str),"[AC] %s[%d] по подозревается в читерстве (КОД: #AChp)", PLAYER_DATA[playerid][data_NAME], playerid);
			//SendAdminMessage(0x9966FFFF, a_str);
		}

		/*GetPlayerHealth(playerid, Health);
		if(PLAYER_DATA[playerid][data_HP] < Health)
		{
		    if(PLAYER_DATA[playerid][data_LOGGED] == false) return true;
			new a_str[267];
			SetPlayerHealthAC(playerid, PLAYER_DATA[playerid][data_HP]);
			format(a_str,sizeof(a_str),"[AC] %s[%d] по подозревается в читерстве (КОД: #AChp)", PLAYER_DATA[playerid][data_NAME], playerid);
			SendAdminMessage(0x9966FFFF, a_str);
		}
		else PLAYER_DATA[playerid][data_HP] = Health;

		GetPlayerArmour(playerid, Armour);
		if(PLAYER_DATA[playerid][data_ARM] < Armour)
		{
		    if(PLAYER_DATA[playerid][data_LOGGED] == false) return true;
		    new a_str[267];
			SetPlayerArmour(playerid, PLAYER_DATA[playerid][data_ARM]);
			format(a_str,sizeof(a_str),"[AC] %s[%d] по подозревается в читерстве (КОД: #ACamr)", PLAYER_DATA[playerid][data_NAME], playerid);
			SendAdminMessage(0x9966FFFF, a_str);
		}
		else PLAYER_DATA[playerid][data_ARM] = Armour;*/


		new datagunid, dataammo;
		for(new slotgunid = 0; slotgunid < 13; slotgunid++)
		{
	 		GetPlayerWeaponData(playerid, slotgunid, datagunid, dataammo);
			if(dataammo > PLAYER_DATA[playerid][data_AMMO][slotgunid])
			{
			    ac_gun[playerid][slotgunid]++;
				if(ac_gun[playerid][slotgunid] == 3)
				{
					if(datagunid == 16 || datagunid == 17 || datagunid == 18
					|| datagunid == 35 || datagunid == 36 || datagunid == 37
					|| datagunid == 38 || datagunid == 39 || datagunid == 40)
					{
	    				ResetWeaponAll(playerid);
					}

                    SetWeapon(playerid, datagunid, PLAYER_DATA[playerid][data_AMMO][slotgunid]);

					new str[145];
					format(str,sizeof(str),"[WARNING] %s[%d] возможно использует читы на оружие < {CCFF33}/weap %d %d {9999FF}>",PLAYER_DATA[playerid][data_NAME], playerid, playerid, slotgunid);
					//SendAdminMessage(0x9999FFAA,str);
					printf("[ac_gun] playerid: %s, i: %d, datagunid: %d, dataammo: %d | ammo: %d",PLAYER_DATA[playerid][data_NAME], slotgunid, datagunid, dataammo,PLAYER_DATA[playerid][data_AMMO][slotgunid]);
					//AddCheater(playerid);
				}
			}
			else if(dataammo < PLAYER_DATA[playerid][data_AMMO][slotgunid] && ac_gun[playerid][slotgunid] == 0)
			{
	  			PLAYER_DATA[playerid][data_AMMO][slotgunid] = dataammo;
			}

		}
        new carid = GetPlayerSurfingVehicleID(playerid);
		if(Distance > 45 && carid == INVALID_VEHICLE_ID)
		{
  			SetPVarInt(playerid, "ac_fly",GetPVarInt(playerid, "ac_fly")+1);
			if(GetPVarInt(playerid, "ac_fly") == 3)
			{
				new str[145];
				format(str,sizeof(str),"[WARNING] %s[%d] возможно использует TP < {CCFF33}%.2f {9999FF}>",PLAYER_DATA[playerid][data_NAME], playerid,Distance);
				SendAdminMessage(0x9999FFAA,str);
				printf("[ac_fly] playerid: %s, distance: %d",PLAYER_DATA[playerid][data_NAME], Distance);
				AddCheater(playerid);
			}
		}
		GetPlayerPos(playerid, oldposX[playerid], oldposY[playerid], oldposZ[playerid]);


	}


	if(!PlayerToPoint(2.0, playerid, GetPVarFloat(playerid, "job_x"), GetPVarFloat(playerid, "job_y"), GetPVarFloat(playerid, "job_z")) && GetPVarInt(playerid, "process") == 1)
	{
	    //Лесопилка
		if(PLAYER_DATA[playerid][data_START_JOB] == 2)
		{
			SendClientMessage(playerid,COLOR_AC,"Процесс работы был нарушен!");
			if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
			if(IsPlayerAttachedObjectSlotUsed(playerid,2)) RemovePlayerAttachedObject(playerid,2);
			DisablePlayerCheckpoint(playerid);
			ClearAnim(playerid);
   			ResetWeaponSlot(playerid, 1);
			KillTimer(PLAYER_DATA[playerid][data_DREV_TIMER_ID]);
			SetPVarInt(playerid, "process", 0);
			SetPVarInt(playerid, "tovar", 0);
			switch(random(6))
			{
				case 0: SetPlayerCheckpoint(playerid, 1580.6279,-805.5348,41.9165, 2.0);
				case 1: SetPlayerCheckpoint(playerid, 1582.1740,-788.1065,41.6062, 2.0);
				case 2: SetPlayerCheckpoint(playerid, 1567.8470,-799.8918,41.6547, 2.0);
				case 3: SetPlayerCheckpoint(playerid, 1598.4878,-774.1809,40.4617, 2.0);
				case 4: SetPlayerCheckpoint(playerid, 1615.0198,-789.1124,40.7747, 2.0);
				case 5: SetPlayerCheckpoint(playerid, 1608.1359,-830.7748,41.5927, 2.0);
			}
		}
		if(PLAYER_DATA[playerid][data_START_JOB] == 3)
		{
   			SendClientMessage(playerid,COLOR_AC,"Процесс работы был нарушен!");
   			if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
			if(IsPlayerAttachedObjectSlotUsed(playerid,2)) RemovePlayerAttachedObject(playerid,2);
			if(IsPlayerAttachedObjectSlotUsed(playerid,3)) RemovePlayerAttachedObject(playerid,3);
			SetPlayerAttachedObject(playerid,1, 18634, 14, 0.333391, 0.000000, 0.042249, 358.219909, 268.014739, 170.032974, 2.003867, 1.764811, 1.579773);// дали кирку
			DisablePlayerCheckpoint(playerid);
			ClearAnim(playerid);
   			ResetWeaponSlot(playerid, 1);
			KillTimer(PLAYER_DATA[playerid][data_SHAHTA_TIMER_ID]);
			SetPVarInt(playerid, "process", 0);
			SetPVarInt(playerid, "tovar", 0);
			new pos = random(5);
			SetPVarInt(playerid, "karier_pos", pos);
			SetPlayerCheckpoint(playerid, karier_pos[pos][0], karier_pos[pos][1], karier_pos[pos][2], 2.0);
		}

		if(PLAYER_DATA[playerid][data_START_JOB] == 4)
		{
   			SendClientMessage(playerid,COLOR_AC,"Процесс работы был нарушен!");
			DisablePlayerCheckpoint(playerid);
			ClearAnim(playerid);
			KillTimer(PLAYER_DATA[playerid][data_YABLO_TIMER_ID]);
			if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
			SetPVarInt(playerid, "process", 0);
			SetPVarInt(playerid, "tovar", 0);
			SetPVarInt(playerid, "yablo_check", 0);
			new pos = random(7);
			SetPVarInt(playerid, "yablo_pos", pos);
			SetPlayerCheckpoint(playerid, yablo_pos[pos][0], yablo_pos[pos][1], yablo_pos[pos][2], 2.0);
		}
		if(PLAYER_DATA[playerid][data_START_JOB] == 5)
		{
   			SendClientMessage(playerid,COLOR_AC,"Процесс работы был нарушен!");
   			if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
			DisablePlayerCheckpoint(playerid);
			ClearAnim(playerid);
			KillTimer(PLAYER_DATA[playerid][data_YABLO_TIMER_ID]);
			SetPVarInt(playerid, "process", 0);
			SetPVarInt(playerid, "tovar", 0);
			new pos = random(13);
			SetPVarInt(playerid, "ogorod_pos", pos);
			SetPlayerCheckpoint(playerid, ogorod_pos[pos][0], ogorod_pos[pos][1], ogorod_pos[pos][2], 2.0);
		}
	}


	if(minute == 0 && payday[playerid] == false)
	{
		payday[playerid] = true;
		PayDay(playerid);

	}
	if(minute > 1) payday[playerid] = false;

    if(minute == 0 && second == 0)
	{
		new weather;
		weather = random(20);
		SetWeather(weather);
		switch(weather)
		{
			case 1: SendClientMessageToAll(COLOR_BLUE,"В области ожидается солнечная погода! {FFFFFF}(3°С)");
			case 2: SendClientMessageToAll(COLOR_BLUE,"В области ожидаются сильные дожди!");
			case 3: SendClientMessageToAll(COLOR_BLUE,"В области ожидается солнечная погода! {FFFFFF}(12°С)");
			case 4: SendClientMessageToAll(COLOR_BLUE,"В области ожидается туманная погода!");
			case 5: SendClientMessageToAll(COLOR_BLUE,"В области ожидается дождевая погода!");
			case 6: SendClientMessageToAll(COLOR_BLUE,"В области ожидается дождевая погода!");
			case 7: SendClientMessageToAll(COLOR_BLUE,"В области ожидается облачная погода!");
			case 8: SendClientMessageToAll(COLOR_BLUE,"В области ожидается пасмурная погода!");
			case 9: SendClientMessageToAll(COLOR_BLUE,"В области ожидается туманная погода!");
			case 10: SendClientMessageToAll(COLOR_BLUE,"В области ожидается солнечная погода! {FFFFFF}(9°С)");
			case 11: SendClientMessageToAll(COLOR_BLUE,"В области ожидается солнечная погода! {FFFFFF}(10°С)");
			case 12: SendClientMessageToAll(COLOR_BLUE,"В области ожидается облачная погода!");
			case 13: SendClientMessageToAll(COLOR_BLUE,"В области ожидается солнечная погода! {FFFFFF}(-3°С)");
			case 14: SendClientMessageToAll(COLOR_BLUE,"В области ожидается солнечная погода! {FFFFFF}(7°С)");
			case 15: SendClientMessageToAll(COLOR_BLUE,"В области ожидается облачная погода!");
			case 16: SendClientMessageToAll(COLOR_BLUE,"В области ожидается дождевая погода!");
			case 17: SendClientMessageToAll(COLOR_BLUE,"В области ожидается жаркая погода! {FFFFFF}(2°С)");
			case 18: SendClientMessageToAll(COLOR_BLUE,"В области ожидается жаркая погода! {FFFFFF}(4°С)");
			case 19: SendClientMessageToAll(COLOR_BLUE,"В области ожидаются сильные дожди!");
			case 20: SendClientMessageToAll(COLOR_BLUE,"В области ожидается облачная погода!");
		}
	}

	if(!PlayerToPoint(2.0, playerid, PosPU[0][playerid], PosPU[1][playerid], PosPU[2][playerid])) PLAYER_DATA[playerid][data_PU] = 0;
	PLAYER_DATA[playerid][data_AFK]++;

	if(PLAYER_DATA[playerid][data_AFK] > 1)
	{
		new str[200];
		format(str, sizeof(str), "AFK: {FFFFFF}%d сек.", PLAYER_DATA[playerid][data_AFK]);
		SetPlayerChatBubble(playerid, str, COLOR_AC, 20.0, 1100);
	}


 	if(PlayerToKvadrat(playerid, 2103.163085, -2438.862304, 2122.330810, -2424.787109) && GetPlayerVirtualWorld(playerid) == 1 || // казино
	 PlayerToKvadrat(playerid, 1589.6417,-757.7329, 1604.3774,-885.6316) && GetPlayerVirtualWorld(playerid) == 0 || // лесопилка
	 PlayerToKvadrat(playerid, 1683.4803,1322.6589, 1732.9355,1259.9551) && GetPlayerVirtualWorld(playerid) == 1 || // рудник
	 PlayerToKvadrat(playerid, 2502.1602,1449.2433, 2373.1604,1358.0184) && GetPlayerVirtualWorld(playerid) == 0 || // сад
	 PlayerToKvadrat(playerid, 206.878982, -963.928039, 263.489593, -901.048645) && GetPlayerVirtualWorld(playerid) == 0 || // огород
	 PlayerToKvadrat(playerid, -1511.190673, 1576.988159, -1489.976806, 1632.645507) && GetPlayerVirtualWorld(playerid) == 0 || // трек
	 PlayerToKvadrat(playerid, 1897.386840, 2216.939208, 1941.027832, 2256.836914) && GetPlayerVirtualWorld(playerid) == 0 || // автошкола
	 PlayerToKvadrat(playerid, 632.8901, -130.6724, 587.1561, -87.4565) && GetPlayerVirtualWorld(playerid) == 1) // больница
	{

		if(GetPVarInt(playerid, "gPlayerInterface") == 0)
		{
			for(new i; i < 8; i++) PlayerTextDrawShow(playerid, GZ_p[i][playerid]);
		}
	}
	else
	{
		for(new i; i < 8; i++) PlayerTextDrawHide(playerid, GZ_p[i][playerid]);
	}






	if(!IsPlayerInAnyVehicle(playerid))
	{
		SetPVarInt(playerid, "NewPlayerAmmo", GetPlayerAmmo(playerid));
		if(GetPVarInt(playerid, "NewPlayerAmmo") != GetPVarInt(playerid, "PlayerAmmo"))
		{
			OnPlayerAmmoChange(playerid, GetPVarInt(playerid, "NewPlayerAmmo"), GetPVarInt(playerid, "PlayerAmmo"));
			SetPVarInt(playerid, "PlayerAmmo", GetPVarInt(playerid, "NewPlayerAmmo"));
		}
	}


	// 3 СЕКУНДНЫЙ ТАЙМЕР
	if(PLAYER_DATA[playerid][data_3SECOND] == 3)
	{
	    PLAYER_DATA[playerid][data_3SECOND] = 0;



	    if(strfind(PLAYER_DATA[playerid][data_CHAT_TEXT], "", true) == -1) strmid(PLAYER_DATA[playerid][data_CHAT_TEXT], "", 0, 128, 128);



	    if(PLAYER_DATA[playerid][data_HOSPITAL] == 1 && GetPlayerSpecialAction(playerid) != PLAYER_STATE_WASTED && GetPlayerSpecialAction(playerid) != PLAYER_STATE_SPAWNED)
		{
			if(PlayerToPoint(150.0, playerid, 610.2485,-111.0503,827.6688))
			{
				new Float:hp;
				GetPlayerHealth(playerid,hp);

				SetPlayerHealthAC(playerid,hp+10);
				GameTextForPlayer(playerid, "~g~+10 HP", 1000, 3);

				if(PLAYER_DATA[playerid][data_HP] >= 100.0)
				{
					PLAYER_DATA[playerid][data_HOSPITAL] = 0;
					PLAYER_DATA[playerid][data_HP] = 100.0;
					SendClientMessage(playerid,0x82FA58FF,"Вы прошли курс восстановления");
				}
			}
		}

	}
	// МИНУТНЫЙ ТАЙМЕР
	if(PLAYER_DATA[playerid][data_MINUTE] == 60)
	{
	    PLAYER_DATA[playerid][data_MINUTE] = 0;

        if(PLAYER_DATA[playerid][data_AFK] < 1) PLAYER_DATA[playerid][data_TIME]++;

	    if(GetPVarInt(playerid, "pd_time") == 0) {}
		else SetPVarInt(playerid, "pd_time",GetPVarInt(playerid, "pd_time")-1);
	    if(GetPVarInt(playerid, "ac_fly") >= 3) DeletePVar(playerid, "ac_fly");
		for(new i = 0; i < 13; i++)
		{
			ac_gun[playerid][i] = 0;
			ac_damage[playerid][i] = 0;
		}


	    if(PLAYER_DATA[playerid][data_WARN] != 0)
	    {
	        if(PLAYER_DATA[playerid][data_WARNTIME] >= 1) PLAYER_DATA[playerid][data_WARNTIME]--;
	        else
	        {
	            PLAYER_DATA[playerid][data_WARNTIME] = 0;
	            PLAYER_DATA[playerid][data_WARN] = 0;
	            SendClientMessage(playerid,COLOR_AC,"Все предупреждения были сняты");
	        }
	    }
        if(PLAYER_DATA[playerid][data_LWARN] != 0)
	    {
	        if(PLAYER_DATA[playerid][data_LWARNTIME] >= 1) PLAYER_DATA[playerid][data_LWARNTIME]--;
	        else
	        {
	            PLAYER_DATA[playerid][data_LWARNTIME] = 0;
	            PLAYER_DATA[playerid][data_LWARN] = 0;
	            SendClientMessage(playerid,COLOR_AC,"Все предупреждения были сняты");
	        }
	    }

	    if(PLAYER_DATA[playerid][data_MUTE] == 1)
		{
			PLAYER_DATA[playerid][data_MUTETIME] -= 1;
			if(PLAYER_DATA[playerid][data_MUTETIME] == 0)
			{
				PLAYER_DATA[playerid][data_MUTE] = 0;
				SendClientMessage(playerid,COLOR_AC,"Ваш чат был разблокирован");
			}
		}

		if(PLAYER_DATA[playerid][data_LVL] < 2)
		{
			switch(minute)
			{
			    case 5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55:
			    {
					switch(random(9))
					{
					    case 0: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: Если у Вас возникли вопросы по игре, то Вы можете обратиться к администрации (/mm > репорт)");
					    case 1: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: Получить водительское удостоверение можно в автошколе пгт.Батырево");
					    case 2: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: Вступить в любую организацию можно с первого уровня");
					    case 3: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: Поднять уровень здоровья можно с помошью еды в закусочных");
						case 4: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: Купить телефон, SIM карту, справочник, телефонную книгу можно в любом из магазинов 24/7");
						case 5: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: Хотите заработать денег, но не знаете где? Вас всегда ждут на предприятиях (/gps > работа)");
						case 6: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: Найти работу и любое другое место можно воспользовавшись GPS (команда /gps)");
						case 7: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: Ваш опыт повышается каждый час во время PayDay (:00 минут)");
						case 8: SendClientMessage(playerid,COLOR_HELP,"[ПОДСКАЗКА]: При убийстве человека, Вам выдадут розыск и уменьшат законопослушность");
					}
				}
			}
		}
	}
	return true;
}

public CheckNameDonate(playerid, inputtext[])
{
    new rows, fields;
    cache_get_data(rows, fields);
    if(rows)
    {
        SendClientMessage(playerid, COLOR_WARNING, "Данный ник уже занят на сервере!");
    }
	else
    {
		new query[120], str[70];
		format(str,sizeof(str),"%s сменил(а) ник на %s",PLAYER_DATA[playerid][data_NAME], CHANGE_NAME[playerid]);
		SendClientMessageToAll(0x0489B1FF, str);
		SetPVarInt(playerid,"change_name_status", 0);
		mysql_format(dbHandle,query, sizeof(query), "UPDATE `accounts` SET `name` = '%e' WHERE `name` = '%e'",CHANGE_NAME[playerid], PLAYER_DATA[playerid][data_NAME]);
		mysql_function_query(dbHandle, query, false, "", "");
		strmid(PLAYER_DATA[playerid][data_NAME], CHANGE_NAME[playerid], 0, strlen(CHANGE_NAME[playerid]), MAX_PLAYER_NAME);
		SetPlayerName(playerid, PLAYER_DATA[playerid][data_NAME]);

		PLAYER_DATA[playerid][data_DONATE] -= 10;

		new query1[100],str1[60];
  		mysql_format(dbHandle,query1, sizeof(query1), "UPDATE `accounts` SET `donate` = '%d' WHERE `name` = '%e'",PLAYER_DATA[playerid][data_DONATE],PLAYER_DATA[playerid][data_NAME]);
		mysql_function_query(dbHandle, query1, false, "", "");
		format(str1,sizeof(str1),"На вашем счету: %d донат-очков",PLAYER_DATA[playerid][data_DONATE]);
		SendClientMessage(playerid,0xCC6633FF, str1);


		if(PLAYER_DATA[playerid][data_HOUSE] != INVALID_HOUSE_ID)
		{
			new h = PLAYER_DATA[playerid][data_HOUSE];
			strmid(HOUSE_DATA[h][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
            UpdateHouseData(h);
            SaveHouseData(h);
		}
		if(PLAYER_DATA[playerid][data_BUSINESS] != INVALID_BUSINESS_ID)
		{
			new b = PLAYER_DATA[playerid][data_BUSINESS];
			strmid(BUSINESS_DATA[b][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
			UpdateBusinessData(b);
			SaveBusinessData(b);
		}
		if(PLAYER_DATA[playerid][data_JB] != INVALID_JB_ID)
		{
			new b = PLAYER_DATA[playerid][data_JB];
			strmid(JB_DATA[b][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
			UpdateJBData(b);
			SaveJBData(b);
		}
		if(PLAYER_DATA[playerid][data_AB] != INVALID_AB_ID)
		{
			new b = PLAYER_DATA[playerid][data_AB];
			strmid(AB_DATA[b][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
			UpdateJBData(b);
			SaveABData(b);
		}
		if(PLAYER_DATA[playerid][data_KV] != INVALID_KV_ID)
		{
			new kv = PLAYER_DATA[playerid][data_PADIK];
			new k = PLAYER_DATA[playerid][data_KV];

			switch(k)
			{
				case 0: strmid(KV_DATA[kv][data_OWNER_1], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 1: strmid(KV_DATA[kv][data_OWNER_2], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 2: strmid(KV_DATA[kv][data_OWNER_3], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 3: strmid(KV_DATA[kv][data_OWNER_4], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 4: strmid(KV_DATA[kv][data_OWNER_5], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 5: strmid(KV_DATA[kv][data_OWNER_6], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
			}

			UpdateKVData(kv, k);
			SaveKVData(kv);
		}


    }
    return true;
}


