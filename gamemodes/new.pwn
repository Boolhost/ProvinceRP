						format(string, sizeof(string), "%s снял(а) наушники",PLAYER_DATA[playerid][data_NAME]);
						ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
						SetPlayerChatBubble(playerid, string, 0xFF66CCFF, 20.0, 4000);
						return true;
					}
					case 1:
					{
						PlayAudioStreamForPlayer(playerid,"https://myradio24.org/kvit4enko");
						SendClientMessage(playerid,COLOR_WARNING,"Если Вам нечего не слышно, нажмите {D02090}(( ESC -> Опции -> Настройка Радио -> Прибавьте звук ))");
						SendClientMessage(playerid,COLOR_BLUE,"Province Radio. Приятного прослушивания ;)");
						SetPlayerAttachedObject(playerid, 3, 19424, 2,0.05,0.0,0.0,90.0,360.0,270.0);
						format(string, sizeof(string), "%s одел(а) наушники",PLAYER_DATA[playerid][data_NAME]);
						ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
						SetPlayerChatBubble(playerid, string, 0xFF66CCFF, 20.0, 4000);
					}
					case 2:
					{
						PlayAudioStreamForPlayer(playerid,"http://air.radiorecord.ru:8102/rus_320");
						SendClientMessage(playerid,COLOR_WARNING,"Если Вам нечего не слышно, нажмите {D02090}(( ESC -> Опции -> Настройка Радио -> Прибавьте звук ))");
						SendClientMessage(playerid,COLOR_BLUE,"Russian Mix. Приятного прослушивания ;)");
						SetPlayerAttachedObject(playerid, 3, 19424, 2,0.05,0.0,0.0,90.0,360.0,270.0);
						format(string, sizeof(string), "%s одел(а) нуашники",PLAYER_DATA[playerid][data_NAME]);
						ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
						SetPlayerChatBubble(playerid, string, 0xFF66CCFF, 20.0, 4000);
					}
				}
			}
		}
	}
	return true;
}

