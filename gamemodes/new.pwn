	switch(PLAYER_DATA[playerid][data_MEMBER])
	{
		case 1:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 6) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
