			if(PLAYER_DATA[playerid][data_RENTJOB] != carid) return ShowPlayerDialogFix(playerid, dialog_RENTJOB_TAXI, DIALOG_STYLE_MSGBOX, "{FFCC00}Аренда такси", "{FFFFFF}Чтобы начать работать в такси вам нужно арендовать рабочию машину\nВы хотите арендовать данное такси?\nСтоимость аренды: {33CCFF}500 рублей", "Арендовать", "Отмена");
				//SetTimerEx("CheckRentCar",8000,0,"i",playerid);
