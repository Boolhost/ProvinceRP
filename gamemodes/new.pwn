CMD:setpod(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    switch(PLAYER_DATA[playerid][data_MEMBER])
	{
		case 3:
		{
		    if(PLAYER_DATA[playerid][data_RANK] < 14) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
		}
		default: return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");

	}
	if(sscanf(params,"ud",params[0],params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /setpod [ид] [0 - ППС, 1 - ОМОН]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(PLAYER_DATA[params[0]][data_MEMBER] == 0) return SendClientMessage(playerid, COLOR_WARNING, "Данный игрок не состоит в Вашей организации!");
	if(PLAYER_DATA[playerid][data_MEMBER] != PLAYER_DATA[params[0]][data_MEMBER]) return SendClientMessage(playerid, COLOR_WARNING, "Данный игрок не состоит в Вашей организации!");
	if(params[1] < 0 || params[1] > 1) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /setpod [ид] [0 - ППС, 1 - ОМОН]");

	PLAYER_DATA[params[0]][data_PODMEMBER] = params[1];

	new podfrak[6],str[145],str2[145];
	switch(PLAYER_DATA[params[0]][data_PODMEMBER])
	{
	    case 0: podfrak = "ППС";
		case 1: podfrak = "ОМОН";
	}
	format(str,sizeof(str),"Вы перевели %s в подразделение %s",PLAYER_DATA[params[0]][data_NAME],podfrak);
	format(str2,sizeof(str2),"Вас перевел %s в новое подразделение %s",PLAYER_DATA[playerid][data_NAME],podfrak);
	SendClientMessage(playerid, COLOR_BLUE, str), SendClientMessage(params[0], COLOR_BLUE, str2);
	return true;
}


