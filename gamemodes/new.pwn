    SetPVarInt(playerid, "GivePrefix2", params[0]);
	cache_get_field_content(params[0], "admprefix", prefixone, dbHandle);
	if(!strcmp(prefixone, "qwerty", true))
	{
		ShowPlayerDialogFix(playerid, dialog_APREFIX, DIALOG_STYLE_INPUT, "{FFCC00}Выдача префикса", "\
		{FFFFFF}Введите префикс, который выдан администратору и будет отображаться над ним\n\n\
		{FFCC00}Примечание:\n\
		\t- Префикс должен состоять из русских букв\n\
		\t- Размер префикса от 6 до 32 символов", "Принять", "Отмена");
	}
	else
	{
		ShowPlayerDialogFix(playerid, dialog_APREFIX, DIALOG_STYLE_INPUT, "{FFCC00}Изменения префикса", "\
		{FFFFFF}Введите префикс, который будет изменен администратору и будет отображаться над ним\n\n\
		{FFCC00}Примечание:\n\
		\t- Префикс должен состоять из русских букв\n\
		\t- Размер префикса от 6 до 32 символов", "Принять", "Отмена");
	}
	return true;
}

CMD:sellmycar(playerid, params[])
{
	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

    if(sscanf(params, "ud", params[0], params[1])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /sellmycar [id игрока] [сумма]");
    new string[264];
    if(PlayerToPoint(90.0, playerid, 2561.2627,-674.7836,12.0670))
	{
	    //new carid = GetPlayerVehicleID(playerid);
	    //if(carid == PLAYER_DATA[playerid][data_VEH]) return SendClientMessage(playerid, COLOR_WARNING, "Вы должны быть за рулем транспорта который продаете!");
	 	for(new c = 0; c < 3; c++)
		{
		    if(PLAYER_DATA[playerid][data_CAR][c] == 0)
		    {
		    	format(string,sizeof(string),"%s{FFFFFF}[%d] cвободно\n",string, c+1);
			}
			else
			{
			    format(string,sizeof(string),"%s{FFFFFF}[%d] {1fa1ea}%s{FFFFFF}\n",string, c+1, VehicleNames[PLAYER_DATA[playerid][data_CAR][c]-400],PLAYER_DATA[playerid][data_CAR][c]);
			}
		}
		SetPVarInt(playerid, "sellmycar_playerid", params[0]);
		SetPVarInt(playerid, "sellmycar_money", params[1]);
		ShowPlayerDialogFix(playerid,dialog_SELLMYCAR, DIALOG_STYLE_LIST, "{FFCC00}Продажа авто", string, "Выбрать", "Отмена");
	}
	else SendClientMessage(playerid, COLOR_WARNING, "Продать машину можно только на Автобазаре");
	return 1;
}

CMD:agm(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 2) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(GetPVarInt(playerid,"agm") == 0)
    {
        SetPVarInt(playerid,"agm", 1);
        SetPlayerHealth(playerid, 0x7F800000);
        SendClientMessage(playerid, COLOR_BLUE, "AGM ON");
    }
    else
    {
        SetPVarInt(playerid,"agm", 0);
        SetPlayerHealth(playerid, 100.0);
        SendClientMessage(playerid, COLOR_WARNING, "AGM OFF");
    }
    return true;
}

CMD:flip(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 2) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new carid = GetPlayerVehicleID(playerid);
	if(carid == 0) return SendClientMessage(playerid, COLOR_WARNING, "Вы должны находиться в транспорте!");
	new Float:x, Float:y, Float:z;
	new Float:angle;
	GetVehiclePos(carid, x, y, z);
	GetVehicleZAngle(carid, angle);
	SetVehiclePos(carid, x, y, z + 1.5);
	SetVehicleZAngle(carid, angle);
	SendClientMessage(playerid, COLOR_BLUE, "Транспорт поставлен на колёса.");
	return true;
}

