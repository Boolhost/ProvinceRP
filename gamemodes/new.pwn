CMD:bot(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new s;
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		s = GetPlayerScore(i);
		if(s == 0)
		{
		    switch(random(3))
			{
				case 0:SetPlayerScore(i, 1);
				case 1:SetPlayerScore(i, 2);
				case 2:SetPlayerScore(i, 3);
			}
		    SetPlayerColor(i, 0xFFFFFF00);
		}
	}
    return true;
}

CMD:m(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(sscanf(params, "s[80]", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /m [текст]");
    if(!IsPlayerCops(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
    new car = GetPlayerVehicleID(playerid);
	if(GetVehicleModel(car) == 598 ||
	GetVehicleModel(car) == 551 ||
	GetVehicleModel(car) == 427 ||
	GetVehicleModel(car) == 443 ||
	GetVehicleModel(car) == 597 ||
	GetVehicleModel(car) == 427 ||
	GetVehicleModel(car) == 599 || GetVehicleModel(car) == 490)
	{
	    new string[145];
		format(string, sizeof(string), ">> %s[%d]: %s <<",PLAYER_DATA[playerid][data_NAME],playerid,params[0]);
		ProxDetector(50.0, playerid, string, 0xFACC2EFF, 0xFACC2EFF, 0xFACC2EFF, 0xFACC2EFF, 0xFACC2EFF);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт не оснащен мегафоном!");
	return true;
}

CMD:piss(playerid)
{
  	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;

	if(GetPVarInt(playerid, "piss") == 0)
	{
	    SetPlayerSpecialAction(playerid, 68);
	    SetPVarInt(playerid, "UseAnim",1);
	    SetPVarInt(playerid, "piss",1);
	    GameTextForPlayer(playerid, "~p~use press enter~n~to stop animations", 5000, 6);
	}
	else
	{
	    SetPlayerSpecialAction(playerid, 0);
	    SetPVarInt(playerid, "UseAnim",0);
	    SetPVarInt(playerid, "piss",0);
	}
	return true;
}

CMD:addgarage(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 6) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(GetPVarInt(playerid, "CREATE_GARAGE")) return SendClientMessage(playerid, COLOR_WARNING, "Вы уже начали создавать гараж!");
	ShowPlayerDialogFix(playerid, dialog_CREATE_GARAGE, DIALOG_STYLE_MSGBOX, "{2291B9}Создание гаража", "{FFFFFF}Вы готовы приступить к созданию гаража?", "Да", "Нет");
	return true;
}

CMD:adg(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 6) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(!GetPVarInt(playerid, "CREATE_GARAGE")) return SendClientMessage(playerid, COLOR_WARNING, "Вы еще не начали создавать гараж");

	new Float:PosX, Float:PosY, Float:PosZ;
	GetPlayerPos(playerid, PosX, PosY, PosZ);

	SetPVarInt(playerid, "CREATE_GARAGE", 1);

	SetPVarFloat(playerid, "GARAGE_X", PosX);
	SetPVarFloat(playerid, "GARAGE_Y", PosY);
	SetPVarFloat(playerid, "GARAGE_Z", PosZ);

	SendClientMessage(playerid, COLOR_BLUE, "Теперь отойдите на расстояние от текстур, чтобы машина не попала в текстуры, и введите /nextgarage");

	return true;
}

CMD:nextgarage(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 6) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(!GetPVarInt(playerid, "CREATE_GARAGE")) return SendClientMessage(playerid, COLOR_WARNING, "Вы еще не начали создавать гараж");

	new Float:X, Float:Y, Float:Z, Float:A;
	GetPlayerPos(playerid, X, Y, Z);
	GetPlayerFacingAngle(playerid, A);

	if(garage_car[playerid] != INVALID_VEHICLE_ID) DestroyVehicle(garage_car[playerid]), garage_car[playerid] = INVALID_VEHICLE_ID;
	garage_car[playerid] = CreateVehicle(466, X, Y, Z, A, -1, -1, 80000);
	PutPlayerInVehicle(playerid, garage_car[playerid], 0);

	SendClientMessage(playerid, COLOR_BLUE, "Теперь выберите место, где будет появляться машина после выезда из гаража, и введите /endgarage");

	return true;
}

CMD:endgarage(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 6) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(!GetPVarInt(playerid, "CREATE_GARAGE")) return SendClientMessage(playerid, COLOR_WARNING, "Вы еще не начали создавать гараж");

	new Float:carX, Float:carY, Float:carZ, Float:carA;
	GetVehiclePos(garage_car[playerid], carX, carY, carZ);
	GetVehicleZAngle(garage_car[playerid], carA);

	if(!IsPlayerInAnyVehicle(playerid) && GetPlayerVehicleID(playerid) != garage_car[playerid])
	return SendClientMessage(playerid, COLOR_WARNING, "Вы должны быть в специально-созданном автомобиле для установки гаража");

	SetPVarFloat(playerid, "GARAGE_CAR_X", carX);
	SetPVarFloat(playerid, "GARAGE_CAR_Y", carY);
	SetPVarFloat(playerid, "GARAGE_CAR_Z", carZ);
	SetPVarFloat(playerid, "GARAGE_CAR_A", carA);

	if(garage_car[playerid] != INVALID_VEHICLE_ID) DestroyVehicle(garage_car[playerid]), garage_car[playerid] = INVALID_VEHICLE_ID;

	ShowPlayerDialogFix(playerid,dialog_CREATE_GARAGE_END, DIALOG_STYLE_LIST,"{2291B9}Выберите класс гаража", "{FFFFFF}1. Низкий класс \t{5AB4E4}Цена: 350.000 рублей\n{FFFFFF}2. Средний класс \t{5AB4E4}Цена: 750.000 рублей\n{FFFFFF}3. Премиум класс \t{5AB4E4}Цена: 1.150.000 рублей","Выбрать", "Выход");

	return true;
}

CMD:garage(playerid)
{
	if(PLAYER_DATA[playerid][data_GR] == INVALID_GARAGE_ID) return SendClientMessage(playerid, COLOR_WARNING, "Вы не имеете гараж");
	new g = PLAYER_DATA[playerid][data_GR], title_str[64];

	format(title_str, sizeof title_str, "{EB9A18}Управление гаражем №%d", g + 1);

	ShowPlayerDialogFix(playerid,dialog_GARAGEMENU,DIALOG_STYLE_LIST,title_str,
	"{43B5E6}1. Информация о гараже\n\
	{FFFFFF}2. Отметить гараж на GPS\n\
	3. Открыть / закрыть гараж\n\
	4. Улучшения\n\
	5. Отремонтировать автомобиль\n\
	6. Воспользоваться радиоприемником\n\
	{FA6442}6. Дополнительные действия",
	"Выбрать", "Отмена");
	return true;
}

CMD:makeadmin(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 8) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new string[200];
	if(sscanf(params,"ud",params[0],params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /makeadmin [id] [level 0 - 8]");
	if(params[1] < 0 || params[1] > 8) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /makeadmin [id] [level 0 - 8]");
	if(PLAYER_DATA[params[0]][data_ADMLVL] > PLAYER_DATA[playerid][data_ADMLVL]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к старшей администрации!");
	format(string,sizeof(string),"Вы выдали игроку %s %d-й уровень администратирования",PLAYER_DATA[playerid][data_NAME],params[1]);
	SendClientMessage(playerid,COLOR_BLUE,string);
	format(string,sizeof(string),"Администратор %s назначил Вас администратором %d-го уровня",PLAYER_DATA[params[0]][data_NAME],params[1]);
	SendClientMessage(params[0],COLOR_WARNING,string);
	format(string,sizeof(string),"{808080}[A] Администратор %s назначил игрока %s админом %d-го уровня",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME],params[1]);
	SendAdminMessage(COLOR_WARNING,string);
	new stringer2[128];
	format(stringer2,sizeof(stringer2),"Админинистратор %s назначил игрока %s админом %d-го уровня",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME],params[1]);
	SendClientMessageToAll(COLOR_WARNING,stringer2);
	new query[100];
	PLAYER_DATA[params[0]][data_ADMLVL] = params[1];
    mysql_format(dbHandle,query, sizeof(query), "UPDATE `accounts` SET `admlvl` = '%d' WHERE `name` = '%e'",params[1],PLAYER_DATA[params[0]][data_NAME]);
	mysql_function_query(dbHandle, query, false, "", "");
	SavePlayerData(params[0]);
	//ShowPlayerDialogFix(id, dialog_ALOGIN, DIALOG_STYLE_INPUT,"{FFFFFF}Админ-панель","{FFFFFF}Придумайте и введите администраторский пароль\nДоступно от 6 до 16 символов","Ввести","");
	return true;
}

CMD:givemoney(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new id,money,string[150],string2[150],string3[150];
	if(sscanf(params,"ud",id,money)) return SendClientMessage(playerid, COLOR_WARNING, "Используй: /givemoney [id] [money]");
	if(!IsPlayerConnected(id)) return false;
	format(string,sizeof(string),"[Информация] {ffffff}Вы дали игроку %s %d рублей",PLAYER_DATA[id][data_NAME],money);
	SendClientMessage(playerid,COLOR_BLUE,string);
	format(string3,sizeof(string3),"Вам выдали денег в размере %d рублей",money);
	SendClientMessage(id,COLOR_BLUE,string3);
	format(string2,sizeof(string2),"{808080}[A] %s[%d] выдал игроку %s[%d] %d рублей",PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[id][data_NAME],id,money);
	SendAdminMessage(0x666699FF,string2);
	give_player_money(id, money,"#GiveMoney");
	return true;
}

CMD:tpcor(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 8) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new Float:x,Float:z,Float:y;
	if(sscanf(params,"fff",x,y,z)) return SendClientMessage(playerid,COLOR_BLUE,"[Подсказка] {ffffff}Используйте /tpcor [x] [y] [z]");
	SetPlayerPosAC(playerid,Float:x,Float:y,Float:z);
	FreezePlayer(playerid);
	SetTimerEx("UnfreezePlayer", 4000, false, "d", playerid);
	return true;
}

CMD:givevoen(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

    if(PLAYER_DATA[playerid][data_RANK] < 13) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
 	if(sscanf(params,"u", params[0])) return SendClientMessage(playerid,COLOR_BLUE,"[Подсказка] {ffffff}Используйте /givevoen [id игрока]");
	if(PLAYER_DATA[params[0]][data_MILITARY] == 1) return SendClientMessage(playerid, COLOR_WARNING, "У игрока уже имеется военный билет!");
	if(PLAYER_DATA[params[0]][data_MEMBER] != 2) return SendClientMessage(playerid, COLOR_WARNING, "Данный игрок не состоит в Вашей организации!");
	new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(5.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");
	PLAYER_DATA[params[0]][data_MILITARY] = 1;
	SendClientMessage(params[0], COLOR_BLUE, "Вам выдали военный билет! Теперь вы сможете работать в Полиции!");
	SendClientMessage(playerid, COLOR_BLUE, "Вы выдали военный билет!");
	return true;
}

CMD:rem(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

	if(!IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_GREY, PlayerIsNotInCar);
	new string[145];
	//new carid = GetPlayerVehicleID(playerid);
	switch(PLAYER_DATA[playerid][data_REM])
	{
	    case 0:
	    {
			format(string, sizeof(string), "%s застягнул(а) ремень",PLAYER_DATA[playerid][data_NAME]);
			ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
			SetPlayerChatBubble(playerid, string, 0xFF66CCFF, 20.0, 4000);
			PLAYER_DATA[playerid][data_REM] = 1;
	    }
	    case 1:
	    {
	        format(string, sizeof(string), "%s растягнул(а) ремень",PLAYER_DATA[playerid][data_NAME]);
			ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
			SetPlayerChatBubble(playerid, string, 0xFF66CCFF, 20.0, 4000);
			PLAYER_DATA[playerid][data_REM] = 0;
	    }
 	}
 	return true;
}

CMD:setstat(playerid, params[])
{
	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new id, param1, param2, string[150];
	if(sscanf(params,"udd",id,param1,param2))
	{
		SendClientMessage(playerid, -1, "Используй: /setstat [id] [код] [значение]");
		SendClientMessage(playerid, -1, "[0]Уровень | [1]Пол | [2]Предупреждения | [3]Патроны | [4]Металл | [5]Наркотики");
		SendClientMessage(playerid, -1, "[6]Счет в банке | [7]Donate счет | [8]Сытность" );
		return true;
	}
	switch(param1)
	{
		case 0:
		{
			SetPlayerScore(id,param2);
			PLAYER_DATA[id][data_LVL] = param2;
			format(string,sizeof(string),"Вы изменили уровень игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
		}
		case 1:
		{
		    new sex[10];
		    if(param1 < 1 || param1 > 2) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: 1 - Муржской, 2 - Женский");
		    switch(PLAYER_DATA[playerid][data_NUMBER])
			{
			    case 1: sex = "Женский";
			    case 2: sex = "Муржской";
			}
			PLAYER_DATA[id][data_SEX] = param2;
			format(string,sizeof(string),"Вы изменили пол игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
		}
		case 2:
		{
			PLAYER_DATA[id][data_WARN] = param2;
			format(string,sizeof(string),"Вы изменили кол-во предупреждений игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
		}
		case 3:
		{
			format(string,sizeof(string),"Вы изменили кол-во патронов игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
			PLAYER_DATA[id][data_PUTPATR] = param2;
		}
		case 4:
		{
			format(string,sizeof(string),"Вы изменили кол-во металла игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
			PLAYER_DATA[id][data_PUTMET] = param2;
		}
		case 5:
		{
			format(string,sizeof(string),"Вы изменили кол-во наркотиков игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
			PLAYER_DATA[id][data_DRUGS] = param2;
		}
		case 6:
		{
			format(string,sizeof(string),"Вы изменили счет состояния в банке игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
			PLAYER_DATA[id][data_BANK] = param2;
		}
		case 7:
		{
			format(string,sizeof(string),"Вы изменили Donate счет игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
			PLAYER_DATA[id][data_DONATE] = param2;
		}
		case 8:
		{
			format(string,sizeof(string),"Вы изменили сытность игрока %s(%d) на %d",PLAYER_DATA[id][data_NAME],id,param2);
			SendClientMessage(playerid,COLOR_BLUE,string);
			PLAYER_DATA[id][data_SATIETY] = param2;
		}
	}
	SavePlayerData(id);
	return true;
}

CMD:drugs(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

    if(PLAYER_DATA[playerid][data_DRUGS] < 2) return SendClientMessage(playerid,COLOR_WARNING,"У вас нет наркотиков!");
	new Float:health;
	new string[100];
	GetPlayerHealth(playerid, health);
	SetPlayerHealthAC(playerid, health+20);
	GetPlayerHealth(playerid, health);
	if(health > 120) return SendClientMessage(playerid, COLOR_WARNING, "Вам плохо от наркотиков, пожалуйста подождите!");
	SendClientMessage(playerid, COLOR_BLUE, "Вы употребили 2 грамма наркотиков!");
	format(string, sizeof(string), "%s употребил(а) наркотики",PLAYER_DATA[playerid][data_NAME]);
	ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
	SetPlayerChatBubble(playerid, string, 0xFF66CCFF, 20.0, 4000);
	SetPlayerTime(playerid,17,0);
	SetPlayerWeather(playerid, -68);
	SetPlayerDrunkLevel(playerid, 3000);
	PLAYER_DATA[playerid][data_DRUGS] -= 2;
	SetTimerEx("DrugEffect", 60000, false, "i", playerid);
	ApplyAnimation(playerid,"SMOKING","M_smk_drag",4.1,0,0,0,0,0,1);
	return true;
}

CMD:buydrugs(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

	new string[100];
	if(PLAYER_DATA[playerid][data_LEADER] == 5 || PLAYER_DATA[playerid][data_LEADER] == 6 || PLAYER_DATA[playerid][data_LEADER] == 7) return SendClientMessage(playerid,COLOR_WARNING,"Доступно только для состоящих в ОПГ!");
	if(!PlayerToPoint(20.0,playerid, 1032.5905,118.2550,1088.6000)) return SendClientMessage(playerid,COLOR_WARNING,"[Подсказка] {ffffff}Наркотики можно купить в наркопритоне");
	if(sscanf(params,"u", params[0])) return SendClientMessage(playerid,COLOR_BLUE,"Используйте /buydrugs [кол-во]");
	if(params[0] < 1 || params[0] > 100) return SendClientMessage(playerid,COLOR_WARNING,"Можно купить от 1 грамма до 100 грамм наркотиков");
	PLAYER_DATA[playerid][data_DRUGS] += params[0];
	format(string, sizeof(string), "Вы купили %s грамм наркотиков", params[0]);
	SendClientMessage(playerid,COLOR_BLUE,string);
	return true;
}

CMD:mostup(playerid, params[])
{
	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	//MoveObject(Most1,2747.3701, -1142.8600, 21.5900, 0.0005, 60.00, 0.00, 180.00);
	MoveDynamicObject(Most1, 2747.3701, -1142.8600, 21.5900, 0.015, 0.0000, 0.0000, 180.0000);
	//MoveObject(Most2,2747.3701, -1261.9200, 21.5900, 0.0005, 60.00, 0.00, 0.00);
	MoveDynamicObject(Most2, 2747.3701, -1261.9200, 21.5900, 0.015, 0.0000, 0.0000, 0.0000);
	SendClientMessageToAll(0xFFCC00FF,"Осторожно, поднимается мост в г. Южный!");
	return 1;
}
