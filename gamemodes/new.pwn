		printf("[serv_log]  Load warehouse. Time: %d ms.",GetTickCount()-time);
	}
	return true;
}



public LoadPolitMember(polit, playerid)
{
    new rows, fields;
    cache_get_data(rows, fields);
    if(rows)
    {
        new name[MAX_PLAYER_NAME],dtext[512];
    	for(new p = 0; p < rows; p++)
    	{
	        cache_get_field_content(p, "name", name, dbHandle, MAX_PLAYER_NAME);
	        if(strfind(POLIT_TEAM[polit][data_OWNER], name, true) != -1) format(dtext,sizeof(dtext),"%s\n{FFFFFF}%s - Основатель",dtext, name);
	        else format(dtext,sizeof(dtext),"%s\n{FFFFFF}%s\n",dtext, name);
        }
    	ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Состав семьи", dtext, "Закрыть", "");
	}
	return true;
}

public LoadPolitMemberOFF()
{
    new rows, fields;
    cache_get_data(rows, fields);
    if(rows)
    {
        new name[MAX_PLAYER_NAME];
    	for(new p = 0; p < rows; p++)
    	{
	        cache_get_field_content(p, "name", name, dbHandle, MAX_PLAYER_NAME);
	        new query[120];
            format(query, sizeof(query), "UPDATE `accounts` SET `polit` = '0' WHERE `name` = '%s'",name);
  			mysql_function_query(dbHandle, query, false, "", "");
        }
	}
	return true;
}


public LoadDepPolitMember(polit, playerid)
{
