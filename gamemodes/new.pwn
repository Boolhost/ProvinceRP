stock NotReklama(playerid, string[])
{
	new i, AR;
	for(i = strlen(string); i != 0; --i)
	switch(string[i])
	{
		case '0'..'9': AR++;
	}
	if(AR > 7)
	{
	    new msg[145];
		format(msg,sizeof(msg),"{808080}[A] %s[%d][%s] подозрение в рекламе",PLAYER_DATA[playerid][data_NAME],playerid,string);
		SendAdminMessage(COLOR_AC,msg);
		return false;
  	}
	return true;
}


