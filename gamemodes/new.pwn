			SetCameraBehindPlayer(playerid);
			SetPlayerVirtualWorld(playerid, 4);
			SetPlayerInterior(playerid, 4);
			switch(random(3))
			{
			    case 0:SetPlayerPosAC(playerid, 969.7978,2098.9324,1122.4600);
