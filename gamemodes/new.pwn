CMD:hi(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /hi [ид]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(playerid == params[0]) return true;


    new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(3.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");


    SetPVarInt(params[0], "yesno_hi", 1);
	SetPVarInt(params[0], "yesno_playerid", playerid);
	SetPVarInt(params[0], "yesno", 1);
	new str1[145], str2[145];
	format(str1,sizeof(str1),"{1fa1ea}Вы предложили пожать руку %s",PLAYER_DATA[params[0]][data_NAME]);
	SendClientMessage(playerid, COLOR_BLUE, str1);
	format(str2,sizeof(str2),"{1fa1ea}%s предложил Вам пожать руку. Для согласия {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME]);
	SendClientMessage(params[0], COLOR_BLUE, str2);




	return true;
}


CMD:time(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) ApplyAnimation(playerid,"COP_AMBIENT","Coplook_watch",4.1,0,0,0,0,0);
  	new hour,minuite,string[36],str[21+MAX_PLAYER_NAME],Year, Month, Day,month[10];
  	gettime(hour,minuite);
	getdate(Year, Month, Day);
	switch(Month)
	{
		case 1: month = "January";
		case 2: month = "February";
		case 3: month = "March";
		case 4: month = "April";
		case 5: month = "May";
		case 6: month = "June";
		case 7: month = "July";
		case 8: month = "August";
		case 9: month = "September";
		case 10: month = "October";
		case 11: month = "November";
		case 12: month = "December";
	}
	if(PLAYER_DATA[playerid][data_JAIL] != 0)
	{
		format(string,sizeof(string),"~y~%02d:%02d~n~%d %s~n~%d jail",hour,minuite,Day, month,PLAYER_DATA[playerid][data_JAILTIME]);
	}
	else
	{
		format(string,sizeof(string),"~y~%02d:%02d~n~%d %s",hour,minuite,Day, month);
	}
	GameTextForPlayer(playerid, string, 5000, 1);
	format(str,sizeof(str),"%s взглянул(а) на часы",PLAYER_DATA[playerid][data_NAME]);
    ProxDetector(30.0, playerid, str,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
    SetPlayerChatBubble(playerid, "взглянул(а) на часы", 0xFF66CCFF, 20.0, 4000);
	switch(PLAYER_DATA[playerid][data_MEMBER])
	{
		case 5,6,7: SendClientMessage(playerid,0x04B431FF,"ЗАХВАТ: 01:00, 03:00, 05:00, 07:00, 09:00, 11:00, 13:00, 15:00, 17:00, 19:00, 21:00, 23:00");
	}
	return true;
}



CMD:s(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MUTE] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Ваш чат временно заблокирован!");
	if(sscanf(params,"s[80]",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /s [текст]");
    NotReklama(playerid, params[0]);
	new string[145];
    format(string, sizeof(string), "%s крикнул(а): %s",PLAYER_DATA[playerid][data_NAME],params[0]);
	ProxDetector(50.0, playerid, string, -1, -1, -1, -1, -1);
	SetPlayerChatBubble(playerid, string, -1, 20.0, 4000);
	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) ApplyAnimation(playerid,"ON_LOOKERS","shout_01",1000.0,0,0,0,0,0,1);
	return true;
}


CMD:weap(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 2) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(sscanf(params,"ud",params[0],params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /weap [id] [slot]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");

	if(params[1] < 0 || params[1] > 12) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /weap [id] [1-12]");

	new datagunid, dataammo;
	GetPlayerWeaponData(params[0], params[1], datagunid, dataammo);
 	new dtext[256];
	format(dtext,sizeof(dtext),"{FFFFFF}slot: %d\ndatagunid: %d\ndataammo: %d\nammo %d\n{FF6666}[!] dataammo > ammo = cheat",params[1], datagunid, dataammo, PLAYER_DATA[playerid][data_AMMO][params[1]]);
	ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX, PLAYER_DATA[params[0]][data_NAME], dtext, "Закрыть", "");

	new message[145];
	format(message,sizeof(message),"{808080}[A] %s проверка /weap %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	SendAdminMessage(0x666699FF,message);
	return true;
}

CMD:resgun(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /resgun [id]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");

	new message[145];
	format(message,sizeof(message),"{808080}[A] %s удалил все оружие у игрока %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	SendAdminMessage(0x666699FF,message);
    ResetWeaponAll(params[0]);
	return true;
}

CMD:jetpack(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 5) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    SetPlayerSpecialAction(playerid, SPECIAL_ACTION_USEJETPACK);

	new message[145];
	format(message,sizeof(message),"{808080}[A] %s выдал себе JetPack",PLAYER_DATA[playerid][data_NAME]);
	SendAdminMessage(0x666699FF,message);
    ResetWeaponAll(params[0]);
	return true;
}




CMD:me(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MUTE] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Ваш чат временно заблокирован!");
	if(sscanf(params,"s[80]",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /me [текст]");
    NotReklama(playerid, params[0]);
	new string[145];
    format(string, sizeof(string), "%s %s",PLAYER_DATA[playerid][data_NAME],params[0]);
	ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
	SetPlayerChatBubble(playerid, string, 0xFF66CCFF, 20.0, 4000);
	return true;
}

