			if(CAR_DATA[carid][data_RENT_A] != INVALID_PLAYER_ID) return SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт уже кто-то арендовал!"),RemovePlayerFromVehicleAC(playerid);
			if(GetPVarInt(playerid,"RENT_AUTO") == 1) return SendClientMessage(playerid, COLOR_WARNING, "Вы уже арендовали транспорт! Дождитесь пока компания заберёт арендованый транспорт."),RemovePlayerFromVehicleAC(playerid);
			ShowPlayerDialogFix(playerid, dialog_RENT_A, DIALOG_STYLE_MSGBOX, "{FFCC00}Аренда машины", "{FFFFFF}Вы хотите арендовать машину {1fa1ea}Высокого класса{FFFFFF} на прокат?\n\nСтоимость аренды составит {31B404}15300{FFFFFF} рублей.\nПри долгом отсутствии компания заюерёт транспорт обратно.", "Арендовать", "Отмена");
		}

		if(carid >= Brent_car[0] && carid <= Brent_car[1])
		{
			if(CAR_DATA[carid][data_RENT_B] != INVALID_PLAYER_ID) return SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт уже кто-то арендовал!"),RemovePlayerFromVehicleAC(playerid);
            if(GetPVarInt(playerid,"RENT_AUTO") == 1) return SendClientMessage(playerid, COLOR_WARNING, "Вы уже арендовали транспорт! Дождитесь пока компания заберёт арендованый транспорт."),RemovePlayerFromVehicleAC(playerid);
			ShowPlayerDialogFix(playerid, dialog_RENT_B, DIALOG_STYLE_MSGBOX, "{FFCC00}Аренда машины", "{FFFFFF}Вы хотите арендовать машину {1fa1ea}Высокого класса{FFFFFF} на прокат?\n\nСтоимость аренды составит {31B404}11800{FFFFFF} рублей.\nПри долгом отсутствии компания заюерёт транспорт обратно.", "Арендовать", "Отмена");
		}

		if(carid >= Crent_car[0] && carid <= Crent_car[1])
		{
			if(CAR_DATA[carid][data_RENT_C] != INVALID_PLAYER_ID) return SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт уже кто-то арендовал!"),RemovePlayerFromVehicleAC(playerid);
            if(GetPVarInt(playerid,"RENT_AUTO") == 1) return SendClientMessage(playerid, COLOR_WARNING, "Вы уже арендовали транспорт! Дождитесь пока компания заберёт арендованый транспорт."),RemovePlayerFromVehicleAC(playerid);
			ShowPlayerDialogFix(playerid, dialog_RENT_C, DIALOG_STYLE_MSGBOX, "{FFCC00}Аренда машины", "{FFFFFF}Вы хотите арендовать машину {1fa1ea}Высокого класса{FFFFFF} на прокат?\n\nСтоимость аренды составит {31B404}8900{FFFFFF} рублей.\nПри долгом отсутствии компания заюерёт транспорт обратно.", "Арендовать", "Отмена");
		}

        if(carid >= prod_car[0] && carid <= prod_car[1])
		{
			if(PLAYER_DATA[playerid][data_START_JOB] != 8)
			{
				SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
          		RemovePlayerFromVehicleAC(playerid);
				return true;
			}
			if(CAR_DATA[carid][data_RENT] != INVALID_PLAYER_ID && PLAYER_DATA[playerid][data_RENTJOB] != carid) return SendClientMessage(playerid,COLOR_WARNING,"На данном транспорте уже кто-то работает!"),RemovePlayerFromVehicleAC(playerid);
			if(PLAYER_DATA[playerid][data_RENTJOB] != carid) return ShowPlayerDialogFix(playerid, dialog_RENTJOB, DIALOG_STYLE_MSGBOX, "{FFCC00}Главный склад", "{FFFFFF}Вы желаете начать рабочий день на данном транспорте?", "Начать", "Отмена");
		}

        if(carid >= gov_car[0] && carid <= gov_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 1)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= mchs_car[0] && carid <= mchs_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 10)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= army_car[0] && carid <= army_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 2)
	        {
	            new model = GetVehicleModel(carid);
				if(model == 433)
				{
				    new str[64];
				    format(str,sizeof(str),"Загружено: %d/10000 патронов, %d/10000 металла",CAR_DATA[carid][data_PATR],CAR_DATA[carid][data_MET]);
				    SendClientMessage(playerid,0x99FFCCFF,str);
				}
			}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= police_car[0] && carid <= police_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 3)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= hospital_car[0] && carid <= hospital_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 4)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= fsb_car[0] && carid <= fsb_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 8)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= smi_car[0] && carid <= smi_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 9)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= rostov_car[0] && carid <= rostov_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 5)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= maykop_car[0] && carid <= maykop_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 6)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
	    if(carid >= odessa_car[0] && carid <= odessa_car[1])
	    {
	        if(PLAYER_DATA[playerid][data_MEMBER] == 7)
	        {}
	        else
	        {
	            SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             	RemovePlayerFromVehicleAC(playerid);
				return true;
	        }
	    }
    }
    //signalka
	if(newstate == PLAYER_STATE_DRIVER)
	{
	    if(carid == PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_VEH])
	    {
			if(CAR_DATA[carid][data_SIGNAL] == 1)
			{
	            new Float:x, Float:y, Float:z;
				SetPVarFloat(playerid, "signal_pos_x",x);
				SetPVarFloat(playerid, "signal_pos_y",y);
				SetPVarFloat(playerid, "signal_pos_z",z);
				GetPlayerPos(playerid, x, y, z);
				SetPlayerCheckpoint(CAR_DATA[carid][data_IDP], x, y, z, 5.0);
				SendClientMessage(CAR_DATA[carid][data_IDP], COLOR_WARNING, "В вашей машине сработала сигнализация!");
				SendClientMessage(CAR_DATA[carid][data_IDP], COLOR_BLUE, "Машина отмечена на карте!");
			}
		}
	}
	return true;
}

public OnPlayerEnterCheckpoint(playerid)
{

    if(PlayerToPoint(5.0, playerid, GetPVarFloat(playerid, "gps_pos_x"),GetPVarFloat(playerid, "gps_pos_y"),GetPVarFloat(playerid, "gps_pos_z")))
	{
	    DisablePlayerCheckpoint(playerid);
	    DeletePVar(playerid, "gps_pos_x");
	    DeletePVar(playerid, "gps_pos_y");
	    DeletePVar(playerid, "gps_pos_z");
	    UseGPS[playerid] = false;
		KillTimer(markTimer[playerid]);
        markDist[playerid] = 0.0;
		HideGPSTextDraws(playerid);
	    SendClientMessage(playerid,0x33CC99FF,"[GPS]: Вы достигли места назначения");
	    return true;
	}

	if(GetPVarInt(playerid,"job_bus") != 0 && PLAYER_DATA[playerid][data_RENTJOB] != INVALID_VEHICLE_ID)
	{
	    new b = GetPVarInt(playerid,"job_bus")-1;
		if(PlayerToPoint(5.0, playerid, 2518.826171, -2145.580322, 21.816497))
		{
			SetPlayerCheckpoint(playerid, JB_DATA[b][data_BUS_POS][0],JB_DATA[b][data_BUS_POS][1], JB_DATA[b][data_BUS_POS][2], 5.0);
			SendClientMessage(playerid,0x339999AA,"Дождитесь пока к Вам сядут пассажиры и отправляйтесь обратно на предприятие  (на карте отмечена красная метка)");
			return true;
		}

		if(PlayerToPoint(5.0, playerid, JB_DATA[b][data_BUS_POS][0],JB_DATA[b][data_BUS_POS][1], JB_DATA[b][data_BUS_POS][2]))
		{
		    new msg[145],chel, money;
		    for(new i = 0; i < MAX_PLAYERS; i++)
		    {
		        if(!IsPlayerConnected(i) || playerid == i) continue;
		        if(PLAYER_DATA[i][data_BUSCAR] == PLAYER_DATA[playerid][data_RENTJOB])
				{
					chel++;
					PLAYER_DATA[i][data_BUSCAR] = INVALID_VEHICLE_ID;
					SendClientMessage(i,0x0489B1FF, "Вас привезли на предприятие. Чтобы устроиться на работу подойдите к синей майке");
				}
		    }
		    SetPVarInt(playerid, "all_tovar", GetPVarInt(playerid, "all_tovar")+chel);
			money = GetPVarInt(playerid, "all_tovar") * JB_DATA[b][data_BUS_MONEY];

		    format(msg,sizeof(msg),"Доставлено новых рабочих: %d человек(а). Всего заработано: %d рублей",chel, money);
		  	SendClientMessage(playerid,0x339999AA,msg);

			SetPlayerCheckpoint(playerid, 2518.826171, -2145.580322, 21.816497, 5.0);
		  	SendClientMessage(playerid,0x66CC00FF,"Отправляйтесь в Южный за новыми рабочими (на карте отмечена красная метка)");
			return true;
		}

	}

    if(PLAYER_DATA[playerid][data_START_JOB] == 1)
	{
	    if(PlayerToPoint(2.0, playerid, 2500.0134, -652.8276, 12.2740) && GetPVarInt(playerid,"tovar") == 1)
		{

		    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);
		    SetPVarInt(playerid,"ac_timer", 4);
		    if(IsPlayerInAnyVehicle(playerid)) return true;
			DisablePlayerCheckpoint(playerid);
	    	if(IsPlayerAttachedObjectSlotUsed(playerid, 1)) RemovePlayerAttachedObject(playerid, 1);
	       	SetPVarInt(playerid,"all_tovar",GetPVarInt(playerid,"all_tovar")+1);
	       	SetPVarInt(playerid,"tovar",0);
			new message[145];
			format(message,sizeof(message),"Вы доставили товар на склад. Всего доставлено: %d шт",GetPVarInt(playerid,"all_tovar"));
			SendClientMessage(playerid,0x339999AA,message);

			switch(random(2))
			{
				case 0: SetPlayerCheckpoint(playerid, 2719.6956,-2325.5881,17.9660, 2.0);
			 	case 1: SetPlayerCheckpoint(playerid, 2742.4841,-2357.4810,17.9660, 2.0);
			}
			return true;
		}
	    if(PlayerToPoint(2.0, playerid, 2719.6956,-2325.5881,17.9660) || PlayerToPoint(2.0, playerid, 2742.4841,-2357.4810,17.9660))
		{
		    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);
		    SetPVarInt(playerid,"ac_timer",4);

		    if(IsPlayerInAnyVehicle(playerid)) return true;
			DisablePlayerCheckpoint(playerid);
	       	SetPVarInt(playerid,"tovar",1);

 			SetPlayerAttachedObject(playerid,1, 1279,5,0.052000,0.044999,0.192999,-76.999969,-3.999996,104.099876,0.576000,0.666999,0.717000);
			SetPlayerCheckpoint(playerid, 2500.0134, -652.8276, 12.2740, 2.0);
	        return true;

		}
	}

	if(PLAYER_DATA[playerid][data_START_JOB] == 2)
	{
	    if(PlayerToPoint(2.0, playerid, 1598.1444,-794.5472,41.5058) && GetPVarInt(playerid,"tovar") != 0)
		{
		    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);
		    SetPVarInt(playerid,"ac_timer",4);

		    if(IsPlayerInAnyVehicle(playerid)) return true;

		    JB_DATA[0][data_RESURS] += GetPVarInt(playerid,"tovar");
		    JB_DATA[0][data_SKLAD] += GetPVarInt(playerid,"tovar");
			DisablePlayerCheckpoint(playerid);
	    	if(IsPlayerAttachedObjectSlotUsed(playerid, 1)) RemovePlayerAttachedObject(playerid, 1);
	    	if(IsPlayerAttachedObjectSlotUsed(playerid, 2)) RemovePlayerAttachedObject(playerid, 2);
	       	SetPVarInt(playerid,"all_tovar",GetPVarInt(playerid,"all_tovar")+GetPVarInt(playerid,"tovar"));



			new message[145];
			format(message,sizeof(message),"Вы доставили %d кг. древесины на склад. Всего доставлено: %d кг",GetPVarInt(playerid,"tovar"),GetPVarInt(playerid,"all_tovar"));
			SendClientMessage(playerid,0x339999AA,message);
			SetPVarInt(playerid,"tovar",0);
			switch(random(6))
			{
				case 0: SetPlayerCheckpoint(playerid, 1580.6279,-805.5348,41.9165, 2.0);
			 	case 1: SetPlayerCheckpoint(playerid, 1582.1740,-788.1065,41.6062, 2.0);
			 	case 2: SetPlayerCheckpoint(playerid, 1567.8470,-799.8918,41.6547, 2.0);
				case 3: SetPlayerCheckpoint(playerid, 1598.4878,-774.1809,40.4617, 2.0);
				case 4: SetPlayerCheckpoint(playerid, 1615.0198,-789.1124,40.7747, 2.0);
				case 5: SetPlayerCheckpoint(playerid, 1608.1359,-830.7748,41.5927, 2.0);
		 	}
    		ClearAnim(playerid);
    		return true;
		}


	    if(PlayerToPoint(2.0, playerid, 1580.6279,-805.5348,41.9165) ||
		PlayerToPoint(2.0, playerid, 1582.1740,-788.1065,41.6062) ||
		PlayerToPoint(2.0, playerid, 1567.8470,-799.8918,41.6547) ||
		PlayerToPoint(2.0, playerid, 1598.4878,-774.1809,40.4617) ||
		PlayerToPoint(2.0, playerid, 1615.0198,-789.1124,40.7747) ||
		PlayerToPoint(2.0, playerid, 1608.1359,-830.7748,41.5927))
		{
		    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);

		    if(IsPlayerInAnyVehicle(playerid)) return true;
		    ClearAnimations(playerid);
			DisablePlayerCheckpoint(playerid);
			GiveWeapon(playerid, 9, 1);
	    	ApplyAnimation(playerid,"CHAINSAW","CSAW_1",4.1,1,0,0,1,1111000);
	    	PLAYER_DATA[playerid][data_DREV_TIMER_ID] = SetTimerEx("DrevLoaded",5000,false,"i",playerid);
			SetPVarInt(playerid, "process", 1);

			new Float:x,Float:y,Float:z;
			GetPlayerPos(playerid,x,y,z);

			SetPVarFloat(playerid, "job_x",x);
			SetPVarFloat(playerid, "job_y",y);
			SetPVarFloat(playerid, "job_z",z);
			return true;
		}
	}


	if(PLAYER_DATA[playerid][data_START_JOB] == 3)
	{
	    if(PlayerToPoint(2.0, playerid, 1547.2593, -2409.6533, 10.1301))
		{
		    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);
		    SetPVarInt(playerid,"ac_timer",1);

		    if(IsPlayerInAnyVehicle(playerid)) return true;
		    JB_DATA[1][data_RESURS] += GetPVarInt(playerid,"tovar");
		    JB_DATA[1][data_SKLAD] += GetPVarInt(playerid,"tovar");
			new message[145];
			ClearAnim(playerid);
			SetPVarInt(playerid, "all_tovar", GetPVarInt(playerid, "all_tovar")+GetPVarInt(playerid, "tovar"));
			format(message,sizeof(message),"Вы доставили %d кг. руды на склад. Всего доставлено: %d кг",GetPVarInt(playerid, "tovar"),GetPVarInt(playerid, "all_tovar"));
			SendClientMessage(playerid, 0x70B95EC8, message);
			SetPVarInt(playerid, "tovar", 0);
	        if(IsPlayerAttachedObjectSlotUsed(playerid,2)) RemovePlayerAttachedObject(playerid,2);// забрали тачку
	        if(IsPlayerAttachedObjectSlotUsed(playerid,3)) RemovePlayerAttachedObject(playerid,3);// забрали камень
	        SetPlayerAttachedObject(playerid,1, 18634, 14, 0.333391, 0.000000, 0.042249, 358.219909, 268.014739, 170.032974, 2.003867, 1.764811, 1.579773);// дали кирку
	        DisablePlayerCheckpoint(playerid);
	        new pos = random(5);
	        SetPVarInt(playerid, "karier_pos", pos);
	        SetPlayerCheckpoint(playerid, karier_pos[pos][0], karier_pos[pos][1], karier_pos[pos][2], 2.0);
	        return true;
	   	}
		new pos = GetPVarInt(playerid, "karier_pos");
	   	if(PlayerToPoint(2.0, playerid, karier_pos[pos][0], karier_pos[pos][1], karier_pos[pos][2]))
	   	{
	   	    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);

	   	    if(IsPlayerInAnyVehicle(playerid)) return true;
	   	    ClearAnimations(playerid);
	   	    ApplyAnimation(playerid, "BASEBALL", "Bat_4", 4.1, 1, 0, 0, 0, 0);
	       	PLAYER_DATA[playerid][data_SHAHTA_TIMER_ID] = SetTimerEx("KamenLoaded",5000,false,"i",playerid);
			DisablePlayerCheckpoint(playerid);
			SetPVarInt(playerid, "process", 1);

			new Float:x,Float:y,Float:z;
			GetPlayerPos(playerid,x,y,z);

			SetPVarFloat(playerid, "job_x",x);
			SetPVarFloat(playerid, "job_y",y);
			SetPVarFloat(playerid, "job_z",z);
			return true;
	   	}
	}

	if(PLAYER_DATA[playerid][data_START_JOB] == 4)
	{
		//Склад яблок
	    if(PlayerToPoint(2.0, playerid, 2466.0354,1444.6637,11.0666))
		{
		    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);
		    SetPVarInt(playerid,"ac_timer",3);

		    if(IsPlayerInAnyVehicle(playerid)) return true;
		    JB_DATA[2][data_RESURS] += 50;
		    JB_DATA[2][data_SKLAD] += 50;
			new message[145];
			ClearAnim(playerid);
			SetPlayerSpecialAction(playerid, 0);
			SetPVarInt(playerid, "all_tovar", GetPVarInt(playerid, "all_tovar")+GetPVarInt(playerid, "tovar"));
			format(message,sizeof(message),"Вы доставили ящик на склад. Всего доставлено: %d шт",GetPVarInt(playerid, "all_tovar"));
			SendClientMessage(playerid, 0x70B95EC8, message);
			SetPVarInt(playerid, "tovar", 0);
	        if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
	        DisablePlayerCheckpoint(playerid);
	        new pos = random(7);
	        SetPVarInt(playerid, "yablo_pos", pos);
	        SetPlayerCheckpoint(playerid, yablo_pos[pos][0], yablo_pos[pos][1], yablo_pos[pos][2], 2.0);
	        return true;
	   	}
		new pos = GetPVarInt(playerid, "yablo_pos");
	   	if(PlayerToPoint(2.0, playerid, yablo_pos[pos][0], yablo_pos[pos][1], yablo_pos[pos][2]))
	   	{
	   	    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);

	   	    if(IsPlayerInAnyVehicle(playerid)) return true;
	   	    ClearAnimations(playerid);
	   	    SetPVarInt(playerid, "yablo_check",0);
	   	    ApplyAnimation(playerid,"CAMERA","picstnd_out",4.1,0, 0, 0, 1, 1);
	       	PLAYER_DATA[playerid][data_YABLO_TIMER_ID] = SetTimerEx("YabloLoaded",1000,true,"i",playerid);
			DisablePlayerCheckpoint(playerid);
			SetPVarInt(playerid, "process", 1);

			new Float:x,Float:y,Float:z;
			GetPlayerPos(playerid,x,y,z);

			SetPVarFloat(playerid, "job_x",x);
			SetPVarFloat(playerid, "job_y",y);
			SetPVarFloat(playerid, "job_z",z);
			return true;
	   	}
	}
    if(PLAYER_DATA[playerid][data_START_JOB] == 5)
	{
	    if(PlayerToPoint(2.0, playerid, 227.4557,-935.0860,40.4509))
		{
		    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);
		    if(IsPlayerInAnyVehicle(playerid)) return true;

		    SetPVarInt(playerid,"ac_timer",1);

		    JB_DATA[3][data_RESURS] += 50;
		    JB_DATA[3][data_SKLAD] += 50;
			new message[145];
			ClearAnim(playerid);
			SetPlayerSpecialAction(playerid, 0);
			SetPVarInt(playerid, "all_tovar", GetPVarInt(playerid, "all_tovar")+GetPVarInt(playerid, "tovar"));
			format(message,sizeof(message),"Вы доставили ящик на склад. Всего доставлено: %d шт",GetPVarInt(playerid, "all_tovar"));
			SendClientMessage(playerid, 0x70B95EC8, message);
			SetPVarInt(playerid, "tovar", 0);
	        if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
	        DisablePlayerCheckpoint(playerid);
	        new pos = random(13);
	        SetPVarInt(playerid, "ogorod_pos", pos);
	        SetPlayerCheckpoint(playerid, ogorod_pos[pos][0], ogorod_pos[pos][1], ogorod_pos[pos][2], 2.0);
	        return true;
	   	}
		new pos = GetPVarInt(playerid, "ogorod_pos");
	   	if(PlayerToPoint(2.0, playerid, ogorod_pos[pos][0], ogorod_pos[pos][1], ogorod_pos[pos][2]))
	   	{
	   	    if(GetPVarInt(playerid, "ac_timer") > 0) return AC_Kick(playerid, 10);

	   	    if(IsPlayerInAnyVehicle(playerid)) return true;
	   	    ClearAnimations(playerid);
	   	    ApplyAnimation(playerid, "BOMBER","BOM_Plant_Loop",4.0,1,0,0,0,0);
	       	PLAYER_DATA[playerid][data_OGOROD_TIMER_ID] = SetTimerEx("OgorodLoaded",5000,false,"i",playerid);
			DisablePlayerCheckpoint(playerid);
			SetPVarInt(playerid, "process", 1);
			new Float:x,Float:y,Float:z;
			GetPlayerPos(playerid,x,y,z);

   			SetPVarFloat(playerid, "job_x",x);
			SetPVarFloat(playerid, "job_y",y);
			SetPVarFloat(playerid, "job_z",z);
			return true;
	   	}
	}
	if(PlayerToPoint(5.0, playerid, GetPVarFloat(playerid, "signal_pos_x"), GetPVarFloat(playerid, "signal_pos_y"), GetPVarFloat(playerid, "signal_pos_z")))
	{
		DisablePlayerCheckpoint(playerid);
		DeletePVar(playerid, "signal_pos_x");
	    DeletePVar(playerid, "signal_pos_y");
	    DeletePVar(playerid, "signal_pos_z");
		SendClientMessage(playerid,0x33CC99FF,"Вы прибыли к своей машине! Посмотрите ничего не пропало?");
	}
	return true;
}

public OnPlayerLeaveCheckpoint(playerid)
{
	return true;
}

public OnPlayerEnterRaceCheckpoint(playerid)
{
    new car = GetPlayerVehicleID(playerid);
	if(cartrack_status == false)
	{
	    for(new i = 0; i < sizeof(chek_cartrack);i++)
		{
	    	if(PlayerToPoint(15.0, playerid, chek_cartrack[i][0],chek_cartrack[i][1],chek_cartrack[i][2]) && PLAYER_DATA[playerid][data_CT_VEH] == car)
			{

			    if(i == sizeof(chek_cartrack)-1)
				{
				    if(PLAYER_DATA[playerid][data_CHEK] == TRACK_KRUG)
				    {
						SetPlayerRaceCheckpoint(playerid, 1, chek_cartrack[0][0],chek_cartrack[0][1],chek_cartrack[0][2],chek_cartrack[0][3],chek_cartrack[0][4],chek_cartrack[0][5], 15.0);
					}
					else
					{
					    SetPlayerRaceCheckpoint(playerid, 0, chek_cartrack[0][0],chek_cartrack[0][1],chek_cartrack[0][2],chek_cartrack[0][3],chek_cartrack[0][4],chek_cartrack[0][5], 15.0);
					}
					return true;
				}

				if(i == 0)
				{
					if(PLAYER_DATA[playerid][data_CHEK] == TRACK_KRUG)
					{
					    for(new g = 0; g < 10; g++)
					    {
							if(CT_DATA[g][data_STATUS] == 0)
							{
								if(g == 0)
								{
								    give_player_money(playerid, 30000, "#81");
									SendClientMessage(playerid, 0xFFCC00FF, "Поздравляем! Вы заняли первое место!");
								}
								if(g == 1)
								{
								    give_player_money(playerid, 20000, "#81");
									SendClientMessage(playerid, 0xFFCC00FF, "Поздравляем! Вы заняли второе место!");
								}
								if(g == 2)
								{
								    give_player_money(playerid, 10000, "#81");
									SendClientMessage(playerid, 0xFFCC00FF, "Поздравляем! Вы заняли третье место!");
								}
								CT_DATA[g][data_STATUS] = 1;
								strmid(CT_DATA[g][data_NAME], PLAYER_DATA[playerid][data_NAME], 0, 24, 24);
						        break;
							}
					    }
					    DestroyVehicle(PLAYER_DATA[playerid][data_CT_VEH]);
						PLAYER_DATA[playerid][data_CT_VEH] = INVALID_VEHICLE_ID;
						PLAYER_DATA[playerid][data_CT_NUMBER] = 0;
						SetPlayerPosAC(playerid, -1503.6699,1609.8861,36.5690);
						DisablePlayerRaceCheckpoint(playerid);
						SendClientMessage(playerid, 0xFFCC00FF, "Гонка завершена");
					}
					else
					{
					    new str[12];
					    PLAYER_DATA[playerid][data_CHEK]++;
					    format(str,sizeof(str),"~w~%d/%d",PLAYER_DATA[playerid][data_CHEK],TRACK_KRUG);
			         	GameTextForPlayer(playerid, str, 3000, 6);
						SetPlayerRaceCheckpoint(playerid, 0, chek_cartrack[i+1][0],chek_cartrack[i+1][1],chek_cartrack[i+1][2],chek_cartrack[i+1][3],chek_cartrack[i+1][4],chek_cartrack[i+1][5], 15.0);
					}
					return true;
				}

			    SetPlayerRaceCheckpoint(playerid, 0, chek_cartrack[i+1][0],chek_cartrack[i+1][1],chek_cartrack[i+1][2],chek_cartrack[i+1][3],chek_cartrack[i+1][4],chek_cartrack[i+1][5], 15.0);
                //PLAYER_DATA[playerid][data_CHEK]++;
			}
		}
	}
    if(PLAYER_DATA[playerid][data_ASH_TEST] == 1)
	{
	    for(new i = 0; i < sizeof(ash_pos);i++)
	    {
	        if(PlayerToPoint(5.0, playerid, ash_pos[i][0],ash_pos[i][1],ash_pos[i][2]) && PLAYER_DATA[playerid][data_ASH_CAR] == car)
			{
			    if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
				{
					if(i == sizeof(ash_pos)-2)
					{
					    PLAYER_DATA[playerid][data_CHEK] = 1;
					 	SetPlayerRaceCheckpoint(playerid, 1, ash_pos[i+1][0],ash_pos[i+1][1],ash_pos[i+1][2],ash_pos[i+1][3],ash_pos[i+1][4],ash_pos[i+1][5], 5.0);
						return true;
					}
	 				if(i == sizeof(ash_pos)-1)
	 				{
	 				    PLAYER_DATA[playerid][data_LICB] = 1;
	 				    PLAYER_DATA[playerid][data_ASH_CAR] = INVALID_VEHICLE_ID;
	 				    PLAYER_DATA[playerid][data_ASH_TEST] = 0;
	 				    CAR_DATA[car][data_RENT] = INVALID_PLAYER_ID;
	 				    DisablePlayerRaceCheckpoint(playerid);
						SendClientMessage(playerid,0x66CC33FF,"Поздравляем! Вы получили водительское удостоверение");
						SetVehicleToRespawn(car);
						return true;
	 				}

	 				if(PLAYER_DATA[playerid][data_CHEK] == 0) return SetPlayerRaceCheckpoint(playerid, 0, ash_pos[i+1][0],ash_pos[i+1][1],ash_pos[i+1][2],ash_pos[i+1][3],ash_pos[i+1][4],ash_pos[i+1][5], 5.0);
				}
			}
	    }
	}
	return true;
}

