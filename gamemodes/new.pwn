stock ClearCarData(car)
{
	CAR_DATA[car][data_LOCK] = 0;
	CAR_DATA[car][data_ENG] = 0;
	CAR_DATA[car][data_LAMP] = 0;
	CAR_DATA[car][data_ASH_TEST] = INVALID_PLAYER_ID;
	CAR_DATA[car][data_RENT] = INVALID_PLAYER_ID;
	CAR_DATA[car][data_RENT_A] = INVALID_PLAYER_ID;
	CAR_DATA[car][data_RENT_B] = INVALID_PLAYER_ID;
	CAR_DATA[car][data_RENT_C] = INVALID_PLAYER_ID;
	CAR_DATA[car][data_KOLVO] = 0;
	CAR_DATA[car][data_GRUZ] = 0;
	CAR_DATA[car][data_PATR] = 0;
	CAR_DATA[car][data_MET] = 0;
	CAR_DATA[car][data_LIMIT] = 0;
	//CAR_DATA[car][data_CREATE] = 0;
	return true;
}

stock SaveCarData(car)
{
    new c = CAR_DATA[car][data_ID]
	PLAYER_DATA[playerid][data_CARFUEL][c] = CAR_DATA[car][data_FUEL];
	return true;
}


stock ShowStats(playerid)
{
	new sex_text[28], polit_stat[25],podfrak[26],sctring[950], voen[25], str[456],ordata_TEXT[30],number_text[22],hous[20],kvs[30],kkvs[30],bis[30],abis[30],jbis[35],status[30];
	switch(PLAYER_DATA[playerid][data_POLIT])
	{
	    case 0: polit_stat = "{1fa1ea}Нет";
	    default: polit_stat = "{1fa1ea}Есть";
	}
	switch(PLAYER_DATA[playerid][data_NUMBER])
	{
	    case 0: number_text = "{1fa1ea}Нет";
	    default: format(number_text,sizeof(number_text),"{1fa1ea}%d",PLAYER_DATA[playerid][data_NUMBER]);
	}
	switch(PLAYER_DATA[playerid][data_LVL])
	{
		case 1..3: status = "{1fa1ea}Новичок";
		case 4..9: status = "{1fa1ea}Освоившийся";
		default: status = "{1fa1ea}Опытный";

	}

	switch(PLAYER_DATA[playerid][data_PADIK])
	{
		case INVALID_KV_ID: kvs = "{1fa1ea}Нет";
		default: format(kvs,sizeof(kvs),"{1fa1ea}№%d",PLAYER_DATA[playerid][data_PADIK]+1);
	}

	switch(PLAYER_DATA[playerid][data_KV])
	{
		case INVALID_KV_ID: kkvs = "{1fa1ea}Нет";
		default: format(kkvs,sizeof(kkvs),"{1fa1ea}№%d",PLAYER_DATA[playerid][data_KV]+1);
	}

	switch(PLAYER_DATA[playerid][data_HOUSE])
	{
		case INVALID_HOUSE_ID: hous = "{1fa1ea}Нет";
		default: format(hous,sizeof(hous),"{1fa1ea}№%d",PLAYER_DATA[playerid][data_HOUSE]+1);
	}
	switch(PLAYER_DATA[playerid][data_BUSINESS])
	{
		case INVALID_BUSINESS_ID: bis = "{1fa1ea}Нет";
		default: format(bis,sizeof(bis),"{1fa1ea}№%d",PLAYER_DATA[playerid][data_BUSINESS]+1);
	}

	switch(PLAYER_DATA[playerid][data_AB])
	{
		case INVALID_AB_ID: abis = "{1fa1ea}Нет";
		case 0: format(abis,sizeof(abis),"{1fa1ea}'Колесо'");
		case 1: format(abis,sizeof(abis),"{1fa1ea}'Навигатор'");
	}
	switch(PLAYER_DATA[playerid][data_JB])
	{
		case INVALID_JB_ID: jbis = "{1fa1ea}Нет";
		case 0: format(jbis,sizeof(jbis),"{1fa1ea}ООО 'Пиломатериалы'");
		case 1: format(jbis,sizeof(jbis),"{1fa1ea}ООО 'Рудник'");
		case 2: format(jbis,sizeof(jbis),"{1fa1ea}ООО 'Сад'");
		case 3: format(jbis,sizeof(jbis),"{1fa1ea}ООО 'Огород'");
	}


	switch(PLAYER_DATA[playerid][data_MEMBER])
	{
	    case 0: ordata_TEXT = "{1fa1ea}Нет";
		case 1: ordata_TEXT = "{1fa1ea}Администрация Области";
		case 2: ordata_TEXT = "{1fa1ea}ВДВ";
		case 3: ordata_TEXT = "{1fa1ea}Полиция";
		case 4: ordata_TEXT = "{1fa1ea}Больница";
		case 5: ordata_TEXT = "{1fa1ea}Трамповское ОПГ";
		case 6: ordata_TEXT = "{1fa1ea}Майкопское ОПГ";
		case 7: ordata_TEXT = "{1fa1ea}Одесское ОПГ";
		case 8: ordata_TEXT = "{1fa1ea}ФСБ";
		case 9: ordata_TEXT = "{1fa1ea}СМИ";
	}
	switch(PLAYER_DATA[playerid][data_PODMEMBER])
	{
	    case 0: podfrak = "{1fa1ea}ППС";
		case 1: podfrak = "{1fa1ea}ОМОН";
	}
	switch(PLAYER_DATA[playerid][data_MILITARY])
	{
		case 0: voen = "{1fa1ea}Нет";
		case 1: voen = "{1fa1ea}Есть";
	}
	switch(PLAYER_DATA[playerid][data_SEX])
	{
		case 1: sex_text = "{1fa1ea}Мужской";
		case 2: sex_text = "{1fa1ea}Женский";
	}
	new nextlvl = PLAYER_DATA[playerid][data_LVL]+1;
	new nextexp = nextlvl*4;
	format(str,sizeof(str),"{FFFFFF}Номер аккаунта:\t\t{1fa1ea}%d\n",PLAYER_DATA[playerid][data_ID]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Имя:\t\t\t\t{1fa1ea}%s\n",PLAYER_DATA[playerid][data_NAME]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Уровень:\t\t\t{1fa1ea}%d\n",PLAYER_DATA[playerid][data_LVL]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Очки опыта:\t\t\t{1fa1ea}%d из %d\n",PLAYER_DATA[playerid][data_EXP], nextexp);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Номер телефона:\t\t%s\n",number_text);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}На счету телефона:\t\t{1fa1ea}%d рублей\n",PLAYER_DATA[playerid][data_NUMBER_M]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Уровень розыска:\t\t{1fa1ea}%d\n",PLAYER_DATA[playerid][data_WANTED]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Законопослушность:\t\t{1fa1ea}%d\n",PLAYER_DATA[playerid][data_ZAKON]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Военный билет:\t\t%s\n", voen);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Пол:\t\t\t\t%s\n\n",sex_text);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Организация:\t\t\t%s{FFFFFF}\n",ordata_TEXT);
	strcat(sctring,str);
	if(PLAYER_DATA[playerid][data_MEMBER] == 3)
	{
		format(str,sizeof(str),"{FFFFFF}Подразделение:\t\t%s\n", podfrak);
		strcat(sctring,str);
	}
	switch(PLAYER_DATA[playerid][data_MEMBER])
 	{
 	    case 0:format(str,sizeof(str),"Должность:\t\t\t{1fa1ea}Нет\n"),strcat(sctring,str);
 	    case 1:format(str,sizeof(str),"Должность:\t\t\t{1fa1ea}%s\n",rang_gov[PLAYER_DATA[playerid][data_RANK]-1][frName]),strcat(sctring,str);
		case 2:format(str,sizeof(str),"Звание:\t\t\t{1fa1ea}%s\n",rang_army[PLAYER_DATA[playerid][data_RANK]-1][frName]),strcat(sctring,str);
		case 3:format(str,sizeof(str),"Звание:\t\t\t{1fa1ea}%s\n",rang_police[PLAYER_DATA[playerid][data_RANK]-1][frName]),strcat(sctring,str);
		case 4:format(str,sizeof(str),"Должность:\t\t\t{1fa1ea}%s\n",rang_hospital[PLAYER_DATA[playerid][data_RANK]-1][frName]),strcat(sctring,str);
	    case 5,6,7:format(str,sizeof(str),"Масть:\t\t\t\t{1fa1ea}%s\n",rang_crime[PLAYER_DATA[playerid][data_RANK]-1][frName]),strcat(sctring,str);
        case 8:format(str,sizeof(str),"Звание:\t\t\t{1fa1ea}%s\n",rang_fsb[PLAYER_DATA[playerid][data_RANK]-1][frName]),strcat(sctring,str);
        case 9:format(str,sizeof(str),"Должность:\t\t\t{1fa1ea}%s\n",rang_smi[PLAYER_DATA[playerid][data_RANK]-1][frName]),strcat(sctring,str);
	}
	format(str,sizeof(str),"{FFFFFF}Ранг:\t\t\t\t{1fa1ea}%d\n\n",PLAYER_DATA[playerid][data_RANK]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Металла:\t\t\t{1fa1ea}%d\n",PLAYER_DATA[playerid][data_MET]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Патронов:\t\t\t{1fa1ea}%d\n",PLAYER_DATA[playerid][data_PATR]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Наркотиков:\t\t\t{1fa1ea}%d\n\n",PLAYER_DATA[playerid][data_DRUGS]);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Семья:\t\t%s\n\n",polit_stat);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Дом:\t\t\t\t%s\n",hous);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Подъезд:\t\t\t%s\n",kvs);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Квартира:\t\t\t%s\n",kkvs);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Бизнес:\t\t\t%s\n",bis);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Автобаза:\t\t\t%s\n",abis);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Предприятие:\t\t\t%s\n\n",jbis);
	strcat(sctring,str);
	format(str,sizeof(str),"{FFFFFF}Игровой статус:\t\t%s\n\n",status);
	strcat(sctring,str);
	format(str,sizeof(str),"{66CC66}Сытость:\t\t\t%d\n",PLAYER_DATA[playerid][data_SATIETY]);
	strcat(sctring,str);
	format(str,sizeof(str),"{66CC66}Жажда:\t\t\t\t%d\n",PLAYER_DATA[playerid][data_DRINK]);
	strcat(sctring,str);
	ShowPlayerDialogFix(playerid,dialog_OK ,DIALOG_STYLE_MSGBOX,"{FF6633}Статистика", sctring, "Закрыть","");
	return true;
}


stock SendFractionMessage(fraction,color, text[])
{
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		if(PLAYER_DATA[i][data_MEMBER] == fraction) SendClientMessage(i, color, text);
	}
}

stock SendPolitMessage(fraction,color, text[])
{
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		if(PLAYER_DATA[i][data_POLIT] == fraction) SendClientMessage(i, color, text);
	}
}


