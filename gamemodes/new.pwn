stock TDS(Slashes,Points)
{
	new string[149];
	new Slash[2] = "|";
	new Point[2] = ".";
	for(new i = 0; i < Slashes; i++) strcat(string, Slash);
	for(new i = 0; i < Points; i++) strcat(string, Point);
    return string;
}


