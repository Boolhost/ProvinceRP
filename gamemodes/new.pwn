CMD:members(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MEMBER] == 0) return  SendClientMessage(playerid,COLOR_WARNING,"Вы не состоите во организации!");
	new string[1024];
    for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i)) continue;
        if(PLAYER_DATA[i][data_MEMBER] == PLAYER_DATA[playerid][data_MEMBER])
        {
            if(PLAYER_DATA[i][data_AFK] > 2)
            {
	            switch(PLAYER_DATA[i][data_MEMBER])
	 		    {
	 		        case 1: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s {FF3333}[AFK: %d]\n",string,PLAYER_DATA[i][data_NAME],i,rang_gov[PLAYER_DATA[i][data_RANK]-1][frName],PLAYER_DATA[i][data_AFK]);
	 		        case 2: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s {FF3333}[AFK: %d]\n",string,PLAYER_DATA[i][data_NAME],i,rang_army[PLAYER_DATA[i][data_RANK]-1][frName],PLAYER_DATA[i][data_AFK]);
					case 3: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s {FF3333}[AFK: %d]\n",string,PLAYER_DATA[i][data_NAME],i,rang_police[PLAYER_DATA[i][data_RANK]-1][frName],PLAYER_DATA[i][data_AFK]);
			 		case 4: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s {FF3333}[AFK: %d]\n",string,PLAYER_DATA[i][data_NAME],i,rang_hospital[PLAYER_DATA[i][data_RANK]-1][frName],PLAYER_DATA[i][data_AFK]);
	 		        case 5,6,7: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s {FF3333}[AFK: %d]\n",string,PLAYER_DATA[i][data_NAME],i,rang_crime[PLAYER_DATA[i][data_RANK]-1][frName],PLAYER_DATA[i][data_AFK]);
					case 8: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s {FF3333}[AFK: %d]\n",string,PLAYER_DATA[i][data_NAME],i,rang_fsb[PLAYER_DATA[i][data_RANK]-1][frName],PLAYER_DATA[i][data_AFK]);
					case 9: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s {FF3333}[AFK: %d]\n",string,PLAYER_DATA[i][data_NAME],i,rang_smi[PLAYER_DATA[i][data_RANK]-1][frName],PLAYER_DATA[i][data_AFK]);
	 		    }
 		    }
 		    else
 		    {
 		        switch(PLAYER_DATA[i][data_MEMBER])
	 		    {
	 		        case 1: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s\n",string,PLAYER_DATA[i][data_NAME],i,rang_gov[PLAYER_DATA[i][data_RANK]-1][frName]);
	 		        case 2: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s\n",string,PLAYER_DATA[i][data_NAME],i,rang_army[PLAYER_DATA[i][data_RANK]-1][frName]);
					case 3: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s\n",string,PLAYER_DATA[i][data_NAME],i,rang_police[PLAYER_DATA[i][data_RANK]-1][frName]);
			 		case 4: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s\n",string,PLAYER_DATA[i][data_NAME],i,rang_hospital[PLAYER_DATA[i][data_RANK]-1][frName]);
	 		        case 5,6,7: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s\n",string,PLAYER_DATA[i][data_NAME],i,rang_crime[PLAYER_DATA[i][data_RANK]-1][frName]);
					case 8: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s\n",string,PLAYER_DATA[i][data_NAME],i,rang_fsb[PLAYER_DATA[i][data_RANK]-1][frName]);
					case 9: format(string,sizeof(string),"%s{FFFFFF}%s[%d] - %s\n",string,PLAYER_DATA[i][data_NAME],i,rang_smi[PLAYER_DATA[i][data_RANK]-1][frName]);
	 		    }
 		    }
        }
    }
    ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Члены фракции онлайн", string, "Закрыть", "");
	return true;
}


CMD:offmember(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_LEADER] == 0) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
	if(sscanf(params, "s[24]", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /offmember [имя]");
	new query[70];
 	mysql_format(dbHandle,query, sizeof(query), "SELECT * FROM `accounts` WHERE `name` = '%e'",params[0]);
 	mysql_function_query(dbHandle, query, true, "OffMember", "is", playerid, params[0]);
	return true;
}

CMD:allmembers(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_LEADER] == 0) return SendClientMessage(playerid,COLOR_WARNING, "Вам недоступна данная команда!");
	new query[70];
	mysql_format(dbHandle,query,sizeof(query),"SELECT * FROM `accounts` WHERE `member` = '%d'",PLAYER_DATA[playerid][data_MEMBER]);
	mysql_function_query(dbHandle, query, true, "LoadAllMembers", "d", playerid);
	return true;
}

CMD:leaders(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	new string[512],bugfix;
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
		new ltext[64];
		if(PLAYER_DATA[i][data_LEADER] != 0)
		{
			switch(PLAYER_DATA[i][data_LEADER])
			{
				case 1: ltext = "Администрация Области";
				case 2: ltext = "ВДВ";
				case 3: ltext = "Полиция";
				case 4: ltext = "Больница";
				case 5: ltext = "Трамповское ОПГ";
				case 6: ltext = "Майкопское ОПГ";
				case 7: ltext = "Одесское ОПГ";
				case 8: ltext = "ФСБ";
				case 9: ltext = "СМИ";
			}
			format(string,sizeof(string),"%s{FFFFFF}%s: %s (%d)\n",string,ltext,PLAYER_DATA[i][data_NAME],PLAYER_DATA[i][data_NUMBER]);
			bugfix = 1;
		}
	}
	if(bugfix == 0) ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Лидеры онлайн", "В данный момент лидеров на сервере нет", "Закрыть", "");
	else ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Лидеры онлайн", string, "Закрыть", "");
	return true;
}

CMD:id(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(sscanf(params, "s[24]", params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /id [имя]");
    new count,ggwp;

	if(ggwp == 10) return true;
    for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i)) continue;
        if(strfind(PLAYER_DATA[i][data_NAME], params[0], true) != -1)
        {
            new string[MAX_PLAYER_NAME+5];
        	format(string,sizeof(string),"%s[%d]",PLAYER_DATA[i][data_NAME], i);
        	SendClientMessage(playerid, -1, string);
        	count++;
			ggwp++;

			if(ggwp == 10) return SendClientMessage(playerid, 0xFFCC00FF, "Первые 10 игроков с похожим ником");
        }
    }
    if(count == 0) return SendClientMessage(playerid, COLOR_WARNING, "Игроков с похожим ником нет на сервере!");
    return true;
}

CMD:pos(playerid)
{
	new Float:x,Float:y,Float:z,Float:a;
	GetPlayerFacingAngle(playerid,a);
	GetPlayerPos(playerid,x,y,z);
	printf("%f, %f, %f, %f",x,y,z,a);
	SendClientMessage(playerid,-1, "yes");


	return true;
}


CMD:vpos(playerid)
{
	if(IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	{

	    new currentveh = GetPlayerVehicleID(playerid),Float:vehx, Float:vehy, Float:vehz, Float:z_rot;
	    new model = GetVehicleModel(currentveh);
      	GetVehiclePos(currentveh, vehx, vehy, vehz);
   	 	GetVehicleZAngle(currentveh, z_rot);
      	printf("%d, %f, %f, %f, %f, -1, -1, 600",model,vehx,vehy,vehz, z_rot);
      	SendClientMessage(playerid,-1, "yes");
	}
	return true;
}

CMD:addbusiness(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	ShowPlayerDialogFix(playerid, dialog_ADD_BUSINESS, DIALOG_STYLE_LIST, "{FFCC00}Добавление бизнеса",
	"{1fa1ea}1.{FFFFFF}Магазин 24/7\n\
	{1fa1ea}2.{FFFFFF}Заправка\n\
	{1fa1ea}3.{FFFFFF}Магазин одежды\n\
	{1fa1ea}4.{FFFFFF}Оружейный магазин\n\
	{1fa1ea}5.{FFFFFF}Закусочная\n\
	{1fa1ea}6.{FFFFFF}СТО", "Выбрать", "Отмена");
	return true;
}

CMD:addkv(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	ShowPlayerDialogFix(playerid,dialog_ADD_KV,DIALOG_STYLE_MSGBOX,"{FFCC00}Добавление подъезда","{FFFFFF}Вы желаете добавить подъезд?","Да","Отмена");
	return true;
}

CMD:tpc(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(GetPVarInt(playerid, "addkv") == 0 && GetPVarInt(playerid, "addhouse") == 0) return SendClientMessage(playerid,COLOR_WARNING,"Вы не начали добавлять Дом или Подъезд!");
	if(IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	{
	    new currentveh = GetPlayerVehicleID(playerid),Float:vehx, Float:vehy, Float:vehz, Float:z_rot;
      	GetVehiclePos(currentveh, vehx, vehy, vehz);
   	 	GetVehicleZAngle(currentveh, z_rot);
      	SetPVarFloat(playerid,"aCarX",vehx);
      	SetPVarFloat(playerid,"aCarY",vehy);
      	SetPVarFloat(playerid,"aCarZ",vehz);
      	SetPVarFloat(playerid,"aCarAngle",z_rot);
      	DestroyVehicle(currentveh);
      	if(GetPVarInt(playerid, "addkv") == 1)
		{
      		SendClientMessage(playerid,-1, "Встаньте на место, где будет находиться Подъезд и введите /tpkv");
		}
        if(GetPVarInt(playerid, "addhouse") == 1)
		{
      		SendClientMessage(playerid,-1, "Встаньте на место, где будет находиться Дом и введите /tph");
		}
	}
	return true;
}

CMD:free(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MEMBER] == 1 && PLAYER_DATA[playerid][data_RANK] == 4)
	{
    	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /free [ид]");
    	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
		if(PLAYER_DATA[params[0]][data_LOGGED] == false) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
		new Float:x,Float:y,Float:z;
		GetPlayerPos(params[0],x,y,z);
		if(!PlayerToPoint(10.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Вы находитесь далеко от данного игрока!");
		if(PLAYER_DATA[params[0]][data_JAIL] == 0) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не находится в тюрьме!");
		switch(PLAYER_DATA[params[0]][data_JAILTIME])
		{
			case 0..600: SetPVarInt(params[0],"free_money",1000);
			case 601..1200: SetPVarInt(params[0],"free_money",2500);
			case 1201..1800: SetPVarInt(params[0],"free_money",5000);
			case 1801..3600: SetPVarInt(params[0],"free_money",10000);
		}
		SetPVarInt(params[0], "yesno_free", 1);
	    SetPVarInt(params[0], "yesno_playerid", playerid);
	    SetPVarInt(params[0], "yesno", 1);
		new str1[145], str2[145];
		format(str1,sizeof(str1),"{1fa1ea}Вы предложили выйти из тюрьмы игроку %s за %d рублей",PLAYER_DATA[params[0]][data_NAME],GetPVarInt(params[0],"free_money"));
		SendClientMessage(playerid, 0xFF66CCFF, str1);
		format(str2,sizeof(str2),"{1fa1ea}Адвокат %s предложил Вам выйти из тюрьмы за %d рублей. Для согласия {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME],GetPVarInt(params[0],"free_money"));
		SendClientMessage(params[0], 0xFF66CCFF, str2);
    }
    else SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
	return true;
}

CMD:licsell(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MEMBER] == 1 && PLAYER_DATA[playerid][data_RANK] == 3)
	{
		if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /licsell [id] [1 - водительские права, 2 - лицензия на оружие]");
		if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
		if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
		if(params[1] < 1 || params[1] > 2) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /licsell [id] [1 - водительские права, 2 - лицензия на оружие]");
		new Float:x,Float:y,Float:z;
		GetPlayerPos(params[0],x,y,z);
		if(!PlayerToPoint(10.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок далеко от Вас!");
		if(GetPVarInt(params[0],"yesno") == 1) return SendClientMessage(playerid,COLOR_WARNING,"Игроку уже поступило предложение!");
		if(params[1] == 1)
		{
			if(PLAYER_DATA[params[0]][data_LICB] == 1) return SendClientMessage(playerid, COLOR_WARNING, "У игрока уже есть водительские права!");
			new str1[145], str2[145];
			format(str1,sizeof(str1),"{1fa1ea}Вы предложили купить водительские права игроку %s за 5000 рублей",PLAYER_DATA[params[0]][data_NAME]);
			SendClientMessage(playerid, 0xFF66CCFF, str1);
			format(str2,sizeof(str2),"{1fa1ea}%s предложил Вам купить водительские права за 5000 рублей. Для согласия {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME]);
			SendClientMessage(params[0], 0xFF66CCFF, str2);
		}
		else
		{
		    if(PLAYER_DATA[params[0]][data_LICG] == 1) return SendClientMessage(playerid, COLOR_WARNING, "У игрока уже есть лицензия на оружие!");
			new str1[145], str2[145];
			format(str1,sizeof(str1),"{1fa1ea}Вы предложили купить лицензию на оружие игроку %s за 30000 рублей",PLAYER_DATA[params[0]][data_NAME]);
			SendClientMessage(playerid, 0xFF66CCFF, str1);
			format(str2,sizeof(str2),"{1fa1ea}%s предложил Вам купить лицензию на оружие за 30000 рублей. Для согласия {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME]);
			SendClientMessage(params[0], 0xFF66CCFF, str2);
		}
	    SetPVarInt(params[0], "yesno_licsell", 1);
	    SetPVarInt(params[0], "licsell", params[1]);
	    SetPVarInt(params[0], "yesno_playerid", playerid);
	    SetPVarInt(params[0], "yesno", 1);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Вам недоступна данная команда!");
	return true;
}

CMD:tpkv(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED]== false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(GetPVarInt(playerid, "addkv") == 0) return SendClientMessage(playerid,COLOR_WARNING,"Вы не начали добавлять подъезд!");
	new Float:x, Float:y, Float:z;
	GetPlayerPos(playerid, x, y, z);
	SetPVarFloat(playerid,"aEnterX",x);
	SetPVarFloat(playerid,"aEnterY",y);
	SetPVarFloat(playerid,"aEnterZ",z);

	addkv(playerid);
	return true;
}

CMD:house(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_HOUSE] == INVALID_HOUSE_ID && PLAYER_DATA[playerid][data_KV] == INVALID_KV_ID) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет недвижимости!");


	if(PLAYER_DATA[playerid][data_HOUSE] != INVALID_HOUSE_ID)
	{
		ShowPlayerDialogFix(playerid, dialog_HOUSE, DIALOG_STYLE_LIST, "{FFCC00}Дом",
		"{1fa1ea}1.{FFFFFF}Информация\n\
		{1fa1ea}2.{FFFFFF}Открыть/закрыть дом\n\
		{1fa1ea}3.{FFFFFF}Продать дом", "Выбрать", "Отмена");
	}
	else
	{
	    ShowPlayerDialogFix(playerid, dialog_KV, DIALOG_STYLE_LIST, "{FFCC00}Квартира",
		"{1fa1ea}1.{FFFFFF}Информация\n\
		{1fa1ea}2.{FFFFFF}Открыть/закрыть квартиру\n\
		{1fa1ea}3.{FFFFFF}Продать квартиру", "Выбрать", "Отмена");
	}
	return true;
}

CMD:buy(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");


	for(new k = 0; k < 6; k++)
    {
        //new kv = GetPlayerVirtualWorld(playerid)-1;
        new kv = GetPVarInt(playerid, "padik");
        if(kv == -1) break;
        if(PlayerToPoint(1.0, playerid, KV_DATA[kv][data_ENTER_POSX][k], KV_DATA[kv][data_ENTER_POSY][k], KV_DATA[kv][data_ENTER_POSZ][k]))
        {

            if(PLAYER_DATA[playerid][data_KV] != INVALID_KV_ID || PLAYER_DATA[playerid][data_HOUSE] != INVALID_HOUSE_ID) return SendClientMessage(playerid,COLOR_WARNING,"У Вас уже есть недвижимость!");
            if(KV_DATA[kv][data_OWNED][k] == 1) return SendClientMessage(playerid,COLOR_WARNING,"У данной квартиры уже есть владелец!");
			if(get_player_money(playerid) < KV_DATA[kv][data_PRICE][k]) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");

			PLAYER_DATA[playerid][data_PADIK] = kv;
			PLAYER_DATA[playerid][data_KV] = k;
            KV_DATA[kv][data_OWNED][k] = 1;
            KV_DATA[kv][data_DAY][k] = 3;

            switch(k)
			{
				case 0: strmid(KV_DATA[kv][data_OWNER_1], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 1: strmid(KV_DATA[kv][data_OWNER_2], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 2: strmid(KV_DATA[kv][data_OWNER_3], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 3: strmid(KV_DATA[kv][data_OWNER_4], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 4: strmid(KV_DATA[kv][data_OWNER_5], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
				case 5: strmid(KV_DATA[kv][data_OWNER_6], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
			}

            give_player_money(playerid,-KV_DATA[kv][data_PRICE][k],"#72");
            SendClientMessage(playerid,0xFFCC33FF, "Поздравляем Вас с покупкой квартиры! Она была оплачена на 3 дня!");
            SendClientMessage(playerid,0xFFCC33FF, "Для управления квартирой используйте: /house");
            SendClientMessage(playerid, 0x9F81F7FF, "Используйте: /setspawn, чтобы изменить место появления");


            new logtext[64];
			format(logtext,sizeof(logtext),"купил квартиру №%d, подъезд ID:%d", k+1, KV_DATA[kv][data_ID]);
			LOG("log_player",PLAYER_DATA[playerid][data_NAME], logtext);


            UpdateKVData(kv,k);
            SaveKVData(kv);
           	SavePlayerData(playerid);
           	return true;
        }
    }

    for(new h = 0; h < TotalHouses; h++)
    {
        if(PlayerToPoint(3.0, playerid, HOUSE_DATA[h][data_ENTERX], HOUSE_DATA[h][data_ENTERY], HOUSE_DATA[h][data_ENTERZ]))
        {
            if(PLAYER_DATA[playerid][data_KV] != INVALID_KV_ID || PLAYER_DATA[playerid][data_HOUSE] != INVALID_HOUSE_ID) return SendClientMessage(playerid,COLOR_WARNING,"У Вас уже есть недвижимость!");
            if(HOUSE_DATA[h][data_OWNED] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Данный дом уже куплен!");
			if(get_player_money(playerid) < HOUSE_DATA[h][data_PRICE]) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");
			PLAYER_DATA[playerid][data_HOUSE] = h;
            HOUSE_DATA[h][data_OWNED] = 1;
            HOUSE_DATA[h][data_DAY] = 3;
            strmid(HOUSE_DATA[h][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
            give_player_money(playerid,-HOUSE_DATA[h][data_PRICE],"#73");
            SendClientMessage(playerid,0xFFCC33FF, "Поздравляем Вас с покупкой дома! Он был оплачен на 3 дня!");
            SendClientMessage(playerid,0xFFCC33FF, "Для управления домом используйте: /house");
            SendClientMessage(playerid, 0x9F81F7FF, "Используйте: /setspawn, чтобы изменить место появления");


            new logtext[64];
			format(logtext,sizeof(logtext),"купил дом ID:%d", HOUSE_DATA[h][data_ID]);
			LOG("log_player",PLAYER_DATA[playerid][data_NAME], logtext);

            UpdateHouseData(h);
            SaveHouseData(h);
           	SavePlayerData(playerid);
           	return true;
        }
    }

    for(new p = 0; p < TotalJB; p++)
    {
        if(PlayerToPoint(3.0, playerid, JB_DATA[p][data_INFO_POS][0], JB_DATA[p][data_INFO_POS][1], JB_DATA[p][data_INFO_POS][2]))
        {
            if(PLAYER_DATA[playerid][data_JB] != INVALID_JB_ID || PLAYER_DATA[playerid][data_BUSINESS] != INVALID_BUSINESS_ID || PLAYER_DATA[playerid][data_AB] != INVALID_AB_ID) return SendClientMessage(playerid,COLOR_WARNING,"У Вас уже есть бизнес!");
            if(JB_DATA[p][data_OWNED] == 1) return SendClientMessage(playerid,COLOR_WARNING,"У данного предприятия уже есть владелец!");
			if(get_player_money(playerid) < JB_DATA[p][data_PRICE]) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");

            PLAYER_DATA[playerid][data_JB] = p;
            JB_DATA[p][data_OWNED] = 1;
            JB_DATA[p][data_BANK] = 0;
            JB_DATA[p][data_SKLAD] = 0;
            strmid(JB_DATA[p][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
            give_player_money(playerid,-JB_DATA[p][data_PRICE],"#74");

            new str[145];
            format(str,sizeof(str),"Поздравляем с покупкой предприятия ООО '%s'",JB_DATA[p][data_NAME]);
            SendClientMessage(playerid,0xFFCC33FF, "Для управления предприятием используйте: /business");

            new logtext[64];
			format(logtext,sizeof(logtext),"купил предприятие ID:%d", JB_DATA[p][data_ID]);
			LOG("log_player",PLAYER_DATA[playerid][data_NAME], logtext);

            UpdateJBData(p);
            SaveJBData(p);
           	SavePlayerData(playerid);
           	return true;
        }
    }

    for(new p = 0; p < TotalAB; p++)
    {
        if(PlayerToPoint(3.0, playerid, AB_DATA[p][data_INFO_POS][0], AB_DATA[p][data_INFO_POS][1], AB_DATA[p][data_INFO_POS][2]))
        {
            if(PLAYER_DATA[playerid][data_JB] != INVALID_JB_ID || PLAYER_DATA[playerid][data_BUSINESS] != INVALID_BUSINESS_ID || PLAYER_DATA[playerid][data_AB] != INVALID_AB_ID) return SendClientMessage(playerid,COLOR_WARNING,"У Вас уже есть бизнес!");
            if(AB_DATA[p][data_OWNED] == 1) return SendClientMessage(playerid,COLOR_WARNING,"У данной автобазы уже есть владелец!");
			if(get_player_money(playerid) < AB_DATA[p][data_PRICE]) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");

            PLAYER_DATA[playerid][data_AB] = p;
            AB_DATA[p][data_OWNED] = 1;
            AB_DATA[p][data_BANK] = 0;
            strmid(AB_DATA[p][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
            give_player_money(playerid,-AB_DATA[p][data_PRICE],"#75");

            new logtext[64];
			format(logtext,sizeof(logtext),"купил автобазу ID:%d", AB_DATA[p][data_ID]);
			LOG("log_player",PLAYER_DATA[playerid][data_NAME], logtext);

            new str[145];
            format(str,sizeof(str),"Поздравляем с покупкой автобазы '%s'",AB_DATA[p][data_NAME]);
            SendClientMessage(playerid,0xFFCC33FF, "Для управления автобазой используйте: /business");

            UpdateABData(p);
            SaveABData(p);
           	SavePlayerData(playerid);
           	return true;
        }
    }


    for(new b = 0; b < TotalBusiness; b++)
    {
        if(PlayerToPoint(3.0, playerid, BUSINESS_DATA[b][data_ENTERX], BUSINESS_DATA[b][data_ENTERY], BUSINESS_DATA[b][data_ENTERZ]))
        {
            if(PLAYER_DATA[playerid][data_JB] != INVALID_JB_ID || PLAYER_DATA[playerid][data_BUSINESS] != INVALID_BUSINESS_ID || PLAYER_DATA[playerid][data_AB] != INVALID_AB_ID) return SendClientMessage(playerid,COLOR_WARNING,"У Вас уже есть бизнес!");
            if(BUSINESS_DATA[b][data_OWNED] == 1) SendClientMessage(playerid,COLOR_WARNING,"Данный бизнес уже куплен!");
			if(get_player_money(playerid) < BUSINESS_DATA[b][data_PRICE]) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");
			PLAYER_DATA[playerid][data_BUSINESS] = b;


			new logtext[64];
			format(logtext,sizeof(logtext),"купил бизнес ID:%d", BUSINESS_DATA[b][data_ID]);
			LOG("log_player",PLAYER_DATA[playerid][data_NAME], logtext);

			BUSINESS_DATA[b][data_BANK] = 0;
			BUSINESS_DATA[b][data_PROD] = 0;
            BUSINESS_DATA[b][data_OWNED] = 1;
            BUSINESS_DATA[b][data_DAY] = 3;
            strmid(BUSINESS_DATA[b][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), 24);
            give_player_money(playerid,-BUSINESS_DATA[b][data_PRICE],"#76");
            SendClientMessage(playerid,0xFFCC33FF, "Поздравляем Вас с покупкой бизнеса!	Он был оплачен на 3 дня");
            SendClientMessage(playerid,0xFFCC33FF, "Для управления бизнесом используйте: /business");
            UpdateBusinessData(b);
            SaveBusinessData(b);
           	SavePlayerData(playerid);
           	break;
        }
    }
    for(new g = 0; g < TotalGarages; g++)
	{
		if(IsPlayerInRangeOfPoint(playerid, 3.0, GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z]))
		{
			//if(GetPlayerGarage(playerid) != -1) return SendClientMessage(playerid, COLOR_WARNING, "У Вас уже имеется гараж");
			if(PLAYER_DATA[playerid][data_GR] != INVALID_GARAGE_ID ) return SendClientMessage(playerid, COLOR_WARNING, "У Вас уже имеется гараж!");
			//if(GARAGE_DATA[g][data_OWNED] != 0) return SendClientMessage(playerid, COLOR_WARNING, "Вы не можете приобрести уже купленный гараж!");
			if(GARAGE_DATA[g][data_OWNED] != 0) SendClientMessage(playerid,COLOR_WARNING,"Данный гараж уже куплен!");
			if(get_player_money(playerid) < GARAGE_DATA[g][data_PRICE]) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");

			new logtext[64];
			format(logtext,sizeof(logtext),"купил гараж ID:%d", GARAGE_DATA[g][data_ID]);
			LOG("log_player",PLAYER_DATA[playerid][data_NAME], logtext);

			GARAGE_DATA[g][data_OWNED] = 1;
			PLAYER_DATA[playerid][data_GR] = g;
			GARAGE_DATA[g][data_DAY] = 3;
			give_player_money(playerid,-GARAGE_DATA[g][data_PRICE],"#44");
			strmid(GARAGE_DATA[g][data_OWNER], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), 24);
			SendClientMessage(playerid,0xFFCC33FF, "Поздравляем Вас с покупкой гаража!	Он был оплачен на 3 дня");
            SendClientMessage(playerid,0xFFCC33FF, "Для управления гаражом используйте: /garage");
            SaveGarageData(g);
			UpdateGarageData(g);
			SavePlayerData(playerid);
			return true;
		}
	}

    return true;
}

CMD:bizinfo(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_BUSINESS] == INVALID_BUSINESS_ID && PLAYER_DATA[playerid][data_JB] == INVALID_JB_ID && PLAYER_DATA[playerid][data_AB] == INVALID_AB_ID) return SendClientMessage(playerid,COLOR_WARNING,"У Вас нет бизнеса!");


	if(PLAYER_DATA[playerid][data_JB] != INVALID_BUSINESS_ID)
	{
	    new dtext[512], b = PLAYER_DATA[playerid][data_JB];
	    format(dtext ,sizeof(dtext),
		"{1fa1ea}1.{FFFFFF}Статистика предприятия\n\
		{1fa1ea}2.{FFFFFF}Управление автопарком\n\
		{1fa1ea}3.{FFFFFF}Изменить зарплату рабочих ({66FF66}%d рублей{FFFFFF})\n\
		{1fa1ea}4.{FFFFFF}Изменить зарплату водителей ({66FF66}%d рублей{FFFFFF})\n\
		{1fa1ea}5.{FFFFFF}Изменить стоимость экспорта ресурсов\nСнять деньги со счета\n\
		{1fa1ea}6.{FFFFFF}Положить деньги на счет\n\
		{FF0033}Продать предприятие государству",JB_DATA[b][data_JOB_MONEY], JB_DATA[b][data_BUS_MONEY]);
	    ShowPlayerDialogFix(playerid, dialog_JB, DIALOG_STYLE_LIST, "{FFCC00}Предприятие", dtext, "Выбрать", "Отмена");

	}
	else if(PLAYER_DATA[playerid][data_AB] != INVALID_AB_ID)
	{
	    new dtext[512], b = PLAYER_DATA[playerid][data_AB];
	    format(dtext ,sizeof(dtext),
		"{1fa1ea}1.{FFFFFF}Статистика автобазы\n\
		{1fa1ea}2.{FFFFFF}Управление автопарком\n\
		{1fa1ea}3.{FFFFFF}Изменить процент зарплаты водителей ({66FF66}%d процентов{FFFFFF})\n\
		{1fa1ea}4.{FFFFFF}Снять деньги со счета\n\
		{1fa1ea}5.{FFFFFF}Положить деньги на счет\n\
		{FF0033}Продать автобазу государству",AB_DATA[b][data_PROCENT]);
	    ShowPlayerDialogFix(playerid, dialog_AB, DIALOG_STYLE_LIST, "{FFCC00}Автобаза", dtext, "Выбрать", "Отмена");
	}
	else if(PLAYER_DATA[playerid][data_BUSINESS] != INVALID_BUSINESS_ID)
	{
	    Business_Panel(playerid);
	}
	return true;
}

CMD:dhelp(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_START_JOB] != 6 && PLAYER_DATA[playerid][data_START_JOB] != 7) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
    ShowPlayerDialogFix(playerid, dialog_DHELP, DIALOG_STYLE_LIST, "{FFCC00}Помощь дальнобойщика",
	"{1fa1ea}1.{FFFFFF}Информация\n\
	{1fa1ea}2.{FFFFFF}Мониторинг\n\
	{1fa1ea}3.{FFFFFF}Команды\n\
	{1fa1ea}4.{FFFFFF}Навык\n\
	{1fa1ea}5.{FFFFFF}GPS", "Выбрать", "Отмена");
	return true;
}

CMD:untrailer(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_START_JOB] != 6 && PLAYER_DATA[playerid][data_START_JOB] != 7) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
	if(PLAYER_DATA[playerid][data_TRAILER] == INVALID_VEHICLE_ID) return SendClientMessage(playerid, COLOR_WARNING, "У Вас нет прицепа!");

    CAR_DATA[PLAYER_DATA[playerid][data_TRAILER]][data_GRUZ] = 0;
	CAR_DATA[PLAYER_DATA[playerid][data_TRAILER]][data_KOLVO] = 0;
    DestroyVehicle(PLAYER_DATA[playerid][data_TRAILER]);
    PLAYER_DATA[playerid][data_TRAILER] = INVALID_VEHICLE_ID;
    SendClientMessage(playerid, -1, "Вы отказались от аренды прицепа. Прицеп будет возвращен на место!");
	return true;
}

