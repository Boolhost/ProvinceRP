			if(GARAGE_DATA[g][data_TYPE] == 1)
			{
				if(GetPVarInt(playerid, "in_garage")) return SendClientMessage(playerid, COLOR_WARNING, "У Вас одноместный гараж и сейчас это место занято другим автомобилем. Уберите транспорт из гаража и повторите попытку..");
