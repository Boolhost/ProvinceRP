CMD:otvet(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 2) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params, "ii", params[0], params[1])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /otvet [id игрока] [id ответа]");
	if(params[1] <= 0 || params[1] >= 5) return SendClientMessage(playerid, COLOR_WARNING,"{FFFFFF} 1 - Приятной игры на Province RolePlay!"), SendClientMessage(playerid, COLOR_WARNING,"{FFFFFF} 2 - Начинаю работать по вашей жалобе!"),
	SendClientMessage(playerid, COLOR_WARNING,"{FFFFFF} 3 - Игрок наказан. Приятной игры!"), SendClientMessage(playerid, COLOR_WARNING,"{FFFFFF} 4 - Не вижу нарушений. Приятной игры!");
	new otvetik = params[1];
	//new otvetikk[128];
	new string[228];
	switch(otvetik)
	{
	    case 1:
		{
			format(string, sizeof(string), "[PM] Администратор %s[%d] для %s[%d]: {FFCC33}Приятной игры на Province RolePlay!", PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[params[0]][data_NAME],params[0]);
		    SendClientMessage(params[0], 0x3399FFFF, string);
		    SendAdminMessage(0x3399FFFF, string);
		}
		case 2:
		{
			format(string, sizeof(string), "[PM] Администратор %s[%d] для %s[%d]: {FFCC33}Начинаю работать по вашей жалобе!", PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[params[0]][data_NAME],params[0]);
		    SendClientMessage(params[0], 0x3399FFFF, string);
		    SendAdminMessage(0x3399FFFF, string);
		}
		case 3:
		{
			format(string, sizeof(string), "[PM] Администратор %s[%d] для %s[%d]: {FFCC33}Игрок наказан. Приятной игры!", PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[params[0]][data_NAME],params[0]);
		    SendClientMessage(params[0], 0x3399FFFF, string);
		    SendAdminMessage(0x3399FFFF, string);
		}
		case 4:
		{
			format(string, sizeof(string), "[PM] Администратор %s[%d] для %s[%d]: {FFCC33}Не вижу нарушений. Приятной игры!", PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[params[0]][data_NAME],params[0]);
		    SendClientMessage(params[0], 0x3399FFFF, string);
		    SendAdminMessage(0x3399FFFF, string);
		}
	}
	return 1;
}

CMD:setyoutuber(playerid, params[])
{
	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
	
	if(sscanf(params, "ii", params[0], params[1])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /setyoutuber [id игрока] [0 - снять, 1 - выдать]");

	if(params[1] >= 2 || params[1] < 0) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /setyoutuber [id игрока] [0 - снять, 1 - выдать]");
	if(params[1] == 1)
	{
		if(PLAYER_DATA[playerid][data_YT] == 1) return SendClientMessage(playerid, COLOR_WARNING, "У игрока уже есть ютуберка!");
		new string[128], str[128];
		format(string, sizeof(string), "Администратор %s выдал вам ютуберку. /ythelp - помощь для ютуберов", PLAYER_DATA[params[0]][data_NAME]);
		SendClientMessage(params[0], COLOR_WARNING, string);
		
		format(str,sizeof(str),"{808080}[A] %s выдал Ютуберку %s[%d]",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME], params[0]);
		SendAdminMessage(0x666699FF,str);
		PLAYER_DATA[params[0]][data_YT] = 1;
	}
	else if(params[1] == 0)
	{
		if(PLAYER_DATA[playerid][data_YT] == 0) return SendClientMessage(playerid, COLOR_WARNING, "У игрока нет ютуберки!");
		new string[128], str[128];
		format(string, sizeof(string), "Администратор %s забрал у вас ютуберку.", PLAYER_DATA[params[0]][data_NAME]);
		SendClientMessage(params[0], COLOR_WARNING, string);
		
		format(str,sizeof(str),"{808080}[A] %s забрал Ютуберку у %s[%d]",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME], params[0]);
		SendAdminMessage(0x666699FF,str);
		PLAYER_DATA[params[0]][data_YT] = 0;
	}
	return true;
}

