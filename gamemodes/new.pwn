public OnPlayerEnterDynamicCP(playerid,checkpointid)
{
    if(checkpointid == help_spawn)
	{
		ShowPlayerDialogFix(playerid, dialog_SPAWNHELP, DIALOG_STYLE_LIST, "{FFCC00}Помощь", "{1fa1ea}1.{FFFFFF}С чего начать играть?", "Выбрать", "Отмена");
		return true;
	}
	return true;
}

public OnPlayerDisconnect(playerid, reason)
{

    if(GetPVarInt(playerid,"PlayerCuffed") == 1 && PLAYER_DATA[playerid][data_WANTED] >= 1)
 	{
 	    PLAYER_DATA[playerid][data_JAIL] = 1;
		PLAYER_DATA[playerid][data_JAILTIME] = 3600;
		PLAYER_DATA[playerid][data_WANTED] = 0;
		new text[145];
		format(text,sizeof(text),"%s был посажен в кпз на 60 минут. Причина: выход при задержании",PLAYER_DATA[playerid][data_NAME]);
		SendClientMessageToAll(COLOR_AC,text);
 	}


    if(PLAYER_DATA[playerid][data_CT_VEH] != INVALID_VEHICLE_ID)
    {
	    DestroyVehicle(PLAYER_DATA[playerid][data_CT_VEH]);
		PLAYER_DATA[playerid][data_CT_VEH] = INVALID_VEHICLE_ID;
		PLAYER_DATA[playerid][data_CT_NUMBER] = 0;
	}

	if(PLAYER_DATA[playerid][data_OPENAUTOSALON] == true)
	{
 		DestroyVehicle(PLAYER_DATA[playerid][data_AUTOSALON_CAR]);
  		PLAYER_DATA[playerid][data_AUTOSALON_CAR] = INVALID_VEHICLE_ID;
		HideAutoSalonMenu(playerid);
	}

    for(new i = 0; i < 9; i++)
	{
	    if(CheatID[i] == playerid)
	    {
    		CheatID[i] = -1;
    		new str_0[4];
    		format(str_0, sizeof(str_0), "%d", CheatID[i]);
    		TextDrawSetString(CheatText[i], str_0);
	    }
	}

 	if(PLAYER_DATA[playerid][data_OPENCASINO] == true) KillTimer(casino_timer[playerid]);

	if(UseGPS[playerid])
	{
    	DisablePlayerRaceCheckpoint(playerid);
    	UseGPS[playerid] = false;
	}


	if(PLAYER_DATA[playerid][data_RENTJOB] != INVALID_VEHICLE_ID) SetVehicleToRespawn(PLAYER_DATA[playerid][data_RENTJOB]);
	if(PLAYER_DATA[playerid][data_RENTCAR] != INVALID_VEHICLE_ID) SetVehicleToRespawn(PLAYER_DATA[playerid][data_RENTCAR]);
	if(PLAYER_DATA[playerid][data_TRAILER] != INVALID_VEHICLE_ID) SetVehicleToRespawn(PLAYER_DATA[playerid][data_TRAILER]);
	if(PLAYER_DATA[playerid][data_VEH] != INVALID_VEHICLE_ID) DestroyVehicle(PLAYER_DATA[playerid][data_VEH]);

    KillTimer(PLAYER_DATA[playerid][data_PLAYER_TIMER_ID]);

    new szDisconnectReason[3][] =
    {
        "Timeout/Crash",
        "Quit",
        "Kick/Ban"
    };

    new str[MAX_PLAYER_NAME+75];
	format(str,sizeof(str),"[A] %s[%d] (%s) отключился от сервера (:%s)",PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[playerid][data_LOGIN_IP],szDisconnectReason[reason]);
	SendAdminMessage(0xF69266AA,str);

	if(GetPVarInt(playerid, "PriceTaxi") > 0)
	{
		//PI[playerid][pPayCheck] += GetPVarInt(playerid, "TaxiMoney");
		if(IsValidDynamic3DTextLabel(TaxiText3D[playerid])) DestroyDynamic3DTextLabel(TaxiText3D[playerid]);
		SetVehicleToRespawn(PLAYER_DATA[playerid][data_RENTJOB_TAXI]);
	}

    PLAYER_DATA[playerid][data_VW] = GetPlayerVirtualWorld(playerid);
	PLAYER_DATA[playerid][data_INT] = GetPlayerInterior(playerid);
    new Float:x,Float:y,Float:z;
	GetPlayerPos(playerid,x,y,z);
	PLAYER_DATA[playerid][data_POSX] = x;
	PLAYER_DATA[playerid][data_POSY] = y;
	PLAYER_DATA[playerid][data_POSZ] = z;


	SavePlayerData(playerid);
	return true;
}

public OnPlayerSpawn(playerid)
{

	//cef_create_browser(playerid, 0x12345, "Province-host.ru/gta-hud/hud.html", false, false);
	//cef_create_browser(playerid, 0x12346, "Province-host.ru/gta-not/not.html", false, false);
    // Пример:
    // cef_create_browser(playerid, 0x12345, "test.maza.ru/hud.html", false, false);

 	SetPVarInt(playerid,"K_Times",0);
    //if(GetPVarInt(playerid,"select_skin") == 1) return SELECT_skin(playerid);

    //PLAYER_DATA[playerid][data_START_JOB] = 0;
    SetPVarInt(playerid,"tovar",0);
    SetPVarInt(playerid,"tovar_all",0);
    SetPVarInt(playerid,"job_bus",0);
    SetPVarInt(playerid,"job_db",0);
    DisablePlayerCheckpoint(playerid);
    DisablePlayerRaceCheckpoint(playerid);
    PLAYER_DATA[playerid][data_PUTPATR] = 0;
    PLAYER_DATA[playerid][data_PUTMET] = 0;
    shield[playerid] = false;


    if(PLAYER_DATA[playerid][data_CT_VEH] != INVALID_VEHICLE_ID)
    {
	    DestroyVehicle(PLAYER_DATA[playerid][data_CT_VEH]);
		PLAYER_DATA[playerid][data_CT_VEH] = INVALID_VEHICLE_ID;
		PLAYER_DATA[playerid][data_CT_NUMBER] = 0;
	}

    if(PLAYER_DATA[playerid][data_RENTJOB] != INVALID_VEHICLE_ID) SetVehicleToRespawn(PLAYER_DATA[playerid][data_RENTJOB]);
	if(PLAYER_DATA[playerid][data_TRAILER] != INVALID_VEHICLE_ID) SetVehicleToRespawn(PLAYER_DATA[playerid][data_TRAILER]);

    if(PLAYER_DATA[playerid][data_CLOTHESMENU] == true)
	{
		TextDrawHideForPlayer(playerid, buy_clothes[0]);
		TextDrawHideForPlayer(playerid, buy_clothes[1]);
		TextDrawHideForPlayer(playerid, buy_clothes[2]);
		TextDrawHideForPlayer(playerid, buy_clothes[3]);
		TextDrawHideForPlayer(playerid, buy_clothes[4]);
		TextDrawHideForPlayer(playerid, buy_clothes[5]);
		PlayerTextDrawHide(playerid, buy_clothes_m[playerid]);
 		CancelSelectTextDraw(playerid);
 		PLAYER_DATA[playerid][data_CLICKTD] = false;
		PLAYER_DATA[playerid][data_CLOTHESMENU] = false;
	}

    if(PLAYER_DATA[playerid][data_OPENAUTOSALON] == true)
	{
 		DestroyVehicle(PLAYER_DATA[playerid][data_AUTOSALON_CAR]);
  		PLAYER_DATA[playerid][data_AUTOSALON_CAR] = INVALID_VEHICLE_ID;
		HideAutoSalonMenu(playerid);
	}


	if(PLAYER_DATA[playerid][data_OPENCASINO] == true)
	{
 		HideCasinoGame(playerid);
   		casino_stavka[playerid] = 0;
		casino_update[playerid] = 0;
		KillTimer(casino_timer[playerid]);
	}


    for(new i = 0; i < 13; i++)
	{
	    if(PLAYER_DATA[playerid][data_GUN][i] != 0 && PLAYER_DATA[playerid][data_AMMO][i] != 0) GivePlayerWeapon(playerid, PLAYER_DATA[playerid][data_GUN][i], PLAYER_DATA[playerid][data_AMMO][i]);
	}


	if(GetPVarInt(playerid,"spawn_ac") == 0)
    {
        InterpolateCameraPos(playerid, 2730.631591, -1627.925537, 95.828208, 2730.631591, -1627.925537, 95.828208, 1000);
		InterpolateCameraLookAt(playerid, 2727.819824, -1632.012084, 95.200065, 2727.819824, -1632.012084, 95.200065, 1000);

        new query[100+MAX_PLAYER_NAME];
		mysql_format(dbHandle,query, sizeof(query), "SELECT * FROM `accounts` WHERE `name` = '%e'", PLAYER_DATA[playerid][data_NAME]);
		mysql_function_query(dbHandle, query, true, "CheckAccount", "d", playerid);
		SelectTextDraw(playerid,0xddddddff);

		SendClientMessage(playerid,0x3399FF00,"Добро пожаловать на Province RolePlay");
    	if(X2DAY == true) SendClientMessage(playerid,0xFFCC0000,"На нашем сервере действует акция X2 DAY.");
    	if(X2DAY == true) SendClientMessage(playerid,0xFFCC0000,"Донат, зарплаты разнорабочих и опыт увеличиваются вдвое");
        if(X2DAY == true) SendClientMessage(playerid,0xFFCC0000,"Успей развится пока действует акция");
        TogglePlayerControllable(playerid, true);
		return true;
    }

 	SetPVarInt(playerid,"spawn_ac",0);

	SetPlayerSpawn(playerid);


	return true;
}

public OnPlayerDeath(playerid, killerid, reason)
{
    if(noclipdata[playerid][cameramode] == CAMERA_MODE_FLY) CancelFlyMode(playerid);


	if(PLAYER_DATA[playerid][data_JAIL] == 0)
	{
 		PLAYER_DATA[playerid][data_HOSPITAL] = 1;
	}

	PLAYER_DATA[playerid][data_HP] = 25;
    ResetWeaponAll(playerid);
    SetPVarInt(playerid,"spawn_ac",1);
    SetPVarInt(playerid,"K_Times",GetPVarInt(playerid,"K_Times") + 1);
    if(GetPVarInt(playerid,"K_Times") > 1) return AC_Kick(playerid, 4);
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return AC_Kick(playerid, 5);
	if(killerid == playerid) return BanEx(playerid, "Gay Kill");
	if(!IsPlayerConnected(killerid) && killerid != 65535) return BanEx(playerid, "Lol Kill");
	if(GetPVarInt(playerid,"open_speed") == 1) HideSpeedometr(playerid);

    if(playerid != 65535 && killerid != 65535)
 	{
		if(IsPlayerCops(killerid) && PLAYER_DATA[playerid][data_WANTED] != 0 && PLAYER_DATA[playerid][data_CS_TEAM] == 0)
		{
		    new str[145];
			format(str,sizeof(str),"[R] %s[%d] нейтрализовал преступника %s[%d]",PLAYER_DATA[killerid][data_NAME],killerid,PLAYER_DATA[playerid][data_NAME],playerid);
			SendFractionMessage(PLAYER_DATA[killerid][data_MEMBER],0x5882FAFF,str);
			PLAYER_DATA[playerid][data_JAIL] = 1;
	 		PLAYER_DATA[playerid][data_JAILTIME] = 600*PLAYER_DATA[playerid][data_WANTED];
	 		PLAYER_DATA[playerid][data_WANTED] = 0;
			UnfreezePlayer(playerid);
			SetPlayerWantedLevel(playerid,PLAYER_DATA[playerid][data_WANTED]);
			SetPlayerSpawn(playerid);
			SetPlayerSpecialAction(playerid, 0);
			RemovePlayerAttachedObject(playerid, 5);
			DeletePVar(playerid,"PlayerCuffed");
			SendClientMessage(playerid, COLOR_AC, "Вы арестованы!");
			give_player_money(killerid, 500,"#1");
		}
		else if(!IsPlayerCops(killerid) && PLAYER_DATA[killerid][data_MEMBER] != 2 && PLAYER_DATA[playerid][data_CS_TEAM] == 0)
		{
		    if(PLAYER_DATA[killerid][data_WANTED] < 6)
		    {
				PLAYER_DATA[killerid][data_WANTED]++;
				SetPlayerWantedLevel(killerid,PLAYER_DATA[killerid][data_WANTED]);
				new str1[145];
				format(str1,sizeof(str1),"[R] %s объявлен(а) в розыск. Жертва: %s. Причина: убийство. [%d/6]",PLAYER_DATA[killerid][data_NAME],PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[killerid][data_WANTED]);
				for(new i = 0; i < MAX_PLAYERS; i++)
				{
				    if(!IsPlayerConnected(i)) continue;
				    if(IsPlayerCops(i)) SendClientMessage(i,COLOR_AC,str1);
				}
				SendClientMessage(killerid,COLOR_AC,"Вы были объявлены в розыск. Причина: убийство");
				if(PLAYER_DATA[killerid][data_ZAKON] > 0) PLAYER_DATA[killerid][data_ZAKON]--;
			}
		}
	}


    if(UseGPS[playerid])
	{
    	DisablePlayerRaceCheckpoint(playerid);
    	UseGPS[playerid] = false;
	}

    if(IsCapture == true)
	{
		if(PLAYER_DATA[killerid][data_MEMBER] == capt_one_team && PLAYER_DATA[playerid][data_MEMBER] == capt_two_team) capt_one_kill++;
		if(PLAYER_DATA[killerid][data_MEMBER] == capt_two_team && PLAYER_DATA[playerid][data_MEMBER] == capt_one_team) capt_two_kill++;
	}
	return true;
}

public OnVehicleSpawn(vehicleid)
{

    if(CAR_DATA[vehicleid][data_RENT] != INVALID_PLAYER_ID)
	{
		new playerid = CAR_DATA[vehicleid][data_RENT];
		if(PLAYER_DATA[playerid][data_LOGGED] == true)
		{
			if(PLAYER_DATA[playerid][data_START_JOB] != 0 && GetPVarInt(playerid, "job_bus") != 0) DisablePlayerCheckpoint(playerid);

			PLAYER_DATA[playerid][data_RENTJOB] = INVALID_VEHICLE_ID;
			PLAYER_DATA[playerid][data_RENTCAR] = INVALID_VEHICLE_ID;
		    SendClientMessage(playerid,0xFF9966FF,"Вы потеряли свой транспорт");
		}
	}

    if(CAR_DATA[vehicleid][data_RENT_A] != INVALID_PLAYER_ID)
	{
		new playerid = CAR_DATA[vehicleid][data_RENT_A];
		if(PLAYER_DATA[playerid][data_LOGGED] == true)
		{
			PLAYER_DATA[playerid][data_RENTAUTO_A] = INVALID_VEHICLE_ID;
			SetPVarInt(playerid,"RENT_AUTO",0);
		    SendClientMessage(playerid,0xFF9966FF,"Арендная компания забрала транспорт из-за долгого отсутствие.");
		}
	}

	if(CAR_DATA[vehicleid][data_RENT_B] != INVALID_PLAYER_ID)
	{
		new playerid = CAR_DATA[vehicleid][data_RENT_B];
		if(PLAYER_DATA[playerid][data_LOGGED] == true)
		{
			PLAYER_DATA[playerid][data_RENTAUTO_B] = INVALID_VEHICLE_ID;
		    SendClientMessage(playerid,0xFF9966FF,"Арендная компания забрала транспорт из-за долгого отсутствие.");
		}
	}

    if(CAR_DATA[vehicleid][data_RENT_C] != INVALID_PLAYER_ID)
	{
		new playerid = CAR_DATA[vehicleid][data_RENT_C];
		if(PLAYER_DATA[playerid][data_LOGGED] == true)
		{
			PLAYER_DATA[playerid][data_RENTAUTO_C] = INVALID_VEHICLE_ID;
		    SendClientMessage(playerid,0xFF9966FF,"Арендная компания забрала транспорт из-за долгого отсутствие.");
		}
	}

	if(vehicleid >= ash_car[0] && vehicleid <= ash_car[1])
	{
		new playerid = CAR_DATA[vehicleid][data_ASH_TEST];
		if(playerid != INVALID_PLAYER_ID)
		{
			CAR_DATA[vehicleid][data_ASH_TEST] = INVALID_PLAYER_ID;

			if(PLAYER_DATA[playerid][data_RENTCAR] == vehicleid)
			{
				PLAYER_DATA[playerid][data_ASH_TEST] = 0;
				PLAYER_DATA[playerid][data_ASH_CAR] = INVALID_VEHICLE_ID;
				DisablePlayerRaceCheckpoint(playerid);
				if(PLAYER_DATA[playerid][data_LICB] == 0) SendClientMessage(playerid,COLOR_AC,"Экзамен по вождению провален");
			}
		}
	}

	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;


		if(PLAYER_DATA[i][data_TRAILER] == vehicleid)
  		{
			DestroyVehicle(PLAYER_DATA[i][data_TRAILER]);
  		    PLAYER_DATA[i][data_TRAILER] = INVALID_VEHICLE_ID;
  		    if(PLAYER_DATA[i][data_LOGGED] == true) SendClientMessage(i,0xFF9966FF,"Вы потеряли свой прицеп");
  		}
    }
    //CAR_DATA[vehicleid][data_FUEL] = 50;
	ClearCarData(vehicleid);

	if(CAR_DATA[vehicleid][data_RIGHT_B] == 1)
	{
 		DestroyObject(CAR_DATA[vehicleid][data_BLICK][0]);
      	DestroyObject(CAR_DATA[vehicleid][data_BLICK][1]);
     	CAR_DATA[vehicleid][data_RIGHT_B] = 0;
	}
	if(CAR_DATA[vehicleid][data_LEFT_B] == 1)
	{
 		DestroyObject(CAR_DATA[vehicleid][data_BLICK][2]);
      	DestroyObject(CAR_DATA[vehicleid][data_BLICK][3]);
     	CAR_DATA[vehicleid][data_LEFT_B] = 0;
	}
	return true;
}

public OnVehicleDeath(vehicleid, killerid)
{
	return true;
}

public OnPlayerText(playerid, text[])
{
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return false;

	if(PLAYER_DATA[playerid][data_MUTE] == 1)
	{
		SendClientMessage(playerid,COLOR_WARNING,"Ваш чат временно заблокирован! (инфо: /mutetime)");
		return false;
	}
	if(antiflood[playerid] > 0)
	{
		SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
		return false;
	}
    antiflood[playerid]++;


    if(strfind(PLAYER_DATA[playerid][data_CHAT_TEXT], text, true) != -1)
	{
		SendClientMessage(playerid, COLOR_WARNING,"Ваше сообщение слишком сильно похоже на предыдущее!");
		return false;
	}
    strmid(PLAYER_DATA[playerid][data_CHAT_TEXT], text, 0, 128, 128);



 	NotReklama(playerid, text);

	new carid = GetPlayerVehicleID(playerid);
 	if(PlayerToPoint(10.0, playerid, 254.3399,1809.7153,563.1203) || carid >= smi_car[0] && carid <= smi_car[1])
 	{
 	    if(efir == true && PLAYER_DATA[playerid][data_EFIR] == true)
 	    {
	 	    new str[145];
			format(str,sizeof(str),"[СМИ] %s[%d]: %s",PLAYER_DATA[playerid][data_NAME],playerid,text);
			SendClientMessageToAll(0x33FFCCC8,str);
			return false;
		}
	}


	if(PLAYER_DATA[playerid][data_CALL] != -1 && PLAYER_DATA[PLAYER_DATA[playerid][data_CALL]][data_CALL] == playerid)
 	{
 	    new message2[145],message[145];
        format(message,sizeof(message),"[ТЕЛЕФОН]: %s | %s (%d) <<<",text,PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[playerid][data_NUMBER]);
        SendClientMessage(PLAYER_DATA[playerid][data_CALL],0xFFFF33FF,message);
        format(message2,sizeof(message2),"[ТЕЛЕФОН]: %s | %s (%d) >>>",text,PLAYER_DATA[PLAYER_DATA[playerid][data_CALL]][data_NAME],PLAYER_DATA[PLAYER_DATA[playerid][data_CALL]][data_NUMBER]);
		SendClientMessage(playerid,0xFFFF33FF,message2);
		return false;
 	}

 	if(!strcmp(text,"xD",true))
	{
	    new message[80];
		format(message, sizeof(message), "%s валяется от смеха", PLAYER_DATA[playerid][data_NAME]);
		ProxDetector(20.0, playerid, message, 0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
		SetPlayerChatBubble(playerid, "валяется от смеха", 0xFF66CCFF, 20.0, 4000);
		return false;
	}
	if(!strcmp(text,"))",true))
	{
	    new message[80];
		format(message, sizeof(message), "%s валяется от смеха", PLAYER_DATA[playerid][data_NAME]);
		ProxDetector(20.0, playerid, message, 0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
		SetPlayerChatBubble(playerid, "валяется от смеха", 0xFF66CCFF, 20.0, 4000);
		return false;
	}
	if(!strcmp(text,"(",true))
	{
	    new message[80];
		format(message, sizeof(message), "%s грустит", PLAYER_DATA[playerid][data_NAME]);
		ProxDetector(20.0, playerid, message, 0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
		SetPlayerChatBubble(playerid, "грустит", 0xFF66CCFF, 20.0, 4000);
		return false;
	}
	if(!strcmp(text,"чВ",true))
	{
	    new message[80];
		format(message, sizeof(message), "%s валяется от смеха", PLAYER_DATA[playerid][data_NAME]);
		ProxDetector(20.0, playerid, message, 0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
		SetPlayerChatBubble(playerid, "валяется от смеха", 0xFF66CCFF, 20.0, 4000);
		return false;
	}
	if(!strcmp(text,")",true))
	{
	    new message[80];
		format(message, sizeof(message), "%s улыбается", PLAYER_DATA[playerid][data_NAME]);
		ProxDetector(20.0, playerid, message, 0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
		SetPlayerChatBubble(playerid, "улыбается", 0xFF66CCFF, 20.0, 4000);
		return false;
	}

    if(!IsPlayerInAnyVehicle(playerid))
	{
	    new message[145];
	    /*format(message, sizeof(message), "- %s %s(%s)[%d]", text, PLAYER_COLOR_CHAT[PLAYER_DATA[playerid][data_MEMBER]][COLOR], PLAYER_DATA[playerid][data_NAME],playerid);
		ProxDetector(30.0, playerid, message, 0xFFFFFFC8, 0xDBDBDBC8, 0xADADADC8, 0x939393C8, 0x737373C8);
		SetPlayerChatBubble(playerid, text, 0xA5DF00AA, 20.0, 4000);
  		if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT && GetPVarInt(playerid,"UseAnim") == 0)
	 	{
	 		ApplyAnimation(playerid,"PED","IDLE_chat",4.1,0,1,1,1,1);
			if(PLAYER_DATA[playerid][data_ANIM] == false) SetTimerEx("anim_OFF", 1400, 0, "d", playerid);
			PLAYER_DATA[playerid][data_ANIM] = true;
	 	}*/


		if(strlen(text) >= 80)//если набранный текст больше 80, то
		{
			new string[228];//переменная для хранения перенесенного текста
			new mess[228];//переменная для форматирования и отправки п.т
			strmid(string,text,64,128,128);//запишем текст для переноса в переменную
			strdel(text,64,128);//удалим из переменной для записи текста половину текста
			format(text, 104, "- %s %s(%s)[%d]", text, PLAYER_COLOR_CHAT[PLAYER_DATA[playerid][data_MEMBER]][COLOR], PLAYER_DATA[playerid][data_NAME],playerid);//форматнем для отправки в первое сообщение
            ProxDetector(30.0, playerid, text, 0xFFFFFFC8, 0xDBDBDBC8, 0xADADADC8, 0x939393C8, 0x737373C8);
			SetPlayerChatBubble(playerid, text, 0xA5DF00AA, 20.0, 4000);
			format(mess, 98, "- %s %s(%s)[%d]", text, PLAYER_COLOR_CHAT[PLAYER_DATA[playerid][data_MEMBER]][COLOR], PLAYER_DATA[playerid][data_NAME],playerid);//форматнем для отправки во второе сообщение
			ProxDetector(30.0, playerid, mess, 0xFFFFFFC8, 0xDBDBDBC8, 0xADADADC8, 0x939393C8, 0x737373C8);
			SetPlayerChatBubble(playerid, mess, 0xA5DF00AA, 20.0, 4000);
			return 0;
		}
		else//а если не больше, то
		{
			format(message, sizeof(message), "- %s %s(%s)[%d]", text, PLAYER_COLOR_CHAT[PLAYER_DATA[playerid][data_MEMBER]][COLOR], PLAYER_DATA[playerid][data_NAME],playerid);
			ProxDetector(30.0, playerid, message, 0xFFFFFFC8, 0xDBDBDBC8, 0xADADADC8, 0x939393C8, 0x737373C8);
			SetPlayerChatBubble(playerid, text, 0xA5DF00AA, 20.0, 4000);
			return 0;
		}
 	}
 	else
 	{
	    new message[245];
	    format(message, sizeof(message), "- {808080}(В машине) {FFFFFF}%s %s(%s)[%d]", text, PLAYER_COLOR_CHAT[PLAYER_DATA[playerid][data_MEMBER]][COLOR], PLAYER_DATA[playerid][data_NAME],playerid);
		ProxDetector(30.0, playerid, message, 0xFFFFFFC8, 0xDBDBDBC8, 0xADADADC8, 0x939393C8, 0x737373C8);
		SetPlayerChatBubble(playerid, text, 0xA5DF00AA, 20.0, 4000);
 	}
	return false;
}

