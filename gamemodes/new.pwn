        case dialog_GARAGE_DAYS:
		{
			if(!response) return true;
			if(PLAYER_DATA[playerid][data_GR] == INVALID_GARAGE_ID) return SendClientMessage(playerid,COLOR_WARNING,"У вас нет гаража!");
			if(strval(inputtext) <= 0) return SendClientMessage(playerid, COLOR_WARNING, "Недопустимое значение!");
			new h_class = strval(inputtext)*600;
			new g = PLAYER_DATA[playerid][data_GR];
			if(GARAGE_DATA[g][data_DAY]+strval(inputtext) > 30) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя оплатить гараж на более 30 суток!");
			if(h_class > get_player_money(playerid)) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");
			give_player_money(playerid,-h_class,"#19");
			GARAGE_DATA[g][data_DAY] += strval(inputtext);
			PlayerPlaySound(playerid, 43000, 0.0, 0.0, 0.0);
			new message[45];
			format(message,sizeof(message),"Ваш гараж оплачен на %d дня/дней",GARAGE_DATA[g][data_DAY]);
			SendClientMessage(playerid,0xFFCC00FF,message);
			SaveGarageData(g);
		}
		
