public CheckEmail(playerid)
{
    new rows, fields;
    cache_get_data(rows, fields);
    if(rows)
	{
	    SendClientMessage(playerid, 0x66666600, "Данный email уже используется на этом сервере");
	    ShowPlayerDialogFix(playerid, dialog_EMAIL, DIALOG_STYLE_INPUT, "{66CCFF}Email", "{FFFFFF}Введите адрес Вашей электронной почты\nИспользуя его, Вы сможете восстановить доступ к аккаунту\nв случае его взлома или если забудете пароль\n\nНа email будет выслан код подтверждения\nЕго нужно будет ввести в следующем окне\n\nУбедитесь в правильности ввода и нажмите 'Далее'", "Далее", "");
	}
	else
    {
  		EmailCode(playerid, PLAYER_DATA[playerid][data_EMAIL]);
		ShowPlayerDialogFix(playerid, dialog_OKEMAIL, DIALOG_STYLE_INPUT, "{66CCFF}Email", "{FFFFFF}Введите код активации. Он был выслан к Вам на email\n{FFCC33}Чтобы свернуть игру используйте: ALT + TAB", "Далее", "");
	}
    return true;
}

public KamenLoaded(playerid)
{
    if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
    SetPlayerAttachedObject(playerid,2, 905, 5, 0.020944, 0.039285, -0.035010, 0.000000, 0.000000, 0.000000, 0.301603, 0.125763, 0.233199 );
    SetPlayerAttachedObject(playerid,3, 906, 6, -0.032336, 0.111448, 0.001745, 0.000000, 0.000000, 0.000000, 0.026124, 0.048238, 0.048593);
	ApplyAnimation(playerid,"PED","IDLE_chat",4.1,0,0,0,1,5150);
    PLAYER_DATA[playerid][data_SHAHTA_TIMER_ID] = SetTimerEx("KamenLoaded2",5150,false,"i",playerid);
	return true;
}

public KamenLoaded2(playerid)
{
    SetPVarInt(playerid,"ac_timer",1);
    SendClientMessage(playerid,0x339966AA,"Вы добыли руду. Отнесите ее на склад (на радаре отмечена красная метка)");
    if(IsPlayerAttachedObjectSlotUsed(playerid,2)) RemovePlayerAttachedObject(playerid,2);
    if(IsPlayerAttachedObjectSlotUsed(playerid,3)) RemovePlayerAttachedObject(playerid,3);
    SetPlayerAttachedObject(playerid,2, 1458, 1, -1.034844, 1.116571, -0.065124, 76.480148, 75.781570, 280.952545, 0.575599, 0.604554, 0.624122);// Дали телегу с камнем
	SetPlayerAttachedObject(playerid,3, 905, 1, -0.275758, 1.305280, 0.000000, 0.000000, 0.000000, 0.000000, 1.000000, 1.000000, 1.000000);// Дали камень
    DeletePVar(playerid, "process");
	switch(random(6))
    {
        case 0: SetPVarInt(playerid, "tovar", 25);
        case 1: SetPVarInt(playerid, "tovar", 30);
        case 2: SetPVarInt(playerid, "tovar", 35);
        case 3: SetPVarInt(playerid, "tovar", 40);
        case 4: SetPVarInt(playerid, "tovar", 45);
        case 5: SetPVarInt(playerid, "tovar", 50);
    }

	SetPlayerCheckpoint(playerid, 1547.2593,-2409.6533,10.1301, 2.0);
	return true;
}

public SpeedUpdate(playerid)
{
    if(IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
    {
        new carid = GetPlayerVehicleID(playerid);

        if(GetPlayerDistanceFromPoint(playerid, CAR_DATA[carid][data_PosX], CAR_DATA[carid][data_PosY], CAR_DATA[carid][data_PosZ]) > 300.0)
		{
		    CAR_DATA[carid][data_ODOM]++;
		    GetPlayerPos(playerid, CAR_DATA[carid][data_PosX], CAR_DATA[carid][data_PosY], CAR_DATA[carid][data_PosZ]);
		}

		if(PLAYER_DATA[playerid][data_CT_NUMBER] != 0) RepairVehicle(carid);



        new stext[4], otext[8],ftext[10],IItext[24];
		format(stext, sizeof(stext),"%.0f", Player_Speed(playerid)*1.5);
		PlayerTextDrawSetString(playerid,SpeedometrSpeed[playerid],stext);
        format(ftext, sizeof(ftext),"%d", CAR_DATA[carid][data_FUEL]);
        PlayerTextDrawSetString(playerid,SpeedometrFuel[playerid],ftext);
        //new spid = Player_Speed(playerid);
        //cef_emit_event(playerid, "pwd:speed", CEFINT(spid));
        switch(Player_Speed(playerid))
    	{
    	    case 0: format(IItext, sizeof(IItext),"");
    	    case 1..5: format(IItext, sizeof(IItext),"~g~i");
    	    case 6..10: format(IItext, sizeof(IItext),"~g~ii");
    	    case 11..15: format(IItext, sizeof(IItext),"~g~ii");
    	    case 16..20: format(IItext, sizeof(IItext),"~g~iii");
    	    case 21..25: format(IItext, sizeof(IItext),"~g~iiii");
    	    case 26..30: format(IItext, sizeof(IItext),"~g~iiiii");
    	    case 31..35: format(IItext, sizeof(IItext),"~g~iiiiii");
    	    case 36..40: format(IItext, sizeof(IItext),"~g~iiiiiii");
    	    case 41..45: format(IItext, sizeof(IItext),"~g~iiiiiiii");
    	    case 46..50: format(IItext, sizeof(IItext),"~g~iiiiiiiii");
    	    case 51..55: format(IItext, sizeof(IItext),"~g~iiiiiiiiii");
    	    case 56..60: format(IItext, sizeof(IItext),"~y~iiiiiiiiiii");
    	    case 61..65: format(IItext, sizeof(IItext),"~y~iiiiiiiiiiii");
    	    case 66..70: format(IItext, sizeof(IItext),"~y~iiiiiiiiiiiii");
    	    case 71..75: format(IItext, sizeof(IItext),"~y~iiiiiiiiiiiiii");
    	    case 76..80: format(IItext, sizeof(IItext),"~y~iiiiiiiiiiiiiii");
    	    case 81..85: format(IItext, sizeof(IItext),"~y~iiiiiiiiiiiiiiii");
    	    case 86..90: format(IItext, sizeof(IItext),"~r~iiiiiiiiiiiiiiiii");
    	    case 91..95: format(IItext, sizeof(IItext),"~r~iiiiiiiiiiiiiiiiii");
    	    case 96..100: format(IItext, sizeof(IItext),"~r~iiiiiiiiiiiiiiiiiii");
    	    default: format(IItext, sizeof(IItext),"~r~iiiiiiiiiiiiiiiiiiii");
    	}

		if(CAR_DATA[GetPlayerVehicleID(playerid)][data_LIMIT])
		{
			new Float:x,Float:y,Float:z;
			GetVehicleVelocity(GetPlayerVehicleID(playerid), x, y, z);
			if((x > MAX_SPEEDO || x < -MAX_SPEEDO) || (y > MAX_SPEEDO || y < -MAX_SPEEDO))
			SetVehicleVelocity(GetPlayerVehicleID(playerid), x*SLOW_FACTOR, y*SLOW_FACTOR, z);
		}

    	//PlayerTextDrawSetString(playerid,SpeedometrII[playerid],IItext);
        switch(CAR_DATA[carid][data_ODOM])
    	{
    	    case 1..9: format(otext, sizeof(otext),"0000%d", CAR_DATA[carid][data_ODOM]);
    		case 10..99: format(otext, sizeof(otext),"000%d", CAR_DATA[carid][data_ODOM]);
    		case 100..999: format(otext, sizeof(otext),"00%d", CAR_DATA[carid][data_ODOM]);
			case 1000..9999: format(otext, sizeof(otext),"0%d", CAR_DATA[carid][data_ODOM]);
			default: format(otext, sizeof(otext),"%d", CAR_DATA[carid][data_ODOM]);
		}
        //PlayerTextDrawSetString(playerid, SpeedometrOdometr[playerid], otext);

		switch(CAR_DATA[carid][data_ENG])
		{
       		case 0:
       		{
       		    PlayerTextDrawHide(playerid, SpeedometrEngine[playerid][0]);
       		    PlayerTextDrawShow(playerid, SpeedometrEngine[playerid][1]);
       		}
	        case 1:
	        {
	            PlayerTextDrawHide(playerid, SpeedometrEngine[playerid][1]);
	            PlayerTextDrawShow(playerid, SpeedometrEngine[playerid][0]);
	        }
		}
		switch(CAR_DATA[carid][data_LAMP])
   		{
            case 0:
       		{
       		    PlayerTextDrawHide(playerid, SpeedometrLamp[playerid][0]);
       		    PlayerTextDrawShow(playerid, SpeedometrLamp[playerid][1]);
       		}
	        case 1:
	        {
	            PlayerTextDrawHide(playerid, SpeedometrLamp[playerid][1]);
	            PlayerTextDrawShow(playerid, SpeedometrLamp[playerid][0]);
	        }
   		}
		switch(CAR_DATA[carid][data_LOCK])
   		{
            case 0:
       		{
       		    PlayerTextDrawHide(playerid, SpeedometrLock[playerid][0]);
       		    PlayerTextDrawShow(playerid, SpeedometrLock[playerid][1]);
       		}
	        case 1:
	        {
	            PlayerTextDrawHide(playerid, SpeedometrLock[playerid][1]);
	            PlayerTextDrawShow(playerid, SpeedometrLock[playerid][0]);
	        }
   		}
	}
	return true;
}

public CheckDonate(playerid)
{
	new rows, fields, don, don_all, temp[10], query[256],donatik;
    cache_get_data(rows, fields);
    if(rows)
    {


        cache_get_field_content(0, "donate", temp), don = strval (temp);
        cache_get_field_content(0, "donate_all", temp), PLAYER_DATA[playerid][data_DONATE_ALL] = strval (temp);

		if(X2DAY == true) donatik = GetPVarInt(playerid, "donate")*2;
		else donatik = GetPVarInt(playerid, "donate");

        PLAYER_DATA[playerid][data_DONATE] = don+donatik;
        don_all = PLAYER_DATA[playerid][data_DONATE_ALL]+GetPVarInt(playerid, "donate");

        format(query, sizeof(query), "UPDATE `accounts` SET `donate` = '%d', `donate_p` = '%d', `donate_all` = '%d' WHERE `name` = '%s'",PLAYER_DATA[playerid][data_DONATE],GetPVarInt(playerid, "donate"),don_all,PLAYER_DATA[playerid][data_NAME]);
		mysql_function_query(dbHandle, query, false, "", "");
        SendClientMessage(playerid, COLOR_AC, "На Ваш счет были начислены донат-очки!");
        DeletePVar(playerid,"donate");
    }
	return true;
}

public CheckFreeKassa(playerid)
{
    new rows, fields, temp[10], query[256], query2[256];
    cache_get_data(rows, fields);
    if(rows)
    {
        new strtime[64],Year, Month, Day,hour,minuite,second;
        gettime(hour,minuite,second), getdate(Year, Month, Day);
		format(strtime,sizeof(strtime),"%02d-%02d-%02d %02d:%02d:%02d",Year, Month, Day,hour,minuite,second);

        cache_get_field_content(0, "sum", temp), SetPVarInt(playerid,"donate",strval(temp));
        format(query, sizeof(query), "UPDATE `freekassa_payments` SET `status` = '1', `update_date` = '%s' WHERE `nick` = '%s' AND `status` = '0' LIMIT 1",strtime, PLAYER_DATA[playerid][data_NAME]);
		mysql_function_query(dbHandle, query, false, "", "");

		format(query2, sizeof(query2), "SELECT * FROM `accounts` WHERE `name` = '%s' LIMIT 1",PLAYER_DATA[playerid][data_NAME]);
        mysql_function_query(dbHandle, query2, true, "CheckDonate", "i", playerid);
    }
    else
	{
		SendClientMessage(playerid, COLOR_WARNING, "Новых пополнений не обнаружено!");
	}
	return true;
}


public LoadDonate(playerid)
{
    new rows, fields, temp[20];
    cache_get_data(rows, fields);
    if(rows)
	{
        cache_get_field_content(0, "donate", temp), PLAYER_DATA[playerid][data_DONATE] = strval (temp);
        cache_get_field_content(0, "donate_p", temp), PLAYER_DATA[playerid][data_DONATE_P] = strval (temp);
        cache_get_field_content(0, "donate_all", temp), PLAYER_DATA[playerid][data_DONATE_ALL] = strval (temp);
        new str[350];
		format(str,sizeof(str),"{FFFFFF}В данном разделе составлен список услуг, которыми можно воспользоваться\nпополнив свой донат кошелек на нашем сайте: {336699}vk.com/provincerp3e (раздел 'Донат')\n\n{33CC99}Информация:\n{CCCC66}Текущее состояние счета: %d донат-очков\nПоследнее пополнение: %d донат-очков\nВсего пополнений: %d донат-очков",PLAYER_DATA[playerid][data_DONATE],PLAYER_DATA[playerid][data_DONATE_P],PLAYER_DATA[playerid][data_DONATE_ALL]);
		SendClientMessage(playerid,0xCC6633FF, str);


		ShowPlayerDialogFix(playerid, dialog_DONATE_I, DIALOG_STYLE_MSGBOX, "{FFCC00}Дополнительные услуги", str, "Услуги", "Отмена");
    }
    return true;
}

public LoadAutoBusiness()
{
    new rows, fields, temp[256],time = GetTickCount(),str[256];
    cache_get_data(rows, fields);
    if(rows)
    {
    	for(new b = 0; b < rows; b++)
    	{
	        cache_get_field_content(b, "id", temp), AB_DATA[b][data_ID] = strval (temp);

	        cache_get_field_content(b, "name", AB_DATA[b][data_NAME], dbHandle, 50);
	        cache_get_field_content(b, "owner", AB_DATA[b][data_OWNER], dbHandle, MAX_PLAYER_NAME);

	        cache_get_field_content(b, "owned", temp), AB_DATA[b][data_OWNED] = strval (temp);
	        cache_get_field_content(b, "price", temp), AB_DATA[b][data_PRICE] = strval (temp);
	        cache_get_field_content(b, "procent", temp), AB_DATA[b][data_PROCENT] = strval (temp);
	        cache_get_field_content(b, "bank", temp), AB_DATA[b][data_BANK] = strval (temp);


	        cache_get_field_content(b, "car1_job", temp), AB_DATA[b][data_MODEL_JOB][0] = strval (temp);
	        cache_get_field_content(b, "car2_job", temp), AB_DATA[b][data_MODEL_JOB][1] = strval (temp);
