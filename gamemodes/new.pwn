public ClearZaezd()
{
    SendClientMessageToAll(0x99FFFFFF,"Мероприятие 'Трек' завершено. Список победителей: /tracklist");

    for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		if(PLAYER_DATA[i][data_CT_VEH] != INVALID_VEHICLE_ID)
		{
		    DestroyVehicle(PLAYER_DATA[i][data_CT_VEH]);
			PLAYER_DATA[i][data_CT_VEH] = INVALID_VEHICLE_ID;
			//SetPlayerPosAC(i, -1503.6699,1609.8861,36.5690);
			DisablePlayerRaceCheckpoint(i);
		}
		PLAYER_DATA[i][data_CT_NUMBER] = 0;
	}


	cartrack_open = false;
	return true;
}

public StartZaezdGO()
{
	if(cartrack_people > 1)
	{
		for(new i = 0; i < MAX_PLAYERS; i++)
		{
		    if(!IsPlayerConnected(i)) continue;
			if(PLAYER_DATA[i][data_CT_NUMBER] != 0)
			{
			    if(PLAYER_DATA[i][data_AFK] > 5 || PLAYER_DATA[i][data_JAIL] != 0 || PLAYER_DATA[i][data_HOSPITAL] != 0)
		    	{
		        	PLAYER_DATA[i][data_CT_NUMBER] = 0;
		        	continue;
		    	}

			    new id = PLAYER_DATA[i][data_CT_NUMBER]-1;
			    PLAYER_DATA[i][data_CT_VEH] = CreateVehicle(562, pos_cartrack[id][0], pos_cartrack[id][1], pos_cartrack[id][2], 180.0, 1, 1, 36000);
                CAR_DATA[PLAYER_DATA[i][data_CT_VEH]][data_FUEL] = 50;
				PutPlayerInVehicleAC(i, PLAYER_DATA[i][data_CT_VEH], 0);

				PLAYER_DATA[i][data_CHEK] = 0;
				SetPlayerRaceCheckpoint(i, 0, chek_cartrack[0][0],chek_cartrack[0][1],chek_cartrack[0][2],chek_cartrack[0][3],chek_cartrack[0][4],chek_cartrack[0][5], 15.0);
				GameTextForPlayer(i, "~w~GO GO GO!", 3000, 6);
				GetVehicleParamsEx(PLAYER_DATA[i][data_CT_VEH],engine,lights,alarm,doors,bonnet,boot,objective);
				SetVehicleParamsEx(PLAYER_DATA[i][data_CT_VEH],true,lights,alarm,doors,bonnet,boot,objective);
				CAR_DATA[PLAYER_DATA[i][data_CT_VEH]][data_ENG] = 1;
			}
		}
		SendClientMessageToAll(0x99FFFFFF,"Мероприятие 'Трек' началось!");
		SetTimer("ClearZaezd",1000*60*10,false);
	}
	else
	{
	    for(new i = 0; i < MAX_PLAYERS; i++)
		{
		    if(!IsPlayerConnected(i)) continue;
		    PLAYER_DATA[i][data_CT_NUMBER] = 0;
		}


	    cartrack_open = false;
	    SendClientMessageToAll(0x99FFFFFF,"Гоночный заезд не состоялся из-за нехватки участников");
	}
	cartrack_status = false;
	return true;
}


public StartCSGO()
{
	if(cs_people > 0)
	{
		new t1, t2;
		for(new i = 0; i < MAX_PLAYERS; i++)
		{
		    if(!IsPlayerConnected(i)) continue;
			if(PLAYER_DATA[i][data_CS_TEAM] != 0)
			{
			    if(PLAYER_DATA[i][data_AFK] > 5 || PLAYER_DATA[i][data_JAIL] != 0 || PLAYER_DATA[i][data_HOSPITAL] != 0)
		    	{
		        	PLAYER_DATA[i][data_CS_TEAM] = 0;
		        	continue;
		    	}

				if(PLAYER_DATA[i][data_CS_TEAM] == 1)
				{
				    SetPlayerSkinAC(i, 287);
				    SetPlayerPosAC(i, cspos_team1[t1][0],cspos_team1[t1][1],cspos_team1[t1][2]);
					SetPlayerFacingAngle(i, cspos_team1[t1][3]);
					SetPlayerVirtualWorld(i, 228);
					FreezePlayer(i);
					SetTimerEx("UnfreezePlayer", 5000, false, "d", i);
					SetPlayerTeam(i, 1);
					SetPlayerColor(i, 0xCC333330);
				    t1++;
				}
				else
				{
				    SetPlayerSkinAC(i, 285);
				    SetPlayerPosAC(i, cspos_team2[t1][0],cspos_team2[t1][1],cspos_team2[t1][2]);
					SetPlayerFacingAngle(i, cspos_team2[t1][3]);
					SetPlayerVirtualWorld(i, 228);
					FreezePlayer(i);
					SetTimerEx("UnfreezePlayer", 5000, false, "d", i);
					SetPlayerTeam(i, 2);
					SetPlayerColor(i, 0x3366CC30);
				    t2++;
				}
				SetPlayerHealthAC(i, 100);
				SetPlayerArmourAC(i, 100);
				GiveWeapon(i, 24, 100);
				GiveWeapon(i, 31, 1000);
				GiveWeapon(i, 29, 1000);
				GiveWeapon(i, 25, 100);
			}
		}
		SendClientMessageToAll(0xFF66CCFF,"[Мероприятие]Мероприятие 'Counter-Strike' началось!");
		cs_time = 300;
	}
	else
	{
	    for(new i = 0; i < MAX_PLAYERS; i++)
		{
		    if(!IsPlayerConnected(i)) continue;
		    PLAYER_DATA[i][data_CS_TEAM] = 0;
		}


	    cs_open = false;
	    SendClientMessageToAll(0xFF66CCFF,"[Мероприятие]Игра Counter-Strike не состоялась из-за нехватки участников");
	}
	cs_status = false;
	return true;
}


public StartCS()
{
    SendClientMessageToAll(0xFF66CCFF,"[Мероприятие]Через 2 минуты стартует командная игра Counter-Strike (/gps > Развлечения > Counter-Strike)");
	SetTimer("StartCSGO",1000*60*2, false);
	return true;
}

