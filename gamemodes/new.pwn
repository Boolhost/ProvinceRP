stock SaveHouseData(h)
{
	new query[500], string[145];
	query = "UPDATE `houses` SET ";
	acc_str_strcat(query, sizeof(query), "owner", HOUSE_DATA[h][data_OWNER]);
	acc_int_strcat(query, sizeof(query), "owned", HOUSE_DATA[h][data_OWNED]);
	acc_int_strcat(query, sizeof(query), "lock", HOUSE_DATA[h][data_LOCK]);
	acc_int_strcat(query, sizeof(query), "day", HOUSE_DATA[h][data_DAY]);
	strdel(query, strlen(query)-1, strlen(query));
	format(string,sizeof(string)," WHERE `id` = '%d' LIMIT 1",HOUSE_DATA[h][data_ID]);
	strcat(query, string);
	mysql_function_query(dbHandle, query, true, "", "");
	return true;
}

