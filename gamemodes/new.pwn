	        cache_get_field_content(b, "car5_job", temp), AB_DATA[b][data_MODEL_JOB][4] = strval (temp);
	        cache_get_field_content(b, "car6_job", temp), AB_DATA[b][data_MODEL_JOB][5] = strval (temp);
	        cache_get_field_content(b, "car7_job", temp), AB_DATA[b][data_MODEL_JOB][6] = strval (temp);


