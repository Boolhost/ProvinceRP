	new str[145];
	switch(PLAYER_DATA[playerid][data_MEMBER])
	{
	    case 1:format(str,sizeof(str),"[R] %s %s[%d]: (( %s ))",rang_gov[PLAYER_DATA[playerid][data_RANK]-1][frName],PLAYER_DATA[playerid][data_NAME],playerid,params[0]);
	    case 2:format(str,sizeof(str),"[R] %s %s[%d]: (( %s ))",rang_army[PLAYER_DATA[playerid][data_RANK]-1][frName],PLAYER_DATA[playerid][data_NAME],playerid,params[0]);
		case 3:
		{
		    new podfrak[6];
			switch(PLAYER_DATA[playerid][data_PODMEMBER])
			{
	    		case 0: podfrak = "ППС";
				case 1: podfrak = "ОМОН";
			}


			format(str,sizeof(str),"[R] %s %s[%d] [%s]: (( %s ))", rang_police[PLAYER_DATA[playerid][data_RANK]-1][frName],PLAYER_DATA[playerid][data_NAME],playerid,podfrak,params[0]);
		}
		case 4:format(str,sizeof(str),"[R] %s %s[%d]: (( %s ))",rang_hospital[PLAYER_DATA[playerid][data_RANK]-1][frName],PLAYER_DATA[playerid][data_NAME],playerid,params[0]);
	    case 5,6,7:format(str,sizeof(str),"[R] %s %s[%d]: (( %s ))",rang_crime[PLAYER_DATA[playerid][data_RANK]-1][frName],PLAYER_DATA[playerid][data_NAME],playerid,params[0]);
	    case 8:
		{
			format(str,sizeof(str),"[R] %s %s[%d]: (( %s ))",rang_fsb[PLAYER_DATA[playerid][data_RANK]-1][frName],PLAYER_DATA[playerid][data_NAME],playerid,params[0]);
		}
		case 9:format(str,sizeof(str),"[R] %s %s[%d]: (( %s ))",rang_smi[PLAYER_DATA[playerid][data_RANK]-1][frName],PLAYER_DATA[playerid][data_NAME],playerid,params[0]);
	}
	SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER],0xFFFF99FF,str);
	return true;
}

