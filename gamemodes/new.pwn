// FLY MODE
stock GetMoveDirectionFromKeys(ud, lr)
{
	new direction = 0;

    if(lr < 0)
	{
		if(ud < 0) 		direction = MOVE_FORWARD_LEFT;
		else if(ud > 0) direction = MOVE_BACK_LEFT;
		else            direction = MOVE_LEFT;
	}
	else if(lr > 0)
	{
		if(ud < 0)      direction = MOVE_FORWARD_RIGHT;
		else if(ud > 0) direction = MOVE_BACK_RIGHT;
		else			direction = MOVE_RIGHT;
	}
	else if(ud < 0) 	direction = MOVE_FORWARD;
	else if(ud > 0) 	direction = MOVE_BACK;

	return direction;
}


stock MoveCamera(playerid)
{
	new Float:FV[3], Float:CP[3];
	GetPlayerCameraPos(playerid, CP[0], CP[1], CP[2]);
    GetPlayerCameraFrontVector(playerid, FV[0], FV[1], FV[2]);

	if(noclipdata[playerid][accelmul] <= 1) noclipdata[playerid][accelmul] += ACCEL_RATE;

	new Float:speed = MOVE_SPEED * noclipdata[playerid][accelmul];

	new Float:X, Float:Y, Float:Z;
	GetNextCameraPosition(noclipdata[playerid][mode], CP, FV, X, Y, Z);
	MovePlayerObject(playerid, noclipdata[playerid][flyobject], X, Y, Z, speed);

	noclipdata[playerid][lastmove] = GetTickCount();
	return true;
}

stock GetNextCameraPosition(move_mode, Float:CP[3], Float:FV[3], &Float:X, &Float:Y, &Float:Z)
{
    #define OFFSET_X (FV[0]*6000.0)
	#define OFFSET_Y (FV[1]*6000.0)
	#define OFFSET_Z (FV[2]*6000.0)
	switch(move_mode)
	{
		case MOVE_FORWARD:
		{
			X = CP[0]+OFFSET_X;
			Y = CP[1]+OFFSET_Y;
			Z = CP[2]+OFFSET_Z;
		}
		case MOVE_BACK:
		{
			X = CP[0]-OFFSET_X;
			Y = CP[1]-OFFSET_Y;
			Z = CP[2]-OFFSET_Z;
		}
		case MOVE_LEFT:
		{
			X = CP[0]-OFFSET_Y;
			Y = CP[1]+OFFSET_X;
			Z = CP[2];
		}
		case MOVE_RIGHT:
		{
			X = CP[0]+OFFSET_Y;
			Y = CP[1]-OFFSET_X;
			Z = CP[2];
		}
		case MOVE_BACK_LEFT:
		{
			X = CP[0]+(-OFFSET_X - OFFSET_Y);
 			Y = CP[1]+(-OFFSET_Y + OFFSET_X);
		 	Z = CP[2]-OFFSET_Z;
		}
		case MOVE_BACK_RIGHT:
		{
			X = CP[0]+(-OFFSET_X + OFFSET_Y);
 			Y = CP[1]+(-OFFSET_Y - OFFSET_X);
		 	Z = CP[2]-OFFSET_Z;
		}
		case MOVE_FORWARD_LEFT:
		{
			X = CP[0]+(OFFSET_X  - OFFSET_Y);
			Y = CP[1]+(OFFSET_Y  + OFFSET_X);
			Z = CP[2]+OFFSET_Z;
		}
		case MOVE_FORWARD_RIGHT:
		{
			X = CP[0]+(OFFSET_X  + OFFSET_Y);
			Y = CP[1]+(OFFSET_Y  - OFFSET_X);
			Z = CP[2]+OFFSET_Z;
		}
	}
}

stock CancelFlyMode(playerid)
{
	DeletePVar(playerid, "FlyMode");
	CancelEdit(playerid);
	TogglePlayerSpectating(playerid, false);

	DestroyPlayerObject(playerid, noclipdata[playerid][flyobject]);
	noclipdata[playerid][cameramode] = CAMERA_MODE_NONE;
	return true;
}


stock FlyMode(playerid)
{
	new Float:X, Float:Y, Float:Z;
	GetPlayerPos(playerid, X, Y, Z);
	noclipdata[playerid][flyobject] = CreatePlayerObject(playerid, 19300, X, Y, Z, 0.0, 0.0, 0.0);

	TogglePlayerSpectating(playerid, true);
	AttachCameraToPlayerObject(playerid, noclipdata[playerid][flyobject]);

	SetPVarInt(playerid, "FlyMode", 1);
	noclipdata[playerid][cameramode] = CAMERA_MODE_FLY;
	return true;
}

stock CreateGarage(playerid)
{
	new Float:enter_x = GetPVarFloat(playerid, "GARAGE_X"),
	Float:enter_y = GetPVarFloat(playerid, "GARAGE_Y"),
	Float:enter_z = GetPVarFloat(playerid, "GARAGE_Z"),

	Float:enter_x_car = GetPVarFloat(playerid, "GARAGE_CAR_X"),
	Float:enter_y_car = GetPVarFloat(playerid, "GARAGE_CAR_Y"),
	Float:enter_z_car = GetPVarFloat(playerid, "GARAGE_CAR_Z"),
	Float:enter_a_car = GetPVarFloat(playerid, "GARAGE_CAR_A"),

	Float:exit_x = GetPVarFloat(playerid, "GARAGE_EXIT_X"),
	Float:exit_y = GetPVarFloat(playerid, "GARAGE_EXIT_Y"),
	Float:exit_z = GetPVarFloat(playerid, "GARAGE_EXIT_Z"),

	garage_type = GetPVarInt(playerid, "GARAGE_CLASS"),
	garage_price = GetPVarInt(playerid, "GARAGE_PRICE"),

	class_text[32];

	new string[312];
	new g = TotalGarages;

	GARAGE_DATA[g][data_ENTER_X] = enter_x;
	GARAGE_DATA[g][data_ENTER_Y] = enter_y;
	GARAGE_DATA[g][data_ENTER_Z] = enter_z;
	GARAGE_DATA[g][data_ENTER_X_CAR] = enter_x_car;
	GARAGE_DATA[g][data_ENTER_Y_CAR] = enter_y_car;
	GARAGE_DATA[g][data_ENTER_Z_CAR] = enter_z_car;
	GARAGE_DATA[g][data_ENTER_A_CAR] = enter_a_car;
	GARAGE_DATA[g][data_EXIT_X] = exit_x;
	GARAGE_DATA[g][data_EXIT_Y] = exit_y;
	GARAGE_DATA[g][data_EXIT_Z] = exit_z;
	GARAGE_DATA[g][data_TYPE] = garage_type;
	GARAGE_DATA[g][data_LOCK] = 1;
	GARAGE_DATA[g][data_OWNED] = 0;
	GARAGE_DATA[g][data_PRICE] = garage_price;
	GARAGE_DATA[g][data_INT] = GARAGE_DATA[g][data_WORLD] = TotalGarages+1;
	strmid(GARAGE_DATA[g][data_OWNER], "None", 0, strlen(GARAGE_DATA[g][data_OWNER]), 24);

	switch(GARAGE_DATA[g][data_TYPE])
	{
		case 1: class_text = "Низкий";
		case 2: class_text = "Средний";
		case 3: class_text = "Премиум";
	}

	format(string, 200, "{5AB4E4}- Гараж №%d -\n\n{5AB4E4}Владелец:{FFFFFF}  государство\n{5AB4E4}Класс:{FFFFFF}  %s\n{5AB4E4}Цена:{FFFFFF}  %d рублей\n\n{C9CBCC}/buy - купить гараж", TotalGarages + 1, class_text, GARAGE_DATA[g][data_PRICE]);

	GARAGE_DATA[g][data_ICON] = CreateDynamicMapIcon(GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z], 35, -1, 0, -1, -1, 100.0);
	GARAGE_DATA[g][data_TEXT] = CreateDynamic3DTextLabel(string, 0xFFFFFFFF, GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z], 15.0, INVALID_PLAYER_ID, INVALID_VEHICLE_ID, 1, -1, -1);
	GARAGE_DATA[g][data_PIC] = CreateDynamicPickup(1239, 23, GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z]);

	TotalGarages++;
	GARAGE_DATA[g][data_ID] = TotalGarages;

	DeletePVar(playerid, "CREATE_GARAGE");

	format(string, sizeof(string), "Гараж №%d успешно добавлен на сервер", TotalGarages);
    SendClientMessage(playerid, COLOR_BLUE, string);

	//new string[312];
	mysql_format(dbHandle, string, 400, "INSERT INTO `garages` (`enter_x`, `enter_y`, `enter_z`, `enter_x_car`, `enter_y_car`, `enter_z_car`, `enter_a_car`, `exit_x`, `exit_y`, `exit_z`, `lock`, `type`, `owner`, `owned`, `price`, `int`, `world`)\
	 VALUES( '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '1', '%d', '%s', '%d', '%d', '%d', '%d')", GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z],
	GARAGE_DATA[g][data_ENTER_X_CAR], GARAGE_DATA[g][data_ENTER_Y_CAR], GARAGE_DATA[g][data_ENTER_Z_CAR], GARAGE_DATA[g][data_ENTER_A_CAR],
	GARAGE_DATA[g][data_EXIT_X], GARAGE_DATA[g][data_EXIT_Y], GARAGE_DATA[g][data_EXIT_Z], GARAGE_DATA[g][data_TYPE], GARAGE_DATA[g][data_OWNER], GARAGE_DATA[g][data_OWNED], GARAGE_DATA[g][data_PRICE],
	GARAGE_DATA[g][data_INT], GARAGE_DATA[g][data_WORLD]);
	mysql_function_query(dbHandle, string, false, "", "");
	return true;
}

stock SaveGarageData(g)
{
	new string[256],query[1000];
	query = "UPDATE `garages` SET ";
	acc_str_strcat(query, sizeof(query), "owner", GARAGE_DATA[g][data_OWNER]);
	acc_int_strcat(query, sizeof(query), "owned", GARAGE_DATA[g][data_OWNED]);
	acc_int_strcat(query, sizeof(query), "update", GARAGE_DATA[g][data_UPDATE]);
	acc_int_strcat(query, sizeof(query), "lock", GARAGE_DATA[g][data_LOCK]);
	acc_int_strcat(query, sizeof(query), "day", GARAGE_DATA[g][data_DAY]);
	strdel(query, strlen(query)-1, strlen(query));
	format(string,sizeof(string)," WHERE `id` = '%d' LIMIT 1",GARAGE_DATA[g][data_ID]);
	strcat(query, string);
	mysql_function_query(dbHandle, query, true, "", "");
	return true;
}

stock UpdateGarageData(g)
{
	new class_text[20];
	new string[312];

	switch(GARAGE_DATA[g][data_TYPE])
	{
	case 1: class_text = "Низкий";
	case 2: class_text = "Средний";
	case 3: class_text = "Высокий";
	}

	if(GARAGE_DATA[g][data_OWNED] == 0)
	{
		format(string, 200, "{5AB4E4}- Гараж №%d -\n\n{5AB4E4}Владелец:{FFFFFF} государство\n{5AB4E4}Класс:{FFFFFF} %s\n{5AB4E4}Цена:{FFFFFF} %d рублей\n\n{C9CBCC}/buy - купить гараж", g + 1, class_text, GARAGE_DATA[g][data_PRICE]);
		UpdateDynamic3DTextLabelText(GARAGE_DATA[g][data_TEXT], -1, string);
	}
	else
	{
		format(string, 200, "{5AB4E4}- Гараж №%d -\n\n{5AB4E4}Владелец: %s\n{5AB4E4}Класс:{FFFFFF} %s\n{C9CBCC}Попасть в гараж: ALT(пешком), H(за рулем)", g + 1, GARAGE_DATA[g][data_OWNER], class_text);
		UpdateDynamic3DTextLabelText(GARAGE_DATA[g][data_TEXT], -1, string);
	}
	return true;
}

stock GetPlayerGarage(playerid)
{
	new garage_id = -1;
	for(new i = 0; i < TotalGarages;i++)
	{
		if(!strcmp(GARAGE_DATA[i][data_OWNER], PLAYER_DATA[playerid][data_NAME], true)) garage_id = i;
	}
	return garage_id;
}

