CMD:pleave(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_POLIT] == 0) return SendClientMessage(playerid, COLOR_WARNING,"Вам недоступна данная команда!");
    new team = GetPlayerPolit(playerid);
	if(strfind(POLIT_TEAM[team][data_OWNER], PLAYER_DATA[playerid][data_NAME], true) != -1) return SendClientMessage(playerid, COLOR_WARNING,"Вам недоступна данная команда!");

	ShowPlayerDialogFix(playerid, dialog_PLEAVE, DIALOG_STYLE_MSGBOX, "{FFCC00}Семья", "{FFFFFF}Вы желаете покинуть семью?", "Покинуть", "Отмена");
	return true;
}


CMD:allpmembers(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_LEADER] == 0) return SendClientMessage(playerid,COLOR_WARNING, "Вам недоступна данная команда!");

    new team = GetPlayerPolit(playerid);
	if(strfind(POLIT_TEAM[team][data_OWNER], PLAYER_DATA[playerid][data_NAME], true) != -1)
	{
	    new query[145];
		format(query,sizeof(query),"SELECT * FROM `accounts` WHERE `polit` = '%d'",PLAYER_DATA[playerid][data_POLIT]);
		mysql_function_query(dbHandle, query, true, "LoadAllPMembers", "d", playerid);
	}
	else SendClientMessage(playerid, COLOR_WARNING,"Данная функция доступна только основателю семьи!");

	return true;
}

CMD:funinvite(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	new team = GetPlayerPolit(playerid);
	if(strfind(POLIT_TEAM[team][data_OWNER], PLAYER_DATA[playerid][data_NAME], true) != -1)
	{
		if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /funinvite [ид]");
	    if(params[0] == playerid) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя использовать на самом себе!");
		if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
		if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
		if(PLAYER_DATA[params[0]][data_POLIT] != PLAYER_DATA[playerid][data_POLIT]) return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок состоит в вашей семье!");

	    new str[145];
		format(str,sizeof(str),"%s выгнал из семьи %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
		SendPolitMessage(PLAYER_DATA[playerid][data_POLIT],0xFF3333FF,str);

	    PLAYER_DATA[params[0]][data_POLIT] = 0;
	    SavePlayerData(params[0]);
	}
	else SendClientMessage(playerid, COLOR_WARNING,"Данная функция доступна только основателю семьи!");
	return true;
}

CMD:fchat(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MUTE] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Ваш чат временно заблокирован!");
	if(sscanf(params,"s[100]",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /fchat [текст]");
	if(PLAYER_DATA[playerid][data_POLIT] == 0) return  SendClientMessage(playerid,COLOR_WARNING,"Вы не состоите в семье!");
	NotReklama(playerid, params[0]);

	new str[145];
	format(str,sizeof(str),"[Семья] %s[%d]: %s",PLAYER_DATA[playerid][data_NAME],playerid,params[0]);
	SendPolitMessage(PLAYER_DATA[playerid][data_POLIT],0x339999FF,str);
	return true;
}

CMD:makegun(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MUTE] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Ваш чат временно заблокирован!");

	if(PLAYER_DATA[playerid][data_MEMBER] == 2 ||
	PLAYER_DATA[playerid][data_MEMBER] == 5 ||
	PLAYER_DATA[playerid][data_MEMBER] == 6||
	PLAYER_DATA[playerid][data_MEMBER] == 7)
	{
	    ShowPlayerDialogFix(playerid, dialog_MAKEGUN, DIALOG_STYLE_LIST, "{FFCC00}Выберите оружие",
		"{1fa1ea}1.{FFFFFF}Пистолет с глушителем (125 металла)\n\
		{1fa1ea}2.{FFFFFF}Убойный пистолет (200 металла)\n\
		{1fa1ea}3.{FFFFFF}Штурмовая винтовка (300 металла)\n\
		{1fa1ea}4.{FFFFFF}Пистолет (100 металла)\n\
		{1fa1ea}5.{FFFFFF}Автомат (250 металла)\n\
		{1fa1ea}6.{FFFFFF}Дробовик (200 металла)\n\
		{1fa1ea}7.{FFFFFF}Снайперская винтовка (500 металла)", "Далее", "Отмена");
	}
	else SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
	return true;
}

CMD:afly(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    SetPVarInt(playerid,"spawn_ac",1);

	if(GetPVarType(playerid, "FlyMode"))
	{
	    new inter, world, Float:X, Float:Y, Float:Z, Float:FA;
	    GetPlayerHealth(playerid,PLAYER_DATA[playerid][data_HP]);
		GetPlayerPos(playerid, X, Y, Z);
		GetPlayerFacingAngle(playerid, FA);
		inter = GetPlayerInterior(playerid);
		world = GetPlayerVirtualWorld(playerid);
		SetPVarFloat(playerid, "SpecX", X);
		SetPVarFloat(playerid, "SpecY", Y);
		SetPVarFloat(playerid, "SpecZ", Z);
		SetPVarFloat(playerid, "SpecFA", FA);
		SetPVarInt(playerid, "SpecInt", inter);
		SetPVarInt(playerid, "SpecWorld", world);

		CancelFlyMode(playerid);
	}
	else
	{
		SetPVarInt(playerid, "SpecBool", 1);
		FlyMode(playerid);
	}
	return true;
}



CMD:sp(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
    if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /sp [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_WARNING,"Нельзя наблюдать за самим собой!");
	if(GetPVarInt(params[0], "SpecBool") == 1) return SendClientMessage(playerid,COLOR_WARNING,"Игрок находится в режиме наблюдения!");
    SetPVarInt(playerid,"spawn_ac",1);
	new inter, world, Float:X, Float:Y, Float:Z, Float:FA;
	ShowAdmInfo(playerid, params[0]);
	SetPVarInt(playerid,"specid",params[0]);
	if(GetPVarInt(playerid,"SpecBool") == 0)
	{
	    GetPlayerHealth(playerid,PLAYER_DATA[playerid][data_HP]);
		GetPlayerPos(playerid, X, Y, Z);
		GetPlayerFacingAngle(playerid, FA);
		inter = GetPlayerInterior(playerid);
		world = GetPlayerVirtualWorld(playerid);
		SetPVarInt(playerid, "SpecBool", 1);
		SetPVarFloat(playerid, "SpecX", X);
		SetPVarFloat(playerid, "SpecY", Y);
		SetPVarFloat(playerid, "SpecZ", Z);
		SetPVarFloat(playerid, "SpecFA", FA);
		SetPVarInt(playerid, "SpecInt", inter);
		SetPVarInt(playerid, "SpecWorld", world);
	}
	SetPlayerInterior(playerid,GetPlayerInterior(params[0]));
	SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(params[0]));
	TogglePlayerSpectating(playerid,true);
	if(IsPlayerInAnyVehicle(params[0]))
	{
		new carid = GetPlayerVehicleID(params[0]);
		PlayerSpectateVehicle(playerid, carid);
	}
	else PlayerSpectatePlayer(playerid,params[0]);
	new message[145];
	format(message,sizeof(message),"{808080}[A] %s[%d] начал следить за %s[%d]",PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[params[0]][data_NAME],params[0]);
	SendAdminMessage(0x666699FF,message);
	return true;
}

CMD:spoff(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
	if(GetPVarInt(playerid, "SpecBool") == 0) return SendClientMessage(playerid,COLOR_WARNING,"Вы не находитесь в статусе слежения!");
    SetPVarInt(playerid,"spawn_ac",1);
	TogglePlayerSpectating(playerid,false);
	return true;
}

CMD:put(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MEMBER] == 2)
	{
	    if(PLAYER_DATA[playerid][data_PUTPATR] == 0 && PLAYER_DATA[playerid][data_PUTMET] == 0) return SendClientMessage(playerid, COLOR_WARNING,"У Вас нет в руках ящика!");
		for(new c = 0; c < MAX_VEHICLES; c++)
		{
			new model = GetVehicleModel(c);
			new Float:x,Float:y,Float:z;
			GetCoordBootVehicle(c, x, y, z);
			if(PlayerToPoint(2.0, playerid, x, y, z))
		 	{
				if(model != 433) return SendClientMessage(playerid,COLOR_WARNING, "Это не специальный грузовик!");

				if(PLAYER_DATA[playerid][data_PUTPATR] != 0)
				{
					if(CAR_DATA[c][data_PATR] >= 10000) return SendClientMessage(playerid,COLOR_WARNING, "В грузовике недостаточно места!");
	                CAR_DATA[c][data_PATR] += 500;
	                PLAYER_DATA[playerid][data_PUTPATR] = 0;
	                GameTextForPlayer(playerid, "~g~PUT PATR", 1000, 1);
	                if(IsPlayerAttachedObjectSlotUsed(playerid, 3)) RemovePlayerAttachedObject(playerid, 3);
	                SetPlayerSpecialAction(playerid,0);
	                return true;
                }
                else if(PLAYER_DATA[playerid][data_PUTMET] != 0)
				{
					if(CAR_DATA[c][data_MET] >= 10000) return SendClientMessage(playerid,COLOR_WARNING, "В грузовике недостаточно места!");
	                CAR_DATA[c][data_MET] += 500;
	                PLAYER_DATA[playerid][data_PUTMET] = 0;
	                GameTextForPlayer(playerid, "~g~PUT MET", 1000, 1);
	                if(IsPlayerAttachedObjectSlotUsed(playerid, 3)) RemovePlayerAttachedObject(playerid, 3);
	                SetPlayerSpecialAction(playerid,0);
	                return true;
                }
			}
		}
		PLAYER_DATA[playerid][data_PUTPATR] = 0;
		PLAYER_DATA[playerid][data_PUTMET] = 0;
		GameTextForPlayer(playerid, "~r~PUT", 1000, 1);
		if(IsPlayerAttachedObjectSlotUsed(playerid, 3)) RemovePlayerAttachedObject(playerid, 3);
		SetPlayerSpecialAction(playerid,0);
	}
	else SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
	return true;
}

CMD:bar(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

	new Float:x,Float:y,Float:z,model;
	for(new c = 0; c < MAX_VEHICLES; c++)
	{
	    GetVehiclePos(c,x,y,z);
	    model = GetVehicleModel(c);
	    if(PlayerToPoint(10.0, playerid, x,y,z) && model == 454)
		{
		    ShowPlayerDialogFix(playerid, dialog_CATER, DIALOG_STYLE_LIST, "{FFCC00}Бар",
			"{1fa1ea}1.{FFFFFF}Спранк\n\
			{1fa1ea}2.{FFFFFF}Кофе\n\
			{1fa1ea}3.{FFFFFF}Пиво\n\
			{1fa1ea}4.{FFFFFF}Водка\n\
			{1fa1ea}5.{FFFFFF}Вино\n\
			{1fa1ea}6.{FFFFFF}Коньяк\n\
			{1fa1ea}7.{FFFFFF}Виски\n\
			{1fa1ea}8.{FFFFFF}Ром", "Выбрать", "Отмена");
			break;
		}
	}
	return true;
}

CMD:gunload(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_MEMBER] == 2)
	{
	    new car = GetPlayerVehicleID(playerid);
	    new model = GetVehicleModel(car);
	    new materials = CAR_DATA[car][data_PATR];
		new metals = CAR_DATA[car][data_MET];
	    if(model != 433) return SendClientMessage(playerid, COLOR_WARNING, "Нужно находиться в специальном грузовике!");

		if(PlayerToPoint(90.0, playerid, 1450.2400,1691.6246,15.3193) && PLAYER_DATA[playerid][data_MEMBER] == 2)
	    {
	        if(car >= army_car[0] && car <= army_car[1])
	        {
	            if(CAR_DATA[car][data_PATR] != 0 || CAR_DATA[car][data_MET] != 0)
	            {
					army_wh[1] += materials;
					CAR_DATA[car][data_PATR] = 0;

					army_wh[0] += metals;
					CAR_DATA[car][data_MET] = 0;

					new str[145];
					format(str,sizeof(str),"[R] %s[%d] разгрузил(а) грузовик с боеприпасами. (+%d патронов, +%d металла)",PLAYER_DATA[playerid][data_NAME],playerid, materials, metals);
					SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER],0xFF9999FF,str);

					new str1[256];
            		format(str1,sizeof(str1),"{3366FF}Склад армии\n{FFFFFF}Металла на складе: {FF6600}%d шт.\n{FFFFFF}Патронов на складе: {FF6600}%d шт.",army_wh[0],army_wh[1]);
       				UpdateDynamic3DTextLabelText(army_sklad_text, -1, str1);

					return true;
				}
                SendClientMessage(playerid, COLOR_WARNING, "Грузовик пуст!");
			}
			else SendClientMessage(playerid, COLOR_WARNING, "Нужно находиться в специальном грузовике!");
		}
		else SendClientMessage(playerid, COLOR_WARNING, "Разгрузить можно только на базе армии!");
	}
	else SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
	return true;
}

CMD:lock(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	for(new c = 0; c < MAX_VEHICLES; c++)
	{
		if(c == PLAYER_DATA[playerid][data_VEH])
		{
			new Float:x,Float:y,Float:z;
		    GetVehiclePos(c,x,y,z);
			if(!PlayerToPoint(5.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Вы находитесь далеко от личного транспорта!");
			switch(CAR_DATA[c][data_LOCK])
			{
				case 0:
				{
				    PlayerPlaySound(playerid, 25800, 0.0, 0.0, 0.0);
					GetVehicleParamsEx(c,engine,lights,alarm,doors,bonnet,boot,objective);
					SetVehicleParamsEx(c,engine,lights,alarm,true,bonnet,boot,objective);
					CAR_DATA[c][data_LOCK] = 1;
					GameTextForPlayer(playerid, "~r~LOCK", 1000, 4);
				}
				case 1:
				{
				    PlayerPlaySound(playerid, 25800, 0.0, 0.0, 0.0);
					GetVehicleParamsEx(c,engine,lights,alarm,doors,bonnet,boot,objective);
					SetVehicleParamsEx(c,engine,lights,alarm,false,bonnet,boot,objective);
					CAR_DATA[c][data_LOCK] = 0;
					GameTextForPlayer(playerid, "~g~LOCK", 1000, 4);
				}
			}
		}
	}
	return true;
}

CMD:ogo(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 5) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(ooc == false)
    {
        new str[145];
        format(str,sizeof(str),"*** Администратор %s включил общий чат (/o [текст]) ***",PLAYER_DATA[playerid][data_NAME]);
        SendClientMessageToAll(-1, str);
    	ooc = true;
    }
    else
    {
        new str[145];
        format(str,sizeof(str),"*** Администратор %s отключил общий чат ***",PLAYER_DATA[playerid][data_NAME]);
        SendClientMessageToAll(-1, str);
        ooc = false;
    }
	return true;
}

CMD:o(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(ooc == false) return SendClientMessage(playerid, COLOR_WARNING, "Функция была отключена администратором!");
	if(sscanf(params,"s[100]",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /o [текст]");
    NotReklama(playerid, params[0]);

	new str[145];
	format(str,sizeof(str),"[OOC] %s[%d]: %s",PLAYER_DATA[playerid][data_NAME],playerid, params[0]);
	SendClientMessageToAll( -1, str);
	return true;
}


CMD:attach(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /attach [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");

    SetPVarInt(playerid, "attach_id",params[0]);
    new string[128];
	for(new x = 0; x < MAX_PLAYER_ATTACHED_OBJECTS; x++)
 	{
		if(IsPlayerAttachedObjectSlotUsed(params[0], x)) format(string, sizeof(string), "%s%d (Used)\n", string, x);
		else format(string, sizeof(string), "%s%d\n", string, x);
	}
	ShowPlayerDialogFix(playerid, dialog_ATTACH_INDEX_SELECTION, DIALOG_STYLE_LIST, "{FFCC00}Выберите слот", string, "Выбрать", "Отмена");
    return true;
}

CMD:editobject(playerid,params[0])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
    if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /editobject [ид]");

	EditObject(playerid, params[0]);
	return true;
}

CMD:object(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new string[2000];
	for(new x;x<sizeof(AttachmentObjects);x++)
	{
		format(string, sizeof(string), "%s%s\n", string, AttachmentObjects[x][attachname]);
	}
  	ShowPlayerDialogFix(playerid, dialog_ATTACH_OBJECT, DIALOG_STYLE_LIST,"{FFCC00}Выберите объект", string, "Выбрать", "Отмена");
    return true;
}

CMD:mphp(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
	if(sscanf(params,"d",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /mphp [кол-во]");

	new Float:x,Float:y,Float:z;
	GetPlayerPos(playerid, x,y,z);


   	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(i == playerid) continue;
		if(!IsPlayerConnected(i)) continue;
		if(PlayerToPoint(100.0, i, x,y,z))
		{
		    SetPlayerHealthAC(playerid, params[0]);
		}
   	}
    return true;
}

