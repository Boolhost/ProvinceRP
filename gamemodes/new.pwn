stock ProxDetector(Float:radi, playerid, string[],col1,col2,col3,col4,col5)
{
    if(IsPlayerConnected(playerid))
    {
        new Float:posx, Float:posy, Float:posz;
        new Float:oldposx, Float:oldposy, Float:oldposz;
        new Float:tempposx, Float:tempposy, Float:tempposz;
        GetPlayerPos(playerid, oldposx, oldposy, oldposz);
        new vw = GetPlayerVirtualWorld(playerid);
        for(new i = 0; i < MAX_PLAYERS; i++)
        {
            if(!IsPlayerConnected(i)) continue;
            if(IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == vw)
            {
                GetPlayerPos(i, posx, posy, posz);
                tempposx = (oldposx -posx);
                tempposy = (oldposy -posy);
                tempposz = (oldposz -posz);
                if (((tempposx < radi/16) && (tempposx > -radi/16)) && ((tempposy < radi/16) && (tempposy > -radi/16)) && ((tempposz < radi/16) && (tempposz > -radi/16))) SendClientMessage(i, col1, string);
                else if (((tempposx < radi/8) && (tempposx > -radi/8)) && ((tempposy < radi/8) && (tempposy > -radi/8)) && ((tempposz < radi/8) && (tempposz > -radi/8))) SendClientMessage(i, col2, string);
                else if (((tempposx < radi/4) && (tempposx > -radi/4)) && ((tempposy < radi/4) && (tempposy > -radi/4)) && ((tempposz < radi/4) && (tempposz > -radi/4))) SendClientMessage(i, col3, string);
                else if (((tempposx < radi/2) && (tempposx > -radi/2)) && ((tempposy < radi/2) && (tempposy > -radi/2)) && ((tempposz < radi/2) && (tempposz > -radi/2))) SendClientMessage(i, col4, string);
                else if (((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi))) SendClientMessage(i, col5, string);
            }
            else {}
        }
    }
    return true;
}

public LOG(tablename[], tname[], itext[])
{
	new string[1024],hour,minute,second,timestr[64];
	gettime(hour,minute,second);
	format(timestr,sizeof(timestr),"%02d:%02d:%02d",hour,minute,second);
	mysql_format(dbHandle,string, sizeof(string), "INSERT INTO `%s` (`name`,`date`, `time`, `text`) VALUES ('%s',NOW(), '%s', '%s')", tablename, tname, timestr, itext);
	mysql_function_query(dbHandle, string, true, "", "");
	return true;
}

public OnPlayerEditAttachedObject( playerid, response, index, modelid, boneid, Float:fOffsetX, Float:fOffsetY, Float:fOffsetZ, Float:fRotX, Float:fRotY, Float:fRotZ, Float:fScaleX, Float:fScaleY, Float:fScaleZ )
{
    SetPlayerAttachedObject(playerid,index,modelid,boneid,fOffsetX,fOffsetY,fOffsetZ,fRotX,fRotY,fRotZ,fScaleX,fScaleY,fScaleZ);
	return true;
}

public ExitServer()
{
    SendRconCommand("exit");
	return true;
}

public RestartServer()
{
    SendRconCommand("gmx");
	return true;
}

public GodModeTest(playerid, testid)
{

	new Float:newhp;
	GetPlayerHealth(testid, newhp);
	GMTest[testid] = false;

	if(newhp >= AdmGMHP[testid])
	{
	    ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, PLAYER_DATA[testid][data_NAME], "{FF6666}Игрок использует GodMode", "Закрыть", "");
	    // gm
	}
	else if(newhp < AdmGMHP[testid])
	{
	    SetPlayerHealthAC(testid, AdmGMHP[testid]);
	    ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, PLAYER_DATA[testid][data_NAME], "{33CC99}Игрок не использует GodMode", "Закрыть", "");
	}
	return true;
}
stock RestartCFG()
{
 	SetTimer("RestartServer",1000*60, false);
    SendRconCommand("hostname РЕСТАРТ СЕРВЕРА, ОЖИДАЙТЕ 1 МИНУТУ!");
	SendRconCommand("password restartServerrp");

	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
		SendClientMessage(i, COLOR_AC, "[ВНИМАНИЕ] Приносим свои извинения. Рестарт сервера!");
		Kick(i);
	}
	for(new h = 0; h < TotalHouses; h++)
	{
		if(HOUSE_DATA[h][data_OWNED] == 1)
		{
			if(HOUSE_DATA[h][data_DAY] > 1)
			{
				HOUSE_DATA[h][data_DAY]--;
			}
			else
			{
			    new query[256];
	            mysql_format(dbHandle,query, sizeof(query), "UPDATE `accounts` SET `house` = '-1', `salary` = '%d' WHERE `house` = '%d'",HOUSE_DATA[h][data_PRICE]/2, h);
    			mysql_function_query(dbHandle, query, false, "", "");
    			strmid(HOUSE_DATA[h][data_OWNER], "none", 0, strlen(HOUSE_DATA[h][data_OWNER]), 24);
    			HOUSE_DATA[h][data_OWNED] = 0;
			}
			SaveHouseData(h);
		}
	}

	for(new kv = 0; kv < TotalKV; kv++)
	{
		for(new k = 0; k < 6; k++)
		{
  			if(KV_DATA[kv][data_OWNED][k] == 1)
			{
				if(KV_DATA[kv][data_DAY][k] > 1)
				{
					KV_DATA[kv][data_DAY][k]--;
				}
				else
				{

				    switch(k)
					{
						case 0: strmid(KV_DATA[kv][data_OWNER_1], "none", 0, strlen(KV_DATA[kv][data_OWNER_1]), MAX_PLAYER_NAME);
						case 1: strmid(KV_DATA[kv][data_OWNER_2], "none", 0, strlen(KV_DATA[kv][data_OWNER_2]), MAX_PLAYER_NAME);
						case 2: strmid(KV_DATA[kv][data_OWNER_3], "none", 0, strlen(KV_DATA[kv][data_OWNER_3]), MAX_PLAYER_NAME);
						case 3: strmid(KV_DATA[kv][data_OWNER_4], "none", 0, strlen(KV_DATA[kv][data_OWNER_4]), MAX_PLAYER_NAME);
						case 4: strmid(KV_DATA[kv][data_OWNER_5], "none", 0, strlen(KV_DATA[kv][data_OWNER_5]), MAX_PLAYER_NAME);
						case 5: strmid(KV_DATA[kv][data_OWNER_6], "none", 0, strlen(KV_DATA[kv][data_OWNER_6]), MAX_PLAYER_NAME);
					}


				    new query[256];
				    mysql_format(dbHandle,query, sizeof(query), "UPDATE `accounts` SET `kv` = '-1', `padik` = '-1', `salary` = '%d' WHERE `padik` = '%d' AND `kv` = '%d'", KV_DATA[kv][data_PRICE][k]/2, kv, k);
	    			mysql_function_query(dbHandle, query, false,  "", "");

	    			KV_DATA[kv][data_OWNED][k] = 0;
				}
			}
		}
		SaveKVData(kv);
	}




	for(new b = 0; b < TotalBusiness; b++)
	{
		if(BUSINESS_DATA[b][data_OWNED] == 1)
		{
			if(BUSINESS_DATA[b][data_DAY] > 1) BUSINESS_DATA[b][data_DAY]--;
			else
			{
			    new query[128];
	            mysql_format(dbHandle,query, sizeof(query), "UPDATE `accounts` SET `business` = '-1', `salary` = '%d' WHERE `business` = '%d'",BUSINESS_DATA[b][data_PRICE]/2,b);
    			mysql_function_query(dbHandle, query, false, "", "");
    			strmid(BUSINESS_DATA[b][data_OWNER], "none", 0, strlen(BUSINESS_DATA[b][data_OWNER]), 24);
    			BUSINESS_DATA[b][data_OWNED] = 0;
			}
			SaveBusinessData(b);
		}
	}
	//mysql_function_query(dbHandle, "UPDATE `accounts` SET `time` = '0', `podarok1` = '0', `podarok2` = '0', `podarok3` = '0', `podarok4` = '0', `podarok5` = '0', `podarok6` = '0', `podarok7` = '0', `podarok8` = '0' WHERE `id` != '0'", false, "", "");


	for(new b = 0; b < TotalJB; b++) SaveJBData(b);
 	for(new a = 0; a < TotalAB; a++) SaveABData(a);
 	SaveWarehouse();


	mysql_function_query(dbHandle, "SELECT * FROM `banlist`",true, "LoadBans", "");
	return true;
}

stock IsMOTO(carid)
{
	new model = GetVehicleModel(carid);
	if(model == 468 || model == 483 || model == 462 || model == 586 || model == 581 ||model == 523 || model == 522 || model == 521 || model == 481 || model == 510 || model == 509 || model == 462 || model == 484 || model == 454) return true;
	return false;
}

stock IsPLANE(carid)
{
	new model = GetVehicleModel(carid);
	if(model == 417 || model == 425 || model == 430 || model == 446 || model == 447 || model == 452 || model == 453 || model == 454 || model == 460 || model == 464 || model == 465 || model == 469 || model == 472 || model == 473 || model == 476 || model == 484 || model == 487 ||
	model == 488 || model == 493 || model == 497 || model == 501 || model == 511 || model == 512 || model == 513 || model == 519 || model == 520 || model == 548 || model == 553 || model == 563 || model == 564 || model == 577 || model == 592 || model == 593 || model == 595)return true;
	return false;
}

stock IsABMX(carid)
{
	new model = GetVehicleModel(carid);
	if(model == 481 || model == 510 || model == 509 || model == 462 || model == 484 || model == 454) return true;
	return false;
}

stock Player_Speed(playerid)
{
    new Float:ST[4];
    if(IsPlayerInAnyVehicle(playerid)) GetVehicleVelocity(GetPlayerVehicleID(playerid),ST[0],ST[1],ST[2]);
   	else GetPlayerVelocity(playerid,ST[0],ST[1],ST[2]);
   	ST[3] = floatsqroot(floatpower(floatabs(ST[0]), 2.0) + floatpower(floatabs(ST[1]), 2.0) + floatpower(floatabs(ST[2]), 2.0)) * 100.3;
    return floatround(ST[3]);
}

stock SpawnPlayerAC(playerid)
{
    SetPVarInt(playerid,"spawn_ac",1);
    SetPlayerSpawn(playerid);
    return true;
}

stock CreateAccount(playerid)
{
	new query[300];
    mysql_format(dbHandle, query, sizeof(query), "INSERT INTO `accounts` ( `name`, `password`, `email`, `register_ip`, `referal`, `sex`, `regdate_day`, `regdate_month`, `regdate_year`, `skin`) VALUES ( '%e', MD5('%e'), '%e', '%s', '%s', '%d', '%d', '%d', '%d', '%d')",
	PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[playerid][data_PASSWORD],PLAYER_DATA[playerid][data_EMAIL],PLAYER_DATA[playerid][data_REGISTER_IP],PLAYER_DATA[playerid][data_REFERAL],PLAYER_DATA[playerid][data_SEX],PLAYER_DATA[playerid][data_REGDATE_DAY],PLAYER_DATA[playerid][data_REGDATE_MONTH],PLAYER_DATA[playerid][data_REGDATE_YEAR],PLAYER_DATA[playerid][data_SKIN]);
    mysql_function_query(dbHandle, query, false, "", "");
    SavePlayerData(playerid);
	return true;
}

stock SELECT_skin(playerid)
{
    SendClientMessage(playerid,0xFF3333FF,"Для выбора кнопки используйте клавиши 'W' и 'S', чтобы нажать на кнопку используйте 'Пробел' или 'Shift'");
	new virtworld = random(687);
	SetPlayerVirtualWorld(playerid,virtworld);
	SetPlayerInterior(playerid,0);
	TogglePlayerControllable(playerid, false);
	SetPlayerPosAC(playerid, -226.2288,487.0842,21.0635);
	SetPlayerFacingAngle(playerid,200.0);
	InterpolateCameraPos(playerid, -222.566482, 485.403137, 22.127206, -222.566482, 485.403137, 22.127206, 1000);
	InterpolateCameraLookAt(playerid, -227.177688, 486.782836, 20.773227, -227.177688, 486.782836, 20.773227, 1000);
    new skin = PLAYER_DATA[playerid][data_CHANGESKIN];
    if(PLAYER_DATA[playerid][data_SEX] == 1)SetPlayerSkinAC(playerid,PedMale[skin]);
	else SetPlayerSkinAC(playerid,PedFeMale[skin]);
	ShowMenuForPlayer(SelectSkin,playerid);
	return true;
}

stock ShowBankMoney(playerid)
{
    new dtext[50];
	format(dtext,sizeof(dtext),"{FFFFFF}Баланс: {66CC33}%d рублей", PLAYER_DATA[playerid][data_BANK]);
	PlayerPlaySound(playerid, 43000, 0.0, 0.0, 0.0);
	ShowPlayerDialogFix(playerid, dialog_BANK_1, DIALOG_STYLE_MSGBOX , "{FFCC00}Банк", dtext, "Закрыть", "Назад");
	return true;
}

