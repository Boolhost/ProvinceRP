			KV_DATA[kv][data_PICK_EXIT] = CreateDynamicPickup(1318, 23, KV_DATA[kv][data_EXIT_X], KV_DATA[kv][data_EXIT_Y], KV_DATA[kv][data_EXIT_Z],KV_DATA[kv][data_ID]);

			format(str1,sizeof(str1), "{66FF66}Подъезд №%d\n{FFCC00}Для входа нажмите 'ALT'",kv+1);
   			KV_DATA[kv][data_INF_ENTER] = CreateDynamic3DTextLabel(str1, -1, KV_DATA[kv][data_ENTER_X], KV_DATA[kv][data_ENTER_Y], KV_DATA[kv][data_ENTER_Z], 5.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,0);
   			KV_DATA[kv][data_INF_EXIT] = CreateDynamic3DTextLabel("{FFCC00}Для выхода нажмите 'ALT'", -1, KV_DATA[kv][data_EXIT_X], KV_DATA[kv][data_EXIT_Y], KV_DATA[kv][data_EXIT_Z], 5.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,KV_DATA[kv][data_ID]);
			new owner[MAX_PLAYER_NAME], class_kv[8],kk;
			for(new k = 0; k < 6; k++)
			{
				switch(k)
				{
				    case 0: strmid(owner, KV_DATA[kv][data_OWNER_1], 0, strlen(KV_DATA[kv][data_OWNER_1]), MAX_PLAYER_NAME);
				    case 1: strmid(owner, KV_DATA[kv][data_OWNER_2], 0, strlen(KV_DATA[kv][data_OWNER_2]), MAX_PLAYER_NAME);
				    case 2: strmid(owner, KV_DATA[kv][data_OWNER_3], 0, strlen(KV_DATA[kv][data_OWNER_3]), MAX_PLAYER_NAME);
				    case 3: strmid(owner, KV_DATA[kv][data_OWNER_4], 0, strlen(KV_DATA[kv][data_OWNER_4]), MAX_PLAYER_NAME);
				    case 4: strmid(owner, KV_DATA[kv][data_OWNER_5], 0, strlen(KV_DATA[kv][data_OWNER_5]), MAX_PLAYER_NAME);
				    case 5: strmid(owner, KV_DATA[kv][data_OWNER_6], 0, strlen(KV_DATA[kv][data_OWNER_6]), MAX_PLAYER_NAME);
				}

				switch(KV_DATA[kv][data_CLASS][k])
				{
				    case 0: class_kv = "Эконом";
				    case 1: class_kv = "Средний";
				    case 2: class_kv = "Элитный";
				}

				KV_DATA[kv][data_PICKKV_ENTER][k] = CreateDynamicPickup(1318, 23, KV_DATA[kv][data_ENTER_POSX][k], KV_DATA[kv][data_ENTER_POSY][k], KV_DATA[kv][data_ENTER_POSZ][k], KV_DATA[kv][data_ID]);
				KV_DATA[kv][data_PICKKV_EXIT][k] = CreateDynamicPickup(1318, 23, KV_DATA[kv][data_EXIT_POSX][k], KV_DATA[kv][data_EXIT_POSY][k], KV_DATA[kv][data_EXIT_POSZ][k], KV_DATA[kv][data_ID]+k);

				if(KV_DATA[kv][data_OWNED][k] == 0)
			    {
                    format(str,sizeof(str), "{66FF66}Квартира №%d\n{6699CC}Класс: {FFFFFF}%s\n{6699CC}Стоимость: {FFFFFF}%d рублей\n{FFCC00}Для покупки используйте: /buy",k+1, class_kv, KV_DATA[kv][data_PRICE][k]);
		 	        KV_DATA[kv][data_INFO][k] = CreateDynamic3DTextLabel(str, -1, KV_DATA[kv][data_ENTER_POSX][k], KV_DATA[kv][data_ENTER_POSY][k], KV_DATA[kv][data_ENTER_POSZ][k], 5.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,KV_DATA[kv][data_ID]);
			    }
			    else
			    {
			        kk++;
			        format(str,sizeof(str), "{66FF66}Квартира №%d\n{6699CC}Класс: {FFFFFF}%s\n{6699CC}Владелец: {FFFFFF}%s",k+1, class_kv, owner);
		 	        KV_DATA[kv][data_INFO][k] = CreateDynamic3DTextLabel(str, -1, KV_DATA[kv][data_ENTER_POSX][k], KV_DATA[kv][data_ENTER_POSY][k], KV_DATA[kv][data_ENTER_POSZ][k], 5.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,KV_DATA[kv][data_ID]);
			    }
			}
			if(kk == 6)
			{
			    KV_DATA[kv][data_MAPICON] = CreateDynamicMapIcon(KV_DATA[kv][data_ENTER_X], KV_DATA[kv][data_ENTER_Y], KV_DATA[kv][data_ENTER_Z], 32, -1, 0, -1, -1, 100.0);
			}
			else
			{
			    KV_DATA[kv][data_MAPICON] = CreateDynamicMapIcon(KV_DATA[kv][data_ENTER_X], KV_DATA[kv][data_ENTER_Y], KV_DATA[kv][data_ENTER_Z], 31, -1, 0, -1, -1, 100.0);
			}
        }
        printf("[serv_log]  Load kvartiry. Load: %d b. Time: %d ms.",TotalKV,GetTickCount()-time);
  	}
    return true;
}

public LoadGarages()
{
	new rows, fields, temp[256], time = GetTickCount();
	new string[312], class_text[32];
    cache_get_data(rows, fields);
    if(rows)
    {
		for(new g = 0; g < rows; g++)
		{
			cache_get_field_content(g, "id", temp), GARAGE_DATA[g][data_ID] = strval (temp);

			cache_get_field_content(g, "enter_x", temp), GARAGE_DATA[g][data_ENTER_X] = floatstr (temp);
			cache_get_field_content(g, "enter_y", temp), GARAGE_DATA[g][data_ENTER_Y] = floatstr (temp);
			cache_get_field_content(g, "enter_z", temp), GARAGE_DATA[g][data_ENTER_Z] = floatstr (temp);
			cache_get_field_content(g, "enter_x_car", temp), GARAGE_DATA[g][data_ENTER_X_CAR] = floatstr (temp);
			cache_get_field_content(g, "enter_y_car", temp), GARAGE_DATA[g][data_ENTER_Y_CAR] = floatstr (temp);
			cache_get_field_content(g, "enter_z_car", temp), GARAGE_DATA[g][data_ENTER_Z_CAR] = floatstr (temp);
			cache_get_field_content(g, "enter_a_car", temp), GARAGE_DATA[g][data_ENTER_A_CAR] = floatstr (temp);
			cache_get_field_content(g, "exit_x", temp), GARAGE_DATA[g][data_EXIT_X] = floatstr (temp);
			cache_get_field_content(g, "exit_y", temp), GARAGE_DATA[g][data_EXIT_Y] = floatstr (temp);
			cache_get_field_content(g, "exit_z", temp), GARAGE_DATA[g][data_EXIT_Z] = floatstr (temp);
			cache_get_field_content(g, "lock", temp), GARAGE_DATA[g][data_LOCK] = strval (temp);
			cache_get_field_content(g, "type", temp), GARAGE_DATA[g][data_TYPE] = strval (temp);
			cache_get_field_content(g, "owner", GARAGE_DATA[g][data_OWNER], dbHandle, MAX_PLAYER_NAME);
			cache_get_field_content(g, "owned", temp), GARAGE_DATA[g][data_OWNED] = strval (temp);
			cache_get_field_content(g, "price", temp), GARAGE_DATA[g][data_PRICE] = strval (temp);
			cache_get_field_content(g, "update", temp), GARAGE_DATA[g][data_UPDATE] = strval (temp);
			cache_get_field_content(g, "int", temp), GARAGE_DATA[g][data_INT] = strval (temp);
			cache_get_field_content(g, "world", temp), GARAGE_DATA[g][data_WORLD] = strval (temp);
			cache_get_field_content(g, "day", temp), GARAGE_DATA[g][data_DAY] = strval (temp);

			TotalGarages++;

			switch(GARAGE_DATA[g][data_TYPE])
			{
	   			case 1: class_text = "Низкий";
				case 2: class_text = "Средний";
				case 3: class_text = "Премиум";
			}

			if(GARAGE_DATA[g][data_OWNED] == 0)
			{
				format(string, 200, "{5AB4E4}- Гараж №%d -\n\n{5AB4E4}Владелец:{FFFFFF} {5AB4E4}государство\n{5AB4E4}Класс:{FFFFFF} %s\n{5AB4E4}Цена:{FFFFFF} %d рублей\n{C9CBCC}/buy - купить гараж", TotalGarages+1, class_text, GARAGE_DATA[g][data_PRICE]);
				GARAGE_DATA[g][data_TEXT] = CreateDynamic3DTextLabel(string, 0xFFFFFFFF, GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z], 15.0);
			}
			else
			{
				format(string, 200, "{5AB4E4}- Гараж №%d -\n\n{5AB4E4}Владелец:{FFFFFF}  %s\n{5AB4E4}Класс:{FFFFFF} %s\n{C9CBCC}Попасть в гараж: ALT(пешком), H(за рулем)", TotalGarages+1, GARAGE_DATA[g][data_OWNER],class_text);
				GARAGE_DATA[g][data_TEXT] = CreateDynamic3DTextLabel(string, 0xFFFFFFFF, GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z], 15.0);
			}
			GARAGE_DATA[g][data_ICON] = CreateDynamicMapIcon(GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z], 35, -1, 0, -1, -1, 200.0);
			GARAGE_DATA[g][data_PIC] = CreateDynamicPickup(1239, 23, GARAGE_DATA[g][data_ENTER_X], GARAGE_DATA[g][data_ENTER_Y], GARAGE_DATA[g][data_ENTER_Z]);

			printf("[serv_log]  Load garages. Load: %d b. Time: %d ms.",TotalGarages,GetTickCount()-time);
		}
	}
	return true;//printf("[Загружено гаражей]: <%d>. Потрачено: <%i ms>.", TotalGarages, GetTickCount()-time);
}

public LoadWarehouse()
{
	new rows, fields, temp[10],time = GetTickCount();
    cache_get_data(rows, fields);
    if(rows)
	{
		cache_get_field_content(0, "rostov_metal", temp), rostov_wh[0] = strval (temp);
		cache_get_field_content(0, "rostov_patr", temp), rostov_wh[1] = strval (temp);
		cache_get_field_content(0, "rostov_narko", temp), rostov_wh[2] = strval (temp);
		cache_get_field_content(0, "maykop_metal", temp), maykop_wh[0] = strval (temp);
		cache_get_field_content(0, "maykop_patr", temp), maykop_wh[1] = strval (temp);
		cache_get_field_content(0, "maykop_narko", temp), maykop_wh[2] = strval (temp);
