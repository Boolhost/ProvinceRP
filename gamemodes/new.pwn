CMD:spawncars(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    new Float:x,Float:y,Float:z;
	for(new v = 0; v < MAX_VEHICLES; v++)
	{
	    GetVehiclePos(v,x,y,z);
		if(PlayerToPoint(30.0, playerid, x,y,z))
  		{
			if(IsVehicleOccupied(v)) continue;
			SetVehicleToRespawn(v);
		}
	}
	new message[145];
	format(message,sizeof(message),"{808080}[A] %s заспавнил транспорт в радиусе 30 метров",PLAYER_DATA[playerid][data_NAME]);
	SendAdminMessage(0x666699FF,message);
	return true;
}

CMD:spawncar(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new carid = GetPlayerVehicleID(playerid);
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return SendClientMessage(playerid,COLOR_WARNING,"Нужно находиться за рулем транспорта!");
	SetVehicleToRespawn(carid);
	SendClientMessage(playerid,-1, "Автомобиль был заспавнен");
	return true;
}

CMD:setfuel(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(sscanf(params,"d",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /setfuel [кол-во]");
    if(IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
    {
		new carid = GetPlayerVehicleID(playerid);
		CAR_DATA[carid][data_FUEL] = params[0];
		SendClientMessage(playerid,COLOR_AC,"Уровень топлива в автомобиле изменен");
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Нужно находиться на водительском месте!");
	return true;

}

