	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
   	if(IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	{
		new carid = GetPlayerVehicleID(playerid);
		if(!IsABMX(carid))
		{
			switch(CAR_DATA[carid][data_LAMP])
			{
				case 0:
				{
					GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
					SetVehicleParamsEx(carid,engine,true,alarm,doors,bonnet,boot,objective);
					CAR_DATA[carid][data_LAMP] = 1;
				}
				case 1:
				{
					GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
					SetVehicleParamsEx(carid,engine,false,alarm,doors,bonnet,boot,objective);
					CAR_DATA[carid][data_LAMP] = 0;
				}
			}
		}
	}
	return true;
}

CMD:pay(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_LVL] < 2) return SendClientMessage(playerid,COLOR_WARNING,"Данную команду можно использовать только со 2 уровня!");
	if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /pay [ид] [кол-во]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(playerid == params[0]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя!");
	new Float:x,Float:y,Float:z,str[145];
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(3.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок далеко от Вас!");
	if(params[1] <= 0) return SendClientMessage(playerid, COLOR_WARNING, "Недопустимое значение!");

	if(PLAYER_DATA[playerid][data_VIP] == 0)
	{
		if(params[1] > 5000) return SendClientMessage(playerid,COLOR_WARNING,"Разрешено передавать не более 5000 рублей за один раз!");
	}
	else
	{
	    if(params[1] > 100000) return SendClientMessage(playerid,COLOR_WARNING,"Разрешено передавать не более 5000 рублей за один раз!");
	}

	if(get_player_money(playerid) < params[1]) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");
	give_player_money(playerid,-params[1],"#70");
	give_player_money(params[0],params[1],"#71");
	format(str,sizeof(str),"%s передал(а) деньги %s",PLAYER_DATA[playerid][data_NAME], PLAYER_DATA[params[0]][data_NAME]);
    ProxDetector(30.0, playerid, str,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF,0xFF66CCFF);
    SetPlayerChatBubble(playerid, "передал(а) деньги", 0xFF66CCFF, 20.0, 4000);

    new logtext[64];
    format(logtext,sizeof(logtext),"передал %s %d рублей",PLAYER_DATA[params[0]][data_NAME],params[1]);
    LOG("log_paymoney",PLAYER_DATA[playerid][data_NAME], logtext);
	return true;
}


CMD:eject(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return SendClientMessage(playerid,COLOR_WARNING,"Вы не за рулем!");
	if(sscanf(params,"d",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /eject [ид]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(params[0] == playerid) return SendClientMessage(playerid,COLOR_WARNING,"Вы не можете выкинуть из машины самого себя!");
    new car = GetPlayerVehicleID(playerid);
	new idcar = GetPlayerVehicleID(params[0]);
	if(!IsPlayerInVehicle(playerid,car)) return true;
	if(car != idcar) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не находиться в Вашей машине!");
	RemovePlayerFromVehicleAC(params[0]);
	new message[145];
	format(message,sizeof(message),"%s был выброшен из автомобиля",PLAYER_DATA[params[0]][data_NAME]);
	SendClientMessage(playerid,COLOR_BLUE,message);
	SendClientMessage(params[0],COLOR_BLUE,"Вас выбросили из автомобиля");
	return true;
}

CMD:lic(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_BLUE, "Используйте: /lic [ид]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(10.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок далеко от Вас!");
	if(GetPVarInt(params[0],"yesno") == 1) return SendClientMessage(playerid,COLOR_WARNING,"Игроку уже поступило предложение!");
    SetPVarInt(params[0], "yesno_showlic", 1);
    SetPVarInt(params[0], "yesno_playerid", playerid);
    SetPVarInt(params[0], "yesno", 1);
	new str1[145], str2[145];
	format(str1,sizeof(str1),"{1fa1ea}Вы предложили взглянуть на Ваши лицензии %s",PLAYER_DATA[params[0]][data_NAME]);
	SendClientMessage(playerid, 0xFF66CCFF, str1);
	format(str2,sizeof(str2),"{1fa1ea}%s предложил Вам взглянуть на его лицензии. Для согласия нажмите {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME]);
	SendClientMessage(params[0], 0xFF66CCFF, str2);
	return true;
}

CMD:payday(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 7) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
		PayDay(i);
	}
	return true;
}


CMD:dice(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_BLUE, "Используйте: /dice [ид] [сумма]");
    if(params[0] == playerid) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя использовать на самом себе!");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(params[1] < 1000 || params[1] > 100000) return SendClientMessage(playerid, COLOR_WARNING, "Сумма ставки должна быть от 1000 до 100000 рублей!");
	if(get_player_money(playerid) < params[1]) return SendClientMessage(playerid, COLOR_WARNING, "У Вас недостаточно денег на руках!");
    if(get_player_money(params[0]) < params[1]) return SendClientMessage(playerid, COLOR_WARNING, "У игрока недостаточно денег на руках!");
	new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);

	if(!PlayerToPoint(10.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок далеко от Вас!");
	if(GetPVarInt(params[0],"yesno") == 1) return SendClientMessage(playerid,COLOR_WARNING,"Игроку уже поступило предложение!");

    if(!PlayerToPoint(100.0, playerid, 602.0834,-106.7030,728.1457)) return SendClientMessage(playerid, COLOR_WARNING, "Нужно находиться в казино!");

	SetPVarInt(params[0], "yesno_dice", 1);
    SetPVarInt(params[0], "dice_sum", params[1]);
    SetPVarInt(params[0], "yesno_playerid", playerid);
    SetPVarInt(params[0], "yesno", 1);
	new str1[145], str2[145];

	format(str1,sizeof(str1),"{1fa1ea}Вы предложили %s сыграть в кости на %d рублей",PLAYER_DATA[params[0]][data_NAME],params[1]);
	SendClientMessage(playerid, COLOR_BLUE, str1);
	format(str2,sizeof(str2),"{1fa1ea}%s предложил Вам сыграть в кости на %d рублей. Для согласия {31B404}Y{1fa1ea}, для отказа нажмите {FE2E2E}N",PLAYER_DATA[playerid][data_NAME],params[1]);
	SendClientMessage(params[0], COLOR_BLUE, str2);
	return true;
}


