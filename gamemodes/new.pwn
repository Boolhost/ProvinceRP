public OnPlayerEnterVehicle(playerid, vehicleid, ispassenger)
{



    if(IsPlayerAttachedObjectSlotUsed(playerid,1) && IsPlayerAttachedObjectSlotUsed(playerid,2) && PLAYER_DATA[playerid][data_START_JOB] == 2)
	{
		SendClientMessage(playerid,COLOR_AC,"Вы разбили тележку!");
		if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
		if(IsPlayerAttachedObjectSlotUsed(playerid,2)) RemovePlayerAttachedObject(playerid,2);
		DisablePlayerCheckpoint(playerid);
		ClearAnim(playerid);
		SetPVarInt(playerid, "tovar", 0);
		DeletePVar(playerid,"ac_timer");
  		switch(random(6))
		{
			case 0: SetPlayerCheckpoint(playerid, 1580.6279,-805.5348,41.9165, 2.0);
			case 1: SetPlayerCheckpoint(playerid, 1582.1740,-788.1065,41.6062, 2.0);
			case 2: SetPlayerCheckpoint(playerid, 1567.8470,-799.8918,41.6547, 2.0);
			case 3: SetPlayerCheckpoint(playerid, 1598.4878,-774.1809,40.4617, 2.0);
			case 4: SetPlayerCheckpoint(playerid, 1615.0198,-789.1124,40.7747, 2.0);
			case 5: SetPlayerCheckpoint(playerid, 1608.1359,-830.7748,41.5927, 2.0);
		}
 	}

	if(IsPlayerAttachedObjectSlotUsed(playerid,1) && PLAYER_DATA[playerid][data_START_JOB] == 1)
	{
		SendClientMessage(playerid,COLOR_AC,"Вы уронили товар!");
		if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
		DisablePlayerCheckpoint(playerid);
		SetPVarInt(playerid, "tovar", 0);
		DeletePVar(playerid,"ac_timer");
		ClearAnimations(playerid);
		switch(random(2))
		{
			case 0: SetPlayerCheckpoint(playerid, 2719.6956,-2325.5881,17.9660, 2.0);
			case 1: SetPlayerCheckpoint(playerid, 2742.4841,-2357.4810,17.9660, 2.0);
		}
 	}

 	if(IsPlayerAttachedObjectSlotUsed(playerid,1) && PLAYER_DATA[playerid][data_START_JOB] == 4)
	{
	    SendClientMessage(playerid,COLOR_AC,"Вы уронили ящик!");
		DisablePlayerCheckpoint(playerid);
		ClearAnim(playerid);
		SetPVarInt(playerid, "process", 0);
		SetPVarInt(playerid, "tovar", 0);
		SetPVarInt(playerid, "yablo_check", 0);
		DeletePVar(playerid,"ac_timer");
		if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid, 1);
		new pos = random(7);
		SetPVarInt(playerid, "yablo_pos", pos);
		SetPlayerCheckpoint(playerid, yablo_pos[pos][0], yablo_pos[pos][1], yablo_pos[pos][2], 2.0);
	}


	if(IsPlayerAttachedObjectSlotUsed(playerid,1) && PLAYER_DATA[playerid][data_START_JOB] == 5)
	{
	    SendClientMessage(playerid,COLOR_AC,"Вы уронили ящик!");
		DisablePlayerCheckpoint(playerid);
		ClearAnim(playerid);
		SetPVarInt(playerid, "process", 0);
		SetPVarInt(playerid, "tovar", 0);
		DeletePVar(playerid,"ac_timer");
		if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid, 1);
		new pos = random(13);
		SetPVarInt(playerid, "ogorod_pos", pos);
		SetPlayerCheckpoint(playerid, ogorod_pos[pos][0], ogorod_pos[pos][1], ogorod_pos[pos][2], 2.0);
	}



 	if(IsPlayerAttachedObjectSlotUsed(playerid,3) && PLAYER_DATA[playerid][data_START_JOB] == 3)
	{
		SendClientMessage(playerid,COLOR_AC,"Вы разбили тележку!");
		if(IsPlayerAttachedObjectSlotUsed(playerid,2)) RemovePlayerAttachedObject(playerid,2);
		if(IsPlayerAttachedObjectSlotUsed(playerid,3)) RemovePlayerAttachedObject(playerid,3);
		SetPlayerAttachedObject(playerid,1, 18634, 14, 0.333391, 0.000000, 0.042249, 358.219909, 268.014739, 170.032974, 2.003867, 1.764811, 1.579773);// дали кирку
		DisablePlayerCheckpoint(playerid);
		SetPVarInt(playerid, "tovar", 0);
		DeletePVar(playerid,"ac_timer");
		new pos = random(5);
		SetPVarInt(playerid, "karier_pos", pos);
		SetPlayerCheckpoint(playerid, karier_pos[pos][0], karier_pos[pos][1], karier_pos[pos][2], 2.0);
	}

	return true;
}

public OnPlayerExitVehicle(playerid, vehicleid)
{
    GetPlayerPos(playerid,oldposX[playerid],oldposY[playerid],oldposZ[playerid]);


	if(GetPVarInt(playerid, "PriceTaxi") > 0)
	{
	    new string[100];
		format(string, sizeof(string), "Рабочий день завершен. Вами заработано: %iр", GetPVarInt(playerid, "TaxiMoney"));
		SendClientMessage(playerid, COLOR_BLUE, string);
		SendClientMessage(playerid, COLOR_BLUE, "Деньги будут перечислены на счет во время зарплаты");
		DeletePVar(playerid, "PriceTaxi");
		DeletePVar(playerid, "TaxiMoney");
		if(IsValidDynamic3DTextLabel(TaxiText3D[playerid])) DestroyDynamic3DTextLabel(TaxiText3D[playerid]);
  		foreach(new i: Player)
		{
			if(PLAYER_DATA[playerid][data_LOGGED] == false) return true;
			if(IsPlayerInVehicle(i, vehicleid) && GetPlayerState(i) != 2)
			{
				DeletePVar(i, "TimeTaxi");
				DeletePVar(i, "TaxiPrice");
				DeletePVar(i, "PlayerTaxi");
			}
		}
	}
    if(GetPVarInt(playerid, "TaxiPrice") > 0)
	{
		DeletePVar(playerid, "TimeTaxi");
		DeletePVar(playerid, "TaxiPrice");
		DeletePVar(playerid, "PlayerTaxi");
	}
	return true;
}

public OnVehicleDamageStatusUpdate(vehicleid, playerid)
{
	SetPVarInt(playerid,"EngineStalled",GetPVarInt(playerid,"EngineStalled")+1);
	if(GetPVarInt(playerid,"EngineStalled") >= 4 && CAR_DATA[vehicleid][data_ENG] == 1)
	{
	    switch(random(5))
	    {
	        case 0:
	        {
	            if(PLAYER_DATA[playerid][data_IMPROVEMENTS2] == 1) return true;
				CAR_DATA[vehicleid][data_ENG] = 0;
				GetVehicleParamsEx(vehicleid,engine,lights,alarm,doors,bonnet,boot,objective);
				SetVehicleParamsEx(vehicleid,false,lights,alarm,doors,bonnet,boot,objective);
				GameTextForPlayer(playerid, "~R~ДВИГАТЕЛЬ ЗАГЛОХ", 1000, 6);
			}
		}
		DeletePVar(playerid,"EngineStalled");
  		switch(PLAYER_DATA[playerid][data_REM])
		{
		    case 0:
		    {
				new Float:hp;
				GetPlayerHealth(playerid, hp);
				SetPlayerHealthAC(playerid, hp-15);
				SetPlayerDrunkLevel(playerid, 900000);
				SetTimer("accident", 2000, playerid);
				SetTimer("accident2", 1900, playerid);
				GameTextForPlayer(playerid,"Accident", 5000, 5);
			}
		}
	}
	return true;
}

public OnPlayerStateChange(playerid, newstate, oldstate)
{
    new carid = GetPlayerVehicleID(playerid);

    if(newstate == PLAYER_STATE_ONFOOT || newstate == PLAYER_STATE_DRIVER || newstate == PLAYER_STATE_PASSENGER)
	{
		if(PLAYER_DATA[playerid][data_LOGGED] == false && GetPVarInt(playerid,"player_auth") == 0) return AC_Kick(playerid, 2);
	}

	if(newstate == PLAYER_STATE_DRIVER || newstate == PLAYER_STATE_PASSENGER)
	{
		if(PLAYER_DATA[playerid][data_REM] == 1)
		{
		    PLAYER_DATA[playerid][data_REM] = 0;
		}
	}

	if(newstate == PLAYER_STATE_PASSENGER)
	{
  foreach(new i: Player)
		{
			if(IsPlayerInVehicle(i, carid) && GetPlayerState(i) == 2)
			{
				if(GetPVarInt(i, "PriceTaxi") > 0)
				{
					PLAYER_DATA[i][data_SALARY] += GetPVarInt(i, "PriceTaxi");
					SetPVarInt(playerid, "TimeTaxi", 30);
					SetPVarInt(playerid, "TaxiPrice",GetPVarInt(i, "PriceTaxi"));
					SetPVarInt(playerid, "PlayerTaxi", i);
					SetPVarInt(i, "TaxiMoney", GetPVarInt(i, "TaxiMoney") + GetPVarInt(i, "PriceTaxi"));
				}
			}
		}
	}

	if(newstate == PLAYER_STATE_DRIVER && oldstate == PLAYER_STATE_PASSENGER) return AC_Kick(playerid, 3);


    if(oldstate == 2 && newstate == 1) // вылазит
    {
        if(PLAYER_DATA[playerid][data_CT_VEH] != INVALID_VEHICLE_ID)
        {
            GetPlayerPos(playerid,oldposX[playerid],oldposY[playerid],oldposZ[playerid]);

            DisablePlayerRaceCheckpoint(playerid);
	        DestroyVehicle(PLAYER_DATA[playerid][data_CT_VEH]);
			PLAYER_DATA[playerid][data_CT_VEH] = INVALID_VEHICLE_ID;
			PLAYER_DATA[playerid][data_CT_NUMBER] = 0;
			SetPlayerPosAC(playerid, -1503.6699,1609.8861,36.5690);
		}



  		if(!IsABMX(carid)) HideSpeedometr(playerid),SetPlayerDrunkLevel (playerid, 0);
    }
    else if(oldstate == 1 && newstate == 2) // залазит
    {
        if(!IsPLANE(carid))
        {
	    	ShowSpeedometr(playerid);
			SendClientMessage(playerid,0x339966FF,"Для включения меню транспорта используйте клавишу {1fa1ea}L.CTRL");
			SendClientMessage(playerid,0x339966FF,"Если вы на скутаре используйте команду {1fa1ea}/en");
			//cef_subscribe("pwd:try", "CefInterface"); //подписываемся на событие js скрипта и передаем его в игру
			//cef_create_browser(playerid, 0x12348, "Province-host.ru/gta-speed/speed.html", false, false); //создаем браузер
		}
		else return SendClientMessage(playerid,0x339966FF,"Для включения двигателя используйте клавишу {1fa1ea}/en для включения фар /lamp");
	}



	if(oldstate == 3 && newstate == 1) // вылазит
    {
        for(new b = 0; b < TotalJB; b++)
        {
            if(carid == JB_DATA[b][data_VEH_JOB][0] ||
			carid == JB_DATA[b][data_VEH_JOB][1] ||
			carid == JB_DATA[b][data_VEH_JOB][2] ||
			carid == JB_DATA[b][data_VEH_JOB][3] ||
			carid == JB_DATA[b][data_VEH_JOB][4])
			{
			    PLAYER_DATA[playerid][data_BUSCAR] = INVALID_VEHICLE_ID;
			}
        }

    }
    else if(oldstate == 1 && newstate == 3) // залазит
    {
        for(new b = 0; b < TotalJB; b++)
        {
            if(carid == JB_DATA[b][data_VEH_JOB][0] ||
			carid == JB_DATA[b][data_VEH_JOB][1] ||
			carid == JB_DATA[b][data_VEH_JOB][2] ||
			carid == JB_DATA[b][data_VEH_JOB][3] ||
			carid == JB_DATA[b][data_VEH_JOB][4])
			{
			    if(PlayerToPoint(250.0, playerid, 2518.826171, -2145.580322, 21.816497))
			    {
			    	PLAYER_DATA[playerid][data_BUSCAR] = carid;
			    }
			}
        }
	}



    if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
    {
        if(PLAYER_DATA[playerid][data_LICB] == 0 && PLAYER_DATA[playerid][data_ASH_TEST] == 0)
        {
            if(!IsABMX(carid))
			{
             	//SetPlayerDrunkLevel (playerid, 400000);
             	SendClientMessage(playerid,COLOR_WARNING,"У вас нет водительских прав!");
				RemovePlayerFromVehicleAC(playerid);
				//return true;
 			}
        }

        if(carid >= ash_car[0] && carid <= ash_car[1])
		{
	        if(PLAYER_DATA[playerid][data_ASH_TEST] == 1 && PLAYER_DATA[playerid][data_ASH_CAR] == INVALID_VEHICLE_ID)
	        {
	            if(CAR_DATA[carid][data_ASH_TEST] == INVALID_PLAYER_ID)
	            {
		            PLAYER_DATA[playerid][data_ASH_CAR] = carid;
