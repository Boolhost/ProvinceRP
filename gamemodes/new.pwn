CMD:show(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new str[125];
    if(!VarSnow)
    {
        for(new x=-3000; x < 3000; x+=100)
        for(new y=-3000; y < 3000; y+=100)
        SnowObject[SnowCout++] = CreateDynamicObject(18864,x,y,2.0000000,0.0000000,  0.0000000,1.0000);
        VarSnow = true;
        format(str,sizeof(str),"{808080}[A] %s включил снегопад",PLAYER_DATA[playerid][data_NAME]);
		SendAdminMessage(0x666699FF,str);
        return true;
    }
    for(new t = 0; t < 3600; t++)
    DestroyDynamicObject(SnowObject[t]);
    VarSnow = false;
    SnowCout = 0;
    format(str,sizeof(str),"{808080}[A] %s выключил снегопад",PLAYER_DATA[playerid][data_NAME]);
	SendAdminMessage(0x666699FF,str);
    return true;
}

CMD:alogin(playerid, params[])
{
	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == true) return SendClientMessage(playerid, COLOR_WARNING, "Вы уже авторизовались как администратор!");
	//Alogin(playerid);

	new string[128];
	format(string, sizeof(string), "SELECT * FROM `accounts` WHERE `name` = '%s'", PLAYER_DATA[playerid][data_NAME]);
	mysql_tquery(dbHandle, string, "Alogin", "is", playerid, PLAYER_DATA[playerid][data_NAME]);
	return true;
}

