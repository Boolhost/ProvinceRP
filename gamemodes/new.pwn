CMD:mpskin(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
	if(sscanf(params,"dd",params[0], params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /mpskin [1, 2, 3] [номер скина]");
	if(params[1] > 297) return true;


	new team_1[250],team_2[250], all, team1, team2;
	new Float:x,Float:y,Float:z;
	GetPlayerPos(playerid, x,y,z);


   	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(i == playerid) continue;
		if(!IsPlayerConnected(i)) continue;
		if(PlayerToPoint(100.0, i, x,y,z))
		{
		    all++;
            if(params[0] == 3)
			{
			    SetPlayerSkinAC(i,params[1]);
			    continue;
			}
            if(params[0] == 2 && all%2 == 0)
            {
                team2++;
            	team_2[team2] = i;
            	SetPlayerSkinAC(i,params[1]);
            	continue;
			}
			if(params[0] == 1 && all%2 == 1)
			{
			    team1++;
			    team_1[team1] = i;
			    SetPlayerSkinAC(i,params[1]);
			    continue;
			}
			if(params[0] < 1 || params[0] > 3)
			{
			    SendClientMessage(playerid, COLOR_WARNING,"Используйте: /mpskin [1, 2, 3] [номер скина]");
			    break;
			}
		}
   	}
    return true;
}



CMD:mpgun(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
	if(sscanf(params, "ddd", params[0], params[1], params[2])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /mpgun [1, 2, 3] [оружие] [патроны]");
  	else if(params[1] > 47 || params[1] < 1) return SendClientMessage(playerid, COLOR_WARNING,"Такого оружия не существует!");
    else if(params[2] > 1000 || params[2] < 1) return SendClientMessage(playerid, COLOR_WARNING,"Не верное количество патрон!");


	new team_1[250],team_2[250], all, team1, team2;
	new Float:x,Float:y,Float:z;
	GetPlayerPos(playerid, x,y,z);


   	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(i == playerid) continue;
		if(!IsPlayerConnected(i)) continue;
		if(PlayerToPoint(100.0, i, x,y,z))
		{
		    all++;
            if(params[0] == 3)
			{
			    GiveWeapon(i,params[1], params[2]);
			    continue;
			}
            if(params[0] == 2 && all%2 == 0)
            {
                team2++;
            	team_2[team2] = i;
            	GiveWeapon(i,params[1], params[2]);
            	continue;
			}
			if(params[0] == 1 && all%2 == 1)
			{
			    team1++;
			    team_1[team1] = i;
			    GiveWeapon(i,params[1], params[2]);
			    continue;
			}
			if(params[0] < 1 || params[0] > 3)
			{
			    SendClientMessage(playerid, COLOR_WARNING,"Используйте: /mpgun [1, 2, 3] [номер скина]");
			    break;
			}
		}
   	}



    return true;
}

CMD:gun(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
	if(sscanf(params, "udd", params[0], params[1], params[2])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /gun [ид] [оружие] [патроны]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	else if(params[1] > 47 || params[1] < 1) return SendClientMessage(playerid, COLOR_WARNING,"Такого оружия не существует!");
    else if(params[2] > 1000 || params[2] < 1) return SendClientMessage(playerid, COLOR_WARNING,"Не верное количество патрон!");
    GiveWeapon(params[0], params[1], params[2]);
    return true;
}

