    if(PLAYER_DATA[playerid][data_ADMLVL] < 2) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	for(new x; x <30; x++) SendClientMessageToAll(-1, " ");
	return true;
}

CMD:goto(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 2) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /goto [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    new string[145], Float:x, Float:y, Float:z;
    GetPlayerPos(params[0],x,y,z);
    SetPlayerPosAC(playerid,x+1,y,z);
    SetPlayerInterior(playerid,GetPlayerInterior(params[0]));
    SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(params[0]));
    format(string,sizeof(string),"Вы телепортировались к игроку %s",PLAYER_DATA[params[0]][data_NAME]);
    SendClientMessage(playerid,-1, string);
    return true;
}


CMD:gethere(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 2) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /gethere [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
    if(params[0] == playerid) return SendClientMessage(playerid, COLOR_WARNING,"Нельзя телепортироватся к самому себе!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    new string[145], Float:x, Float:y, Float:z;
    DeletePVar(params[0], "ac_fly");
    GetPlayerPos(playerid,x,y,z);
    SetPlayerPosAC(params[0],x+1,y,z+1.0);
    SetPlayerInterior(params[0],GetPlayerInterior(playerid));
    SetPlayerVirtualWorld(params[0],GetPlayerVirtualWorld(playerid));
    format(string,sizeof(string),"Вы телепортировали к себе игрока: %s",PLAYER_DATA[params[0]][data_NAME]);
    SendClientMessage(playerid,-1, string);
    return true;
}

CMD:skick(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 5) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /skick [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
    if(playerid == params[0]) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя приминить на себе!");
    if(PLAYER_DATA[params[0]][data_ADMLVL] > PLAYER_DATA[playerid][data_ADMLVL]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к старшей администрации!");
	Kick(params[0]);
	new message[145];
	format(message,sizeof(message),"{808080}[A] %s тихо кикнул игрока %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	SendAdminMessage(0x666699FF,message);
	return true;
}


CMD:mute(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"uds[100]",params[0],params[1],params[2])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /mute [ид] [минут] [причина]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(params[1] < 1) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя меньше 1 минуты!");
    if(PLAYER_DATA[params[0]][data_ADMLVL] > PLAYER_DATA[playerid][data_ADMLVL]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к старшей администрации!");
 	new mut = params[1];
	PLAYER_DATA[params[0]][data_MUTE] = 1;
	PLAYER_DATA[params[0]][data_MUTETIME] = mut;
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(GetPVarInt(i,"gPlayerAaction") == 0)
		{
  			new string[145];
			format(string, sizeof(string), "Администратор %s заблокировал чат %s на %d минут(у). Причина: %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME],params[1],params[2]);
			SendClientMessage(i,COLOR_AC,string);
		}
	}
	SendClientMessage(params[0],COLOR_AC,"Вам выдали мут (инфо: /mutetime)");
	return true;
}

CMD:unmute(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /unmute [ид]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(PLAYER_DATA[params[0]][data_MUTE] == 0) return SendClientMessage(playerid,COLOR_WARNING,"У данного игрока нет блокировки чата!");
	PLAYER_DATA[params[0]][data_MUTE] = 0;
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(GetPVarInt(i,"gPlayerAaction") == 0)
	    {
	        new string[145];
			format(string, sizeof(string), "Администратор %s разблокировал чат у %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
			SendClientMessage(i,COLOR_AC,string);
		}
	}
	return true;
}

CMD:skin(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"ud",params[0], params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /skin [ид] [номер скина]");
	if(params[1] < 1 || params[1] > 299) return SendClientMessage(playerid, COLOR_WARNING,"[ПОМОЩЬ] Используйте от 1 до 299");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(params[1] > 297) return true;
	SetPlayerSkinAC(params[0],params[1]);
	PLAYER_DATA[playerid][data_SKIN] = params[1];
    return true;
}

