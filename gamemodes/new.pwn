	        cache_get_field_content(b, "car3_posx", temp), AB_DATA[b][data_CAR_POSX][2] = floatstr (temp);
	        cache_get_field_content(b, "car3_posy", temp), AB_DATA[b][data_CAR_POSY][2] = floatstr (temp);
	        cache_get_field_content(b, "car3_posz", temp), AB_DATA[b][data_CAR_POSZ][2] = floatstr (temp);
	        cache_get_field_content(b, "car3_posa", temp), AB_DATA[b][data_CAR_POSA][2] = floatstr (temp);

	        cache_get_field_content(b, "car4_posx", temp), AB_DATA[b][data_CAR_POSX][3] = floatstr (temp);
	        cache_get_field_content(b, "car4_posy", temp), AB_DATA[b][data_CAR_POSY][3] = floatstr (temp);
	        cache_get_field_content(b, "car4_posz", temp), AB_DATA[b][data_CAR_POSZ][3] = floatstr (temp);
	        cache_get_field_content(b, "car4_posa", temp), AB_DATA[b][data_CAR_POSA][3] = floatstr (temp);

	        cache_get_field_content(b, "car5_posx", temp), AB_DATA[b][data_CAR_POSX][4] = floatstr (temp);
	        cache_get_field_content(b, "car5_posy", temp), AB_DATA[b][data_CAR_POSY][4] = floatstr (temp);
	        cache_get_field_content(b, "car5_posz", temp), AB_DATA[b][data_CAR_POSZ][4] = floatstr (temp);
	        cache_get_field_content(b, "car5_posa", temp), AB_DATA[b][data_CAR_POSA][4] = floatstr (temp);

	        cache_get_field_content(b, "car6_posx", temp), AB_DATA[b][data_CAR_POSX][5] = floatstr (temp);
	        cache_get_field_content(b, "car6_posy", temp), AB_DATA[b][data_CAR_POSY][5] = floatstr (temp);
	        cache_get_field_content(b, "car6_posz", temp), AB_DATA[b][data_CAR_POSZ][5] = floatstr (temp);
	        cache_get_field_content(b, "car6_posa", temp), AB_DATA[b][data_CAR_POSA][5] = floatstr (temp);

	        cache_get_field_content(b, "car7_posx", temp), AB_DATA[b][data_CAR_POSX][6] = floatstr (temp);
	        cache_get_field_content(b, "car7_posy", temp), AB_DATA[b][data_CAR_POSY][6] = floatstr (temp);
	        cache_get_field_content(b, "car7_posz", temp), AB_DATA[b][data_CAR_POSZ][6] = floatstr (temp);
	        cache_get_field_content(b, "car7_posa", temp), AB_DATA[b][data_CAR_POSA][6] = floatstr (temp);


	        cache_get_field_content(b, "info_posx", temp), AB_DATA[b][data_INFO_POS][0] = floatstr (temp);
	        cache_get_field_content(b, "info_posy", temp), AB_DATA[b][data_INFO_POS][1] = floatstr (temp);
	        cache_get_field_content(b, "info_posz", temp), AB_DATA[b][data_INFO_POS][2] = floatstr (temp);

	        cache_get_field_content(b, "job_posx", temp), AB_DATA[b][data_JOB_POS][0] = floatstr (temp);
	        cache_get_field_content(b, "job_posy", temp), AB_DATA[b][data_JOB_POS][1] = floatstr (temp);
	        cache_get_field_content(b, "job_posz", temp), AB_DATA[b][data_JOB_POS][2] = floatstr (temp);



	        TotalAB++;

	        AB_DATA[b][data_PICKUP][1] = CreateDynamicPickup(1275, 23,  AB_DATA[b][data_JOB_POS][0],  AB_DATA[b][data_JOB_POS][1],  AB_DATA[b][data_JOB_POS][2], -1);
			AB_DATA[b][data_PICKUP][0] = CreateDynamicPickup(1239, 23, AB_DATA[b][data_INFO_POS][0], AB_DATA[b][data_INFO_POS][1], AB_DATA[b][data_INFO_POS][2], -1);

            for(new c = 0; c < 7; c++)
			{
				if(AB_DATA[b][data_MODEL_JOB][c] != 0)
				{
					AB_DATA[b][data_VEH_JOB][c] = CreateVehicle(AB_DATA[b][data_MODEL_JOB][c], AB_DATA[b][data_CAR_POSX][c], AB_DATA[b][data_CAR_POSY][c], AB_DATA[b][data_CAR_POSZ][c], AB_DATA[b][data_CAR_POSA][c], -1, -1, 600);
              		ClearCarData(AB_DATA[b][data_VEH_JOB][c]);
              		CAR_DATA[AB_DATA[b][data_VEH_JOB][c]][data_FUEL] = 50;
				}
			}




			CreateDynamicMapIcon(AB_DATA[b][data_INFO_POS][0], AB_DATA[b][data_INFO_POS][1], AB_DATA[b][data_INFO_POS][2], 51, -1, 0, -1, -1, 400.0);


			if(AB_DATA[b][data_OWNED] == 1)
			{
		        format(str,sizeof(str),"{FFFFFF}Автобаза '%s'\n{FFFF33}Владелец: {FFFFFF}%s\n{FFFF33}Стоимость: {FFFFFF}%d рублей\n{FFFF33}Зарплата водителя: {FFFFFF}%d процент(ов)", AB_DATA[b][data_NAME], AB_DATA[b][data_OWNER], AB_DATA[b][data_PRICE], AB_DATA[b][data_PROCENT]);
			 	AB_DATA[b][data_INFO] = CreateDynamic3DTextLabel(str, -1, AB_DATA[b][data_INFO_POS][0], AB_DATA[b][data_INFO_POS][1], AB_DATA[b][data_INFO_POS][2], 5.0);
			}
			else
			{
		        format(str,sizeof(str),"{FFFFFF}Автобаза '%s'\n{FFFF33}Стоимость: {FFFFFF}%d рублей\n{99FFFF}Для покупки используйте: /buy", AB_DATA[b][data_NAME], AB_DATA[b][data_PRICE]);
			 	AB_DATA[b][data_INFO] = CreateDynamic3DTextLabel(str, -1, AB_DATA[b][data_INFO_POS][0], AB_DATA[b][data_INFO_POS][1], AB_DATA[b][data_INFO_POS][2], 5.0);
			}
        }
        printf("[serv_log]  Load auto business. Load: %d b. Time: %d ms.",TotalAB,GetTickCount()-time);
  	}
    return true;
}

