		case dialog_AD:
		{
		    if(!response) return true;
			if(response)
			{
				new money = GetPVarInt(playerid, "ad_money");
			    if(PLAYER_DATA[playerid][data_NUMBER_M] <= 0) return SendClientMessage(playerid,COLOR_WARNING,"У Вас закончились деньги на счету телефона!");
				for(new a = 0; a < 15; a++)
				{
				    if(AD_DATA[a][data_STATUS] != 0) continue;
                    AD_DATA[a][data_STATUS] = 1;
                    GetPVarString(playerid,"ad_text", AD_DATA[a][data_TEXT], 128);
                    strmid(AD_DATA[a][data_NAME], PLAYER_DATA[playerid][data_NAME], 0, strlen(PLAYER_DATA[playerid][data_NAME]), MAX_PLAYER_NAME);
					AD_DATA[a][data_NUMBER] = PLAYER_DATA[playerid][data_NUMBER];
					AD_DATA[a][data_PID] = playerid;
					break;
				}
				TotalAD++;
				ad_timer = 15;
				PLAYER_DATA[playerid][data_NUMBER_M] -= money;
				smi_money += money;
				SendClientMessage(playerid, -1, "Вы отправили объявление в редакцию СМИ");
			}
		}
		case dialog_NEWS:
