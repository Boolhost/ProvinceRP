stock RulesDialog(playerid)
{
	new dtext[2300];
	strcat(dtext, "{33FF33}« Игровой процесс »\n");
	strcat(dtext, "{FF3300}Запрещено:\n");
	strcat(dtext, "{FFFFFF}- использование любых программ, скриптов, читов и т.п. дающие преимущество в игре\n");
	strcat(dtext, "{FFFFFF}- использование багов (ошибок, неисправностей мода)\n");
	strcat(dtext, "{FFFFFF}- использовать ESC в целях ухода от погони/смерти\n");
	strcat(dtext, "{FFFFFF}- убивать игроков на спавне (место возрождения, база организации)\n");
	strcat(dtext, "{FFFFFF}- убивать игроков при помощи транспорта (давить)\n");
	strcat(dtext, "{FFFFFF}- убийство/нанесение урона игрокам без причины (DM - Death Match)\n");
	strcat(dtext, "{FFFFFF}- злоупотребление игроВыми возможностями для создания неудобств игрокам\n\n");
	strcat(dtext, "{33FF33}« Ник в игре »\n");
	strcat(dtext, "{FFFFFF}- ник должен состоять из Имени_Фамилии с заглавных букв\n");
	strcat(dtext, "{FFFFFF}- запрещено использовать чужие (уже кем-то занятые ники)\n");
	strcat(dtext, "{FFFFFF}- запрещено использовать ники, содержащие оскорбительные и нецензурные слова\n\n");
	strcat(dtext, "{33FF33}« Чат сервера »\n");
	strcat(dtext, "{FF3300}Запрещено:\n");
	strcat(dtext, "{FFFFFF}- ругательство, оскорбления или нецензурная речь в OOC чат\n");
	strcat(dtext, "{FFFFFF}- угрозы игрокам в OOC чат\n");
	strcat(dtext, "{FFFFFF}- писать сообщения в верхнем регистре (Caps Lock)\n");
	strcat(dtext, "{FFFFFF}- писать в обычный чат сообщения не относящиеся к IC\n");
	strcat(dtext, "{FFFFFF}- использование OOC информации в IC (MеtaGаming)\n");
	strcat(dtext, "{FFFFFF}- писать одно и тоже сообщение слишком часто\n");
	strcat(dtext, "{FFFFFF}- реклама сторонних ресурсов\n\n");
	strcat(dtext, "{33FF33}« Администрация сервера »\n");
	strcat(dtext, "{FFFFFF}- не желательно препятствовать администрации в работе\n");
	strcat(dtext, "{FFFFFF}- необходимо сообщать администрации о любых нарушениях правил (/mm > Репорт)\n");
	strcat(dtext, "{FFFFFF}- администрации самостоятельно выбирает штрафные санкции для каждого из случаев\n");
	strcat(dtext, "{FFFFFF}- решение администарции не является окончательным и подлежит обжалованию\n");
	strcat(dtext, "{FFFFFF}- штрафные санкции могут применяться непосредственно после нарушения, так и через некоторое время\n");
	strcat(dtext, "{FFFFFF}- незнание правил не освобождает от ответственности\n\n");
	strcat(dtext, "{33FF33}« Внутриигровая торговля »\n");
	strcat(dtext, "{FFFFFF} - запрещены любые денежные махинации\n");
	strcat(dtext, "{FFFFFF}- запрещена продажа/покупка чего-либо за реальные деньги\n");
	strcat(dtext, "{FFFFFF} - запрещен обмен внеигровых предметов, в любой форме, на игровые\n");
	strcat(dtext, "{FFFFFF}- запрещена продажа/передача аккаунта\n");
	ShowPlayerDialogFix(playerid,dialog_OK,DIALOG_STYLE_MSGBOX,"{FFCC00}Правила сервера",dtext,"Закрыть","");
}


stock SendDBMessage(color, text[])
{
 	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		if(GetPVarInt(i, "job_db") != 0) SendClientMessage(i, color, text);
	}
	return true;
}

stock SendAdminMessage(color, text[])
{
 	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		if(PLAYER_DATA[i][data_ADMLVL] >= 1) SendClientMessage(i, color, text);
	}
	return true;
}

stock SendYTMessage(color, text[])
{
 	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		if(PLAYER_DATA[i][data_YT] >= 1 && PLAYER_DATA[i][data_ADMLVL] >= 1) SendClientMessage(i, color, text);
	}
	return true;
}

stock SendAdminText(playerid)
{
	if(PLAYER_DATA[playerid][data_ADMLVL] >= 1)
	{
	    new prefix[32][MAX_PLAYERS];
		cache_get_field_content(playerid, "admprefix", prefix[playerid], dbHandle);
		if(!strcmp(prefix[playerid], "qwerty", true)) return true;
		Delete3DTextLabel(test3dtext);
		test3dtext = Create3DTextLabel(prefix[playerid], COLOR_WARNING, 0.0, 0.0, 0.0, 25.0, 0, 1);
	    Attach3DTextLabelToPlayer(test3dtext, playerid, 0.0, 0.0, 0.5);
	}
	return true;
}

