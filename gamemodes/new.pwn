			carid == AB_DATA[b][data_VEH_JOB][3] ||
			carid == AB_DATA[b][data_VEH_JOB][4] ||
			carid == AB_DATA[b][data_VEH_JOB][5] ||
			carid == AB_DATA[b][data_VEH_JOB][6])
			{
			    if(GetPVarInt(playerid, "job_db") != AB_DATA[b][data_ID])
				{
			        SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             		RemovePlayerFromVehicleAC(playerid);
			        return true;
			    }
				if(CAR_DATA[carid][data_RENT] != INVALID_PLAYER_ID && PLAYER_DATA[playerid][data_RENTJOB] != carid) return SendClientMessage(playerid,COLOR_WARNING,"На данном транспорте уже кто-то работает!"),RemovePlayerFromVehicleAC(playerid);
				if(PLAYER_DATA[playerid][data_RENTJOB] != carid) return ShowPlayerDialogFix(playerid, dialog_RENTJOB, DIALOG_STYLE_MSGBOX, "{FFCC00}Автобаза", "{FFFFFF}Вы желаете начать рабочий день на данном транспорте?", "Начать", "Отмена");
			}
        }


        for(new b = 0; b < TotalJB; b++)
        {
            if(carid == JB_DATA[b][data_VEH_JOB][0] ||
			carid == JB_DATA[b][data_VEH_JOB][1] ||
			carid == JB_DATA[b][data_VEH_JOB][2] ||
			carid == JB_DATA[b][data_VEH_JOB][3] ||
			carid == JB_DATA[b][data_VEH_JOB][4])
			{
			    if(GetPVarInt(playerid, "job_bus") != JB_DATA[b][data_ID])
			    {
			        SendClientMessage(playerid,COLOR_WARNING,"Данный транспорт Вам недоступен!");
             		RemovePlayerFromVehicleAC(playerid);
			        return true;
			    }
				if(CAR_DATA[carid][data_RENT] != INVALID_PLAYER_ID && PLAYER_DATA[playerid][data_RENTJOB] != carid) return SendClientMessage(playerid,COLOR_WARNING,"На данном транспорте уже кто-то работает!"),RemovePlayerFromVehicleAC(playerid);
				if(PLAYER_DATA[playerid][data_RENTJOB] != carid) return ShowPlayerDialogFix(playerid, dialog_RENTJOB, DIALOG_STYLE_MSGBOX, "{FFCC00}Предприятие", "{FFFFFF}Вы желаете начать рабочий день на данном транспорте?", "Начать", "Отмена");
