	ShowPlayerDialogFix(playerid, dialog_SETLEADER, DIALOG_STYLE_LIST, "{FFCC00}Выберете организацию",
	"{1fa1ea}1.{FFFFFF}Снять с лидерства\n\
	{1fa1ea}2.{FFFFFF}Администрация Области\n\
	{1fa1ea}3.{FFFFFF}ВДВ\n\
	{1fa1ea}4.{FFFFFF}Полиция\n\
	{1fa1ea}5.{FFFFFF}Больница\n\
	{1fa1ea}6.{FFFFFF}Трамповское ОПГ\n\
	{1fa1ea}7.{FFFFFF}Майкопское ОПГ\n\
	{1fa1ea}8.{FFFFFF}Одесское ОПГ\n\
	{1fa1ea}9.{FFFFFF}ФСБ\n\
	{1fa1ea}10.{FFFFFF}СМИ", "Выбрать", "Отмена");
	return true;
}

CMD:get(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
    if(sscanf(params,"s[24]",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /get [имя]");

	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;

	    if(strfind(PLAYER_DATA[i][data_CHAT_TEXT], params[0], true) != -1)
	    {

         	new dtext[512],message[145];

			format(dtext,sizeof(dtext),"{FFFFFF}Номер акаунта: %d\nДонат: %d\nНаличные: %d руб.\nБанковский счет: %d руб.\nУровень: %d\nEXP: %d\nДом: %d +1 (-1 - нет)\nБизнес: %d +1 (-1 - нет)\nНомер телефона: %d (0 - нет)\nОрганизация: %d\nРанг: %d\nЛидер: %d\nREG-IP: %s\nLOG-IP: %s\nREG-DATA: %d/%d/%d\nLOG-DATA: %d/%d/%d\nПроведенное время в игре (сегодня): %d минут",

			PLAYER_DATA[i][data_ID],PLAYER_DATA[i][data_DONATE],PLAYER_DATA[i][data_MONEY],PLAYER_DATA[i][data_BANK],PLAYER_DATA[i][data_EXP],
			PLAYER_DATA[i][data_HOUSE],PLAYER_DATA[i][data_BUSINESS],PLAYER_DATA[i][data_NUMBER],PLAYER_DATA[i][data_MEMBER],PLAYER_DATA[i][data_RANK],
			PLAYER_DATA[i][data_LEADER],PLAYER_DATA[i][data_REGISTER_IP],PLAYER_DATA[i][data_LOGIN_IP],PLAYER_DATA[i][data_REGDATE_DAY],PLAYER_DATA[i][data_REGDATE_MONTH],
			PLAYER_DATA[i][data_LOGDATE_DAY],PLAYER_DATA[i][data_LOGDATE_MONTH],PLAYER_DATA[i][data_LOGDATE_YEAR],PLAYER_DATA[i][data_TIME]);


			ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX, PLAYER_DATA[i][data_NAME], dtext, "Закрыть", "");

			format(message,sizeof(message),"{808080}[A] %s просматривает информацию аккаунта %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[i][data_NAME]);
			SendAdminMessage(0x666699FF,message);

	        return true;
	    }
	}
	new query[80];
 	mysql_format(dbHandle,query, sizeof(query), "SELECT * FROM `accounts` WHERE `name` = '%e'",params[0]);
 	mysql_function_query(dbHandle, query, true, "GetAccount", "i", playerid);
   	return true;
}

CMD:allleaders(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	mysql_function_query(dbHandle, "SELECT * FROM `accounts` WHERE `leader` != '0'", true, "LoadAllLeaders", "d", playerid);

	return true;
}

