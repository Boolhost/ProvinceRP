    if(PLAYER_DATA[playerid][data_MUTE] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Ваш чат временно заблокирован!");
	if(GetPVarInt(playerid,"job_db") == 0) return SendClientMessage(playerid, COLOR_WARNING, "Вам недоступна данная команда!");
    new carid = GetPlayerVehicleID(playerid);
	if(PLAYER_DATA[playerid][data_RENTJOB] != carid) return SendClientMessage(playerid, COLOR_WARNING, "Вы должны находиться в своём тягаче!");
	if(PLAYER_DATA[playerid][data_MUTE] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Ваш чат временно заблокирован!");
	if(sscanf(params,"s[100]",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /rtk [текст]");
	NotReklama(playerid, params[0]);
	new str[145];
 	format(str,sizeof(str),"[R] %s[%d]: %s",PLAYER_DATA[playerid][data_NAME], playerid, params[0]);
	SendDBMessage(0xFF9966FF,str);
	return true;
}


