public ChangePassword(playerid)
{
    new rows, fields;
    cache_get_data(rows, fields);
    if(rows) ShowPlayerDialogFix(playerid, dialog_SETTING_2, DIALOG_STYLE_INPUT,"{FFCC00}Изменение пароля","Введите новый пароль", "Далее", "Отмена");
    else SendClientMessage(playerid,COLOR_AC,"Вы ввели нерпавильный пароль!"),ShowPlayerDialogFix(playerid, dialog_SETTING_1, DIALOG_STYLE_INPUT,"{FFCC00}Изменение пароля","Введите свой старый пароль", "Далее", "Отмена");
