stock acc_int_strcat(query[], len, name[], number)
{
    new stringer[64];
 	format(stringer, sizeof(stringer), "`%s` = '%d',",name, number);
 	strcat(query, stringer, len);
 	return true;
}

stock acc_float_strcat(query[], len, name[], Float:number)
{
    new stringer[64];
 	format(stringer, sizeof(stringer), "`%s` = '%f',", name, number);
 	strcat(query, stringer, len);
 	return true;
}

stock acc_str_strcat(query[], len, name[], str[])
{
    new stringer[64];
 	format(stringer, sizeof(stringer), "`%s` = '%s',",name, str);
 	strcat(query, stringer, len);
 	return true;
}

stock PlayerToPoint(Float:radi, playerid, Float:x, Float:y, Float:z)
{
	if(IsPlayerConnected(playerid))
	{
		new Float:oldposx, Float:oldposy, Float:oldposz;
		new Float:tempposx, Float:tempposy, Float:tempposz;
		GetPlayerPos(playerid, oldposx, oldposy, oldposz);
		tempposx = (oldposx -x);
		tempposy = (oldposy -y);
		tempposz = (oldposz -z);
		if (((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi))) return true;
	}
	return false;
}


stock IsPlayerApplyAnimation(id, ...)
{
    new n = numargs(), anim[32], animlib[32], animname[32];
    new id_anim = GetPlayerAnimationIndex(id);
    if(id_anim == 0) return false;
    else GetAnimationName(id_anim, animlib, sizeof(animlib), animname, sizeof(animname));
    for (new a = 0; a < n; a++)
    {
        new index = 0;
        for(;;)
        {
            anim[index] = getarg(a, index);
            if(anim[index] == 0) break;
            index++;
        }
        if(index != 0 && strcmp(animname, anim, true) == 0) return true;
    }
    return false;
}

stock SendDepMessage(color, text[])
{
 	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
		switch(PLAYER_DATA[i][data_MEMBER])
		{
		    case 1,2,3,4,8,9: SendClientMessage(i, color, text);
		}
	}
	return true;
}

stock GetOPGName(fnumbwer)
{
	new string[20];
	switch(fnumbwer)
	{
		case 5: format(string,sizeof(string),"Трамповское ОПГ");
		case 6: format(string,sizeof(string),"Майкопское ОПГ");
		case 7: format(string,sizeof(string),"Одесское ОПГ");
	}
	return string;
}

stock CaptureStart(t1,t2)
{
	new text1[70];
	format(text1,sizeof(text1),"[F] %s напала на бизнес %s",GetOPGName(t1),GetOPGName(t2));

	for(new i = 0; i < MAX_PLAYERS; i++)
	{
	    if(!IsPlayerConnected(i)) continue;
	    if(!IsPlayerOPG(i)) continue;
	    SendClientMessage(i, COLOR_AC, text1);
	}
	return true;
}

stock CaptureStop()
{
	IsCapture = false;
 	capt_one_kill = 0;
	capt_two_kill = 0;
	capt_time = 0;
	capt_one_team = 0;
	capt_two_team = 0;
	capt_biz = -1;
	return true;
}

