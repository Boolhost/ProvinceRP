CMD:jail(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"uds[100]",params[0],params[1],params[2])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /jail [ид] [время] [причина]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(params[1] < 1 || params[1] > 600) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя меньше 1 минуты и больше 600 минут!");
    if(PLAYER_DATA[params[0]][data_ADMLVL] > PLAYER_DATA[playerid][data_ADMLVL]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к старшей администрации!");
    PLAYER_DATA[params[0]][data_JAIL] = 1;
	PLAYER_DATA[params[0]][data_JAILTIME] = params[1]*60;
	SetPlayerSpawn(params[0]);


	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(GetPVarInt(i,"gPlayerAaction") == 0)
	    {
	        new string[145];
			format(string, sizeof(string), "Администратор %s посадил %s в тюрьму на %d минут. Причина: %s", PLAYER_DATA[playerid][data_NAME], PLAYER_DATA[params[0]][data_NAME], params[1], params[2]);
			SendClientMessage(i,COLOR_AC,string);
		}
	}

	return true;
}



CMD:unjail(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /unjail [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");

	PLAYER_DATA[params[0]][data_JAIL] = 0;
	PLAYER_DATA[params[0]][data_JAILTIME] = 0;
	//SetPlayerSpawn(params[0]);

	SetPlayerPosAC(params[0], 2723.0916,-2439.3308,21.8921);
    SetPlayerVirtualWorld(params[0], 0);
	SetPlayerInterior(params[0],0);
	SetPlayerFacingAngle(params[0], 90);
	SetCameraBehindPlayer(params[0]);

	new message[145];
	format(message,sizeof(message),"{808080}[A] %s[%d] освободил игрока %s[%d] из тюрьмы",PLAYER_DATA[playerid][data_NAME],playerid,PLAYER_DATA[params[0]][data_NAME],params[0]);
	SendAdminMessage(0x666699FF,message);
	return true;
}

CMD:gomp(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 5) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new message[145];
	if(gomp_status == false)
	{
		GetPlayerPos(playerid, gomp_pos[0],gomp_pos[1],gomp_pos[2]);

        gomp_status = true;
		format(message,sizeof(message),"{808080}[A] %s[%d] запустил GO MP",PLAYER_DATA[playerid][data_NAME], playerid);
		SendAdminMessage(0x666699FF,message);
	}
	else
	{
	    gomp_status = false;
		format(message,sizeof(message),"{808080}[A] %s[%d] остановил GO MP",PLAYER_DATA[playerid][data_NAME], playerid);
		SendAdminMessage(0x666699FF,message);
	}

	return true;
}

CMD:mp(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

	if(gomp_status == false) return SendClientMessage(playerid, COLOR_WARNING, "В данный момент недоступно!");

	SetPlayerPosAC(playerid, gomp_pos[0],gomp_pos[1],gomp_pos[2]);
	SetPlayerInterior(playerid,0);
	SetPlayerVirtualWorld(playerid,0);
    DeletePVar(playerid, "ac_fly");
	return true;
}


CMD:gm(playerid,params[])
{
	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 2) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /gm [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");

	if(GMTest[params[0]] != false) return true;

	new Float:boomx, Float:boomy, Float:boomz;
	GetPlayerPos(params[0],boomx, boomy, boomz);
	GetPlayerHealth(params[0],AdmGMHP[params[0]]);

	if(AdmGMHP[params[0]] < 50) return SendClientMessage(playerid, COLOR_WARNING, "У игрока слишком мало хп!");

	GMTest[params[0]] = true;

	CreateExplosion(boomx, boomy , boomz+7, 5, 0.5);
	SetTimerEx("GodModeTest",1000,false, "dd", playerid,params[0]);


 	return true;
 }

CMD:givelic(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /givelic [ид]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");


	PLAYER_DATA[params[0]][data_LICB] = 1;
	new str[145];
	format(str,sizeof(str),"{808080}[A] %s выдал водительские права %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	SendAdminMessage(0x666699FF,str);
	format(str,sizeof(str),"Вам выдал водительские права %s",PLAYER_DATA[playerid][data_NAME]);
	SendClientMessage(params[0], COLOR_BLUE,str);

	return true;
}

CMD:givelicweap(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
	if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /givelicweap [ид]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");


	PLAYER_DATA[params[0]][data_LICG] = 1;
	new str[145];
	format(str,sizeof(str),"{808080}[A] %s выдал лицензию на оружие %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	SendAdminMessage(0x666699FF,str);
	format(str,sizeof(str),"Вам выдал лицензию на оружие %s",PLAYER_DATA[playerid][data_NAME]);
	SendClientMessage(params[0], COLOR_BLUE,str);

	return true;
}



