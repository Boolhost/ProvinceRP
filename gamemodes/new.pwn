stock SaveWarehouse()
{
	new query[3000], string[145];
	query = "UPDATE `warehouse` SET ";
	acc_int_strcat(query, sizeof(query), "rostov_metal", rostov_wh[0]);
	acc_int_strcat(query, sizeof(query), "rostov_patr", rostov_wh[1]);
	acc_int_strcat(query, sizeof(query), "rostov_narko", rostov_wh[2]);
	acc_int_strcat(query, sizeof(query), "maykop_metal", maykop_wh[0]);
	acc_int_strcat(query, sizeof(query), "maykop_patr", maykop_wh[1]);
	acc_int_strcat(query, sizeof(query), "maykop_narko", maykop_wh[2]);
	acc_int_strcat(query, sizeof(query), "odessa_metal", odessa_wh[0]);
	acc_int_strcat(query, sizeof(query), "odessa_patr", odessa_wh[1]);
	acc_int_strcat(query, sizeof(query), "odessa_narko", odessa_wh[2]);
	acc_int_strcat(query, sizeof(query), "army_metal", army_wh[0]);
	acc_int_strcat(query, sizeof(query), "army_patr", army_wh[1]);
	acc_int_strcat(query, sizeof(query), "smi_money", smi_money);
	strdel(query, strlen(query)-1, strlen(query));
	format(string,sizeof(string)," WHERE `id` = '1'");
	strcat(query, string);
	mysql_function_query(dbHandle, query, false, "", "");
	return true;
}





stock SavePlayerData(playerid)
{
	if(PLAYER_DATA[playerid][data_LOGGED] == true && IsPlayerConnected(playerid))
	{

		if(PLAYER_DATA[playerid][data_CS_TEAM] != 0) ResetWeaponAll(playerid);
	    new query[3000], string[145];
		query = "UPDATE `accounts` SET ";
		acc_int_strcat(query, sizeof(query), "logdate_day", PLAYER_DATA[playerid][data_LOGDATE_DAY]);
		acc_int_strcat(query, sizeof(query), "logdate_month", PLAYER_DATA[playerid][data_LOGDATE_MONTH]);
		acc_int_strcat(query, sizeof(query), "logdate_year", PLAYER_DATA[playerid][data_LOGDATE_YEAR]);
		acc_int_strcat(query, sizeof(query), "skin", PLAYER_DATA[playerid][data_SKIN]);
