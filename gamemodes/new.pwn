stock AC_Kick(playerid, code)
{
	new str[70], a_str[145];
	format(str, sizeof(str), "[AC] Вы были кикнуты по подозрению в читерстве (КОД: #AC%d)",code);
	SendClientMessage(playerid, COLOR_AC, str);
	format(a_str,sizeof(a_str),"[AC] %s[%d] был кикнут по подозрению в читерстве (КОД: #AC%d)", PLAYER_DATA[playerid][data_NAME], playerid, code);
	SendAdminMessage(0x9966FFFF, a_str);
	Kick(playerid);
	return true;
}



