                if(strlen(inputtext) < 5 || strlen(inputtext) > 45)
				{
					SendClientMessage(playerid, COLOR_WARNING, "Девиз может содержать не менее 5 и не более 45 символов!");
					ShowPlayerDialogFix(playerid,dialog_CREATE_POLIT_TEAM_2, DIALOG_STYLE_INPUT, "{FFCC00}Девиз семьи", "{FFFFFF}Введите девиз Вашей будущей семьи\n\nПримечание:\n- Девиз семьи может состоять максимум из 45 символов\n- Разрешено использовать только русские буквы\n- Запрещено использовать различные запрещенные символы", "Создать", "Отмена");
					return true;
				}
				for(new i = strlen(inputtext); i != 0; --i)
				switch(inputtext[i])
				{
					case 'A'..'Z', 'a'..'z', '`', '=':
					{
						SendClientMessage(playerid, 0x33CC33AA, "Разрешено использовать только латинские буквы и цифры");
						ShowPlayerDialogFix(playerid,dialog_CREATE_POLIT_TEAM_2, DIALOG_STYLE_INPUT, "{FFCC00}Девиз семьи", "{FFFFFF}Введите девиз Вашей будущей семьи\n\nПримечание:\n- Девиз семьи может состоять максимум из 45 символов\n- Разрешено использовать только русские буквы\n- Запрещено использовать различные запрещенные символы", "Создать", "Отмена");
						return true;
					}
				}
				strmid(POLIT_DEVIZ[playerid], inputtext, 0, 50, 50);
				new string[256];
				mysql_format(dbHandle, string, sizeof(string), "INSERT INTO `polit_team` (`name`,`deviz`, `owner`) VALUES ('%s', '%s', '%s')", POLIT_NAME[playerid], POLIT_DEVIZ[playerid], PLAYER_DATA[playerid][data_NAME]);
				mysql_function_query(dbHandle, string, false, "", "");

				strmid(POLIT_TEAM[TotalPolitT][data_NAME], POLIT_NAME[playerid], 0, strlen(POLIT_NAME[playerid]), 30);
				strmid(POLIT_TEAM[TotalPolitT][data_DEVIZ], POLIT_DEVIZ[playerid], 0, strlen(POLIT_DEVIZ[playerid]), 50);
				new msg[145];
				format(msg, sizeof(msg),"Название: '%s' Девиз: '%s'",POLIT_NAME[playerid], POLIT_DEVIZ[playerid]);
				SendClientMessage(playerid, -1, msg);
				SendClientMessage(playerid, -1, "Поздравляем Вас с успешной регистрацией семьи! (/family)");
				give_player_money(playerid, -10000000,"#79");
    			mysql_function_query(dbHandle, "SELECT * FROM `polit_team`",true, "LoadPolitT", "");
			}
  		}


		case dialog_ASHAN_STOPJOB:
