		case dialog_YABLO_STOPJOB:
		{
		    if(!response) return true;
		    if(response)
		    {
		        if(GetPVarInt(playerid, "job_bus") == 0)
		        {
			        new money = GetPVarInt(playerid,"all_tovar")*JB_DATA[2][data_JOB_MONEY], message[92];

			        if(JB_DATA[2][data_BANK] >= money)
			        {
			            if(PLAYER_DATA[playerid][data_VIP] == 1 || X2DAY == true)
						{
							format(message,sizeof(message),"Вы завершили рабочий день. Доставлено ящиков: %d шт. Ваша зарплата: %d рублей {FFCC00}(x2)",GetPVarInt(playerid,"all_tovar"),money*2);
							SendClientMessage(playerid, 0x99CC00FF, message);
							give_player_money(playerid, money*2,"#31");
						}
						else
						{
						    format(message,sizeof(message),"Вы завершили рабочий день. Доставлено ящиков: %d шт. Ваша зарплата: %d рублей",GetPVarInt(playerid,"all_tovar"),money);
							SendClientMessage(playerid, 0x99CC00FF, message);
							give_player_money(playerid, money,"#31");
						}

						JB_DATA[2][data_BANK] -= money;
						JB_DATA[2][data_ZATRATY] += money;
					}
