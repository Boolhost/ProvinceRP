					{
					    if(PLAYER_DATA[playerid][data_PROMOCODE] == 1) return SendClientMessage(playerid, COLOR_WARNING, "Вы уже активировали свой промокод!");
					    ShowPlayerDialogFix(playerid, dialog_PROMOCODE, DIALOG_STYLE_INPUT, "{FFCC00}Промокод", "{FFFFFF}Введите промокод в окошко ниже:", "Подтведить", "Отмена");
					}
					case 10:
					{
					    new IMPROVEMENTS1[268], IMPROVEMENTS2[268], dtext[268];
					    switch(PLAYER_DATA[playerid][data_IMPROVEMENTS1])
					    {
					        case 0: format(IMPROVEMENTS1,sizeof(IMPROVEMENTS1),"{1fa1ea}1. {FFFFFF}Решительность\t| {F04245}Не имеется (5 уровень и 100.000 рублей)");
					        case 1: format(IMPROVEMENTS1,sizeof(IMPROVEMENTS1),"{1fa1ea}1. {FFFFFF}Решительность\t| {63BD4E}Куплено (/leave)");
					    }
                        switch(PLAYER_DATA[playerid][data_IMPROVEMENTS2])
					    {
					        case 0: format(IMPROVEMENTS2,sizeof(IMPROVEMENTS2),"{1fa1ea}2. {FFFFFF}Мастер вождения\t| {F04245}Не имеется (7 уровень и 150.000 рублей)");
					        case 1: format(IMPROVEMENTS2,sizeof(IMPROVEMENTS2),"{1fa1ea}2. {FFFFFF}Мастер вождения\t| {63BD4E}Куплено");
					    }
					    format(dtext,sizeof(dtext),"%s\n%s",IMPROVEMENTS1, IMPROVEMENTS2);
						ShowPlayerDialogFix(playerid, dialog_IMPROVEMENTS, DIALOG_STYLE_LIST, "{1fa1ea}Улучшение", dtext, "Выбрать", "Назад");
					}
			    }
			}
		}

        case dialog_IMPROVEMENTS:
		{
		    if(!response) return true;
		    if(response)
		    {
		        switch(listitem)
		        {
		            case 0:
		            {
                        if(PLAYER_DATA[playerid][data_IMPROVEMENTS1] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Вы уже приобрели данное улучшение!");
						if(PLAYER_DATA[playerid][data_LVL] < 5) return SendClientMessage(playerid, COLOR_WARNING, "Необходим 5 уровень и 100.000р");
						if(PLAYER_DATA[playerid][data_MONEY] < 100000) return SendClientMessage(playerid, COLOR_WARNING, "Необходим 5 уровень и 100.000 рублей");
						give_player_money(playerid, -50000,"#IMPROVEMENTS1");
						PLAYER_DATA[playerid][data_IMPROVEMENTS1] = 1;
						SendClientMessage(playerid, COLOR_BLUE, "Теперь Вы можете самостоятельно увольняться с организации (/leave)");
						SavePlayerData(playerid);
		            }
		            case 1:
		            {
		                if(PLAYER_DATA[playerid][data_IMPROVEMENTS2] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Вы уже приобрели данное улучшение!");
						if(PLAYER_DATA[playerid][data_LVL] < 7) return SendClientMessage(playerid, COLOR_GREY, "Необходим 7 уровень и 150.000 рублей");
						if(PLAYER_DATA[playerid][data_MONEY] < 150000) return SendClientMessage(playerid, COLOR_GREY, "Необходим 7 уровень и 150.000 рублей");
						give_player_money(playerid, -75000,"#IMPROVEMENTS2");
						PLAYER_DATA[playerid][data_IMPROVEMENTS2] = 1;
