			SendClientMessage(playerid, COLOR_GREY,"Ворота автоматический закроются через 10 секунд");
			MoveDynamicObject(police_barrier[1], 2579.84, -2438.85, 21.60, 0.5, 0.00, 0.00, 90.00);
			SetTimer("Cops2", 10000, 0);
			return true;
   		}
	}
	return true;
}

public OnRconLoginAttempt(ip[], password[], success)
{
    if(success || !success)
    {
    	new YouIP[16];
     	for(new i = 0; i <= MAX_PLAYERS; i++)
      	{
       		if(IsPlayerConnected(i))
  			{
     			GetPlayerIp(i, YouIP, sizeof(YouIP));
     			if(!strcmp(ip, YouIP, true))
     			{
                   printf("[serv_log] %s attemp is RCON",ip);
                   Kick(i);
                   return true;
               }
           }
       }
	}
	return true;
}

public OnPlayerUpdate(playerid)
{
    if(Player_Speed(playerid) > 300)
	{
	    if(!IsPlayerInAnyVehicle(playerid)) return AC_Kick(playerid, 7);
	}


	if(GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK && PLAYER_DATA[playerid][data_ADMLVL] == 0) AC_Kick(playerid, 9);

	if (GetPlayerState(playerid) == PLAYER_STATE_ONFOOT)
	{
		new Float:vec[3];
		GetPlayerCameraFrontVector(playerid, vec[0], vec[1], vec[2]);
		new bool:possible_crasher = false;
		for (new i = 0; !possible_crasher && i < sizeof(vec); i++)
		if (floatabs(vec[i]) > 10.0)
		possible_crasher = true;
		if (possible_crasher)
		{
		    printf("[server_log] %s is. Crasher.",PLAYER_DATA[playerid][data_LOGIN_IP]);
		    return 0;
		}
	}



    if(PLAYER_DATA[playerid][data_AFK] > 1) SetPlayerChatBubble(playerid, "", -1, 20.0, 1100);
    PLAYER_DATA[playerid][data_AFK] = -1;



    if(noclipdata[playerid][cameramode] == CAMERA_MODE_FLY)
	{
		new keys,ud,lr;
		GetPlayerKeys(playerid,keys,ud,lr);

		if(noclipdata[playerid][mode] && (GetTickCount() - noclipdata[playerid][lastmove] > 100))
		{
		    MoveCamera(playerid);
		}

		if(noclipdata[playerid][udold] != ud || noclipdata[playerid][lrold] != lr)
		{
			if((noclipdata[playerid][udold] != 0 || noclipdata[playerid][lrold] != 0) && ud == 0 && lr == 0)
			{
				StopPlayerObject(playerid, noclipdata[playerid][flyobject]);
				noclipdata[playerid][mode]      = 0;
				noclipdata[playerid][accelmul]  = 0.0;
			}
			else
			{

				noclipdata[playerid][mode] = GetMoveDirectionFromKeys(ud, lr);
				MoveCamera(playerid);
			}
		}
		noclipdata[playerid][udold] = ud; noclipdata[playerid][lrold] = lr;
		return 0;
	}

	return true;
}

