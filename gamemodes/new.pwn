CMD:awarn(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 8) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"us[100]",params[0],params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /awarn [ид] [причина]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(playerid == params[0]) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя приминить на себе!");
    if(PLAYER_DATA[params[0]][data_ADMLVL] > PLAYER_DATA[playerid][data_ADMLVL]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к старшей администрации!");
    if(PLAYER_DATA[params[0]][data_ADMLVL] == 0) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к простому игроку!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < PLAYER_DATA[params[0]][data_ADMLVL]) return SendClientMessage(playerid,COLOR_WARNING,"Вы не можете приминить к вышестоящему администратору!");

	if(PLAYER_DATA[params[0]][data_AWARN] < 3)
	{
	    PLAYER_DATA[params[0]][data_AWARN]++;
	    for(new i = 0; i < MAX_PLAYERS; i++)
		{
			if(!IsPlayerConnected(i)) continue;
			if(GetPVarInt(i,"gPlayerAaction") == 0)
	  		{
	    		new string[145];
				format(string, sizeof(string), "Администратор %s выдал предупреждение Администратору %s [%d|3]. Причина: %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME],PLAYER_DATA[params[0]][data_AWARN],params[1]);
				SendClientMessage(i,COLOR_AC,string);
			}
		}
	    return true;
	}

	if(PLAYER_DATA[params[0]][data_AWARN] >= 3)
	{
	 	new query[256];
	    mysql_format(dbHandle,query, sizeof(query),"UPDATE `accounts` SET `admlvl` = '0' WHERE `name` = '%e'", PLAYER_DATA[params[0]][data_NAME]);
	    mysql_function_query(dbHandle, query, false, "", "");
		Kick(params[0]);

		for(new i = 0; i < MAX_PLAYERS; i++)
		{
			if(!IsPlayerConnected(i)) continue;
			if(GetPVarInt(i,"gPlayerAaction") == 0)
	  		{
	    		new string[145];
				format(string, sizeof(string), "Администратор %s снял с поста Администратора %s. Причина: 3 предупреждения",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
				SendClientMessage(i,COLOR_AC,string);
			}
		}
		return true;
	}
	return true;
}

