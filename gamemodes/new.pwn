public OnPlayerGiveDamage(playerid, damagedid, Float:amount, weaponid)
{
    new slot = getWeaponIdSlot(playerid);
    if(slot != 0 && slot != -1 && weaponid != 0)
    {
		if(PLAYER_DATA[playerid][data_GUN][slot] == 0 || PLAYER_DATA[playerid][data_AMMO][slot] == 0)
	    {
	        ac_damage[playerid][slot]++;
			if(ac_damage[playerid][slot] == 3)
		    {

		        printf("[test_ac] slot: %d, playerid: %d, damagedid: %d, amount: %d, weaponid: %d",slot,playerid, damagedid, amount, weaponid);
		        new str[145];
				format(str,sizeof(str),"[WARNING] %s[%d] возможно использует читы на оружие < {CCFF33}damageid: %d | weaponid: %d | amount: %d {9999FF}>",PLAYER_DATA[playerid][data_NAME], playerid, damagedid, weaponid, amount);
				//SendAdminMessage(0x9999FFAA,str);
		        return true;
	        }
	    }
    }





	if(GetPlayerWeapon(playerid) == 3)
 	{
 		if(GetPVarInt(damagedid, "freeze") == 0)
 		{
 			new Float:health;
 			GetPlayerHealth(damagedid, health);
 			ClearAnimations(damagedid);

			FreezePlayer(damagedid);
			SetTimerEx("UnfreezePlayer", 4000, false, "d", damagedid);
			SetPlayerHealth(damagedid, health+amount);
		}
	}
	return true;
}


