				}
			}

			SetPlayerPosAC(playerid, GARAGE_DATA[g][data_EXIT_X], GARAGE_DATA[g][data_EXIT_Y], GARAGE_DATA[g][data_EXIT_Z]);
			SetPlayerInterior(playerid, 0);
