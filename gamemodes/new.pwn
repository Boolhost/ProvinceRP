CMD:cmd(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 5) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(sscanf(params, "is[128]", params[0], params[1])) return SendClientMessage(playerid, COLOR_WARNING, "[Подсказка] {ffffff}Введите: /cmd [id игрока] [текст]");
    OnPlayerText(params[0], params[1]);
    return true;
}


CMD:donate(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

	new query[80];
	mysql_format(dbHandle,query, sizeof(query), "SELECT * FROM `accounts` WHERE `name` = '%e'",PLAYER_DATA[playerid][data_NAME]);
	mysql_function_query(dbHandle, query, true, "LoadDonate", "i", playerid);
	return true;
}

CMD:kiss(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /kiss [id игрока]");
	new Float:x,Float:y,Float:z,Float:a;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(3.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	if(params[0] == playerid) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя поцеловать себя в губы!");
	if(PLAYER_DATA[params[0]][data_SEX] != PLAYER_DATA[playerid][data_SEX]) return SendClientMessage(playerid,COLOR_WARNING,"Нужен человек противоположнего пола!");
	GetPlayerFacingAngle(playerid,a);
	SetPlayerFacingAngle(params[0],180+a);
	ApplyAnimation(params[0],"BD_FIRE","GRLFRD_KISS_03",4.0,0,0,0,0,0,1);
	ApplyAnimation(playerid,"BD_FIRE","PLAYA_KISS_03",4.0,0,0,0,0,0,1);
	return true;
}

CMD:iznas(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
	antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");

    new string[145];
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /iznas [id игрока]");
    new Float:x,Float:y,Float:z;
	GetPlayerPos(params[0],x,y,z);
	if(!PlayerToPoint(3.0, playerid, x,y,z)) return SendClientMessage(playerid,COLOR_WARNING,"Данный игрок слишком далеко от Вас!");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(params[0] == playerid) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя использовать на самом себе!");
	if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя использовать в машине!");
	new Float:angle,Float:hp;
	GetPlayerHealth(playerid,hp);
	SetPlayerHealthAC(playerid,hp-25.0);
	GetPlayerFacingAngle(playerid, angle);
	SetPlayerFacingAngle(params[0], angle+180);
	SendClientMessage(playerid, COLOR_WARNING, "Вы изнасиловали прохожего. Жертва сильно ударила вас");
	SendClientMessage(params[0], COLOR_WARNING, "Вас изнасиловал маньяк");
    format(string, sizeof(string), "%s изнасиловал(а) %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	ProxDetector(30.0, playerid, string, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF, 0xFF66CCFF);
	SetPlayerChatBubble(playerid, string, 0xFF66CCFF, 20.0, 4000);
	ApplyAnimation(params[0], "SNM", "SPANKINGW",4.1,0,1,1,1,1,1);
	ApplyAnimation(playerid, "SNM", "SPANKEDW",4.1,0,1,1,1,1,1);
	return true;
}

CMD:alldveh(playerid, params[])
{
	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 4) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	new string[128];
	for(new i = 0; i != MAX_VEHICLES; i++)
	{
	    if(!IsValidVehicle(i)) continue;
		if(IsVehicleOccupied(i)) continue;
		if(CAR_DATA[i][data_CREATE] == 0) continue;
		DestroyVehicle(i);
		ClearCarData(i);
	}

	format(string, sizeof(string), "{808080}[A] %s[%i] удалил все автомобили созданные администраторами", PLAYER_DATA[playerid][data_NAME], playerid);
	SendAdminMessage(0x666699FF,string);
	return true;
}

CMD:gotocar(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 5) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params, "i", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /gotocar [id транспорта]");
	new Float:x, Float:y, Float:z;
	GetVehiclePos(params[0], x, y, z);
	SetPlayerPosAC(playerid, x+2, y+2, z);
	return true;
}

CMD:getcar(playerid, params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 5) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(sscanf(params, "i", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /getcar [id транспорта]");
	new Float:x, Float:y, Float:z;
	GetPlayerPos(playerid, x, y, z);
	SetVehiclePos(params[0], x+2, y+2, z);
	return true;
}

