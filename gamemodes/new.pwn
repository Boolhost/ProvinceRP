	if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WARNING, "Используйте: /giveprefix [id игрока]");
	if(PLAYER_DATA[params[0]][data_ADMLVL] < 1) return SendClientMessage(playerid, COLOR_WARNING, "Выдать префикс можно только администратору");

	/*new string[128];
	SetPVarInt(params[0], "GivePrefix", playerid);
