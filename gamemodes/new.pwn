	    for(new i; i < 9; i ++)
	    {
	    	endobjecttwo = CreateObject( 19122 + random(6), X, Y, Z-0.5, 0, 0, 0 );
	    }
    	SetTimerEx("BigFireWorkStart", 500+random(300), 0, "iiii", box_objectidtwo, fobjecttwo, endobjecttwo, counttwo+1);
