        case dialog_APREFIX:
		{
			if(!response) return true;
			if(response)
   			{
                new prefix[32][MAX_PLAYERS], string[256], str[256];
                new i = GetPVarInt(playerid,"GivePrefix2");
				if(!strlen(inputtext)|| !strcmp(inputtext, "qwerty", true) || strlen(inputtext) < 6 || strlen(inputtext) > 32 || strfind(inputtext, "=", true) != -1)
				return ShowPlayerDialogFix(playerid, dialog_APREFIX, DIALOG_STYLE_INPUT, "{FFCC00}Выдача префикса", "\
						{FFFFFF}Введите префикс, который выдан администратору и будет отображаться над ним\n\n\
						{FFCC00}Примечание:\n\
						\t- Префикс должен состоять из русских букв\n\
						\t- Размер префикса от 6 до 32 символов", "Принять", "Отмена");
				cache_get_field_content(i, "admprefix", prefix[playerid], dbHandle);
			    strmid(prefix[playerid], inputtext, 0, strlen(inputtext), 32);
				mysql_format(dbHandle, string, sizeof(string), "UPDATE `accounts` SET `admprefix` = '%s' WHERE `name` = '%s' LIMIT 1", inputtext, PLAYER_DATA[i][data_NAME]);
				mysql_tquery(dbHandle, string, "", "");
				format(str,sizeof(str),"{808080}[A] Администратор %s изменил префикс администратору %s на [%s]",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[i][data_NAME], inputtext);
				SendAdminMessage(0x666699FF,str);
				DeletePVar(playerid,"GivePrefix2");
				SendAdminText(i);
		    }
		}

		case dialog_ALOGIN:
		{
			if(response || !response)
			{
                new string[144];
				switch(GetPVarInt(playerid,"aLogin"))
				{
					case 1:
					{
						if(!strlen(inputtext)|| !strcmp(inputtext, "qwerty", true) || strlen(inputtext) < 6 || strlen(inputtext) > 32 || strfind(inputtext, "=", true) != -1)
						return ShowPlayerDialogFix(playerid, dialog_ALOGIN, DIALOG_STYLE_PASSWORD, "Регистрация администратора", "{FFFFFF}Введите пароль, который будет от панели администратора\n\n{63BD4E}Примечание:\n\t- Пароль должен состоять из латинских букв и цифр\n\t- Размер пароля от 6 до 31 символов", "Принять", "Отмена");
						SetPVarString(playerid, "inputtext", inputtext);
						format(string, sizeof(string), "SELECT * FROM `accounts` WHERE `name` = '%s'",  PLAYER_DATA[playerid][data_NAME]);
						mysql_tquery(dbHandle, string, "AloginReg", "is", playerid,  PLAYER_DATA[playerid][data_NAME]);
					}
					case 0:
					{
						if(!strlen(inputtext)) return ShowPlayerDialogFix(playerid, dialog_ALOGIN, DIALOG_STYLE_PASSWORD, "Доступ администратора", "{FFFFFF}Введите Ваш пароль от панели администратора", "Принять", "Отмена");
						mysql_format(dbHandle, string, sizeof(string), "SELECT * FROM `accounts` WHERE `name` = '%s' AND `admpass` = '%e'", PLAYER_DATA[playerid][data_NAME], inputtext);
						mysql_tquery(dbHandle, string, "AloginAuth", "is", playerid, inputtext);
					}
				}
		    }
		}

		case dialog_SHAHTA_STOPJOB:
		{
		    if(!response) return true;
		    if(response)
		    {
		        if(GetPVarInt(playerid, "job_bus") == 0)
		        {
			        new money = GetPVarInt(playerid,"all_tovar")*JB_DATA[1][data_JOB_MONEY], message[92];


					if(JB_DATA[1][data_BANK] >= money)
			        {

			            if(PLAYER_DATA[playerid][data_VIP] == 1 || X2DAY == true)
						{
						    format(message,sizeof(message),"Вы завершили рабочий день. Доставлено руды: %d кг. Ваша зарплата: %d рублей {FFCC00}(x2)",GetPVarInt(playerid,"all_tovar"),money*2);
							SendClientMessage(playerid, 0x99CC00FF, message);
							give_player_money(playerid, money*2,"#26");
						}
						else
						{
						    format(message,sizeof(message),"Вы завершили рабочий день. Доставлено руды: %d кг. Ваша зарплата: %d рублей",GetPVarInt(playerid,"all_tovar"),money);
							SendClientMessage(playerid, 0x99CC00FF, message);
							give_player_money(playerid, money,"#26");
						}

						JB_DATA[1][data_BANK] -= money;
						JB_DATA[1][data_ZATRATY] += money;
					}
					else if(JB_DATA[1][data_BANK] < money)
					{
					    format(message,sizeof(message),"Вы завершили рабочий день. Доставлено руды: %d кг",GetPVarInt(playerid,"all_tovar"));
						SendClientMessage(playerid, 0x99CC00FF, message);
						SendClientMessage(playerid, COLOR_AC, "К сожалению у владельца предприятия закончились деньги");
					}

                    SetPlayerSpecialAction(playerid, 0);
                    DeletePVar(playerid,"ac_timer");
     				DeletePVar(playerid, "tovar");
					DeletePVar(playerid, "all_tovar");

					PLAYER_DATA[playerid][data_START_JOB] = 0;

					SetPlayerSkinAC(playerid,PLAYER_DATA[playerid][data_SKIN]);

					if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
					if(IsPlayerAttachedObjectSlotUsed(playerid,2)) RemovePlayerAttachedObject(playerid,2);
					if(IsPlayerAttachedObjectSlotUsed(playerid,3)) RemovePlayerAttachedObject(playerid,3);
				 	DisablePlayerCheckpoint(playerid);


				}
				else
				{
				    new money = GetPVarInt(playerid,"all_tovar")*JB_DATA[1][data_BUS_MONEY], message[92];

			        if(JB_DATA[1][data_BANK] >= money)
			        {
					    format(message,sizeof(message),"Вы завершили рабочий день. Доставлено: %d человек(а). Ваша зарплата: %d рублей",GetPVarInt(playerid,"all_tovar"),money);
						SendClientMessage(playerid, 0x99CC00FF, message);
						give_player_money(playerid, money,"#27");
						JB_DATA[1][data_BANK] -= money;
						JB_DATA[1][data_ZATRATY] += money;
					}
					else if(JB_DATA[1][data_BANK] < money)
					{
					    format(message,sizeof(message),"Вы завершили рабочий день. Доставлено: %d человек(а)",GetPVarInt(playerid,"all_tovar"));
						SendClientMessage(playerid, 0x99CC00FF, message);
						SendClientMessage(playerid, COLOR_AC, "К сожалению у владельца предприятия закончились деньги");
					}
                    DeletePVar(playerid, "job_bus");
                    DeletePVar(playerid,"ac_timer");
     				DeletePVar(playerid, "all_tovar");
					PLAYER_DATA[playerid][data_START_JOB] = 0;

					if(PLAYER_DATA[playerid][data_MEMBER] == 0) SetPlayerSkinAC(playerid,PLAYER_DATA[playerid][data_SKIN]);
					else SetPlayerSkinAC(playerid,PLAYER_DATA[playerid][data_SKINM]);
				 	DisablePlayerCheckpoint(playerid);

				 	if(PLAYER_DATA[playerid][data_RENTJOB] != INVALID_VEHICLE_ID)
					{
						new car = PLAYER_DATA[playerid][data_RENTJOB];
					    CAR_DATA[car][data_RENT] = INVALID_PLAYER_ID;
					    PLAYER_DATA[playerid][data_RENTJOB] = INVALID_VEHICLE_ID;
					    SetVehicleToRespawn(car);
					}
				}
		    }

		}

		case dialog_YABLO_STARTJOB:
		{
		    if(!response) return true;
		    if(response)
		    {
		        PLAYER_DATA[playerid][data_START_JOB] = 4;
		        switch(listitem)
		        {
					case 0:
					{
				        PreloadAnimLib(playerid,"CAMERA");
				        PreloadAnimLib(playerid,"CARRY");
				        SetPVarInt(playerid, "all_tovar", 0);
				        SetPVarInt(playerid, "tovar", 0);
				        if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid, 1);
				        SetPlayerSkinAC(playerid, 254);

		                new pos = random(7);
				        SetPVarInt(playerid, "yablo_pos", pos);
				        SetPlayerCheckpoint(playerid, yablo_pos[pos][0], yablo_pos[pos][1], yablo_pos[pos][2], 2.0);
				 	 	SendClientMessage(playerid, 0x99CC00FF, "Вы начали рабочий день. Отправляйтесь в сад собирать фрукты (на карте отмечена красная метка)");
		    		}
		    		case 1:
					{
					    if(PLAYER_DATA[playerid][data_LICB] == 0) return SendClientMessage(playerid, COLOR_WARNING, "У Вас нет водительских прав!");
					    SetPVarInt(playerid, "job_bus", 3);
					    SetPVarInt(playerid, "all_tovar", 0);
					    SetPlayerSkinAC(playerid, 254);
				        SendClientMessage(playerid, 0x99CC00FF, "Вы начали рабочий день. Возьмите автомобиль и отправляйтесь в Южный на ЖД Вокзал");
					}
				}
			}
		}

		case dialog_BUYFUEL:
		{
			if(!response) return true;
			if(response)
			{
				switch(listitem)
				{
				    case 0:
				    {
				        new car = GetPlayerVehicleID(playerid);
				        if(IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return SendClientMessage(playerid, COLOR_WARNING, "Нужно находиться в машине!");
						if(CAR_DATA[car][data_ENG] == 1) return SendClientMessage(playerid, COLOR_WARNING, "Заглушите двигатель!");
				        new dtext[110],b = GetPVarInt(playerid, "business");
						format(dtext,sizeof(dtext),"{FFFFFF}Стоимость бензина: %d рублей за 1 литр\nВведите количество бензина которое хотите приобрести",BUSINESS_DATA[b][data_CENA]);
						ShowPlayerDialogFix(playerid, dialog_BUYFUEL_1, DIALOG_STYLE_INPUT, "{FFCC00}Бензин",dtext, "Купить", "Отмена");
				    }
				    case 1:
				    {
				        new dtext[110],b = GetPVarInt(playerid, "business");
						format(dtext,sizeof(dtext),"{FFFFFF}Вы желаете купить канисту с бензином? Стоимость: %d рублей",BUSINESS_DATA[b][data_CENA]*20);
						ShowPlayerDialogFix(playerid, dialog_BUYFUEL_2, DIALOG_STYLE_MSGBOX, "{FFCC00}Канистра",dtext, "Купить", "Отмена");
				    }
				    case 2:
				    {
				        new dtext[110],b = GetPVarInt(playerid, "business");
						format(dtext,sizeof(dtext),"{FFFFFF}Вы желаете купить комплект запчастей? Стоимость: %d рублей",BUSINESS_DATA[b][data_CENA]*30);
					   	ShowPlayerDialogFix(playerid, dialog_BUYFUEL_3, DIALOG_STYLE_MSGBOX, "{FFCC00}Запчасти",dtext, "Купить", "Отмена");
				    }
				}
			}
		}


		case dialog_BUYFUEL_1:
		{
			if(!response) return true;
			if(response)
			{
			    new b = GetPVarInt(playerid,"business");
	   			new cena = BUSINESS_DATA[b][data_CENA]*strval(inputtext);
			    new car = GetPlayerVehicleID(playerid);
			    new c = CAR_DATA[car][data_ID];
	   			if(strval(inputtext) <= 0) return SendClientMessage(playerid, COLOR_WARNING, "Недопустимое значение!");
				if(strval(inputtext)+CAR_DATA[car][data_FUEL] > 50) return SendClientMessage(playerid, COLOR_WARNING, "Допустимо максимум 50 литров в баке!");
                if(strval(inputtext) > BUSINESS_DATA[b][data_PROD]  && BUSINESS_DATA[b][data_OWNED] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Недостаточно топлива на складе!");
				if(get_player_money(playerid) < cena) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");

                BUSINESS_DATA[b][data_PROD] -= strval(inputtext);
				BUSINESS_DATA[b][data_BANK] += cena;
				give_player_money(playerid,-cena,"#28");
				CAR_DATA[car][data_FUEL] += strval(inputtext);
				if(car == PLAYER_DATA[CAR_DATA[car][data_IDP]][data_VEH])
				{
					PLAYER_DATA[CAR_DATA[car][data_IDP]][data_CARFUEL][c] = CAR_DATA[car][data_FUEL];
				}
				//PLAYER_DATA[CAR_DATA[car][data_IDP]][data_CARFUEL][c] = CAR_DATA[car][data_FUEL];
				UpdateBusinessData(b);

				new ftext[15];
				format(ftext, sizeof(ftext),"%d", CAR_DATA[car][data_FUEL]);
				PlayerTextDrawSetString(playerid,SpeedometrFuel[playerid],ftext);
			}
		}

		case dialog_BUYFUEL_2:
		{
			if(!response) return true;
			if(response)
			{
	   			new b = GetPVarInt(playerid,"business");
	   			new cena = BUSINESS_DATA[b][data_CENA]*20;
				if(PLAYER_DATA[playerid][data_KANISTRA] == 1) return SendClientMessage(playerid,COLOR_WARNING,"У вас уже есть канистра!");
	   			if(10 > BUSINESS_DATA[b][data_PROD] && BUSINESS_DATA[b][data_OWNED] == 1) return SendClientMessage(playerid,COLOR_WARNING,"Недостаточно топлива на складе!");
				if(get_player_money(playerid) < cena) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");
				BUSINESS_DATA[b][data_PROD] -= 10;
				BUSINESS_DATA[b][data_BANK] += cena;
				give_player_money(playerid,-cena,"#29");
				UpdateBusinessData(b);
				PLAYER_DATA[playerid][data_KANISTRA] = 1;
				SendClientMessage(playerid, 0x99CC33FF, "Вы купили канистру с бензином (/fuelcar)");
			}
		}
		case dialog_BUYFUEL_3:
		{
		    if(!response) return true;
			if(response)
			{
			  	new b = GetPVarInt(playerid,"business");
			  	new cena = BUSINESS_DATA[b][data_CENA]*30;
			  	if(PLAYER_DATA[playerid][data_ZAPCHASTI] == 1) return SendClientMessage(playerid,COLOR_WARNING,"У вас уже есть ящик с инструментами!");
			  	if(3 > BUSINESS_DATA[b][data_PROD]) return SendClientMessage(playerid,COLOR_WARNING,"Недостаточно топлива на складе");
				if(get_player_money(playerid) < cena) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");
				BUSINESS_DATA[b][data_PROD] -= 3;
				BUSINESS_DATA[b][data_BANK] += cena;
				give_player_money(playerid,-cena,"#30");
            	UpdateBusinessData(b);
            	PLAYER_DATA[playerid][data_ZAPCHASTI] = 1;
            	SendClientMessage(playerid, 0x99CC33FF, "Вы купили ящик с инструментами (/healcar)");
			}
		}

		case dialog_ATTACH_INDEX_SELECTION:
        {
            if(!response) return true;
            if(response)
            {
                new p_id = GetPVarInt(playerid, "attach_id");
                if(IsPlayerAttachedObjectSlotUsed(p_id, listitem))
                {
                    ShowPlayerDialogFix(playerid, dialog_ATTACH_EDITREPLACE, DIALOG_STYLE_MSGBOX,"{FFCC00}Объект", "{FFFFFF}Вы хотите изменить или удалить объект из данного слота?", "Изменить", "Удалить");
                }
                else
                {
                    new string[2000];
                    for(new x = 0; x < sizeof(AttachmentObjects); x++)
                    {
                        format(string, sizeof(string), "%s%s\n", string, AttachmentObjects[x][attachname]);
                    }
                    ShowPlayerDialogFix(playerid, dialog_ATTACH_MODEL_SELECTION, DIALOG_STYLE_LIST, "{FFCC00}Выберите объект", string, "Выбрать", "Отмена");
                }
                SetPVarInt(playerid, "AttachmentIndexSel", listitem);
            }
        }
        case dialog_ATTACH_EDITREPLACE:
        {
            new p_id = GetPVarInt(playerid, "attach_id");
            if(!response) RemovePlayerAttachedObject(p_id, GetPVarInt(playerid, "AttachmentIndexSel"));
			if(response) EditAttachedObject(p_id, GetPVarInt(playerid, "AttachmentIndexSel"));
            DeletePVar(playerid, "AttachmentIndexSel");
        }
        case dialog_ATTACH_MODEL_SELECTION:
        {
            if(!response) return DeletePVar(playerid, "AttachmentIndexSel");
            if(response)
            {
                new p_id = GetPVarInt(playerid, "attach_id");
                if(GetPVarInt(playerid, "AttachmentUsed") == 1) EditAttachedObject(p_id, listitem);
                else
                {
                    SetPVarInt(playerid, "AttachmentModelSel", AttachmentObjects[listitem][attachmodel]);
                    new string[256+1];
                    for(new x = 0; x < sizeof(AttachmentBones); x++)
                    {
                        format(string, sizeof(string), "%s%s\n", string, AttachmentBones[x]);
                    }
                    ShowPlayerDialogFix(playerid, dialog_ATTACH_BONE_SELECTION, DIALOG_STYLE_LIST, "{FFCC00}Выберите часть тела", string, "Выбрать", "Отмена");
                }
            }
        }
        case dialog_ATTACH_BONE_SELECTION:
        {
            if(!response)
            {
                DeletePVar(playerid, "AttachmentIndexSel");
            	DeletePVar(playerid, "AttachmentModelSel");
                return true;
            }
            if(response)
            {
                new p_id = GetPVarInt(playerid, "attach_id"),str[145];
                SetPlayerAttachedObject(p_id, GetPVarInt(playerid, "AttachmentIndexSel"), GetPVarInt(playerid, "AttachmentModelSel"), listitem+1);
                EditAttachedObject(p_id, GetPVarInt(playerid, "AttachmentIndexSel"));
	    		format(str,sizeof(str),"{808080}[A] %s выдал объект %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[p_id][data_NAME]);
				SendAdminMessage(0x666699FF,str);
                DeletePVar(playerid, "AttachmentIndexSel");
            	DeletePVar(playerid, "AttachmentModelSel");
			}
        }

        case dialog_ATTACH_OBJECT:
        {
            if(!response) return true;
            if(response)
            {
                new str[145],obj,Float:x,Float:y,Float:z;
                GetPlayerPos(playerid, x,y,z);
                obj = CreateObject(AttachmentObjects[listitem][attachmodel], x, y, z, 0.0, 0.0, 0.0);
                EditObject(playerid, obj);
   	    		format(str,sizeof(str),"{808080}[A] %s создал объект ID:%d",PLAYER_DATA[playerid][data_NAME], obj);
				SendAdminMessage(0x666699FF,str);
            }
        }


