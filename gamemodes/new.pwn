}

public UnbanAccount(playerid,name[])
{
    new rows, fields;
    cache_get_data(rows, fields);
    if(rows)
	{
	    new query[150];
	    mysql_format(dbHandle,query, sizeof(query), "DELETE FROM `banlist` WHERE `name` = '%s'", name);
	    mysql_function_query(dbHandle, query, false, "", "");
     	new str[145];
	    format(str,sizeof(str),"{808080}[A] %s разбанил акаунт %s",PLAYER_DATA[playerid][data_NAME],name);
		SendAdminMessage(0x666699FF,str);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Данный акаунт не найден в базе данных!");
	return true;
}

public SecondTimer()
{
	global_minute++;



	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(GetPlayerState(i) == PLAYER_STATE_DRIVER)
	 	{
			new carid = GetPlayerVehicleID(i);
	 	    new Float:vehhealth;
	    	GetVehicleHealth(carid, vehhealth);
	    	if(vehhealth <= 600)
	    	{
	    	    if(CAR_DATA[carid][data_ENG] == 1) SendClientMessage(i, COLOR_WARNING, "Транспорт заглох. Вы можете вызвать механика: /call");
	  			CAR_DATA[carid][data_ENG] = 0;
	        	GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
	        	SetVehicleParamsEx(carid,false,lights,alarm,doors,bonnet,boot,objective);
	    	}
	    }
	}

	if(cs_open == true && cs_status == false)
	{
		if(cs_time > 0)
		{
			cs_time--;
			for(new i = 0; i < MAX_PLAYERS; i++)
		 	{
		 	    if(!IsPlayerConnected(i)) continue;
		 	    if(PLAYER_DATA[i][data_CS_TEAM] != 0)
				{
			 		new captmsg[10];
					format(captmsg,sizeof(captmsg),"~w~%d",cs_time);
					GameTextForPlayer(i, captmsg, 1000, 6);
				}
			}
		}
		else if(cs_time == 0)
		{
		    for(new i = 0; i < MAX_PLAYERS; i++)
		 	{
		 	    if(!IsPlayerConnected(i)) continue;

			    if(PLAYER_DATA[i][data_CS_TEAM] != 0)
				{
				    SetPlayerTeam(i, NO_TEAM);
				    SetPlayerSkills(i);
				    SetPlayerColorEx(i);
				    if(PLAYER_DATA[i][data_MEMBER] == 0) SetPlayerSkinAC(i, PLAYER_DATA[i][data_SKIN]);
				    else SetPlayerSkinAC(i, PLAYER_DATA[i][data_SKINM]);


	       			PLAYER_DATA[i][data_CS_TEAM] = 0;
				    PLAYER_DATA[i][data_HOSPITAL] = 0;
				    SetPlayerHealthAC(i, 100);

				    SetPlayerPosAC(i, 2285.4358,1370.0557,11.4574);
				    SetPlayerVirtualWorld(i, 0);
					SetPlayerInterior(i,0);
					SetPlayerFacingAngle(i, 90.0);
					SetCameraBehindPlayer(i);
					ResetWeaponAll(i);
				}
			}
			SendClientMessageToAll(0xFF66CCFF,"[Мероприятие]Мероприятие 'Counter-Strike' завершено.");
			cs_open = false;
		}
	}
    if(IsCapture == true)
	{
	    if(capt_time > 0)
	    {
			capt_time--;
			for(new i = 0; i < MAX_PLAYERS; i++)
		 	{
		 	    if(!IsPlayerConnected(i)) continue;
				if(IsCapture == true && IsPlayerOPG(i))
				{
			 		new captmsg[10];
					format(captmsg,sizeof(captmsg),"~w~%d",capt_time);
					GameTextForPlayer(i, captmsg, 1000, 6);
				}
			}
		}
		else if(capt_time == 0)
		{
			new oneteam, twoteam;
			for(new i = 0; i < MAX_PLAYERS; i++)
			{
				if(!IsPlayerConnected(i)) continue;

				if(PlayerToPoint(25.0, i, BUSINESS_DATA[capt_biz][data_ENTERX],BUSINESS_DATA[capt_biz][data_ENTERY],BUSINESS_DATA[capt_biz][data_ENTERZ]))
				{
					if(PLAYER_DATA[i][data_MEMBER] == capt_one_team) oneteam++;
					if(PLAYER_DATA[i][data_MEMBER] == capt_two_team) twoteam++;
				}
			}
			if(oneteam == 0 && twoteam != 0)
	 		{
		  		SendFractionMessage(capt_one_team,COLOR_AC,"[F] Ваша группировка не смогла захватить новый бизнес!");
		  		SendFractionMessage(capt_two_team,COLOR_AC,"[F] Ваша группировка отстояла бизнес!");
		   		CaptureStop();
	 		}
			else if(twoteam == 0 && oneteam != 0)
			{
				SendFractionMessage(capt_one_team,COLOR_AC,"[F] Ваша группировка захватила новый бизнес!");
		      	SendFractionMessage(capt_two_team,COLOR_AC,"[F] Ваша группировка потеряла бизнес!");
	           	BUSINESS_DATA[capt_biz][data_MAFIA] = capt_one_team;
				SaveBusinessData(capt_biz);
		    	CaptureStop();
			}
			else if(twoteam != 0 && oneteam != 0) capt_time += 60;
	 		else
	 		{
		    	SendFractionMessage(capt_one_team,COLOR_AC,"[F] Ваша группировка не смогла захватить новый бизнес!");
		    	SendFractionMessage(capt_two_team,COLOR_AC,"[F] Ваша группировка отстояла бизнес!");
				CaptureStop();
			}
		}
	}
	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(GetPVarInt(i, "TimeTaxi") > 0)
		{
		    if(PLAYER_DATA[i][data_LOGGED] == false) return true;
			SetPVarInt(i, "TimeTaxi", GetPVarInt(i, "TimeTaxi") - 1);
			if(GetPVarInt(i, "TimeTaxi") == 0)
			{
				PLAYER_DATA[GetPVarInt(i, "PlayerTaxi")][data_SALARY] += GetPVarInt(i, "TaxiPrice");
				SetPVarInt(i, "TimeTaxi", 30);
				SetPVarInt(GetPVarInt(i, "PlayerTaxi"), "TaxiMoney", GetPVarInt(GetPVarInt(i, "PlayerTaxi"), "TaxiMoney") + GetPVarInt(i, "TaxiPrice"));
			}
		}
	}

    if(ad_timer > 0) ad_timer--;

    // МИНУТЕЫЙ ТАЙМЕР
	if(global_minute == 60)
	{
	    new hour, minute, second;
	    gettime(hour, minute, second);

	    //SetWorldTime(hour);

	    switch(minute)
	    {
		    case 2:
			{
				for(new b = 0; b < TotalBusiness; b++)
				{
					if(BUSINESS_DATA[b][data_OWNED] == 0) continue;
					if(BUSINESS_DATA[b][data_DAY] == 0) continue;
					if(BUSINESS_DATA[b][data_PROD] < 200) continue;
					new tovar = RandomEX(10, 200),money;
					switch(BUSINESS_DATA[b][data_TYPE])
					{
						case 1:money = tovar*8;
						case 2:money = tovar*7;
						case 3:money = tovar*6;
						case 4:money = tovar*15;
						case 5:money = tovar*5;
						case 6:money = tovar*7;
					}
					BUSINESS_DATA[b][data_BANK] += money;
					BUSINESS_DATA[b][data_PROD] -= tovar;
					UpdateBusinessData(b);
					SaveBusinessData(b);

				}
			}

			case 6: GOZaezd();

			case 35:
			{
			    SendClientMessageToAll(0xFFCC00AA,"~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
			    SendClientMessageToAll(0xFFCC00AA,"- Пополнить Донат кошелек можно в нашей группе VK: vk.com/provincerp3e");
			    SendClientMessageToAll(0xFFCC00AA,"- С помощью доната Вы можете приобрести игровую валюту и множество других привелегий");
			    SendClientMessageToAll(0xFFCC00AA,"- Подробно о функциях доната можно узнать в специальном меню /mm > Дополнительные услуги");
			    SendClientMessageToAll(0xFFCC00AA,"~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");

			    new time = GetTickCount();

			    for(new b = 0; b < TotalJB; b++) SaveJBData(b);
			    for(new k = 0; k < TotalKV; k++) SaveKVData(k);
			    //for(new g = 0; g < TotalGarages; g++) SaveGarageData(g);
			    for(new a = 0; a < TotalAB; a++) SaveABData(a);
			    for(new h = 0; h < TotalHouses; h++) SaveHouseData(h);
			    for(new b = 0; b < TotalBusiness; b++) SaveBusinessData(b);
			    SaveWarehouse();

			    printf("[server_log] save all. Time: %d ms.",GetTickCount()-time );

			    //StartShar();

			}
			case 36: GOCS();

			case 58:
			{
			    if(hour == 4) SendClientMessageToAll(COLOR_AC,"[ВНИМАНИЕ] Через минуту произойдет рестарт сервера!");
			}
            case 59:
            {
                if(hour == 4 && restartserver == 0)
				{
				    restartserver = 1;
					RestartCFG();
				}
            }

		}

  		global_minute = 0;

		for(new carid; carid < MAX_VEHICLES; carid++)
		{
			if(!IsABMX(carid))
			{
				if(CAR_DATA[carid][data_ENG] == 1)
				{
			  		if(CAR_DATA[carid][data_FUEL] <= 0)
			    	{
			    		GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
						SetVehicleParamsEx(carid,false,lights,alarm,doors,bonnet,boot,objective);
						CAR_DATA[carid][data_ENG] = 0;
						CAR_DATA[carid][data_FUEL] = 0;
						return true;
			    	}
					//new c = CAR_DATA[carid][data_ID];
					//CAR_DATA[carid][data_FUEL] -= 1;
					if(carid == PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_VEH])
					{
					    switch(CAR_DATA[carid][data_ID])
					    {
					        case 0:
					        {
					        	PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_CARFUEL][0] = CAR_DATA[carid][data_FUEL];
					        	CAR_DATA[carid][data_FUEL] -= 1;
					        }
					        case 1:
					        {
					            PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_CARFUEL][1] = CAR_DATA[carid][data_FUEL];
					            CAR_DATA[carid][data_FUEL] -= 1;
					        }
					        case 2:
					        {
					            PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_CARFUEL][2] = CAR_DATA[carid][data_FUEL];
					            CAR_DATA[carid][data_FUEL] -= 1;
					        }
					    }
			            //PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_CARFUEL][CAR_DATA[carid][data_ID]] = CAR_DATA[carid][data_FUEL];
						SavePlayerFuel(CAR_DATA[carid][data_IDP]);
					}
			    	CAR_DATA[carid][data_FUEL] -= 1;
			    	/*new c = CAR_DATA[carid][data_ID];
			    	CAR_DATA[carid][data_FUEL] -= 1;
                    PLAYER_DATA[CAR_DATA[carid][data_IDP]][data_CARFUEL][c] = CAR_DATA[carid][data_FUEL];
                    SavePlayerFuel(CAR_DATA[carid][data_IDP]);*/
			   	}
			}
		}
	}
	return true;
}

public LoadBans()
{
    new rows, fields, temp[60],time = GetTickCount(),query[256],banac;
    cache_get_data(rows, fields);
    if(rows)
    {
    	for(new b = 0; b < rows; b++)
    	{
         	cache_get_field_content(b, "id", temp), BANS_DATA[b][data_ID] = strval (temp);
         	cache_get_field_content(b, "day", temp), BANS_DATA[b][data_DAY] = strval (temp);
			TotalBans++;

   			if(BANS_DATA[b][data_DAY] <= 0)
			{
			    mysql_format(dbHandle,query, sizeof(query), "DELETE FROM `banlist` WHERE `id` = '%d'", BANS_DATA[b][data_ID]);
	    		mysql_function_query(dbHandle, query, false, "", "");
	    		banac++;
			}
			else
			{
       			BANS_DATA[b][data_DAY]--;
			    mysql_format(dbHandle,query, sizeof(query),"UPDATE `banlist` SET `day` = '%d' WHERE `id` = '%d'",BANS_DATA[b][data_DAY],BANS_DATA[b][data_ID]);
			    mysql_function_query(dbHandle, query, false, "", "");
			}
		}
		printf("[serv_log]  Load bans accounts. Load: %d. Unban: %d. Ex unban: %d. Time: %d ms.",TotalBans,banac,TotalBans-banac, GetTickCount()-time);
  	}
    return true;
}

public LoadAllMembers(playerid)
{
    new rows, fields,temp[10];
    cache_get_data(rows, fields);
    SendClientMessage(playerid,0xFFCC33FF,"Члены организации:");
    for(new i = 0; i < rows; i++)
    {
		new name[MAX_PLAYER_NAME],rank,str[80],logd1,logd2,logd3;
		cache_get_field_content(i, "name", name, dbHandle, MAX_PLAYER_NAME);
		cache_get_field_content(i, "rank", temp), rank = strval (temp);
		cache_get_field_content(i, "logdate_day", temp), logd1 = strval (temp);
		cache_get_field_content(i, "logdate_month", temp), logd2 = strval (temp);
		cache_get_field_content(i, "logdate_year", temp), logd3 = strval (temp);

		format(str,sizeof(str),"%s - ранг %d, заходил %d/%d/%d",name,rank,logd1,logd2,logd3);
		SendClientMessage(playerid, 0x00BFFFFF, str);
	}
	return true;

}

public OffMember(playerid,name[])
{
    new rows, fields, leaderr, memberr, temp[10];
    cache_get_data(rows, fields);
    if(rows)
	{
	    cache_get_field_content(0, "leader", temp), leaderr = strval (temp);
	    cache_get_field_content(0, "member", temp), memberr = strval (temp);



	    if(memberr != PLAYER_DATA[playerid][data_MEMBER]) return SendClientMessage(playerid,COLOR_WARNING, "Данный игрок не состоит в Вашей организации!");
	    if(leaderr != 0) return SendClientMessage(playerid,COLOR_WARNING, "Данный игрок является лидером Вашей организации!");
	    for(new i = 0; i < MAX_PLAYERS; i++)
	    {
	        if(!IsPlayerConnected(i)) continue;
	        if(strcmp(PLAYER_DATA[i][data_NAME], name, true, 24) == 0)
	        {
	            SendClientMessage(i,COLOR_AC,"Вы были уволены из организации!");
				PLAYER_DATA[i][data_MEMBER] = 0;
				PLAYER_DATA[i][data_PODMEMBER] = 0;
				PLAYER_DATA[i][data_RANK] = 0;
				SetPlayerSkinAC(i,PLAYER_DATA[i][data_SKIN]);
				SetPlayerColorEx(i);
	        }
	    }
	    new query[120];
	    mysql_format(dbHandle,query, sizeof(query),"UPDATE `accounts` SET `member` = '0', `rank` = '0' WHERE `name` = '%e'", name);
	    mysql_function_query(dbHandle, query, false, "", "");
	    new str[145];
	    format(str,sizeof(str),"[R] %s уволил оффлайн %s",PLAYER_DATA[playerid][data_NAME], name);
		SendFractionMessage(PLAYER_DATA[playerid][data_MEMBER],COLOR_WARNING,str);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Данный акаунт не найден в базе данных!");
	return true;
}

public OnPlayerClickTextDraw(playerid, Text:clickedid)
{
    if(clickedid == Text:INVALID_TEXT_DRAW && PLAYER_DATA[playerid][data_CLICKTD] == true)
    {
        if(PLAYER_DATA[playerid][data_OPENCASINO] == true)
        {
            HideCasinoGame(playerid);
            casino_stavka[playerid] = 0;
			casino_update[playerid] = 0;
			KillTimer(casino_timer[playerid]);
            return true;
        }
  		if(PLAYER_DATA[playerid][data_CLOTHESMENU] == true)
		{
			TextDrawHideForPlayer(playerid, buy_clothes[0]);
		  	TextDrawHideForPlayer(playerid, buy_clothes[1]);
		  	TextDrawHideForPlayer(playerid, buy_clothes[2]);
		  	TextDrawHideForPlayer(playerid, buy_clothes[3]);
		  	TextDrawHideForPlayer(playerid, buy_clothes[4]);
		  	TextDrawHideForPlayer(playerid, buy_clothes[5]);
		  	PlayerTextDrawHide(playerid, buy_clothes_m[playerid]);
 			PLAYER_DATA[playerid][data_CLICKTD] = false;
 			PLAYER_DATA[playerid][data_CLOTHESMENU] = false;
 			SetPlayerSkinAC(playerid,PLAYER_DATA[playerid][data_SKIN]);

 			new b = GetPVarInt(playerid,"Clothes_biz");
 			SetPlayerPosAC(playerid,BUSINESS_DATA[b][data_EXITX],BUSINESS_DATA[b][data_EXITY],BUSINESS_DATA[b][data_EXITZ]);
    		SetPlayerInterior(playerid,BUSINESS_DATA[b][data_INT]);
    		SetPlayerVirtualWorld(playerid,BUSINESS_DATA[b][data_VW]);
    		FreezePlayer(playerid);
			SetTimerEx("UnfreezePlayer", 4000, false, "d", playerid);
			SetCameraBehindPlayer(playerid);
 			CancelSelectTextDraw(playerid);
			return true;
		}
  		if(PLAYER_DATA[playerid][data_OPENAUTOSALON] == true)
		{
  			DestroyVehicle(PLAYER_DATA[playerid][data_AUTOSALON_CAR]);
  			PLAYER_DATA[playerid][data_AUTOSALON_CAR] = INVALID_VEHICLE_ID;
			HideAutoSalonMenu(playerid);

			SetPlayerInterior(playerid,0);
			SetPlayerVirtualWorld(playerid,1);
			SetPlayerPosAC(playerid,2647.0122,-1910.7844,2327.3301);
			SetCameraBehindPlayer(playerid);
			return true;
		}
	}
	else
	{
     	if(clickedid == casino_bet)
		{
		    if(casino_update[playerid] != 0) return SendClientMessage(playerid, COLOR_WARNING, "Дождитесь окончания игры!");
		    for(new i = 0; i < sizeof(casino_pos); i++)
		 	{
		 	    if(PlayerToPoint(0.2, playerid, casino_pos[i][0], casino_pos[i][1], casino_pos[i][2]) && PLAYER_DATA[playerid][data_OPENCASINO] == true)
				{
				    ShowPlayerDialogFix(playerid, dialog_CASINO, DIALOG_STYLE_INPUT, "{FFCC00}Color Game","{ffffff}Укажите вашу ставку", "Начать", "Отмена");
					return true;
				}
	 		}
		}
  		if(clickedid == autorpass)
		{
		    if(GetPVarInt(playerid,"autorpass") == 1) return true;
			ShowPlayerDialogFix(playerid, dialog_LOGIN, DIALOG_STYLE_PASSWORD, "{1fa1ea}Ввод пароля","{FFFFFF}Добро пожаловать на сервер Province RolePlay\nВаш аккаунт уже зарегистрирован\n{FFFFFF}Чтобы авторизоваться введите пароль\n\nУ вас есть 1 минута на авторизацию","Ввести","Отмена");
			return true;
		}
		if(clickedid == autorlog)
		{
		    if(GetPVarInt(playerid,"autorpass") == 0) return SendClientMessage(playerid, COLOR_WARNING, "Введите пароль!");
            DeletePVar(playerid,"autorpass");
  			TextDrawHideForPlayer(playerid, autor);
  			SetPVarInt(playerid,"autorlog",1);
  			//PlayerTextDrawHide(playerid, autorpass[playerid]);
  			TextDrawHideForPlayer(playerid, autorpass);
  			TextDrawHideForPlayer(playerid, autorpass2);
  			TextDrawHideForPlayer(playerid, autorlog);
			PlayerTextDrawHide(playerid, autornick[playerid]);
			DeletePVar(playerid,"player_auth");
	        PLAYER_DATA[playerid][data_LOGGED] = true;
	        CancelSelectTextDraw(playerid);
	        TogglePlayerControllable(playerid, true);
			SpawnBegin(playerid);
			return true;
		}
	    for(new i = 0; i < 48; i++)
		{
		    if(clickedid == AutoSalon_Color[i])
		 	{
			    if(GetPVarInt(playerid,"as_color") == 0) PLAYER_DATA[playerid][data_ONECOLOR_AS] = color_veh[i][ciCar];
			    else PLAYER_DATA[playerid][data_TWOCOLOR_AS] = color_veh[i][ciCar];
			    ChangeVehicleColor(PLAYER_DATA[playerid][data_AUTOSALON_CAR], PLAYER_DATA[playerid][data_ONECOLOR_AS], PLAYER_DATA[playerid][data_TWOCOLOR_AS]);
			    return true;
		    }
		}
	    if(clickedid == AutoSalon_ButtonColor[0]) SetPVarInt(playerid,"as_color",0);
	    if(clickedid == AutoSalon_ButtonColor[1]) SetPVarInt(playerid,"as_color",1);
	    if(clickedid == AutoSalon_Button[0])
	    {
	        new dtext[80];
			format(dtext,sizeof(dtext),"{FFFFFF}Вы хотите купить данный транспорт. Стоимость: {66CC00}%d рублей",autosalon_cars[PLAYER_DATA[playerid][data_CHANGECAR]][asCena]);
	        ShowPlayerDialogFix(playerid, dialog_BUY_CAR_1, DIALOG_STYLE_MSGBOX, "{FFCC00}Покупка транспорта",dtext, "Купить", "Отмена");
			return true;
		}
     	if(clickedid == AutoSalon_Button[1])
	    {
	        PLAYER_DATA[playerid][data_CHANGECAR]--;
			if(PLAYER_DATA[playerid][data_CHANGECAR] <= -1) PLAYER_DATA[playerid][data_CHANGECAR] = sizeof(autosalon_cars)-1;

			new info2[50],info3[50];
			format(info2,sizeof(info2),"Цена: %d рублей",autosalon_cars[PLAYER_DATA[playerid][data_CHANGECAR]][asCena]);
			format(info3,sizeof(info3),"Класс авто: %s",autosalon_cars[PLAYER_DATA[playerid][data_CHANGECAR]][asClass]);


		    PlayerTextDrawSetString(playerid,AutoSalon_Stats[playerid][0],info2);
		    PlayerTextDrawSetString(playerid,AutoSalon_Stats[playerid][1],info3);
		    for(new i = 0; i < 2; i++)PlayerTextDrawShow(playerid, AutoSalon_Stats[playerid][i]);

			DestroyVehicle(PLAYER_DATA[playerid][data_AUTOSALON_CAR]);
		    PLAYER_DATA[playerid][data_AUTOSALON_CAR] = CreateVehicle(autosalon_cars[PLAYER_DATA[playerid][data_CHANGECAR]][asModel], 2641.2471,-1920.3633,2325.8000,270.0000, PLAYER_DATA[playerid][data_ONECOLOR_AS], PLAYER_DATA[playerid][data_TWOCOLOR_AS], 36000);

			LinkVehicleToInterior(PLAYER_DATA[playerid][data_AUTOSALON_CAR], 1);
	    	SetVehicleVirtualWorld(PLAYER_DATA[playerid][data_AUTOSALON_CAR], playerid);
	    	return true;
		}
	   	if(clickedid == AutoSalon_Button[2])
	    {
	        PLAYER_DATA[playerid][data_CHANGECAR]++;
			if(PLAYER_DATA[playerid][data_CHANGECAR] >= sizeof(autosalon_cars)) PLAYER_DATA[playerid][data_CHANGECAR] = 0;

			new info2[50],info3[50];
			format(info2,sizeof(info2),"Цена: %d рублей",autosalon_cars[PLAYER_DATA[playerid][data_CHANGECAR]][asCena]);
			format(info3,sizeof(info3),"Класс авто: %s",autosalon_cars[PLAYER_DATA[playerid][data_CHANGECAR]][asClass]);


		    PlayerTextDrawSetString(playerid,AutoSalon_Stats[playerid][0],info2);
		    PlayerTextDrawSetString(playerid,AutoSalon_Stats[playerid][1],info3);
		    for(new i = 0; i < 2; i++)PlayerTextDrawShow(playerid, AutoSalon_Stats[playerid][i]);


			DestroyVehicle(PLAYER_DATA[playerid][data_AUTOSALON_CAR]);
		    PLAYER_DATA[playerid][data_AUTOSALON_CAR] = CreateVehicle(autosalon_cars[PLAYER_DATA[playerid][data_CHANGECAR]][asModel], 2641.2471,-1920.3633,2325.8000,270.0000, PLAYER_DATA[playerid][data_ONECOLOR_AS], PLAYER_DATA[playerid][data_TWOCOLOR_AS], 36000);

			LinkVehicleToInterior(PLAYER_DATA[playerid][data_AUTOSALON_CAR], 1);
	    	SetVehicleVirtualWorld(PLAYER_DATA[playerid][data_AUTOSALON_CAR], playerid);
	    	return true;
		}

		if(PLAYER_DATA[playerid][data_CLOTHESMENU] == true)
		{
		    if(clickedid == buy_clothes[1])
			{
				if(PLAYER_DATA[playerid][data_SEX] == 1)
				{
				    PLAYER_DATA[playerid][data_CHANGESKIN]--;
	       			if(PLAYER_DATA[playerid][data_CHANGESKIN] <= -1) PLAYER_DATA[playerid][data_CHANGESKIN] = 99;
	              	SetPlayerSkinAC(playerid,SkinMale[PLAYER_DATA[playerid][data_CHANGESKIN]][0]);
	              	new string[9];
	   				format(string,sizeof(string),"%d",SkinMale[PLAYER_DATA[playerid][data_CHANGESKIN]][1]);
	    			PlayerTextDrawSetString(playerid,  buy_clothes_m[playerid], string);
				}
				else
				{
				    PLAYER_DATA[playerid][data_CHANGESKIN]--;
	       			if(PLAYER_DATA[playerid][data_CHANGESKIN] <= -1) PLAYER_DATA[playerid][data_CHANGESKIN] = 17;
	              	SetPlayerSkinAC(playerid,SkinFeMale[PLAYER_DATA[playerid][data_CHANGESKIN]][0]);
	              	new string[9];
	   				format(string,sizeof(string),"%d",SkinFeMale[PLAYER_DATA[playerid][data_CHANGESKIN]][1]);
		    		PlayerTextDrawSetString(playerid,  buy_clothes_m[playerid], string);
				}
			}
			if(clickedid == buy_clothes[2])
			{
				if(PLAYER_DATA[playerid][data_SEX] == 1)
				{
				    PLAYER_DATA[playerid][data_CHANGESKIN]++;
	       			if(PLAYER_DATA[playerid][data_CHANGESKIN] >= 100) PLAYER_DATA[playerid][data_CHANGESKIN] = 0;
	              	SetPlayerSkinAC(playerid,SkinMale[PLAYER_DATA[playerid][data_CHANGESKIN]][0]);
	              	new string[9];
	   				format(string,sizeof(string),"%d",SkinMale[PLAYER_DATA[playerid][data_CHANGESKIN]][1]);
	    			PlayerTextDrawSetString(playerid,  buy_clothes_m[playerid], string);
				}
				else
				{
				    PLAYER_DATA[playerid][data_CHANGESKIN]++;
	       			if(PLAYER_DATA[playerid][data_CHANGESKIN] >= 18) PLAYER_DATA[playerid][data_CHANGESKIN] = 0;
	              	SetPlayerSkinAC(playerid,SkinFeMale[PLAYER_DATA[playerid][data_CHANGESKIN]][0]);
	              	new string[9];
	   				format(string,sizeof(string),"%d",SkinFeMale[PLAYER_DATA[playerid][data_CHANGESKIN]][1]);
		    		PlayerTextDrawSetString(playerid,  buy_clothes_m[playerid], string);
				}
			}
			if(clickedid == buy_clothes[0])
			{
			    new b = GetPVarInt(playerid,"Clothes_biz");
			    if(BUSINESS_DATA[b][data_PROD] < 100 && BUSINESS_DATA[b][data_OWNED] == 1) return SendClientMessage(playerid, COLOR_WARNING,"В бизнесе недостаточно продуктов!");
				if(PLAYER_DATA[playerid][data_SEX] == 1)
				{
				    new CenaSkin;
			    	CenaSkin = SkinMale[PLAYER_DATA[playerid][data_CHANGESKIN]][1];
					if(get_player_money(playerid) < CenaSkin) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");
					PLAYER_DATA[playerid][data_SKIN] = GetPlayerSkin(playerid);
					give_player_money(playerid,-CenaSkin,"#64");
					TextDrawHideForPlayer(playerid, buy_clothes[0]);
				    TextDrawHideForPlayer(playerid, buy_clothes[1]);
				    TextDrawHideForPlayer(playerid, buy_clothes[2]);
				    TextDrawHideForPlayer(playerid, buy_clothes[3]);
				    TextDrawHideForPlayer(playerid, buy_clothes[4]);
				    TextDrawHideForPlayer(playerid, buy_clothes[5]);
				    PlayerTextDrawHide(playerid, buy_clothes_m[playerid]);
		          	PLAYER_DATA[playerid][data_CLICKTD] = false;
		          	PLAYER_DATA[playerid][data_CLOTHESMENU] = false;
		          	SetPlayerSkinAC(playerid,PLAYER_DATA[playerid][data_SKIN]);


		 			SetPlayerPosAC(playerid,BUSINESS_DATA[b][data_EXITX],BUSINESS_DATA[b][data_EXITY],BUSINESS_DATA[b][data_EXITZ]);
		    		SetPlayerInterior(playerid,BUSINESS_DATA[b][data_INT]);
		    		SetPlayerVirtualWorld(playerid,BUSINESS_DATA[b][data_VW]);
		    		FreezePlayer(playerid);
					SetTimerEx("UnfreezePlayer", 4000, false, "d", playerid);
		        	SetCameraBehindPlayer(playerid);
		        	CancelSelectTextDraw(playerid);
		        	SendClientMessage(playerid,0x00FF33FF,"Поздравляем Вас с покупкой новой одежды!");
				}
				else
				{
				    new CenaSkin;
			    	CenaSkin = SkinFeMale[PLAYER_DATA[playerid][data_CHANGESKIN]][1];
				    if(get_player_money(playerid) < CenaSkin) return SendClientMessage(playerid,COLOR_WARNING,"У Вас недостаточно денег на руках!");
					PLAYER_DATA[playerid][data_SKIN] = GetPlayerSkin(playerid);
					give_player_money(playerid,-CenaSkin,"#65");
					TextDrawHideForPlayer(playerid, buy_clothes[0]);
				    TextDrawHideForPlayer(playerid, buy_clothes[1]);
				    TextDrawHideForPlayer(playerid, buy_clothes[2]);
				    TextDrawHideForPlayer(playerid, buy_clothes[3]);
				    TextDrawHideForPlayer(playerid, buy_clothes[4]);
				    TextDrawHideForPlayer(playerid, buy_clothes[5]);
				    PlayerTextDrawHide(playerid, buy_clothes_m[playerid]);
		          	PLAYER_DATA[playerid][data_CLICKTD] = false;
		          	PLAYER_DATA[playerid][data_CLOTHESMENU] = false;
		          	SetPlayerSkinAC(playerid,PLAYER_DATA[playerid][data_SKIN]);
		          	SetPlayerPosAC(playerid,BUSINESS_DATA[b][data_EXITX],BUSINESS_DATA[b][data_EXITY],BUSINESS_DATA[b][data_EXITZ]);
		    		SetPlayerInterior(playerid,BUSINESS_DATA[b][data_INT]);
		    		SetPlayerVirtualWorld(playerid,BUSINESS_DATA[b][data_VW]);
		    		FreezePlayer(playerid);
					SetTimerEx("UnfreezePlayer", 4000, false, "d", playerid);
		        	SetCameraBehindPlayer(playerid);
		        	CancelSelectTextDraw(playerid);
		        	SendClientMessage(playerid,0x00FF33FF,"Поздравляем Вас с покупкой новой одежды");
				}

				if(BUSINESS_DATA[b][data_OWNED] != 0)
				{
					BUSINESS_DATA[b][data_PROD] -= 100;
					BUSINESS_DATA[b][data_BANK] += 6500;
					UpdateBusinessData(b);
				}
				return true;
			}
		}
	}
	return true;
}

public CasinoUpdate(playerid)
{
    casino_update[playerid]++;
	if(casino_update[playerid] < 6)
	{
 		casino_point[playerid][0] = random(3);
		switch(casino_point[playerid][0])
		{
			case 0:PlayerTextDrawColor(playerid, casino_card[playerid][0], 16711935);
			case 1:PlayerTextDrawColor(playerid, casino_card[playerid][0], -65281);
			case 2:PlayerTextDrawColor(playerid, casino_card[playerid][0], -5963521);
			case 3:PlayerTextDrawColor(playerid, casino_card[playerid][0], -2147483393);
		}

		PlayerTextDrawShow(playerid,casino_card[playerid][0]);
		return true;
	}

	else if(casino_update[playerid] < 11 && casino_update[playerid] > 5)
	{
 		casino_point[playerid][1] = random(3);
		switch(casino_point[playerid][1])
		{
			case 0:PlayerTextDrawColor(playerid, casino_card[playerid][1], 16711935);
			case 1:PlayerTextDrawColor(playerid, casino_card[playerid][1], -65281);
			case 2:PlayerTextDrawColor(playerid, casino_card[playerid][1], -5963521);
			case 3:PlayerTextDrawColor(playerid, casino_card[playerid][1], -2147483393);
		}

		PlayerTextDrawShow(playerid,casino_card[playerid][1]);
		return true;
	}
	else if(casino_update[playerid] < 16 && casino_update[playerid] > 10)
	{
 		casino_point[playerid][2] = random(3);
		switch(casino_point[playerid][2])
		{
			case 0:PlayerTextDrawColor(playerid, casino_card[playerid][2], 16711935);
			case 1:PlayerTextDrawColor(playerid, casino_card[playerid][2], -65281);
			case 2:PlayerTextDrawColor(playerid, casino_card[playerid][2], -5963521);
			case 3:PlayerTextDrawColor(playerid, casino_card[playerid][2], -2147483393);
		}

		PlayerTextDrawShow(playerid,casino_card[playerid][2]);
		return true;
	}
	else if(casino_update[playerid] < 21 && casino_update[playerid] > 15)
	{
 		casino_point[playerid][3] = random(3);
		switch(casino_point[playerid][3])
		{
			case 0:PlayerTextDrawColor(playerid, casino_card[playerid][3], 16711935);
			case 1:PlayerTextDrawColor(playerid, casino_card[playerid][3], -65281);
			case 2:PlayerTextDrawColor(playerid, casino_card[playerid][3], -5963521);
			case 3:PlayerTextDrawColor(playerid, casino_card[playerid][3], -2147483393);
		}

		PlayerTextDrawShow(playerid,casino_card[playerid][3]);
		return true;
	}
	else
	{
	    KillTimer(casino_timer[playerid]);
	    new str_1[12],str_2[12];
	    if(casino_point[playerid][0] == casino_point[playerid][1] &&
		casino_point[playerid][2] == casino_point[playerid][3] &&
		casino_point[playerid][0] == casino_point[playerid][3])
		{
		    new money = casino_stavka[playerid]*10;
		    give_player_money(playerid, money, "co#2");
		    GameTextForPlayer(playerid, "~g~WIN", 1000, 6);

		    new text[90];
		    format(text,sizeof(text),"Поздравляем! Вы выйграли %d рублей",money);
		    SendClientMessage(playerid ,0xFFFF33FF, text);


		    //wins
		}
		else
		{
		    // хуй
		    GameTextForPlayer(playerid, "~r~GAME OVER", 1000, 6);
		    SendClientMessage(playerid ,0xCC3333FF, "Игра завершена. Вы проиграли!");

		}

		casino_stavka[playerid] = 0;
		casino_update[playerid] = 0;
		format(str_1, sizeof(str_1), "%d RUB", get_player_money(playerid));
		format(str_2, sizeof(str_2), "%d RUB", casino_stavka[playerid]);
		PlayerTextDrawSetString(playerid,casino_money[playerid][0],str_1);
		PlayerTextDrawSetString(playerid,casino_money[playerid][1],str_2);

	}
	return true;
}


public  WalkAnim(playerid)
{
    new keys, updown, leftright;
    GetPlayerKeys(playerid,keys,updown,leftright);
    if (GetPlayerWalkingStyle(playerid) == WALK_NORMAL)
    {
  		if ((keys & KEY_WALK && updown & KEY_UP) || (keys & KEY_WALK && updown & KEY_DOWN) || (keys & KEY_WALK && leftright & KEY_LEFT) || (keys & KEY_WALK && leftright & KEY_RIGHT))
        {
        	KillTimer(PLAYER_DATA[playerid][data_WALK_TIMER]);
            ApplyAnimation(playerid,"PED","WALK_player",4.1,1,1,1,1,1);
            PLAYER_DATA[playerid][data_WALK_TIMER] = SetTimerEx("WalkAnim",200,0,"d",playerid);
        }
        else ApplyAnimation(playerid,"PED","WALK_player",4.0,0,0,0,0,1), KillTimer(PLAYER_DATA[playerid][data_WALK_TIMER]);
