}


public LoadPolitT()
{
    new rows, fields, temp[256], time = GetTickCount();
    cache_get_data(rows, fields);
    TotalPolitT = 0;
    if(rows)
    {
    	for(new p = 0; p < rows; p++)
    	{
	        cache_get_field_content(p, "id", temp), POLIT_TEAM[p][data_ID] = strval (temp);
	        cache_get_field_content(p, "owner", POLIT_TEAM[p][data_OWNER], dbHandle, MAX_PLAYER_NAME);
	        cache_get_field_content(p, "name", POLIT_TEAM[p][data_NAME], dbHandle, 30);
	        cache_get_field_content(p, "deviz", POLIT_TEAM[p][data_DEVIZ], dbHandle, 50);
	        cache_get_field_content(p, "bank", temp), POLIT_TEAM[p][data_BANK] = strval (temp);
	        cache_get_field_content(p, "status", temp), POLIT_TEAM[p][data_STATUS] = strval (temp);
			for(new i = 0; i < MAX_PLAYERS; i++)
			{
			    if(!IsPlayerConnected(i)) continue;
			    if(strfind(POLIT_TEAM[p][data_OWNER], PLAYER_DATA[i][data_NAME], true) != -1)
				{
				    PLAYER_DATA[i][data_POLIT] = POLIT_TEAM[p][data_ID];
				    SavePlayerData(i);
				}
			}
         	TotalPolitT++;
        }
        printf("[serv_log]  Load polit. Load: %d p. Time: %d ms.",TotalPolitT, GetTickCount()-time);
	}
	return true;
}


public OffPMember(playerid,name[])
{
    new rows, fields, polit, temp[10];
    cache_get_data(rows, fields);
    if(rows)
	{
	    cache_get_field_content(0, "polit", temp), polit = strval (temp);



	    if(polit != PLAYER_DATA[playerid][data_POLIT]) return SendClientMessage(playerid,COLOR_WARNING, "Данный игрок не состоит в Вашей семье!");

	    for(new i = 0; i < MAX_PLAYERS; i++)
	    {
	        if(!IsPlayerConnected(i)) continue;
	        if(strcmp(PLAYER_DATA[i][data_NAME], name, true, 24) == 0)
	        {
	            SendClientMessage(i,COLOR_AC,"Вас выгнали из семьи!");
				PLAYER_DATA[i][data_POLIT] = 0;
	        }
	    }
	    new query[120];
	    format(query, sizeof(query),"UPDATE `accounts` SET `polit` = '0' WHERE `name` = '%s'", name);
	    mysql_function_query(dbHandle, query, false, "", "");

	    new str[145];
	    format(str,sizeof(str),"[P] %s[%d] выгнал из семьи оффлайн %s",PLAYER_DATA[playerid][data_NAME],playerid,name);
		SendPolitMessage(PLAYER_DATA[playerid][data_POLIT],COLOR_WARNING,str);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Данный акаунт не найден в базе данных!");
	return true;
}
