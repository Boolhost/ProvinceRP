CMD:spawn(playerid,params[])
{
	if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
	if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

    if(GetPlayerState(playerid) != PLAYER_STATE_ONFOOT) return SendClientMessage(playerid, COLOR_WARNING,"Нельзя использовать в транспорте!");
    if(sscanf(params,"u",params[0])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /spawn [ид]");
    if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
	SetPlayerPosAC(params[0], 2723.0916,-2439.3308,21.8921);
    SetPlayerVirtualWorld(params[0], 0);
	SetPlayerInterior(params[0],0);
	SetPlayerFacingAngle(params[0], 90);
	SetCameraBehindPlayer(params[0]);
	FreezePlayer(params[0]);
	SetTimerEx("UnfreezePlayer", 4000, false, "d", params[0]);
	new message[145];
	format(message,sizeof(message),"{808080}[A] %s заспавнил игрока %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
	SendAdminMessage(0x666699FF,message);
	return true;
}

CMD:admins(playerid)
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 1 && PLAYER_DATA[playerid][data_VIP] == 0) return true;
    new string[512];
    for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i)) continue;
        new atext[64];
        if(PLAYER_DATA[i][data_ADMLVL] != 0)
        {
            switch(PLAYER_DATA[i][data_ADMLVL])
            {
                case 1: atext = "Хелпер";
                case 2: atext = "Администратор";
                case 3: atext = "Администратор";
                case 4: atext = "Администратор";
                case 5: atext = "Администратор";
                case 6: atext = "Гл.Администратор";
                case 7: atext = "Руководитель";
                case 8: atext = "Основатель";
            }

			if(PLAYER_DATA[i][data_AFK] > 2)
			{
            	format(string,sizeof(string),"%s{FFFFFF}(%d admlvl) %s: %s[%d] {FF3333}[AFK: %d] [AWARN: %d/3]\n",string,PLAYER_DATA[i][data_ADMLVL],atext,PLAYER_DATA[i][data_NAME],i,PLAYER_DATA[i][data_AFK],PLAYER_DATA[i][data_AWARN]);
            }
            else
            {
                format(string,sizeof(string),"%s{FFFFFF}(%d admlvl) %s: %s[%d] [AWARN: %d/3]\n",string,PLAYER_DATA[i][data_ADMLVL],atext,PLAYER_DATA[i][data_NAME],i, PLAYER_DATA[i][data_AWARN]);
            }
		}
    }
    ShowPlayerDialogFix(playerid,dialog_ADMINS, DIALOG_STYLE_MSGBOX, "{FFCC00}Администраторы онлайн", string, "Закрыть", "");
	return true;
}

CMD:warn(playerid,params[])
{
    if(antiflood[playerid] > 0) return SendClientMessage(playerid, COLOR_WARNING,"{808080}Не флуди!");
    antiflood[playerid]++;
    if(PLAYER_DATA[playerid][data_LOGGED] == false) return SendClientMessage(playerid,COLOR_WARNING,"Вы не авторизованы на сервере!");
    if(PLAYER_DATA[playerid][data_ADMLVL] < 3) return true;
    if(PLAYER_DATA[playerid][data_ALOGGED] == false) return SendClientMessage(playerid, COLOR_WARNING, "{808080}Вы не авторизованы. Используйте {1fa1ea}/alogin");

	if(sscanf(params,"us[100]",params[0],params[1])) return SendClientMessage(playerid,COLOR_WARNING,"Используйте: /warn [ид] [причина]");
	if(!IsPlayerConnected(params[0]))return  SendClientMessage(playerid,COLOR_WARNING,"Данного ID нет на сервере!");
	if(PLAYER_DATA[params[0]][data_LOGGED] == false)return  SendClientMessage(playerid,COLOR_WARNING,"Данный игрок не прошел авторизацию!");
    if(playerid == params[0]) return SendClientMessage(playerid,COLOR_WARNING,"Нельзя приминить на себе!");
    if(PLAYER_DATA[params[0]][data_ADMLVL] > PLAYER_DATA[playerid][data_ADMLVL]) return SendClientMessage(playerid, COLOR_WARNING, "Нельзя применить к старшей администрации!");
    PLAYER_DATA[params[0]][data_MEMBER] = 0;
    PLAYER_DATA[params[0]][data_PODMEMBER] = 0;
	PLAYER_DATA[params[0]][data_LEADER] = 0;
	PLAYER_DATA[params[0]][data_RANK] = 0;
	PLAYER_DATA[params[0]][data_ADMLVL] = 0;

	if(PLAYER_DATA[params[0]][data_WARN] < 3)
	{
	    PLAYER_DATA[params[0]][data_WARN]++;
	    PLAYER_DATA[params[0]][data_WARNTIME] += 1200;
	    for(new i = 0; i < MAX_PLAYERS; i++)
		{
			if(!IsPlayerConnected(i)) continue;
			if(GetPVarInt(i,"gPlayerAaction") == 0)
	  		{
	    		new string[145];
				format(string, sizeof(string), "Администратор %s выдал предупреждение %s [%d|3]. Причина: %s",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME],PLAYER_DATA[params[0]][data_WARN],params[1]);
				SendClientMessage(i,COLOR_AC,string);
			}
		}

	    SendClientMessage(params[0],COLOR_WARNING,"Для просмотра информации о предупреждении, используйте: /warntime");
	    SendClientMessage(params[0],COLOR_WARNING,"До снятия всех предупреждений запрещено вступать во фракции");
	    Kick(params[0]);
	    return true;
	}

	if(PLAYER_DATA[params[0]][data_WARN] >= 3)
	{
	 	new query[256];
	    mysql_format(dbHandle,query, sizeof(query), "INSERT INTO `banlist` ( `name`,`admin`, `day`, `text`, `ip`) VALUES ( '%e', '%e', '30', '%e', '%e')",PLAYER_DATA[params[0]][data_NAME],PLAYER_DATA[playerid][data_NAME],params[2],PLAYER_DATA[params[0]][data_LOGIN_IP]);
	    mysql_function_query(dbHandle, query, false, "", "");
		Kick(params[0]);

		for(new i = 0; i < MAX_PLAYERS; i++)
		{
			if(!IsPlayerConnected(i)) continue;
			if(GetPVarInt(i,"gPlayerAaction") == 0)
	  		{
	    		new string[145];
				format(string, sizeof(string), "Администратор %s заблокировал %s на 30 дней. Причина: 3 предупреждения",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[params[0]][data_NAME]);
				SendClientMessage(i,COLOR_AC,string);
			}
		}
		return true;
	}
	return true;
}

