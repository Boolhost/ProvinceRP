forward Alogin(playerid, name[]);
public Alogin(playerid, name[])
{
    new rows, fields;
	cache_get_data(rows, fields);
	if(!rows)
	{
	    return true;
	}
    new Password[16];
	cache_get_field_content(0, "admpass", Password, dbHandle);
	if(!strcmp(Password, "qwerty", true))
	{
		SetPVarInt(playerid, "aLogin", 1);
		ShowPlayerDialogFix(playerid, dialog_ALOGIN, DIALOG_STYLE_INPUT, "{FFCC00}Регистрация администратора", "\
		{FFFFFF}Введите пароль, который будет от панели администратора\n\n\
		{FFCC00}Примечание:\n\
		\t- Пароль должен состоять из латинских букв и цифр\n\
		\t- Размер пароля от 6 до 31 символов", "Принять", "Отмена");
	}
	else
	{
		SetPVarInt(playerid, "aLogin", 0);
		ShowPlayerDialogFix(playerid, dialog_ALOGIN, DIALOG_STYLE_INPUT, "{FFCC00}Доступ администратора", "\
		{FFFFFF}Введите Ваш пароль от панели администратора:", "Принять", "Отмена");
	}
	return true;
}

forward AloginReg(playerid, name[]);
public AloginReg(playerid, name[])
{
	new rows, fields;
	cache_get_data(rows, fields);
	if(!rows) return true;
	new inputtext[16], string[144];
	GetPVarString(playerid, "inputtext", inputtext, sizeof(inputtext));
	mysql_format(dbHandle, string, sizeof(string), "UPDATE `accounts` SET `admpass` = '%s' WHERE `name` = '%s' LIMIT 1", inputtext, PLAYER_DATA[playerid][data_NAME]);
	mysql_tquery(dbHandle, string, "", "");
	PLAYER_DATA[playerid][data_ALOGGED] = true;
	new str[214];
    for(new i = 0; i < 9; i++) TextDrawShowForPlayer(playerid, CheatText[i]);
	format(str,sizeof(str),"[A] Администратор %s (%s) [admlvl: %d] авторизовался на сервере",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[playerid][data_LOGIN_IP],PLAYER_DATA[playerid][data_ADMLVL]);
	SendAdminMessage(COLOR_AC,str);
	SendAdminText(playerid);
	return true;
}

forward AloginAuth(playerid, inputtext[]);
public AloginAuth(playerid, inputtext[])
{
	new rows, fields;
	cache_get_data(rows, fields);
	if(!rows)
	{
		SendClientMessage(playerid, COLOR_GREY, "Неверный пароль");
		SetPVarInt(playerid, "attempt_pass", GetPVarInt(playerid, "attempt_pass") + 1);
		if(GetPVarInt(playerid, "attempt_pass") > 3)
		{
			new str[214];
            Kick(playerid);
            format(str,sizeof(str),"[A] Администратор %s (%s) [admlvl: %d] не смог авторизоваться на сервере",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[playerid][data_LOGIN_IP],PLAYER_DATA[playerid][data_ADMLVL]);
			SendAdminMessage(COLOR_AC,str);
		}
	}
	else
	{
	    PLAYER_DATA[playerid][data_ALOGGED] = true;
        new str[214];
	    for(new i = 0; i < 9; i++) TextDrawShowForPlayer(playerid, CheatText[i]);
		format(str,sizeof(str),"[A] Администратор %s (%s) [admlvl: %d] авторизовался на сервере",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[playerid][data_LOGIN_IP],PLAYER_DATA[playerid][data_ADMLVL]);
		SendAdminMessage(COLOR_AC,str);
		//SendAdminText(playerid);
	}
	return true;
}

public PromoCheck(playerid,code[])
{
    new rows, temp[10], fields;
    cache_get_data(rows, fields);
    if(!rows) return SendClientMessage(playerid, COLOR_WARNING, "Промокод не найден!");
    new string[128], str[256], query[256];
    new nextlvl = PLAYER_DATA[playerid][data_LVL]+1;
	new nextexp = nextlvl*4;
	new lvlup = 0;
	new money,ludi,exp;
	/*new money = cache_get_field_content(0, "money");
	new ludi = cache_get_field_content(0, "ludi");
	new exp = cache_get_field_content(0, "exp");*/
	cache_get_field_content(0, "money", temp), money = strval (temp);
	cache_get_field_content(0, "ludi", temp), ludi = strval (temp);
	cache_get_field_content(0, "exp", temp), exp = strval (temp);

    format(str,sizeof(str),"{1fa1ea}Вы успешно активировали промо-код!\n\n");
	strcat(string,str);
    format(str,sizeof(str),"{FFFFFF}Вы получили:{1fa1ea} %d денег\n",money);
	strcat(string,str);
	format(str,sizeof(str),"{FFFFFF}Вы получили:{1fa1ea} %d EXP\n",exp);
	strcat(string,str);
	ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX,"{0099FF}Промокод",string, "Закрыть", "");
	give_player_money(playerid, money, "Code");
	PLAYER_DATA[playerid][data_EXP] += exp;

	if(PLAYER_DATA[playerid][data_EXP] >= nextexp)
	{
 		lvlup = 1;
 		PLAYER_DATA[playerid][data_EXP] = 0;
 		PLAYER_DATA[playerid][data_LVL]++;
 		SetPlayerScore(playerid,PLAYER_DATA[playerid][data_LVL]);
	}
	if(lvlup == 1) SendClientMessage(playerid,0x33993300,"{1fa1ea}Ваш игровой уровень повысился. Поздравляем!");
	PLAYER_DATA[playerid][data_PROMOCODE] = 1;
	SavePlayerData(playerid);

    ludi ++;
    mysql_format(dbHandle,query, sizeof(query), "UPDATE `promo` SET `ludi` = '%d' WHERE `code` = '%s'",ludi,code);
    mysql_function_query(dbHandle, query, false, "", "");
    return true;
}
public PromoCodeShow(playerid)
{
    new rows, temp[10], fields;
    cache_get_data(rows, fields);
    if(!rows) return SendClientMessage(playerid, COLOR_WARNING, "Список промокодов отсутствует!");
    new promolist[1256],code[32],money,ludi,exp;
    for(new i; i<rows; i++)
    {
        cache_get_field_content(i, "code",  code, dbHandle);
        cache_get_field_content(i, "money", temp), money = strval (temp);
		cache_get_field_content(i, "ludi", temp), ludi = strval (temp);
		cache_get_field_content(i, "exp", temp), exp = strval (temp);

        format(promolist,sizeof(promolist),"%s%d. Промокод:{1fa1ea} %s | {FFFFFF}Деньги:{1fa1ea} %d рублей | {FFFFFF}EXP:{1fa1ea} %d | {FFFFFF}Активаций:{1fa1ea} %d\n", promolist, i+1, code, money, exp, ludi);
    }
    ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_LIST,"{FF6347}Список промокодов", promolist, "Закрыть", "");
    return true;
}
forward PromoCreate(playerid,code[]);
public PromoCreate(playerid,code[])
{
    new rows,fields;
    cache_get_data(rows, fields);
    if(rows) return SendClientMessage(playerid, COLOR_WARNING, "Промокод уже есть в списке!");

    new string[256];
    new promoexp = GetPVarInt(playerid,"PROMOEXP");
    new promolic = 0;
    new promolud = 0;
    new promomoney = GetPVarInt(playerid,"PROMOMONEY");

    format(string,sizeof(string),"INSERT INTO `promo` (`code`,`exp`,`money`,`lic`,`ludi`) VALUES ('%s','%d','%d','%d','%d')",code,promoexp,promomoney,promolic,promolud);
    mysql_function_query(dbHandle, string, false, "", "");

    format(string,sizeof(string),"{FFFFFF}Промокод '%s' успешно создан!\n\nВыдача денег на %d рублей\nВыдача EXP: %d\n",code,promomoney,promoexp);
    ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX, "{66CC00}Создание промокода", string, "Закрыть", "");

    return DeletePVar(playerid,"PROMONAME"),DeletePVar(playerid,"PROMOMONEY"),DeletePVar(playerid,"PROMOEXP");
}

