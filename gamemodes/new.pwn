public OffLeader(playerid,name[])
{
    new rows, fields,query[128];
    cache_get_data(rows, fields);
    if(rows)
	{
	    for(new i = 0; i < MAX_PLAYERS; i++)
	    {
	        if(!IsPlayerConnected(i)) continue;
	        if(strcmp(PLAYER_DATA[i][data_NAME], name, true, 24) == 0)
	        {
	            SendClientMessage(i,COLOR_AC,"Вы были сняты с должности лидера!");
				PLAYER_DATA[i][data_LEADER] = 0;
				PLAYER_DATA[i][data_MEMBER] = 0;
				PLAYER_DATA[i][data_PODMEMBER] = 0;
				SetPlayerSkinAC(i,PLAYER_DATA[i][data_SKIN]);
				SetPlayerColorEx(i);
	        }
	    }
	    mysql_format(dbHandle,query, sizeof(query),"UPDATE `accounts` SET `leader` = '0', `member` = '0' WHERE `name` = '%e'", name);
	    mysql_function_query(dbHandle, query, false, "", "");

	    new str[145];
	    format(str,sizeof(str),"{808080}[A] %s снял с лидерства оффлайн %s",PLAYER_DATA[playerid][data_NAME],name);
		SendAdminMessage(0x666699FF,str);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Данный акаунт не найден в базе данных!");
	return true;
}

public OffAdmin(playerid,name[])
{
    new rows, fields,query[70];
    cache_get_data(rows, fields);
    if(rows)
	{
		for(new i = 0; i < MAX_PLAYERS; i++)
	    {
	        if(!IsPlayerConnected(i)) continue;
	        if(strcmp(PLAYER_DATA[i][data_NAME], name, true, 24) == 0)
	        {
	            SendClientMessage(i,COLOR_AC,"Вы были сняты с должности администратора!");
				PLAYER_DATA[i][data_ADMLVL] = 0;
	        }
	    }
	    mysql_format(dbHandle,query, sizeof(query),"UPDATE `accounts` SET `admlvl` = '0' WHERE `name` = '%e'", name);
	    mysql_function_query(dbHandle, query, false, "", "");
	    new str[145];
	    format(str,sizeof(str),"{808080}[A] %s снял с админки оффлайн %s",PLAYER_DATA[playerid][data_NAME],name);
		SendAdminMessage(0x666699FF,str);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Данный акаунт не найден в базе данных!");
	return true;
}

public OffBan(playerid,name[])
{
    new rows, fields,query[256],query1[256],temp[34],login_ip;
    cache_get_data(rows, fields);
    if(rows)
	{
	    cache_get_field_content(0, "login_ip", temp), login_ip = strval (temp);

	    new days = GetPVarInt(playerid, "DaysBan");
	    new textban[110];
	    GetPVarString(playerid, "TextBan", textban, sizeof(textban));
	    /*for(new i = 0; i < MAX_PLAYERS; i++)
		{
			if(!IsPlayerConnected(i)) continue;
			if(GetPVarInt(i,"gPlayerAaction") == 0)
		    {
		        new string[145];
				format(string, sizeof(string), "Администратор %s заблокировал оффлайн %s на %d дней. Причина: %s",PLAYER_DATA[playerid][data_NAME],name,days,textban);
				SendClientMessage(i,COLOR_AC,string);
			}
			if(strcmp(PLAYER_DATA[i][data_NAME], name, true, 24) == 0)
	        {
	            SendClientMessage(i,COLOR_AC,"Вы были заблокированы на сервере!");
	            PLAYER_DATA[i][data_MEMBER] = 0;
				PLAYER_DATA[i][data_LEADER] = 0;
				PLAYER_DATA[i][data_RANK] = 0;
				PLAYER_DATA[i][data_ADMLVL] = 0;
				Kick(i);
	        }
		}*/

	    mysql_format(dbHandle,query, sizeof(query), "INSERT INTO `banlist` ( `name`,`admin`, `day`, `text`, `ip`) VALUES ( '%e', '%e', '%d', '%e', '%e')",name,PLAYER_DATA[playerid][data_NAME],days,textban,login_ip);
	    mysql_function_query(dbHandle, query, false, "", "");

	    mysql_format(dbHandle,query1, sizeof(query1),"UPDATE `accounts` SET `admlvl` = '0', `member` = '0', `leader` = '0', `rank` = '0', WHERE `name` = '%e'", name);
	    mysql_function_query(dbHandle, query1, false, "", "");

	    new str[145];
	    format(str,sizeof(str),"{808080}[A] %s заблокировал оффлайн %s на %d дней.",PLAYER_DATA[playerid][data_NAME],name, days);
		SendAdminMessage(0x666699FF,str);
	}
	else SendClientMessage(playerid,COLOR_WARNING,"Данный акаунт не найден в базе данных!");
	return true;
}


public CheckReferal(playerid)
{
    new rows, fields,temp[10],salary,testq[145];
    cache_get_data(rows, fields);
    if(rows)
 	{
        cache_get_field_content(0, "salary",temp), salary = strval (temp);
        salary += 50000;

 		mysql_format(dbHandle,testq, sizeof(testq), "UPDATE `accounts` SET `salary` = '%d' WHERE `name` = '%e'",salary,PLAYER_DATA[playerid][data_REFERAL]);
		mysql_function_query(dbHandle, testq, false, "", "");

  	}
    return true;
}



public CheckBan(playerid)
{
    new rows, fields,temp[256];
    cache_get_data(rows, fields);
    if(rows)
 	{
 	    new dtext[256], day, text[50], id;
        cache_get_field_content(0, "id",temp), id = strval (temp);
        cache_get_field_content(0, "day",temp), day = strval (temp);
		cache_get_field_content(0, "text", text, dbHandle);
		format(dtext,sizeof(dtext),"{ffffff}BANID: %d\nИмя: %s\nПричина блокировки: %s\nАкаунт будет разблокирован через %d дня/дней",id,PLAYER_DATA[playerid][data_NAME],text,day);
		ShowPlayerDialog(playerid, dialog_BAN, DIALOG_STYLE_MSGBOX,"{FFCC00}Акаунт заблокирован", dtext, "Закрыть", "");
		Kick(playerid);
  	}
    else
    {
        new query[150];
        mysql_format(dbHandle, query, sizeof(query), "SELECT * FROM `accounts` WHERE `name` = '%e' AND `password` = MD5('%s')",PLAYER_DATA[playerid][data_NAME],PLAYER_DATA[playerid][data_PASSWORD]);
		mysql_function_query(dbHandle, query, true, "LoadPlayerData", "d", playerid);
    }
    return true;
}

public GetAccount(playerid)
{
    new rows, fields,temp[32];
    cache_get_data(rows, fields);
    if(rows)
    {
        new dtext[512], name[24], time, id, lvl,house, business,number, mmember, rank, leader, exp, regd1, regd2, regd3, logd1, logd2, logd3, logip[16], regip[16], money,donate, bankmoney;
        cache_get_field_content(0, "name", name, dbHandle);
        cache_get_field_content(0, "id",temp), id = strval (temp);
        cache_get_field_content(0, "regdate_day", temp), regd1 = strval (temp);
		cache_get_field_content(0, "regdate_month", temp), regd2 = strval (temp);
		cache_get_field_content(0, "regdate_year", temp), regd3 = strval (temp);
		cache_get_field_content(0, "logdate_day", temp), logd1 = strval (temp);
		cache_get_field_content(0, "logdate_month", temp), logd2 = strval (temp);
		cache_get_field_content(0, "logdate_year", temp), logd3 = strval (temp);
		cache_get_field_content(0, "bank", temp), bankmoney = strval (temp);
		cache_get_field_content(0, "money", temp), money = strval (temp);
		cache_get_field_content(0, "lvl", temp), lvl = strval (temp);
		cache_get_field_content(0, "exp", temp), exp = strval (temp);
		cache_get_field_content(0, "donate", temp), donate = strval (temp);
		cache_get_field_content(0, "house", temp), house = strval (temp);
		cache_get_field_content(0, "business", temp), business = strval (temp);
		cache_get_field_content(0, "number", temp), number = strval (temp);
		cache_get_field_content(0, "member", temp), mmember = strval (temp);
		cache_get_field_content(0, "rank", temp), rank = strval (temp);
		cache_get_field_content(0, "leader", temp), leader = strval (temp);
		cache_get_field_content(0, "login_ip", logip, dbHandle);
		cache_get_field_content(0, "register_ip", regip, dbHandle);
		cache_get_field_content(0, "time", temp), time = strval (temp);
		format(dtext,sizeof(dtext),"{FFFFFF}Номер акаунта: %d\nДонат: %d\nНаличные: %d руб.\nБанковский счет: %d руб.\nУровень: %d\nEXP: %d\nДом: %d +1 (-1 - нет)\nБизнес: %d +1 (-1 - нет)\nНомер телефона: %d (0 - нет)\nОрганизация: %d\nРанг: %d\nЛидер: %d\nREG-IP: %s\nLOG-IP: %s\nREG-DATA: %d/%d/%d\nLOG-DATA: %d/%d/%d\nПроведенное время в игре (сегодня): %d минут",id,donate,money,bankmoney,lvl,exp,house,business,number,mmember,rank,leader,regip,logip,regd1,regd2,regd3,logd1,logd2,logd3,time);
		ShowPlayerDialogFix(playerid, dialog_OK, DIALOG_STYLE_MSGBOX, name, dtext, "Закрыть", "");
        new message[145];
		format(message,sizeof(message),"{808080}[A] %s просматривает информацию аккаунта %s",PLAYER_DATA[playerid][data_NAME],name);
		SendAdminMessage(0x666699FF,message);
	}
    else SendClientMessage(playerid,COLOR_WARNING,"Аккаунт не найден в базе данных!");
    return true;
}

public LoadAllLeaders(playerid)
{
    new rows, fields, leader,name[MAX_PLAYER_NAME],temp[20],string[625],bugfix,logd1,logd2,logd3;
    cache_get_data(rows, fields);
    for(new i = 0; i < rows; i++)
    {
		cache_get_field_content(i, "name", name, dbHandle, MAX_PLAYER_NAME);
		cache_get_field_content(i, "leader", temp), leader = strval (temp);

		cache_get_field_content(i, "logdate_day", temp), logd1 = strval (temp);
		cache_get_field_content(i, "logdate_month", temp), logd2 = strval (temp);
		cache_get_field_content(i, "logdate_year", temp), logd3 = strval (temp);



		new ltext[64];
		switch(leader)
  		{
			case 1: ltext = "Администрация Области";
			case 2: ltext = "ВДВ";
			case 3: ltext = "Полиция";
   			case 4: ltext = "Больница";
			case 5: ltext = "Трамповское ОПГ";
			case 6: ltext = "Майкопское ОПГ";
			case 7: ltext = "Одесское ОПГ";
			case 8: ltext = "ФСБ";
			case 9: ltext = "СМИ";
  		}
    	format(string,sizeof(string),"%s{FFFFFF}%s: %s заходил %d/%d/%d\n",string,ltext,name, logd1, logd2, logd3);
    	bugfix = 1;
	}
	if(bugfix == 1) return ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Список лидеров", string, "Закрыть", "");
  	ShowPlayerDialogFix(playerid,dialog_OK, DIALOG_STYLE_MSGBOX, "{FFCC00}Список лидеров", "{FFFFFF}В данный момент лидеров нет", "Закрыть", "");
	return true;

}


