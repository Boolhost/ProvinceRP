public OnGameModeInit()
{
    X2DAY = true; //х2 день

    Most1 = CreateDynamicObject(2168,2747.3701, -1142.8600, 21.5900,0.0000, 0.0000, 180.0000);
	Most2 = CreateDynamicObject(2168,2747.3701, -1261.9200, 21.5900,0.0000, 0.0000, 0.0000);
	for(new id = 0; id<MAX_BANK; id++) CreateObject(2754,bnakInfo[id][entX], bnakInfo[id][entY], bnakInfo[id][entZ], bnakInfo[id][outX], bnakInfo[id][outY], bnakInfo[id][outZ]);

    //CreateObject(1352, 1825.83, 2085.67, 14.74,   0.00, 0.00, 0.00);
    sklad_fuel = 50000;
    // создание пикапов телепорта
	for(new i = 0; i < sizeof(teleport); i++)
 	{
		CreateDynamicPickup(1318, 23, teleport[i][T_PICKUP_POS_X], teleport[i][T_PICKUP_POS_Y] ,teleport[i][T_PICKUP_POS_Z], teleport[i][T_PICKUP_VIRTUAL_WORLD]);
		Create3DTextLabel(teleport[i][T_NAME], -1, teleport[i][T_PICKUP_POS_X], teleport[i][T_PICKUP_POS_Y] ,teleport[i][T_PICKUP_POS_Z], 5.0, teleport[i][T_PICKUP_VIRTUAL_WORLD]);
	}

	for(new i = 0; i < 10; i++)
	{
		CT_DATA[i][data_STATUS] = 0;
		strmid(CT_DATA[i][data_NAME], "нет", 0, 24, 24);
	}

    new hour, minute, second;
	gettime(hour, minute, second);
	SetWorldTime(hour);
	SetTimer("Timer",1000*60,true);

	shar = CreateObject(19335, shar_cords[0][0], shar_cords[0][1], shar_cords[0][2],   0.00000, 0.00000, 0.00000);


	/*for(new i = 0; i < sizeof(podarok_pos); i++)
	{
	    switch(random(5))
	    {
	        case 0: CreateDynamicPickup(19054, 2, podarok_pos[i][0], podarok_pos[i][1] ,podarok_pos[i][2], 0);
	        case 1: CreateDynamicPickup(19055, 2, podarok_pos[i][0], podarok_pos[i][1] ,podarok_pos[i][2], 0);
	        case 2: CreateDynamicPickup(19056, 2, podarok_pos[i][0], podarok_pos[i][1] ,podarok_pos[i][2], 0);
	        case 3: CreateDynamicPickup(19057, 2, podarok_pos[i][0], podarok_pos[i][1] ,podarok_pos[i][2], 0);
	        case 4: CreateDynamicPickup(19058, 2, podarok_pos[i][0], podarok_pos[i][1] ,podarok_pos[i][2], 0);
		}
	}*/

	sell_vagonka = RandomEX(3,10);
	sell_doska = RandomEX(3,10);
	sell_brus = RandomEX(3,10);
	sell_ruda = RandomEX(3,10);
	sell_morkov = RandomEX(3,10);
	sell_kapusta = RandomEX(3,10);
	sell_ogurec = RandomEX(3,10);
	sell_pomidor = RandomEX(3,10);
	sell_kartofel = RandomEX(3,10);
	sell_orange = RandomEX(3,10);
	sell_persiky = RandomEX(3,10);
	sell_sliva = RandomEX(3,10);
	sell_yabloki = RandomEX(3,10);
	sell_fuel = RandomEX(3,10);

	efir_ved = INVALID_PLAYER_ID;

    AntiDeAMX();
    restartserver = 0;
    SendRconCommand("password 0");
    //SendRconCommand("hostname Запланированные тех.работы | 10 минут");

    if(X2DAY == false) SendRconCommand("hostname НОВЫЙ ИГРОВОЙ ХОСТИНГ СЕРВЕРОВ BOOLHOST.RU");
    else SendRconCommand("hostname НОВЫЙ ИГРОВОЙ ХОСТИНГ СЕРВЕРОВ BOOLHOST.RU");
	//SendRconCommand("hostname Rage RolePlay | GTA Criminal Russia (Тестовый сервер)");


    SendRconCommand("mapname Criminal Russia");
    LoadTextDraws();
	LoadObjects();
	LoadMaps();
    // Подключение к базе данных
    dbHandle = mysql_connect(MySQLSettings[HOST],MySQLSettings[USERNAME],MySQLSettings[DATABASE],MySQLSettings[PASSWORD]);
    if(mysql_errno(dbHandle) != 0)
	{
	    print("MySQL connection: ERROR");
	}
    else
    {
        print("MySQL connection: OK");
    }
    mysql_log(LOG_ERROR | LOG_WARNING);
    mysql_function_query(dbHandle, "SET NAMES cp1251", false, "", "");
    mysql_set_charset("cp1251");

    mysql_function_query(dbHandle, "SELECT * FROM `warehouse`",true, "LoadWarehouse", "");
    mysql_function_query(dbHandle, "SELECT * FROM `job_business`",true, "LoadJobBusiness", "");
    mysql_function_query(dbHandle, "SELECT * FROM `auto_business`",true, "LoadAutoBusiness", "");
    mysql_function_query(dbHandle, "SELECT * FROM `kvartiry`",true, "LoadKV", "");
    mysql_function_query(dbHandle, "SELECT * FROM `garages`",true, "LoadGarages", "");
    mysql_function_query(dbHandle, "SELECT * FROM `houses`",true, "LoadHouses", "");
    mysql_function_query(dbHandle, "SELECT * FROM `business`",true, "LoadBusiness", "");
    mysql_function_query(dbHandle, "SELECT * FROM `polit_team`",true, "LoadPolitT", "");


	SetTimer("SecondTimer",1000,true);


    // выбор скина
    SelectSkin = CreateMenu("Victim", 1, 50.0, 160.0, 90.0);
	SetMenuColumnHeader(SelectSkin, 0, "Choose skin");
	AddMenuItem(SelectSkin,0,"> Next");
	AddMenuItem(SelectSkin,0,"< Back");
	AddMenuItem(SelectSkin,0,"Select");

	// Настройки игры
    ManualVehicleEngineAndLights();
	LimitPlayerMarkerRadius(65.0);
	AllowInteriorWeapons(1);
	DisableInteriorEnterExits();
	EnableStuntBonusForAll(0);
	SetNameTagDrawDistance(15.0);
	SetGameModeText("Province RolePlay");


	rentcater = CreateDynamicPickup(1239, 23, 2312.3274,-1129.5494,2.1728, 0);
	Create3DTextLabel("{33FF33}Аренда прогулочных катеров", -1, 2312.3274,-1129.5494,2.1728, 10.0, 0);

	army_barrier = CreateDynamicObject(980, 1891.0800, 1722.3900, 16.2200, 0.0000, 0.0000, -90.0000);

	dver_ao[0] = CreateDynamicObject(1495, -1412.8900, -1121.2300, 1520.9301, 0.0000, 0.0000, 270.0000);
	dver_ao[1] = CreateDynamicObject(1495, -1412.8467, -1130.7002, 1520.9301, 0.0000, 0.0000, 450.0000);

	//Арзамас
	police_barrier[0] = CreateDynamicObject(968, 383.45, 764.48, 11.82, 0.00, -90.00, 160.00);
	//Южный
	police_barrier[1] = CreateDynamicObject(968, 2579.84, -2438.85, 21.60, 0.00, 90.00, 90.00);

	pickcs = CreateDynamicPickup(1239, 23, 2284.7061,1378.7278,11.9110, 0);
	Create3DTextLabel("{33FF33}Регистрация участников", -1, 2284.7061,1378.7278,11.9110, 10.0, 0);

	pickbuycar = CreateDynamicPickup(19134, 23, 2638.6621, -1909.2032, 2328.1699, 1);
	Create3DTextLabel("{33FF33}Покупка авто", -1, 2638.6621, -1909.2032, 2328.1699, 10.0, 1);

	pickcartrack = CreateDynamicPickup(1239, 23, -1511.1638,1608.1748,36.7735, 0);
	Create3DTextLabel("{FF6633}Регистрация участников\n\n{FF6633}/tracklist - список победителей", -1, -1511.1638,1608.1748,36.7735, 10.0, 0);

	army_clothes = CreateDynamicPickup(1275, 23, 1612.9740,1984.9990,1281.8171, 1);
	ao_clothes = CreateDynamicPickup(1275, 23, -1415.6401,-1139.7705,1521.9399, 1);
	hos_clothes = CreateDynamicPickup(1275, 23, 600.2487,-106.1164,827.6688, 1);
	polic_clothes = CreateDynamicPickup(1275, 23, 952.3314,2089.8079,1122.4600, 4);
	polic_clothes2 = CreateDynamicPickup(1275, 23, 952.3314,2089.8079,1122.4600, 1);
	opg_clothes1 = CreateDynamicPickup(1275, 23, 2090.7705,-1607.0488,2056.6399, 1);
